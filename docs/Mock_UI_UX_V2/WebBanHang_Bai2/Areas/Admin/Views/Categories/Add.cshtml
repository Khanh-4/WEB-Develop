@model WebBanHang_Bai2.Models.Category
@{ ViewData["Title"] = "Thêm danh mục"; }

<div class="tx-card" style="max-width:640px;">
    <div class="tx-card-head"><h5><i class="bi bi-plus-circle"></i> Thêm danh mục</h5></div>
    <form asp-action="Add" method="post" class="p-4">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
        <div class="mb-3"><label asp-for="Name" class="form-label fw-semibold"></label><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger small"></span></div>
        <div class="mb-3"><label asp-for="Icon" class="form-label fw-semibold"></label><input asp-for="Icon" class="form-control" placeholder="bi-laptop" /><small class="text-muted">Xem danh sách icon tại <a href="https://icons.getbootstrap.com" target="_blank">icons.getbootstrap.com</a></small></div>
        <div class="mb-3"><label asp-for="Description" class="form-label fw-semibold"></label><textarea asp-for="Description" class="form-control" rows="2"></textarea></div>
        <button class="btn btn-gradient ripple"><i class="bi bi-check-circle"></i> Lưu</button>
        <a asp-action="Index" class="btn btn-soft">Huỷ</a>
    </form>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
