@model IEnumerable<WebBanHang_Bai2.Models.Category>
@{
    ViewData["Title"] = "Danh mục";
    var counts = (Dictionary<int, int>)ViewBag.ProductCounts;
}

<div class="tx-card">
    <div class="tx-card-head">
        <h5><i class="bi bi-tags"></i> Danh mục sản phẩm</h5>
        <a asp-action="Add" class="btn btn-gradient ripple"><i class="bi bi-plus-lg"></i> Thêm danh mục</a>
    </div>
    <table class="tx-table">
        <thead><tr><th>#</th><th>Tên danh mục</th><th>Icon</th><th>Mô tả</th><th>Sản phẩm</th><th class="text-end">Hành động</th></tr></thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td><strong>#@c.Id</strong></td>
                    <td><div class="d-flex align-items-center gap-2"><div class="cat-icon" style="width:36px;height:36px;font-size:.95rem;"><i class="bi @c.Icon"></i></div><span class="fw-semibold">@c.Name</span></div></td>
                    <td><code>@c.Icon</code></td>
                    <td class="text-muted small">@c.Description</td>
                    <td><span class="badge-pill bg-primary text-white">@(counts.TryGetValue(c.Id, out var n) ? n : 0)</span></td>
                    <td class="text-end">
                        <a class="btn btn-soft btn-sm" asp-action="Update" asp-route-id="@c.Id"><i class="bi bi-pencil"></i></a>
                        <button class="btn btn-soft btn-sm text-danger" data-bs-toggle="modal" data-bs-target="#del-@c.Id"><i class="bi bi-trash"></i></button>
                        <div class="modal fade" id="del-@c.Id" tabindex="-1">
                            <div class="modal-dialog modal-dialog-centered">
                                <form asp-action="Delete" asp-route-id="@c.Id" method="post" class="modal-content text-start">
                                    @Html.AntiForgeryToken()
                                    <div class="modal-header"><h5 class="modal-title">Xác nhận xoá danh mục</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                                    <div class="modal-body">Xoá danh mục <strong>@c.Name</strong>? Sản phẩm trong danh mục này có thể mất nhãn.</div>
                                    <div class="modal-footer"><button type="button" class="btn btn-soft" data-bs-dismiss="modal">Huỷ</button><button class="btn btn-danger">Xoá</button></div>
                                </form>
                            </div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
