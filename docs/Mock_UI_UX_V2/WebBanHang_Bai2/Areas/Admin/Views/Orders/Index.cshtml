@model IEnumerable<WebBanHang_Bai2.Models.Order>
@{
    ViewData["Title"] = "Đơn hàng";
    var statuses = Enum.GetValues<WebBanHang_Bai2.Models.OrderStatus>();
    string? kw = ViewBag.Keyword;
    WebBanHang_Bai2.Models.OrderStatus? status = ViewBag.Status;
}

<div class="tx-card">
    <div class="tx-card-head">
        <h5><i class="bi bi-receipt"></i> Quản lý đơn hàng</h5>
        <span class="text-muted small">@Model.Count() đơn</span>
    </div>
    <form method="get" class="p-3 row g-2 align-items-end">
        <div class="col-md-5">
            <label class="form-label small fw-semibold">Tìm theo mã đơn / tên / điện thoại</label>
            <input name="keyword" class="form-control" value="@kw" />
        </div>
        <div class="col-md-4">
            <label class="form-label small fw-semibold">Trạng thái</label>
            <select name="status" class="form-select">
                <option value="">-- Tất cả --</option>
                @foreach (var s in statuses)
                {
                    <option value="@((int)s)" selected="@(status == s)">@s</option>
                }
            </select>
        </div>
        <div class="col-md-3"><button class="btn btn-gradient w-100"><i class="bi bi-search"></i> Lọc</button></div>
    </form>

    <table class="tx-table">
        <thead><tr><th>Mã đơn</th><th>Khách hàng</th><th>Ngày đặt</th><th>Thanh toán</th><th>Tổng tiền</th><th>Trạng thái</th><th class="text-end">Hành động</th></tr></thead>
        <tbody>
            @foreach (var o in Model)
            {
                <tr>
                    <td><code>@o.OrderCode</code></td>
                    <td>
                        <div class="fw-semibold">@o.CustomerName</div>
                        <small class="text-muted">@o.Phone</small>
                    </td>
                    <td>@o.CreatedAt.ToLocalTime().ToString("dd/MM/yy HH:mm")</td>
                    <td><span class="badge-pill bg-secondary text-white">@o.PaymentMethod</span></td>
                    <td class="fw-bold text-danger">@o.Total.ToString("#,##0")đ</td>
                    <td><span class="status-pill @o.Status.ToString().ToLower()">@o.Status</span></td>
                    <td class="text-end">
                        <a class="btn btn-soft btn-sm" asp-action="Detail" asp-route-id="@o.Id"><i class="bi bi-eye"></i> Chi tiết</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
