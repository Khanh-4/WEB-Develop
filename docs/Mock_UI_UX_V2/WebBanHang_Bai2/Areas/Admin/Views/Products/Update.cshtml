@model WebBanHang_Bai2.Models.Product
@{
    ViewData["Title"] = "Sửa sản phẩm";
    var existing = Model.ImageUrls ?? new List<string>();
}

<div class="tx-card">
    <div class="tx-card-head"><h5><i class="bi bi-pencil-square"></i> Sửa sản phẩm #@Model.Id</h5>
        <a asp-action="Index" class="btn btn-soft btn-sm"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>
    <form asp-action="Update" enctype="multipart/form-data" method="post" class="p-4">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ImageUrl" id="hiddenMainImage" />

        <div class="row g-3">
            <div class="col-md-8">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="CategoryId" class="form-label fw-semibold">Danh mục</label>
                <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select"></select>
            </div>
            <div class="col-md-4"><label asp-for="Price" class="form-label fw-semibold"></label><input asp-for="Price" class="form-control" type="number" step="1000" /></div>
            <div class="col-md-4"><label asp-for="OldPrice" class="form-label fw-semibold"></label><input asp-for="OldPrice" class="form-control" type="number" step="1000" /></div>
            <div class="col-md-4"><label asp-for="Stock" class="form-label fw-semibold"></label><input asp-for="Stock" class="form-control" type="number" /></div>
            <div class="col-md-12"><label asp-for="ShortDescription" class="form-label fw-semibold"></label><input asp-for="ShortDescription" class="form-control" /></div>
            <div class="col-md-12"><label asp-for="Description" class="form-label fw-semibold"></label><textarea asp-for="Description" class="form-control" rows="4"></textarea></div>
            <div class="col-md-6 d-flex gap-3 align-items-center">
                <div class="form-check form-switch"><input asp-for="IsHot" class="form-check-input" /><label asp-for="IsHot" class="form-check-label">HOT</label></div>
                <div class="form-check form-switch"><input asp-for="IsNew" class="form-check-input" /><label asp-for="IsNew" class="form-check-label">NEW</label></div>
            </div>

            <div class="col-md-6">
                <label class="form-label fw-semibold">Ảnh đại diện</label>
                @if (!string.IsNullOrEmpty(Model.ImageUrl)) { <img src="@Model.ImageUrl" class="img-thumbnail mb-2 d-block" style="max-height:180px;" /> }
                <input type="file" name="mainImage" id="mainImage" class="form-control" accept="image/*" />
                <small class="text-muted">Bỏ trống để giữ ảnh hiện tại.</small>
                <img id="mainPreview" class="img-thumbnail mt-2 d-none" style="max-height:180px;" />
            </div>

            <div class="col-md-6">
                <label class="form-label fw-semibold">Bộ sưu tập ảnh</label>
                <div class="border rounded p-2 mb-2">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <small class="fw-semibold text-muted">Ảnh hiện có (<span id="existingCount">@existing.Count</span>)</small>
                    </div>
                    <div class="gallery-grid" id="existingGallery">
                        @foreach (var url in existing)
                        {
                            <div class="gallery-item">
                                <img src="@url" />
                                <input type="hidden" name="ImageUrls" value="@url" />
                                <button type="button" class="remove-btn">&times;</button>
                            </div>
                        }
                    </div>
                </div>

                <label class="form-label small fw-semibold">Thêm ảnh mới (drag & drop)</label>
                <div class="dropzone" id="dropzone"><i class="bi bi-cloud-arrow-up"></i>
                    <p class="mb-0">Kéo thả hoặc <strong>bấm để chọn</strong></p>
                    <input type="file" name="newImages" id="newImages" multiple accept="image/*" class="d-none" />
                </div>
                <div class="gallery-grid" id="extraPreview"></div>
            </div>
        </div>
        <hr />
        <button type="submit" class="btn btn-gradient ripple"><i class="bi bi-save"></i> Lưu thay đổi</button>
        <a asp-action="Index" class="btn btn-soft">Huỷ</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const main = document.getElementById('mainImage'), mp = document.getElementById('mainPreview');
        main.addEventListener('change', e => { const f = e.target.files[0]; if (f) { mp.src = URL.createObjectURL(f); mp.classList.remove('d-none'); } });

        const ex = document.getElementById('existingGallery'), exCount = document.getElementById('existingCount');
        ex.addEventListener('click', e => {
            const b = e.target.closest('.remove-btn');
            if (!b) return;
            b.closest('.gallery-item').remove();
            exCount.textContent = ex.querySelectorAll('.gallery-item').length;
        });

        const dz = document.getElementById('dropzone'), input = document.getElementById('newImages'), preview = document.getElementById('extraPreview');
        dz.addEventListener('click', () => input.click());
        ['dragenter','dragover'].forEach(ev => dz.addEventListener(ev, e => { e.preventDefault(); dz.classList.add('dragover'); }));
        ['dragleave','drop'].forEach(ev => dz.addEventListener(ev, e => { e.preventDefault(); dz.classList.remove('dragover'); }));
        
        let accumulatedFiles = [];

        dz.addEventListener('drop', e => {
            if (e.dataTransfer.files.length) {
                accumulatedFiles.push(...Array.from(e.dataTransfer.files));
                syncInputFiles();
                renderExtras();
            }
        });

        input.addEventListener('change', () => {
            if (input.files.length) {
                accumulatedFiles.push(...Array.from(input.files));
                syncInputFiles();
                renderExtras();
            }
        });

        function syncInputFiles() {
            const dt = new DataTransfer();
            accumulatedFiles.forEach(f => dt.items.add(f));
            input.files = dt.files;
        }

        function renderExtras() {
            preview.innerHTML = '';
            accumulatedFiles.forEach((f, idx) => {
                const d = document.createElement('div'); d.className = 'gallery-item';
                const img = document.createElement('img'); img.src = URL.createObjectURL(f);
                
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'remove-btn';
                btn.innerHTML = '&times;';
                btn.addEventListener('click', () => {
                    accumulatedFiles.splice(idx, 1);
                    syncInputFiles();
                    renderExtras();
                });

                d.appendChild(img);
                d.appendChild(btn);
                preview.appendChild(d);
            });
        }
    </script>
}
