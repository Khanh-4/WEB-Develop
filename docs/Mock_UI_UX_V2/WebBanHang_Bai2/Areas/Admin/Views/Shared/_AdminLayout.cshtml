@{
    var c = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string ActiveIf(params string[] names) => names.Any(n => string.Equals(n, c, StringComparison.OrdinalIgnoreCase)) ? "active" : "";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · Admin · TechStore</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
        // Áp dark mode ngay đầu để tránh flash
        document.documentElement.setAttribute('data-theme', localStorage.getItem('techstore.theme') || 'light');
    </script>
</head>
<body>
    <div class="admin-shell">
        <!-- ===== SIDEBAR ===== -->
        <aside class="admin-sidebar" id="adminSidebar">
            <div class="brand">
                <span class="logo"><i class="bi bi-lightning-charge-fill"></i></span>
                <span>TechStore <small class="text-muted">Admin</small></span>
            </div>

            <div class="section-label">Tổng quan</div>
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="@ActiveIf("Dashboard")"><i class="bi bi-speedometer2"></i> Dashboard</a>

            <div class="section-label">Catalog</div>
            <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="@ActiveIf("Products")"><i class="bi bi-box-seam"></i> Sản phẩm</a>
            <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="@ActiveIf("Categories")"><i class="bi bi-tags"></i> Danh mục</a>
            <a asp-area="Admin" asp-controller="Reviews" asp-action="Index" class="@ActiveIf("Reviews")"><i class="bi bi-chat-quote"></i> Đánh giá</a>

            <div class="section-label">Bán hàng</div>
            <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="@ActiveIf("Orders")"><i class="bi bi-receipt"></i> Đơn hàng</a>

            <div class="section-label">Hệ thống</div>
            <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="@ActiveIf("Users")"><i class="bi bi-people"></i> Người dùng</a>
            <a asp-controller="Home" asp-action="Index" asp-area=""><i class="bi bi-box-arrow-left"></i> Về trang chính</a>
        </aside>

        <!-- ===== MAIN ===== -->
        <div class="admin-main">
            <div class="admin-topbar">
                <div class="d-flex align-items-center gap-2">
                    <button class="btn-icon d-lg-none" id="sidebarToggle" type="button"><i class="bi bi-list"></i></button>
                    <h5 class="mb-0">@(ViewData["Title"] ?? "Admin")</h5>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <button id="darkToggle" class="btn-icon" title="Đổi giao diện"><i class="bi bi-moon-stars"></i></button>
                    <div class="dropdown">
                        <button class="btn btn-link p-0 d-flex align-items-center gap-2" data-bs-toggle="dropdown">
                            <span class="avatar">@(User.Identity?.Name?.Substring(0,1).ToUpper() ?? "A")</span>
                            <div class="d-none d-md-block text-start">
                                <div class="fw-semibold small">@User.Identity?.Name</div>
                                <div class="small text-muted">Quản trị viên</div>
                            </div>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow">
                            <li><a class="dropdown-item" asp-area="" asp-controller="Account" asp-action="Profile"><i class="bi bi-person"></i> Hồ sơ</a></li>
                            <li><a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="Index"><i class="bi bi-shop"></i> Cửa hàng</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button class="dropdown-item text-danger"><i class="bi bi-box-arrow-right"></i> Đăng xuất</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            @if (TempData["Success"] is string ok)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle"></i> @ok
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] is string err)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-octagon"></i> @err
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>
    </div>

    <div class="tx-toast-wrap" id="toastWrap"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.getElementById('sidebarToggle')?.addEventListener('click', () => {
            document.getElementById('adminSidebar').classList.toggle('open');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
