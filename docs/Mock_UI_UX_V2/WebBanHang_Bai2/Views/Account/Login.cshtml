@model WebBanHang_Bai2.Models.LoginViewModel
@{ ViewData["Title"] = "Đăng nhập"; }

<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-cover">
            <h2 class="position-relative">Chào mừng trở lại 👋</h2>
            <p class="position-relative">Đăng nhập để tiếp tục mua sắm và theo dõi đơn hàng tại TechStore.</p>
            <ul class="list-unstyled small position-relative mt-4">
                <li class="mb-2"><i class="bi bi-check2-circle"></i> Theo dõi đơn hàng dễ dàng</li>
                <li class="mb-2"><i class="bi bi-check2-circle"></i> Tích điểm thành viên</li>
                <li class="mb-2"><i class="bi bi-check2-circle"></i> Ưu đãi riêng cho thành viên</li>
            </ul>
            <div class="mt-auto small position-relative opacity-75">
                <hr style="border-color: rgba(255,255,255,.2);" />
                <strong>Demo:</strong> admin/admin123 · khachhang/123456
            </div>
        </div>
        <div class="auth-form">
            <h3 class="fw-bold mb-1">Đăng nhập</h3>
            <p class="text-muted">Chưa có tài khoản? <a asp-action="Register">Đăng ký ngay</a></p>

            <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="mt-3">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
                <div class="mb-3">
                    <label asp-for="UserName" class="form-label fw-semibold"></label>
                    <div class="input-group"><span class="input-group-text bg-white"><i class="bi bi-person"></i></span>
                        <input asp-for="UserName" class="form-control" placeholder="admin / khachhang" />
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold"></label>
                    <div class="input-group"><span class="input-group-text bg-white"><i class="bi bi-key"></i></span>
                        <input asp-for="Password" class="form-control" />
                    </div>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label small"></label>
                    </div>
                    <a href="#" class="small text-decoration-none">Quên mật khẩu?</a>
                </div>
                <button class="btn btn-gradient w-100 ripple py-2 fw-semibold"><i class="bi bi-box-arrow-in-right"></i> Đăng nhập</button>
            </form>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
