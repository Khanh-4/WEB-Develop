@model IEnumerable<WebBanHang_Bai2.Models.Order>
@{ ViewData["Title"] = "Đơn hàng của tôi"; }

<h2 class="fw-bold mt-3 mb-3"><i class="bi bi-bag-check"></i> Đơn hàng của tôi</h2>

@if (!Model.Any())
{
    <div class="tx-card p-5 text-center">
        <i class="bi bi-bag" style="font-size:4rem;color:var(--text-muted);opacity:.5;"></i>
        <h5 class="mt-3">Bạn chưa có đơn hàng nào</h5>
        <a asp-controller="Shop" asp-action="Index" class="btn btn-gradient mt-2">Mua sắm ngay</a>
    </div>
}
else
{
    <div class="tx-card p-0">
        <table class="tx-table">
            <thead><tr><th>Mã đơn</th><th>Ngày đặt</th><th>Trạng thái</th><th>Tổng tiền</th><th>Thanh toán</th></tr></thead>
            <tbody>
            @foreach (var o in Model)
            {
                <tr>
                    <td><code>@o.OrderCode</code></td>
                    <td>@o.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    <td><span class="status-pill @o.Status.ToString().ToLower()">@o.Status</span></td>
                    <td class="fw-bold text-danger">@o.Total.ToString("#,##0")đ</td>
                    <td>@o.PaymentMethod</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
