@model WebBanHang_Bai2.Models.ApplicationUser
@{ ViewData["Title"] = "Tài khoản của tôi"; }

<h2 class="fw-bold mt-3 mb-3"><i class="bi bi-person-circle"></i> Tài khoản của tôi</h2>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="tx-card p-4 text-center">
            <div class="avatar mx-auto" style="width:88px;height:88px;font-size:2rem;">@Model.FullName.Substring(0,1).ToUpper()</div>
            <h5 class="mt-3 mb-0">@Model.FullName</h5>
            <small class="text-muted">@Model.Email</small>
            <div class="mt-3">
                <span class="badge-pill bg-primary text-white">@Model.Role</span>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="tx-card p-4">
            <h6 class="fw-bold mb-3">Thông tin cá nhân</h6>
            <dl class="row mb-0">
                <dt class="col-sm-4">Tên đăng nhập</dt><dd class="col-sm-8">@Model.UserName</dd>
                <dt class="col-sm-4">Họ tên</dt><dd class="col-sm-8">@Model.FullName</dd>
                <dt class="col-sm-4">Email</dt><dd class="col-sm-8">@Model.Email</dd>
                <dt class="col-sm-4">Điện thoại</dt><dd class="col-sm-8">@(Model.Phone ?? "—")</dd>
                <dt class="col-sm-4">Địa chỉ</dt><dd class="col-sm-8">@(Model.Address ?? "—")</dd>
                <dt class="col-sm-4">Ngày tạo</dt><dd class="col-sm-8">@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
            </dl>
        </div>
    </div>
</div>
