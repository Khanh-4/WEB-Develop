@model WebBanHang_Bai2.Models.RegisterViewModel
@{ ViewData["Title"] = "Đăng ký"; }

<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-cover">
            <h2 class="position-relative">Tạo tài khoản mới ✨</h2>
            <p class="position-relative">Tham gia TechStore để nhận ưu đãi đặc biệt dành cho thành viên.</p>
            <ul class="list-unstyled small position-relative mt-4">
                <li class="mb-2"><i class="bi bi-gift"></i> Quà tặng chào mừng 50.000đ</li>
                <li class="mb-2"><i class="bi bi-shield-check"></i> Bảo mật hai lớp</li>
                <li class="mb-2"><i class="bi bi-truck"></i> Lưu địa chỉ giao hàng</li>
            </ul>
        </div>
        <div class="auth-form">
            <h3 class="fw-bold mb-1">Đăng ký</h3>
            <p class="text-muted">Đã có tài khoản? <a asp-action="Login">Đăng nhập</a></p>
            <form asp-action="Register" method="post" class="mt-3">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
                <div class="mb-3">
                    <label asp-for="FullName" class="form-label fw-semibold"></label>
                    <input asp-for="FullName" class="form-control" />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="UserName" class="form-label fw-semibold"></label>
                        <input asp-for="UserName" class="form-control" />
                        <span asp-validation-for="UserName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email" class="form-control" type="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                </div>
                <div class="row g-3 mt-1">
                    <div class="col-md-6">
                        <label asp-for="Password" class="form-label fw-semibold"></label>
                        <input asp-for="Password" class="form-control" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                        <input asp-for="ConfirmPassword" class="form-control" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>
                <button class="btn btn-gradient w-100 ripple py-2 fw-semibold mt-4"><i class="bi bi-person-plus"></i> Tạo tài khoản</button>
            </form>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
