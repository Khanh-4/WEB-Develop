@model WebBanHang_Bai2.Models.ShoppingCart
@{ ViewData["Title"] = "Giỏ hàng"; }

<h2 class="fw-bold mt-3 mb-3"><i class="bi bi-bag-check"></i> Giỏ hàng của bạn</h2>

@if (!Model.Items.Any())
{
    <div class="tx-card p-5 text-center">
        <i class="bi bi-bag" style="font-size:4rem;color:var(--text-muted);opacity:.5;"></i>
        <h5 class="mt-3">Giỏ hàng trống</h5>
        <p class="text-muted">Khám phá hàng nghìn sản phẩm công nghệ hấp dẫn tại TechStore.</p>
        <a asp-controller="Shop" asp-action="Index" class="btn btn-gradient ripple"><i class="bi bi-shop"></i> Tiếp tục mua sắm</a>
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="tx-card p-0">
                <table class="tx-table">
                    <thead><tr><th>Sản phẩm</th><th>Đơn giá</th><th>Số lượng</th><th>Thành tiền</th><th></th></tr></thead>
                    <tbody id="cartTbody">
                    @foreach (var i in Model.Items)
                    {
                        <tr data-id="@i.ProductId">
                            <td>
                                <div class="d-flex gap-3 align-items-center">
                                    <img class="thumb" src="@(i.ImageUrl ?? "/images/placeholder.svg")" />
                                    <div>
                                        <a class="fw-semibold" asp-controller="Product" asp-action="Detail" asp-route-id="@i.ProductId">@i.Name</a>
                                    </div>
                                </div>
                            </td>
                            <td class="text-danger fw-bold">@i.Price.ToString("#,##0")đ</td>
                            <td>
                                <div class="qty-stepper d-inline-flex align-items-center" style="border:1px solid var(--border);border-radius:999px;overflow:hidden;">
                                    <button type="button" class="btn-icon page-dec" style="border:none;background:transparent;border-radius:0;"><i class="bi bi-dash"></i></button>
                                    <input class="page-qty" type="text" value="@i.Quantity" readonly style="width:48px;text-align:center;border:none;background:transparent;color:var(--text);" />
                                    <button type="button" class="btn-icon page-inc" style="border:none;background:transparent;border-radius:0;"><i class="bi bi-plus"></i></button>
                                </div>
                            </td>
                            <td class="line-total fw-bold">@i.LineTotal.ToString("#,##0")đ</td>
                            <td><button class="btn btn-sm text-danger page-del" type="button"><i class="bi bi-trash"></i></button></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
            <a asp-controller="Shop" asp-action="Index" class="btn btn-soft mt-3"><i class="bi bi-arrow-left"></i> Tiếp tục mua sắm</a>
        </div>

        <div class="col-lg-4">
            <div class="tx-card p-4 sticky-top" style="top:100px;">
                <h6 class="fw-bold mb-3">Tóm tắt đơn hàng</h6>
                <div class="d-flex justify-content-between mb-2"><span class="text-muted">Tạm tính</span><span id="sumSubtotal">@Model.Subtotal.ToString("#,##0")đ</span></div>
                <div class="d-flex justify-content-between mb-2"><span class="text-muted">Vận chuyển</span><span id="sumShipping">@(Model.ShippingFee == 0 ? "Miễn phí" : Model.ShippingFee.ToString("#,##0") + "đ")</span></div>
                <hr />
                <div class="d-flex justify-content-between mb-3"><strong>Tổng cộng</strong><strong class="text-danger" id="sumTotal">@Model.Total.ToString("#,##0")đ</strong></div>
                <a asp-controller="Checkout" asp-action="Index" class="btn btn-gradient w-100 ripple"><i class="bi bi-credit-card"></i> Tiến hành thanh toán</a>
            </div>
        </div>
    </div>
}

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        const VND = n => new Intl.NumberFormat('vi-VN').format(n) + 'đ';
        async function syncRow(tr, qty) {
            const id = parseInt(tr.dataset.id, 10);
            const r = await fetch('/Cart/Update', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ productId: id, quantity: qty, __RequestVerificationToken: document.querySelector('input[name="__RequestVerificationToken"]').value })
            });
            if (!r.ok) return;
            const cart = await r.json();
            // re-render row
            const line = cart.items.find(x => x.productId === id);
            if (!line) { tr.remove(); }
            else {
                tr.querySelector('.page-qty').value = line.quantity;
                tr.querySelector('.line-total').textContent = VND(line.price * line.quantity);
            }
            document.getElementById('sumSubtotal').textContent = VND(cart.subtotal);
            document.getElementById('sumShipping').textContent = cart.shippingFee === 0 ? 'Miễn phí' : VND(cart.shippingFee);
            document.getElementById('sumTotal').textContent = VND(cart.total);
            const badge = document.getElementById('cartCount');
            if (badge) { if (cart.totalQuantity > 0) { badge.textContent = cart.totalQuantity; badge.style.display=''; } else badge.style.display='none'; }
            if (cart.items.length === 0) window.location.reload();
        }
        document.querySelectorAll('#cartTbody tr').forEach(tr => {
            tr.querySelector('.page-inc').addEventListener('click', () => syncRow(tr, parseInt(tr.querySelector('.page-qty').value, 10) + 1));
            tr.querySelector('.page-dec').addEventListener('click', () => {
                const cur = parseInt(tr.querySelector('.page-qty').value, 10);
                syncRow(tr, Math.max(0, cur - 1));
            });
            tr.querySelector('.page-del').addEventListener('click', () => syncRow(tr, 0));
        });
    </script>
}
