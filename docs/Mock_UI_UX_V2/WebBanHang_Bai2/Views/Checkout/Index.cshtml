@model WebBanHang_Bai2.Models.CheckoutViewModel
@{
    ViewData["Title"] = "Thanh toán";
    var cart = (WebBanHang_Bai2.Models.ShoppingCart)ViewBag.Cart;
}

<h2 class="fw-bold mt-3 mb-3"><i class="bi bi-credit-card"></i> Thanh toán</h2>

<form asp-action="Confirm" method="post">
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="tx-card p-4 mb-3">
                <h6 class="fw-bold mb-3"><i class="bi bi-truck"></i> Thông tin giao hàng</h6>
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="CustomerName" class="form-label"></label>
                        <input asp-for="CustomerName" class="form-control" />
                        <span asp-validation-for="CustomerName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Phone" class="form-label"></label>
                        <input asp-for="Phone" class="form-control" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="ShippingAddress" class="form-label"></label>
                        <textarea asp-for="ShippingAddress" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="ShippingAddress" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Notes" class="form-label"></label>
                        <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Yêu cầu đặc biệt, thời gian nhận, v.v."></textarea>
                    </div>
                </div>
            </div>

            <div class="tx-card p-4">
                <h6 class="fw-bold mb-3"><i class="bi bi-cash-stack"></i> Phương thức thanh toán</h6>
                @{
                    var pms = new (string Code, string Label, string Icon)[]
                    {
                        ("COD", "Thanh toán khi nhận hàng (COD)", "bi-cash-coin"),
                        ("VNPay", "VNPay - Internet Banking / QR", "bi-qr-code"),
                        ("Momo", "Ví Momo", "bi-wallet2"),
                        ("BankTransfer", "Chuyển khoản ngân hàng", "bi-bank")
                    };
                }
                <div class="row g-2">
                    @foreach (var pm in pms)
                    {
                        <div class="col-md-6">
                            <label class="tx-card p-3 d-flex align-items-center gap-2" style="cursor:pointer;">
                                <input class="form-check-input m-0" type="radio" name="PaymentMethod" value="@pm.Code" @(Model.PaymentMethod == pm.Code ? "checked" : "") />
                                <i class="bi @pm.Icon text-primary"></i>
                                <span class="fw-semibold">@pm.Label</span>
                            </label>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="tx-card p-4 sticky-top" style="top:100px;">
                <h6 class="fw-bold mb-3"><i class="bi bi-bag-check"></i> Đơn hàng của bạn</h6>
                @foreach (var i in cart.Items)
                {
                    <div class="d-flex gap-2 align-items-center py-2 border-bottom">
                        <img class="thumb" src="@(i.ImageUrl ?? "/images/placeholder.svg")" />
                        <div class="flex-grow-1 small">
                            <div class="fw-semibold">@i.Name</div>
                            <div class="text-muted">SL: @i.Quantity × @i.Price.ToString("#,##0")đ</div>
                        </div>
                        <div class="fw-bold">@i.LineTotal.ToString("#,##0")đ</div>
                    </div>
                }
                <div class="d-flex justify-content-between mt-3"><span class="text-muted">Tạm tính</span><span>@cart.Subtotal.ToString("#,##0")đ</span></div>
                <div class="d-flex justify-content-between"><span class="text-muted">Phí vận chuyển</span><span>@(cart.ShippingFee == 0 ? "Miễn phí" : cart.ShippingFee.ToString("#,##0") + "đ")</span></div>
                <hr />
                <div class="d-flex justify-content-between mb-3"><strong>Tổng cộng</strong><strong class="text-danger fs-5">@cart.Total.ToString("#,##0")đ</strong></div>
                <button class="btn btn-gradient w-100 btn-lg ripple"><i class="bi bi-check-circle"></i> Đặt hàng ngay</button>
                <small class="text-muted d-block mt-2 text-center">Bằng việc đặt hàng, bạn đồng ý với <a href="#">điều khoản</a> của TechStore.</small>
            </div>
        </div>
    </div>
</form>
