@model WebBanHang_Bai2.Models.Order
@{ ViewData["Title"] = "Đặt hàng thành công"; }

<div class="text-center py-4">
    <div class="d-inline-flex align-items-center justify-content-center"
         style="width:96px;height:96px;border-radius:50%;background:linear-gradient(135deg,#10b981,#059669);color:#fff;font-size:3rem;">
        <i class="bi bi-check2"></i>
    </div>
    <h1 class="mt-3 fw-bold">Đặt hàng thành công!</h1>
    <p class="text-muted">Mã đơn hàng của bạn: <strong>@Model.OrderCode</strong></p>
</div>

<div class="tx-card p-4">
    <div class="row g-3">
        <div class="col-md-6">
            <h6 class="fw-bold">Thông tin người nhận</h6>
            <p class="mb-1"><strong>@Model.CustomerName</strong></p>
            <p class="mb-1 text-muted">@Model.Phone · @Model.Email</p>
            <p class="text-muted">@Model.ShippingAddress</p>
        </div>
        <div class="col-md-6">
            <h6 class="fw-bold">Thanh toán</h6>
            <p class="mb-1">Phương thức: <strong>@Model.PaymentMethod</strong></p>
            <p class="mb-1">Tổng tiền: <strong class="text-danger">@Model.Total.ToString("#,##0")đ</strong></p>
            <p class="text-muted">Ngày đặt: @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
        </div>
    </div>
    <hr />
    <h6 class="fw-bold mb-3">Chi tiết đơn hàng</h6>
    <table class="tx-table">
        <thead><tr><th>Sản phẩm</th><th>SL</th><th>Đơn giá</th><th>Thành tiền</th></tr></thead>
        <tbody>
            @foreach (var i in Model.Items)
            {
                <tr>
                    <td><div class="d-flex gap-2 align-items-center"><img class="thumb" src="@(i.ImageUrl ?? "/images/placeholder.svg")" /><span>@i.ProductName</span></div></td>
                    <td>@i.Quantity</td>
                    <td>@i.Price.ToString("#,##0")đ</td>
                    <td class="fw-bold">@i.LineTotal.ToString("#,##0")đ</td>
                </tr>
            }
        </tbody>
    </table>
    <div class="d-flex gap-2 mt-3">
        <a asp-controller="Home" asp-action="Index" class="btn btn-soft"><i class="bi bi-house"></i> Về trang chủ</a>
        <a asp-controller="Account" asp-action="Orders" class="btn btn-gradient"><i class="bi bi-list-check"></i> Đơn hàng của tôi</a>
    </div>
</div>
