@{ ViewData["Title"] = "Giới thiệu"; }

<section class="tx-hero">
    <div class="row align-items-center">
        <div class="col-lg-7">
            <h1>Về TechStore</h1>
            <p class="lead">Chuỗi bán lẻ thiết bị công nghệ hàng đầu — tiên phong từ 2018.</p>
        </div>
        <div class="col-lg-5 text-center hero-art d-none d-lg-block"><i class="bi bi-building"></i></div>
    </div>
</section>

<div class="row g-4">
    <div class="col-md-4">
        <div class="tx-card p-4 h-100">
            <div class="cat-icon mb-3"><i class="bi bi-bullseye"></i></div>
            <h5>Sứ mệnh</h5>
            <p class="text-muted">Mang công nghệ chính hãng, giá tốt nhất đến mọi gia đình Việt.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="tx-card p-4 h-100">
            <div class="cat-icon mb-3"><i class="bi bi-people"></i></div>
            <h5>Đội ngũ</h5>
            <p class="text-muted">120+ chuyên gia công nghệ, tư vấn tận tâm tại 24 cửa hàng toàn quốc.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="tx-card p-4 h-100">
            <div class="cat-icon mb-3"><i class="bi bi-award"></i></div>
            <h5>Cam kết</h5>
            <p class="text-muted">Bảo hành nhanh 24h, đổi trả 7 ngày miễn phí, hỗ trợ trọn đời.</p>
        </div>
    </div>
</div>
