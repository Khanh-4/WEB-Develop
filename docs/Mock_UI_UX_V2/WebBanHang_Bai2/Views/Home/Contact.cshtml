@{ ViewData["Title"] = "Liên hệ"; }

<div class="row g-4 mt-2">
    <div class="col-lg-5">
        <h2 class="fw-bold mb-3"><i class="bi bi-envelope-paper"></i> Liên hệ với chúng tôi</h2>
        <p class="text-muted">Mọi ý kiến đóng góp, vui lòng gửi qua form bên cạnh hoặc liên hệ trực tiếp.</p>
        <div class="d-flex gap-3 mb-3"><div class="cat-icon" style="width:42px;height:42px;font-size:1rem;"><i class="bi bi-geo-alt"></i></div>
            <div><div class="fw-semibold">Trụ sở</div><small class="text-muted">123 Nguyễn Huệ, Q.1, TP.HCM</small></div></div>
        <div class="d-flex gap-3 mb-3"><div class="cat-icon" style="width:42px;height:42px;font-size:1rem;"><i class="bi bi-telephone"></i></div>
            <div><div class="fw-semibold">Hotline</div><small class="text-muted">1900 1234 (8:00 - 22:00)</small></div></div>
        <div class="d-flex gap-3 mb-3"><div class="cat-icon" style="width:42px;height:42px;font-size:1rem;"><i class="bi bi-envelope"></i></div>
            <div><div class="fw-semibold">Email</div><small class="text-muted">support@techstore.local</small></div></div>
    </div>
    <div class="col-lg-7">
        <div class="tx-card p-4">
            <form onsubmit="event.preventDefault(); TechStore.toast('Đã gửi liên hệ. Cảm ơn bạn!', 'success'); this.reset();">
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label">Họ và tên</label><input type="text" class="form-control" required /></div>
                    <div class="col-md-6"><label class="form-label">Email</label><input type="email" class="form-control" required /></div>
                    <div class="col-12"><label class="form-label">Tiêu đề</label><input type="text" class="form-control" required /></div>
                    <div class="col-12"><label class="form-label">Nội dung</label><textarea rows="5" class="form-control" required></textarea></div>
                    <div class="col-12"><button class="btn btn-gradient ripple"><i class="bi bi-send"></i> Gửi đi</button></div>
                </div>
            </form>
        </div>
    </div>
</div>
