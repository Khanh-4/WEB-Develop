@model WebBanHang_Bai2.Models.ErrorViewModel
@{ ViewData["Title"] = "Lỗi"; }

<div class="text-center py-5">
    <i class="bi bi-bug" style="font-size:4rem;color:var(--danger);"></i>
    <h1 class="mt-3">Đã xảy ra lỗi</h1>
    @if (Model.ShowRequestId)
    {
        <p class="text-muted"><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
    }
    <a class="btn btn-gradient" asp-controller="Home" asp-action="Index">Về trang chủ</a>
</div>
