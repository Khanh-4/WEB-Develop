@model WebBanHang_Bai2.Models.ShopViewModel
@{
    ViewData["Title"] = "Cửa hàng";
}

<section class="tx-hero py-4" style="padding: 2.5rem 2.5rem;">
    <div class="row align-items-center">
        <div class="col-lg-8">
            <h1 class="mb-2">Cửa hàng TechStore</h1>
            <p class="lead mb-0">Khám phá @Model.TotalItems sản phẩm chính hãng — giá tốt nhất thị trường.</p>
        </div>
        <div class="col-lg-4 text-center d-none d-lg-block hero-art" style="font-size:5rem;">
            <i class="bi bi-shop"></i>
        </div>
    </div>
</section>

<div class="row g-4">
    <!-- Sidebar filter -->
    <aside class="col-lg-3">
        <form method="get" asp-controller="Shop" asp-action="Index" class="tx-card p-3 sticky-top" style="top: 100px;">
            <h6 class="fw-bold mb-3"><i class="bi bi-funnel"></i> Bộ lọc</h6>

            <label class="form-label small fw-semibold">Danh mục</label>
            <div class="d-flex flex-column gap-2 mb-3">
                <label class="d-flex align-items-center gap-2">
                    <input type="radio" name="categoryId" value="" @(Model.CategoryId == null ? "checked" : "") />
                    <span>Tất cả</span>
                </label>
                @foreach (var c in Model.Categories)
                {
                    <label class="d-flex align-items-center gap-2">
                        <input type="radio" name="categoryId" value="@c.Id" @(Model.CategoryId == c.Id ? "checked" : "") />
                        <span><i class="bi @c.Icon text-primary"></i> @c.Name</span>
                    </label>
                }
            </div>

            <label class="form-label small fw-semibold">Khoảng giá (đ)</label>
            <div class="row g-2 mb-3">
                <div class="col-6"><input type="number" name="minPrice" value="@Model.MinPrice" class="form-control" placeholder="Từ" /></div>
                <div class="col-6"><input type="number" name="maxPrice" value="@Model.MaxPrice" class="form-control" placeholder="Đến" /></div>
            </div>

            @if (!string.IsNullOrEmpty(Model.Keyword))
            {
                <input type="hidden" name="keyword" value="@Model.Keyword" />
            }
            <input type="hidden" name="sort" value="@Model.Sort" />

            <button class="btn btn-gradient w-100 ripple"><i class="bi bi-search"></i> Áp dụng</button>
            <a asp-controller="Shop" asp-action="Index" class="btn btn-soft w-100 mt-2">
                <i class="bi bi-arrow-counterclockwise"></i> Xoá bộ lọc
            </a>
        </form>
    </aside>

    <!-- Products grid -->
    <div class="col-lg-9">
        <div class="tx-card p-3 mb-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div class="small text-muted">
                @if (!string.IsNullOrEmpty(Model.Keyword)) { <span>Kết quả cho "<strong>@Model.Keyword</strong>" · </span> }
                Hiển thị <strong>@Model.Products.Count</strong> / @Model.TotalItems sản phẩm
            </div>
            <form method="get" asp-controller="Shop" asp-action="Index" class="d-flex gap-2 align-items-center">
                @if (Model.CategoryId.HasValue) { <input type="hidden" name="categoryId" value="@Model.CategoryId" /> }
                @if (!string.IsNullOrEmpty(Model.Keyword)) { <input type="hidden" name="keyword" value="@Model.Keyword" /> }
                <label class="small text-muted">Sắp xếp:</label>
                <select name="sort" class="form-select form-select-sm" onchange="this.form.submit()" style="min-width:170px;">
                    <option value="newest" selected="@(Model.Sort == "newest")">Mới nhất</option>
                    <option value="price_asc" selected="@(Model.Sort == "price_asc")">Giá: Thấp → Cao</option>
                    <option value="price_desc" selected="@(Model.Sort == "price_desc")">Giá: Cao → Thấp</option>
                    <option value="name_asc" selected="@(Model.Sort == "name_asc")">Tên A → Z</option>
                    <option value="rating" selected="@(Model.Sort == "rating")">Đánh giá cao nhất</option>
                    <option value="hot" selected="@(Model.Sort == "hot")">Bán chạy</option>
                </select>
            </form>
        </div>

        @if (!Model.Products.Any())
        {
            <div class="tx-card p-5 text-center">
                <i class="bi bi-search text-muted" style="font-size:3rem;"></i>
                <h5 class="mt-3">Không tìm thấy sản phẩm</h5>
                <p class="text-muted">Thử thay đổi bộ lọc hoặc xoá từ khoá để xem kết quả khác.</p>
                <a asp-controller="Shop" asp-action="Index" class="btn btn-gradient">Xem tất cả sản phẩm</a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var p in Model.Products)
                {
                    <div class="col-6 col-md-4 col-xl-4"><partial name="_ProductCard" model="p" /></div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        @for (var i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.Page ? "active" : "")">
                                <a class="page-link"
                                   asp-controller="Shop" asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-categoryId="@Model.CategoryId"
                                   asp-route-keyword="@Model.Keyword"
                                   asp-route-sort="@Model.Sort"
                                   asp-route-minPrice="@Model.MinPrice"
                                   asp-route-maxPrice="@Model.MaxPrice">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
    </div>
</div>

@Html.AntiForgeryToken()
