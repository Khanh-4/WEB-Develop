@model TechSpecs.ViewModels.ForgotPasswordViewModel
@{ ViewData["Title"] = "Forgot Password"; }

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <h2>Forgot Password</h2>
            <p>Enter your email and we'll send a reset link</p>
        </div>

        <form asp-action="ForgotPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="you@example.com" autofocus />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 mb-3">Send Reset Link</button>
        </form>

        <p class="text-center mb-0">
            <a asp-action="Login">← Back to Sign In</a>
        </p>
    </div>
</div>

@section Styles {
<style>
    .auth-wrapper { min-height:80vh;display:flex;align-items:center;justify-content:center; }
    .auth-card { width:100%;max-width:420px;padding:2rem;background:rgba(255,255,255,.05);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.12);border-radius:16px; }
    .auth-header { text-align:center;margin-bottom:1.5rem; }
    .auth-header h2 { font-weight:700; }
    .auth-header p { color:#aaa; }
</style>
}
@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
