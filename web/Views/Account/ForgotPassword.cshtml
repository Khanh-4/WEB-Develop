@model TechSpecs.ViewModels.ForgotPasswordViewModel
@{ ViewData["Title"] = "Quên mật khẩu"; }

<div class="auth-wrap">
    <div class="tx-card p-4 p-md-5" style="width:100%;max-width:460px">
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                 style="width:56px;height:56px;background:var(--gradient-primary)">
                <i class="bi bi-lock-fill" style="color:#fff;font-size:1.4rem"></i>
            </div>
            <h4 class="fw-bold" style="color:var(--text)">Quên mật khẩu?</h4>
            <p class="mb-0" style="color:var(--text-muted)">Nhập email để nhận link đặt lại mật khẩu</p>
        </div>

        <form asp-action="ForgotPassword" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label" style="color:var(--text-muted)"></label>
                <input asp-for="Email" class="form-control" placeholder="you@example.com" autofocus />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-gradient w-100 mb-3">
                <i class="bi bi-envelope me-2"></i>Gửi link đặt lại mật khẩu
            </button>
        </form>

        <p class="text-center mb-0 small">
            <a asp-action="Login" style="color:var(--primary)">← Quay lại đăng nhập</a>
        </p>
    </div>
</div>

@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
