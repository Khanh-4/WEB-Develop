@{ ViewData["Title"] = "Kiểm tra email"; }

<div class="auth-wrap">
    <div class="tx-card p-4 p-md-5 text-center" style="width:100%;max-width:460px">
        <div class="mb-4">
            <i class="bi bi-envelope-check-fill" style="font-size:3rem;color:#4ade80"></i>
        </div>
        <h4 class="fw-bold mb-2" style="color:var(--text)">Kiểm tra email của bạn</h4>
        <p class="mb-4" style="color:var(--text-muted)">
            Nếu email đó đã đăng ký, chúng tôi đã gửi một link đặt lại mật khẩu.<br>
            <span style="font-size:.85rem">Link có hiệu lực trong 1 giờ.</span>
        </p>
        <a asp-action="Login" class="btn btn-gradient px-4">Quay lại đăng nhập</a>
        <p class="mt-3 mb-0 small" style="color:var(--text-muted)">
            Không nhận được? Kiểm tra hộp thư spam, hoặc
            <a asp-action="ForgotPassword" style="color:var(--primary)">thử lại</a>.
        </p>
    </div>
</div>
