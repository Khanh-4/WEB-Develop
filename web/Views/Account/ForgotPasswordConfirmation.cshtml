@{ ViewData["Title"] = "Check Your Email"; }

<div class="auth-wrapper">
    <div class="auth-card text-center">
        <div class="mb-4">
            <i class="bi bi-envelope-check-fill text-success" style="font-size:3rem"></i>
        </div>
        <h2 class="fw-bold mb-2">Check your inbox</h2>
        <p class="text-muted-white mb-4">
            If that email is registered, we've sent a password reset link.<br>
            <span style="font-size:.85rem">The link expires in 1 hour.</span>
        </p>
        <a asp-action="Login" class="btn btn-gradient px-4">Back to Sign In</a>
        <p class="mt-3 mb-0" style="font-size:.85rem;color:#888">
            Didn't receive it? Check spam, or
            <a asp-action="ForgotPassword">try again</a>.
        </p>
    </div>
</div>

@section Styles {
<style>
    .auth-wrapper { min-height:80vh;display:flex;align-items:center;justify-content:center; }
    .auth-card { width:100%;max-width:420px;padding:2.5rem;background:rgba(255,255,255,.05);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.12);border-radius:16px; }
</style>
}
