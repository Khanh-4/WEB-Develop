@model TechSpecs.ViewModels.LoginViewModel
@{ ViewData["Title"] = "Đăng nhập"; }

<div class="auth-wrap">
    <div class="auth-card">

        <!-- Left cover panel -->
        <div class="auth-cover">
            <div style="position:relative;z-index:1">
                <div class="mb-3">
                    <span class="logo d-inline-flex align-items-center justify-content-center"
                          style="width:48px;height:48px;background:rgba(255,255,255,.2);border-radius:14px;font-size:1.4rem">
                        <i class="bi bi-cpu"></i>
                    </span>
                </div>
                <h2 class="fw-bold text-white mb-2">Chào mừng trở lại!</h2>
                <p class="mb-4" style="color:rgba(255,255,255,.8)">
                    Đăng nhập để tiếp tục mua sắm linh kiện PC và theo dõi đơn hàng tại TechSpecs.
                </p>
                <ul class="list-unstyled small mb-0">
                    <li class="mb-2 d-flex align-items-center gap-2" style="color:rgba(255,255,255,.9)">
                        <i class="bi bi-check2-circle"></i> Theo dõi đơn hàng dễ dàng
                    </li>
                    <li class="mb-2 d-flex align-items-center gap-2" style="color:rgba(255,255,255,.9)">
                        <i class="bi bi-check2-circle"></i> Lưu cấu hình PC yêu thích
                    </li>
                    <li class="mb-2 d-flex align-items-center gap-2" style="color:rgba(255,255,255,.9)">
                        <i class="bi bi-check2-circle"></i> Ưu đãi và tích điểm thành viên
                    </li>
                    <li class="d-flex align-items-center gap-2" style="color:rgba(255,255,255,.9)">
                        <i class="bi bi-check2-circle"></i> Tra cứu bảo hành tiện lợi
                    </li>
                </ul>
            </div>
        </div>

        <!-- Right form panel -->
        <div class="auth-form">
            <h3 class="fw-bold mb-1" style="color:var(--text)">Đăng nhập</h3>
            <p class="mb-4" style="color:var(--text-muted)">
                Chưa có tài khoản? <a asp-action="Register" asp-route-returnUrl="@Model.ReturnUrl"
                                       style="color:var(--primary)">Đăng ký ngay</a>
            </p>

            <form asp-action="Login" method="post">
                <input type="hidden" asp-for="ReturnUrl" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold small" style="color:var(--text)"></label>
                    <div class="input-group">
                        <span class="input-group-text" style="background:var(--surface-2);border-color:var(--border);color:var(--text-muted)">
                            <i class="bi bi-envelope"></i>
                        </span>
                        <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between">
                        <label asp-for="Password" class="form-label fw-semibold small" style="color:var(--text)"></label>
                        <a asp-action="ForgotPassword" class="small text-decoration-none" style="color:var(--primary)">
                            Quên mật khẩu?
                        </a>
                    </div>
                    <div class="input-group">
                        <span class="input-group-text" style="background:var(--surface-2);border-color:var(--border);color:var(--text-muted)">
                            <i class="bi bi-key"></i>
                        </span>
                        <input asp-for="Password" class="form-control" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label small" style="color:var(--text-muted)"></label>
                    </div>
                </div>

                <button type="submit" class="btn btn-gradient w-100 py-2 fw-semibold ripple mb-3">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                </button>
            </form>

            <div class="d-flex align-items-center gap-2 mb-3">
                <div style="flex:1;height:1px;background:var(--border)"></div>
                <small style="color:var(--text-muted)">hoặc</small>
                <div style="flex:1;height:1px;background:var(--border)"></div>
            </div>

            <form asp-action="ExternalLogin" method="post">
                <input type="hidden" name="provider" value="Google" />
                <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
                <button type="submit" class="btn w-100 py-2 fw-semibold d-flex align-items-center justify-content-center gap-2"
                        style="background:#fff;color:#333;border:1px solid #ddd">
                    <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="Google" width="18" />
                    Tiếp tục với Google
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
