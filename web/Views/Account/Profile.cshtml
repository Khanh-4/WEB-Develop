@model TechSpecs.ViewModels.ProfileViewModel
@using TechSpecs.Models
@{ ViewData["Title"] = "My Profile";
   var tier = MembershipTier.Resolve(Model.TotalSpend);
   var (nextThreshold, pct) = MembershipTier.Progress(Model.TotalSpend);
}

<div class="container py-5 px-3" style="max-width:680px">
    <h1 class="text-white fw-bold mb-4">My Profile</h1>

    <!-- Membership Tier Card -->
    <div class="glass p-4 rounded-4 mb-4" style="background:linear-gradient(135deg,rgba(168,85,247,.12),rgba(99,102,241,.08));border:1px solid rgba(168,85,247,.25)">
        <div class="d-flex align-items-center gap-3 mb-3">
            <div style="width:52px;height:52px;border-radius:50%;background:rgba(255,255,255,.08);display:flex;align-items:center;justify-content:center;border:2px solid @tier.Color">
                <i class="bi @tier.Icon" style="font-size:1.4rem;color:@tier.Color"></i>
            </div>
            <div>
                <div class="fw-bold" style="color:@tier.Color;font-size:1.1rem">Thành viên @tier.NameVi</div>
                <div class="text-muted-white" style="font-size:.82rem">@Model.LoyaltyPoints.ToString("N0") điểm tích lũy</div>
            </div>
            <div class="ms-auto text-end">
                <div class="text-white fw-semibold">@Model.TotalSpend.ToString("N0")đ</div>
                <div class="text-muted-white" style="font-size:.75rem">Tổng chi tiêu</div>
            </div>
        </div>
        @if (pct < 100)
        {
            <div class="mb-1 d-flex justify-content-between" style="font-size:.75rem">
                <span class="text-muted-white">Tiến độ đến hạng tiếp theo</span>
                <span style="color:@tier.Color">@nextThreshold.ToString("N0")đ</span>
            </div>
            <div style="height:6px;background:rgba(255,255,255,.1);border-radius:3px">
                <div style="width:@pct%;height:100%;background:linear-gradient(90deg,@tier.Color,#c084fc);border-radius:3px;transition:width .6s"></div>
            </div>
        }
        else
        {
            <div class="text-center" style="font-size:.8rem;color:@tier.Color;opacity:.8">
                <i class="bi bi-stars me-1"></i>Bạn đang ở hạng cao nhất!
            </div>
        }
        <!-- Tier ladder -->
        <div class="d-flex justify-content-between mt-3">
            @foreach (var t in MembershipTier.Tiers.Reverse())
            {
                var active = t.Name == tier.Name;
                <div class="text-center" style="flex:1">
                    <i class="bi @t.Icon" style="color:@(active ? t.Color : "rgba(255,255,255,.2)");font-size:1rem"></i>
                    <div style="font-size:.65rem;color:@(active ? t.Color : "rgba(255,255,255,.3)")" class="@(active ? "fw-bold" : "")">@t.NameVi</div>
                </div>
            }
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert border-0 rounded-3 mb-4 d-flex align-items-center gap-2"
             style="background:rgba(34,197,94,.15);color:#4ade80">
            <i class="bi bi-check-circle-fill fs-5"></i>
            <span>@TempData["Success"]</span>
        </div>
    }

    <form asp-action="Profile" method="post">
        @Html.AntiForgeryToken()

        <!-- Account info card -->
        <div class="glass p-4 rounded-4 mb-4">
            <h6 class="text-white fw-semibold mb-4"
                style="font-size:.85rem;letter-spacing:.05em;text-transform:uppercase;opacity:.7">
                Account Information
            </h6>

            <!-- Avatar placeholder -->
            <div class="d-flex align-items-center gap-4 mb-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width:72px;height:72px;background:linear-gradient(135deg,#a855f7,#6366f1)">
                    <span class="text-white fw-bold fs-4">
                        @(Model.FullName.Length > 0 ? Model.FullName[0].ToString().ToUpper() : "?")
                    </span>
                </div>
                <div>
                    <div class="text-white fw-semibold">@Model.FullName</div>
                    <div style="color:rgba(255,255,255,.5);font-size:.85rem">@Model.Email</div>
                    <div class="mt-1">
                        @if (Model.IsGoogleAccount)
                        {
                            <span class="badge rounded-pill px-2"
                                  style="background:rgba(66,133,244,.2);color:#93c5fd;font-size:.7rem">
                                <i class="bi bi-google me-1"></i>Google Account
                            </span>
                        }
                        <span class="badge rounded-pill px-2 ms-1"
                              style="background:rgba(255,255,255,.08);color:rgba(255,255,255,.5);font-size:.7rem">
                            Member since @Model.CreatedAt.ToString("MMM yyyy")
                        </span>
                    </div>
                </div>
            </div>

            <!-- Full name field -->
            <div class="mb-3">
                <label asp-for="FullName" class="form-label text-white" style="font-size:.875rem"></label>
                <input asp-for="FullName" class="form-control" placeholder="Your full name" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <!-- Email (read-only) -->
            <div class="mb-1">
                <label class="form-label text-white" style="font-size:.875rem">Email</label>
                <input type="email" class="form-control" value="@Model.Email" disabled
                       style="opacity:.5;cursor:not-allowed" />
                <div class="mt-1" style="color:rgba(255,255,255,.4);font-size:.78rem">
                    Email cannot be changed.
                </div>
            </div>
        </div>

        <!-- Change password card (hidden for Google accounts) -->
        @if (!Model.IsGoogleAccount)
        {
            <div class="glass p-4 rounded-4 mb-4">
                <h6 class="text-white fw-semibold mb-4"
                    style="font-size:.85rem;letter-spacing:.05em;text-transform:uppercase;opacity:.7">
                    Change Password
                    <span style="color:rgba(255,255,255,.4);font-weight:400;text-transform:none;letter-spacing:0"> — leave blank to keep current</span>
                </h6>

                <div class="mb-3">
                    <label asp-for="CurrentPassword" class="form-label text-white" style="font-size:.875rem"></label>
                    <input asp-for="CurrentPassword" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label text-white" style="font-size:.875rem"></label>
                    <input asp-for="NewPassword" class="form-control" placeholder="Min 8 characters" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>
                <div class="mb-1">
                    <label asp-for="ConfirmPassword" class="form-label text-white" style="font-size:.875rem"></label>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
            </div>
        }

        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-gradient px-4 py-2 fw-semibold rounded-3">
                <i class="bi bi-check-lg me-2"></i>Save Changes
            </button>
            <a href="/" class="btn glass text-white px-4 py-2 rounded-3">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
