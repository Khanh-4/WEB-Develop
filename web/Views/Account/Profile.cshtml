@model TechSpecs.ViewModels.ProfileViewModel
@using TechSpecs.Models
@{
    ViewData["Title"] = "Hồ sơ";
    var tier = MembershipTier.Resolve(Model.TotalSpend);
    var (nextThreshold, pct) = MembershipTier.Progress(Model.TotalSpend);
}

<div class="container py-5 px-3" style="max-width:680px">
    <h4 class="fw-bold mb-4" style="color:var(--text)">
        <i class="bi bi-person-circle me-2" style="color:var(--primary)"></i>Hồ sơ của tôi
    </h4>

    @if (TempData["Success"] != null)
    {
        <div class="alert glass mb-4 py-2 d-flex align-items-center gap-2" style="color:#4ade80">
            <i class="bi bi-check-circle-fill fs-5"></i>
            <span>@TempData["Success"]</span>
        </div>
    }

    <form asp-action="Profile" method="post">
        @Html.AntiForgeryToken()

        <!-- Account info -->
        <div class="tx-card p-4 mb-4">
            <h6 class="fw-semibold mb-4" style="color:var(--text-muted);font-size:.8rem;letter-spacing:.06em;text-transform:uppercase">
                Thông tin tài khoản
            </h6>

            <div class="d-flex align-items-center gap-4 mb-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width:72px;height:72px;background:var(--gradient-primary)">
                    <span class="fw-bold fs-4" style="color:#fff">
                        @(Model.FullName.Length > 0 ? Model.FullName[0].ToString().ToUpper() : "?")
                    </span>
                </div>
                <div>
                    <div class="fw-semibold" style="color:var(--text)">@Model.FullName</div>
                    <div style="color:var(--text-muted);font-size:.85rem">@Model.Email</div>
                    <div class="mt-1 d-flex gap-1 flex-wrap">
                        @if (Model.IsGoogleAccount)
                        {
                            <span class="badge glass-sm" style="color:var(--accent);font-size:.7rem">
                                <i class="bi bi-google me-1"></i>Google
                            </span>
                        }
                        <span class="badge glass-sm" style="color:var(--text-muted);font-size:.7rem">
                            Thành viên từ @Model.CreatedAt.ToString("MM/yyyy")
                        </span>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="FullName" class="form-label small" style="color:var(--text-muted)"></label>
                <input asp-for="FullName" class="form-control" placeholder="Nguyễn Văn A" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>
            <div>
                <label class="form-label small" style="color:var(--text-muted)">Email</label>
                <input type="email" class="form-control" value="@Model.Email" disabled style="opacity:.5;cursor:not-allowed" />
                <div class="mt-1" style="color:var(--text-muted);font-size:.78rem">Email không thể thay đổi.</div>
            </div>
        </div>

        <!-- Change password -->
        @if (!Model.IsGoogleAccount)
        {
            <div class="tx-card p-4 mb-4">
                <h6 class="fw-semibold mb-4" style="color:var(--text-muted);font-size:.8rem;letter-spacing:.06em;text-transform:uppercase">
                    Đổi mật khẩu
                    <span style="color:var(--text-muted);font-weight:400;text-transform:none;letter-spacing:0;opacity:.6"> — để trống để giữ nguyên</span>
                </h6>

                <div class="mb-3">
                    <label asp-for="CurrentPassword" class="form-label small" style="color:var(--text-muted)"></label>
                    <input asp-for="CurrentPassword" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label small" style="color:var(--text-muted)"></label>
                    <input asp-for="NewPassword" class="form-control" placeholder="Tối thiểu 8 ký tự" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>
                <div>
                    <label asp-for="ConfirmPassword" class="form-label small" style="color:var(--text-muted)"></label>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
            </div>
        }

        <!-- Membership Tier -->
        <div class="tx-card p-4 mb-4" style="border-color:@tier.Color;border-width:1px">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0"
                     style="width:52px;height:52px;background:var(--surface-2);border:2px solid @tier.Color">
                    <i class="bi @tier.Icon" style="font-size:1.4rem;color:@tier.Color"></i>
                </div>
                <div>
                    <div class="fw-bold" style="color:@tier.Color;font-size:1.05rem">Thành viên @tier.NameVi</div>
                    <div style="color:var(--text-muted);font-size:.82rem">@Model.LoyaltyPoints.ToString("N0") điểm tích lũy</div>
                </div>
                <div class="ms-auto text-end">
                    <div class="fw-semibold" style="color:var(--text)">@Model.TotalSpend.ToString("N0")đ</div>
                    <div style="color:var(--text-muted);font-size:.75rem">Tổng chi tiêu</div>
                </div>
            </div>
            @if (pct < 100)
            {
                <div class="mb-1 d-flex justify-content-between" style="font-size:.75rem">
                    <span style="color:var(--text-muted)">Tiến độ đến hạng tiếp theo</span>
                    <span style="color:@tier.Color">@nextThreshold.ToString("N0")đ</span>
                </div>
                <div style="height:5px;background:var(--surface-2);border-radius:3px">
                    <div style="width:@pct%;height:100%;background:@tier.Color;border-radius:3px;transition:width .6s"></div>
                </div>
            }
            else
            {
                <div class="text-center" style="font-size:.8rem;color:@tier.Color">
                    <i class="bi bi-stars me-1"></i>Bạn đang ở hạng cao nhất!
                </div>
            }
            <div class="d-flex justify-content-between mt-3">
                @foreach (var t in MembershipTier.Tiers.Reverse())
                {
                    var active = t.Name == tier.Name;
                    <div class="text-center" style="flex:1">
                        <i class="bi @t.Icon" style="color:@(active ? t.Color : "var(--text-muted)");font-size:1rem;opacity:@(active ? "1" : ".35")"></i>
                        <div style="font-size:.65rem;color:@(active ? t.Color : "var(--text-muted)");font-weight:@(active ? "700" : "400");opacity:@(active ? "1" : ".5")">@t.NameVi</div>
                    </div>
                }
            </div>
        </div>

        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-gradient px-4 py-2 fw-semibold">
                <i class="bi bi-check-lg me-2"></i>Lưu thay đổi
            </button>
            <a href="/" class="btn glass px-4 py-2" style="color:var(--text)">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
