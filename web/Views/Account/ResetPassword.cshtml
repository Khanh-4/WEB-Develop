@model TechSpecs.ViewModels.ResetPasswordViewModel
@{ ViewData["Title"] = "Reset Password"; }

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <h2>Reset Password</h2>
            <p>Enter your new password below</p>
        </div>

        <form asp-action="ResetPassword" method="post">
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Token" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" placeholder="Min. 8 characters" autofocus />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword" class="form-control" placeholder="Repeat password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">Set New Password</button>
        </form>
    </div>
</div>

@section Styles {
<style>
    .auth-wrapper { min-height:80vh;display:flex;align-items:center;justify-content:center; }
    .auth-card { width:100%;max-width:420px;padding:2rem;background:rgba(255,255,255,.05);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.12);border-radius:16px; }
    .auth-header { text-align:center;margin-bottom:1.5rem; }
    .auth-header h2 { font-weight:700; }
    .auth-header p { color:#aaa; }
</style>
}
@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
