@model TechSpecs.ViewModels.ResetPasswordViewModel
@{ ViewData["Title"] = "Đặt lại mật khẩu"; }

<div class="auth-wrap">
    <div class="tx-card p-4 p-md-5" style="width:100%;max-width:460px">
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
                 style="width:56px;height:56px;background:var(--gradient-primary)">
                <i class="bi bi-key-fill" style="color:#fff;font-size:1.4rem"></i>
            </div>
            <h4 class="fw-bold" style="color:var(--text)">Đặt lại mật khẩu</h4>
            <p class="mb-0" style="color:var(--text-muted)">Nhập mật khẩu mới cho tài khoản của bạn</p>
        </div>

        <form asp-action="ResetPassword" method="post">
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Token" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label" style="color:var(--text-muted)"></label>
                <input asp-for="Password" class="form-control" placeholder="Tối thiểu 8 ký tự" autofocus />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label" style="color:var(--text-muted)"></label>
                <input asp-for="ConfirmPassword" class="form-control" placeholder="Nhập lại mật khẩu" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-gradient w-100">
                <i class="bi bi-check-lg me-2"></i>Đặt mật khẩu mới
            </button>
        </form>
    </div>
</div>

@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
