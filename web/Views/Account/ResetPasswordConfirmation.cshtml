@{ ViewData["Title"] = "Đặt lại mật khẩu thành công"; }

<div class="auth-wrap">
    <div class="tx-card p-4 p-md-5 text-center" style="width:100%;max-width:460px">
        <div class="mb-4">
            <i class="bi bi-check-circle-fill" style="font-size:3rem;color:#4ade80"></i>
        </div>
        <h4 class="fw-bold mb-2" style="color:var(--text)">Mật khẩu đã được cập nhật!</h4>
        <p class="mb-4" style="color:var(--text-muted)">Mật khẩu của bạn đã được đặt lại thành công.</p>
        <a asp-action="Login" class="btn btn-gradient px-4">
            <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập ngay
        </a>
    </div>
</div>
