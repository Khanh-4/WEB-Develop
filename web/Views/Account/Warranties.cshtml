@model List<TechSpecs.Models.WarrantyRecord>
@{
    ViewData["Title"] = "Bảo hành của tôi";
    Layout = "_Layout";
    var now = DateTime.UtcNow;
}

<div class="container py-4" style="max-width:900px">
    <h3 class="text-white fw-bold mb-4">
        <i class="bi bi-shield-check me-2" style="color:#a855f7"></i>Bảo hành của tôi
    </h3>

    @if (!Model.Any())
    {
        <div class="glass p-5 text-center">
            <i class="bi bi-shield-slash" style="font-size:3rem;color:rgba(255,255,255,.2)"></i>
            <p class="text-muted-white mt-3 mb-0">Bạn chưa có sản phẩm nào trong danh sách bảo hành.<br>
               Bảo hành được tạo tự động khi đơn hàng chuyển sang trạng thái "Đã xác nhận".</p>
        </div>
    }
    else
    {
        <div class="row g-3">
        @foreach (var r in Model)
        {
            var expiry = r.PurchaseDate.AddMonths(r.WarrantyMonths);
            var daysLeft = (expiry - now).TotalDays;
            var pct = Math.Max(0, Math.Min(100, daysLeft / (r.WarrantyMonths * 30.0) * 100));
            var (barColor, statusText, statusStyle) = daysLeft switch
            {
                <= 0   => ("#f87171", "Hết hạn", "color:#f87171"),
                <= 30  => ("#fb923c", $"Còn {(int)daysLeft} ngày", "color:#fb923c"),
                <= 90  => ("#f59e0b", $"Còn {(int)daysLeft} ngày", "color:#f59e0b"),
                _      => ("#4ade80", $"Còn {(int)daysLeft} ngày", "color:#4ade80"),
            };
            <div class="col-12">
                <div class="glass p-4 d-flex gap-3 align-items-start">
                    @if (!string.IsNullOrEmpty(r.ImageUrl))
                    {
                        <img src="@r.ImageUrl" style="width:64px;height:64px;object-fit:contain;border-radius:8px;background:rgba(255,255,255,.05);flex-shrink:0" />
                    }
                    else
                    {
                        <div style="width:64px;height:64px;border-radius:8px;background:rgba(255,255,255,.05);display:flex;align-items:center;justify-content:center;flex-shrink:0">
                            <i class="bi bi-cpu" style="font-size:1.8rem;color:rgba(255,255,255,.3)"></i>
                        </div>
                    }
                    <div class="flex-grow-1 min-w-0">
                        <div class="fw-bold text-white" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@r.ProductName</div>
                        <div class="d-flex gap-3 mt-1 flex-wrap" style="font-size:.8rem">
                            <span class="text-muted-white">Mua: @r.PurchaseDate.ToString("dd/MM/yyyy")</span>
                            <span class="text-muted-white">Hết hạn: @expiry.ToString("dd/MM/yyyy")</span>
                            @if (!string.IsNullOrEmpty(r.SerialNumber))
                            {
                                <span class="text-muted-white">Serial: @r.SerialNumber</span>
                            }
                            @if (r.OrderId.HasValue)
                            {
                                <a href="/Orders/Detail/@r.OrderId" class="text-muted-white" style="text-decoration:none">
                                    #@r.OrderId
                                </a>
                            }
                        </div>
                        <!-- Progress bar -->
                        <div class="mt-2" style="height:4px;background:rgba(255,255,255,.1);border-radius:2px">
                            <div style="width:@pct.ToString("F0")%;height:100%;background:@barColor;border-radius:2px;transition:width .5s"></div>
                        </div>
                        <div class="mt-1 fw-semibold" style="font-size:.8rem;@statusStyle">@statusText · @r.WarrantyMonths tháng</div>
                    </div>
                </div>
            </div>
        }
        </div>
    }
</div>
