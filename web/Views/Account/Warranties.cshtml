@model List<TechSpecs.Models.WarrantyRecord>
@{
    ViewData["Title"] = "Bảo hành của tôi";
    var now = DateTime.UtcNow;
}

<div class="container py-4" style="max-width:900px">
    <h4 class="fw-bold mb-4" style="color:var(--text)">
        <i class="bi bi-shield-check me-2" style="color:var(--primary)"></i>Bảo hành của tôi
    </h4>

    @if (!Model.Any())
    {
        <div class="tx-card p-5 text-center">
            <i class="bi bi-shield-slash" style="font-size:3rem;color:var(--text-muted);opacity:.3"></i>
            <p class="mt-3 mb-0" style="color:var(--text-muted)">
                Bạn chưa có sản phẩm nào trong danh sách bảo hành.<br>
                Bảo hành được tạo tự động khi đơn hàng chuyển sang trạng thái "Đã xác nhận".
            </p>
        </div>
    }
    else
    {
        <div class="row g-3">
        @foreach (var r in Model)
        {
            var expiry = r.PurchaseDate.AddMonths(r.WarrantyMonths);
            var daysLeft = (expiry - now).TotalDays;
            var pct = Math.Max(0, Math.Min(100, daysLeft / (r.WarrantyMonths * 30.0) * 100));
            var (barColor, statusText) = daysLeft switch
            {
                <= 0   => ("var(--danger)", "Hết hạn"),
                <= 30  => ("#fb923c", $"Còn {(int)daysLeft} ngày"),
                <= 90  => ("#f59e0b", $"Còn {(int)daysLeft} ngày"),
                _      => ("#4ade80", $"Còn {(int)daysLeft} ngày"),
            };
            <div class="col-12">
                <div class="tx-card p-4 d-flex gap-3 align-items-start">
                    @if (!string.IsNullOrEmpty(r.ImageUrl))
                    {
                        <img src="@r.ImageUrl" style="width:64px;height:64px;object-fit:contain;border-radius:8px;background:var(--surface-2);flex-shrink:0" />
                    }
                    else
                    {
                        <div style="width:64px;height:64px;border-radius:8px;background:var(--surface-2);display:flex;align-items:center;justify-content:center;flex-shrink:0">
                            <i class="bi bi-cpu" style="font-size:1.8rem;color:var(--text-muted);opacity:.4"></i>
                        </div>
                    }
                    <div class="flex-grow-1 min-w-0">
                        <div class="fw-bold" style="color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@r.ProductName</div>
                        <div class="d-flex gap-3 mt-1 flex-wrap" style="font-size:.8rem">
                            <span style="color:var(--text-muted)">Mua: @r.PurchaseDate.ToString("dd/MM/yyyy")</span>
                            <span style="color:var(--text-muted)">Hết hạn: @expiry.ToString("dd/MM/yyyy")</span>
                            @if (!string.IsNullOrEmpty(r.SerialNumber))
                            {
                                <span style="color:var(--text-muted)">Serial: @r.SerialNumber</span>
                            }
                            @if (r.OrderId.HasValue)
                            {
                                <a href="/Orders/Detail/@r.OrderId" style="color:var(--primary);text-decoration:none">#@r.OrderId</a>
                            }
                        </div>
                        <div class="mt-2" style="height:4px;background:var(--surface-2);border-radius:2px">
                            <div style="width:@pct.ToString("F0")%;height:100%;background:@barColor;border-radius:2px;transition:width .5s"></div>
                        </div>
                        <div class="mt-1 fw-semibold" style="font-size:.8rem;color:@barColor">
                            @statusText · @r.WarrantyMonths tháng
                        </div>
                    </div>
                </div>
            </div>
        }
        </div>
    }
</div>
