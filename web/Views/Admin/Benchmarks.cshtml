@model List<TechSpecs.Models.ComponentBenchmark>
@{
    ViewData["Title"] = "Benchmark";
    var cpus = Model.Where(b => b.Category == "cpu").ToList();
    var gpus = Model.Where(b => b.Category == "gpu").ToList();
}

<div class="p-4">
    <div class="d-flex align-items-center gap-3 mb-2">
        <h4 class="fw-bold mb-0" style="color:var(--text)">
            <i class="bi bi-bar-chart-fill me-2" style="color:#6366f1"></i>Benchmark linh kiện
        </h4>
        <button class="btn btn-gradient ms-auto" data-bs-toggle="modal" data-bs-target="#addModal">
            <i class="bi bi-plus-lg me-1"></i>Thêm benchmark
        </button>
    </div>
    <p style="color:var(--text-muted);font-size:.82rem" class="mb-4">
        Tên linh kiện dùng để khớp ILIKE — gõ ngắn gọn (VD: "RTX 4070", "i5-12400F").
    </p>

    @if (!Model.Any())
    {
        <div class="tx-card p-5 text-center" style="color:var(--text-muted)">
            <i class="bi bi-bar-chart fs-1 d-block mb-2 opacity-30"></i>Chưa có dữ liệu benchmark nào.
        </div>
    }

    @if (cpus.Any())
    {
        <h5 class="fw-semibold mb-2" style="color:var(--text)"><i class="bi bi-cpu me-2" style="color:#60a5fa"></i>CPU</h5>
        <div class="tx-card mb-4" style="overflow-x:auto">
            <table class="tx-table">
                <thead>
                    <tr>
                        <th>Tên linh kiện</th>
                        <th>CB R23 Multi</th>
                        <th>CB R23 Single</th>
                        <th style="color:var(--text-muted)">Cập nhật</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var b in cpus)
                {
                    <tr>
                        <td class="fw-semibold" style="color:var(--text)">@b.ComponentName</td>
                        <td style="color:var(--text)">@(b.CinebenchR23Multi?.ToString("N0") ?? "—")</td>
                        <td style="color:var(--text)">@(b.CinebenchR23Single?.ToString("N0") ?? "—")</td>
                        <td style="color:var(--text-muted);font-size:.75rem">@(b.UpdatedAt?.ToString("dd/MM/yy") ?? b.CreatedAt.ToString("dd/MM/yy"))</td>
                        <td class="text-end">
                            <button class="btn btn-sm glass px-2 py-1 me-1 edit-btn"
                                style="color:var(--primary)"
                                data-id="@b.Id" data-category="@b.Category"
                                data-name="@b.ComponentName"
                                data-cbm="@b.CinebenchR23Multi"
                                data-cbs="@b.CinebenchR23Single">
                                <i class="bi bi-pencil" style="font-size:.8rem"></i>
                            </button>
                            <form method="post" action="/Admin/DeleteBenchmark" class="d-inline"
                                  onsubmit="return confirm('Xóa benchmark này?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@b.Id" />
                                <button type="submit" class="btn btn-sm px-2 py-1" style="color:var(--danger);background:rgba(239,68,68,.12);border:none">
                                    <i class="bi bi-trash3" style="font-size:.8rem"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }

    @if (gpus.Any())
    {
        <h5 class="fw-semibold mb-2" style="color:var(--text)"><i class="bi bi-gpu-card me-2" style="color:#10b981"></i>GPU</h5>
        <div class="tx-card mb-4" style="overflow-x:auto">
            <table class="tx-table">
                <thead>
                    <tr>
                        <th>Tên linh kiện</th>
                        <th>CS2 1080p</th>
                        <th>CS2 1440p</th>
                        <th>Cyberpunk 1080p</th>
                        <th>Cyberpunk 1440p</th>
                        <th>Valorant 1080p</th>
                        <th>Valorant 1440p</th>
                        <th style="color:var(--text-muted)">Cập nhật</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var b in gpus)
                {
                    <tr>
                        <td class="fw-semibold" style="color:var(--text)">@b.ComponentName</td>
                        <td>@(b.FpsCs2_1080p?.ToString() ?? "—")</td>
                        <td>@(b.FpsCs2_1440p?.ToString() ?? "—")</td>
                        <td>@(b.FpsCyberpunk_1080p?.ToString() ?? "—")</td>
                        <td>@(b.FpsCyberpunk_1440p?.ToString() ?? "—")</td>
                        <td>@(b.FpsValorant_1080p?.ToString() ?? "—")</td>
                        <td>@(b.FpsValorant_1440p?.ToString() ?? "—")</td>
                        <td style="color:var(--text-muted);font-size:.75rem">@(b.UpdatedAt?.ToString("dd/MM/yy") ?? b.CreatedAt.ToString("dd/MM/yy"))</td>
                        <td class="text-end">
                            <button class="btn btn-sm glass px-2 py-1 me-1 edit-btn"
                                style="color:var(--primary)"
                                data-id="@b.Id" data-category="@b.Category"
                                data-name="@b.ComponentName"
                                data-cs2-1080="@b.FpsCs2_1080p"
                                data-cs2-1440="@b.FpsCs2_1440p"
                                data-cp-1080="@b.FpsCyberpunk_1080p"
                                data-cp-1440="@b.FpsCyberpunk_1440p"
                                data-val-1080="@b.FpsValorant_1080p"
                                data-val-1440="@b.FpsValorant_1440p">
                                <i class="bi bi-pencil" style="font-size:.8rem"></i>
                            </button>
                            <form method="post" action="/Admin/DeleteBenchmark" class="d-inline"
                                  onsubmit="return confirm('Xóa benchmark này?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@b.Id" />
                                <button type="submit" class="btn btn-sm px-2 py-1" style="color:var(--danger);background:rgba(239,68,68,.12);border:none">
                                    <i class="bi bi-trash3" style="font-size:.8rem"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Add Modal -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" style="background:var(--surface);border:1px solid var(--border)">
            <div class="modal-header" style="border-color:var(--border)">
                <h5 class="modal-title" style="color:var(--text)">Thêm benchmark mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/Admin/CreateBenchmark">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label small" style="color:var(--text-muted)">Danh mục</label>
                            <select name="category" class="form-select" style="background:var(--surface-2);border-color:var(--border);color:var(--text)" required>
                                <option value="cpu">CPU</option>
                                <option value="gpu">GPU</option>
                            </select>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label small" style="color:var(--text-muted)">Tên linh kiện (ILIKE match)</label>
                            <input name="componentName" class="form-control" placeholder="VD: RTX 4070 Ti, i5-12400F" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small" style="color:var(--text-muted)">Cinebench R23 Multi</label>
                            <input name="cinebenchR23Multi" type="number" class="form-control" placeholder="VD: 15200" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small" style="color:var(--text-muted)">Cinebench R23 Single</label>
                            <input name="cinebenchR23Single" type="number" class="form-control" placeholder="VD: 1780" />
                        </div>
                        <div class="col-6 col-md-4">
                            <label class="form-label small" style="color:var(--text-muted)">CS2 FPS @@ 1080p</label>
                            <input name="fpsCs2_1080p" type="number" class="form-control" />
                        </div>
                        <div class="col-6 col-md-4">
                            <label class="form-label small" style="color:var(--text-muted)">CS2 FPS @@ 1440p</label>
                            <input name="fpsCs2_1440p" type="number" class="form-control" />
                        </div>
                        <div class="col-6 col-md-4">
                            <label class="form-label small" style="color:var(--text-muted)">Cyberpunk @@ 1080p</label>
                            <input name="fpsCyberpunk_1080p" type="number" class="form-control" />
                        </div>
                        <div class="col-6 col-md-4">
                            <label class="form-label small" style="color:var(--text-muted)">Cyberpunk @@ 1440p</label>
                            <input name="fpsCyberpunk_1440p" type="number" class="form-control" />
                        </div>
                        <div class="col-6 col-md-4">
                            <label class="form-label small" style="color:var(--text-muted)">Valorant @@ 1080p</label>
                            <input name="fpsValorant_1080p" type="number" class="form-control" />
                        </div>
                        <div class="col-6 col-md-4">
                            <label class="form-label small" style="color:var(--text-muted)">Valorant @@ 1440p</label>
                            <input name="fpsValorant_1440p" type="number" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer" style="border-color:var(--border)">
                    <button type="button" class="btn glass" style="color:var(--text-muted)" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-gradient">Lưu benchmark</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" style="background:var(--surface);border:1px solid var(--border)">
            <div class="modal-header" style="border-color:var(--border)">
                <h5 class="modal-title" style="color:var(--text)">Chỉnh sửa benchmark</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/Admin/EditBenchmark">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="editId" />
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small" style="color:var(--text-muted)">Tên linh kiện</label>
                            <input name="componentName" id="editName" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small" style="color:var(--text-muted)">Cinebench R23 Multi</label>
                            <input name="cinebenchR23Multi" id="editCbMulti" type="number" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small" style="color:var(--text-muted)">Cinebench R23 Single</label>
                            <input name="cinebenchR23Single" id="editCbSingle" type="number" class="form-control" />
                        </div>
                        <div class="col-6 col-md-4">
                            <label class="form-label small" style="color:var(--text-muted)">CS2 1080p</label>
                            <input name="fpsCs2_1080p" id="editCs2_1080" type="number" class="form-control" />
                        </div>
                        <div class="col-6 col-md-4">
                            <label class="form-label small" style="color:var(--text-muted)">CS2 1440p</label>
                            <input name="fpsCs2_1440p" id="editCs2_1440" type="number" class="form-control" />
                        </div>
                        <div class="col-6 col-md-4">
                            <label class="form-label small" style="color:var(--text-muted)">Cyberpunk 1080p</label>
                            <input name="fpsCyberpunk_1080p" id="editCp_1080" type="number" class="form-control" />
                        </div>
                        <div class="col-6 col-md-4">
                            <label class="form-label small" style="color:var(--text-muted)">Cyberpunk 1440p</label>
                            <input name="fpsCyberpunk_1440p" id="editCp_1440" type="number" class="form-control" />
                        </div>
                        <div class="col-6 col-md-4">
                            <label class="form-label small" style="color:var(--text-muted)">Valorant 1080p</label>
                            <input name="fpsValorant_1080p" id="editVal_1080" type="number" class="form-control" />
                        </div>
                        <div class="col-6 col-md-4">
                            <label class="form-label small" style="color:var(--text-muted)">Valorant 1440p</label>
                            <input name="fpsValorant_1440p" id="editVal_1440" type="number" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer" style="border-color:var(--border)">
                    <button type="button" class="btn glass" style="color:var(--text-muted)" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-gradient">Cập nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.querySelectorAll('.edit-btn').forEach(btn => {
    btn.addEventListener('click', () => {
        const d = btn.dataset;
        document.getElementById('editId').value      = d.id;
        document.getElementById('editName').value    = d.name;
        document.getElementById('editCbMulti').value  = d.cbm  ?? '';
        document.getElementById('editCbSingle').value = d.cbs  ?? '';
        document.getElementById('editCs2_1080').value = d['cs2-1080'] ?? '';
        document.getElementById('editCs2_1440').value = d['cs2-1440'] ?? '';
        document.getElementById('editCp_1080').value  = d['cp-1080']  ?? '';
        document.getElementById('editCp_1440').value  = d['cp-1440']  ?? '';
        document.getElementById('editVal_1080').value = d['val-1080'] ?? '';
        document.getElementById('editVal_1440').value = d['val-1440'] ?? '';
        new bootstrap.Modal(document.getElementById('editModal')).show();
    });
});
</script>
}
