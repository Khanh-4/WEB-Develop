@model List<TechSpecs.Models.Coupon>
@{
    ViewData["Title"] = "Quản lý Coupon";
    Layout = "_Layout";
    var now = DateTime.UtcNow;
}

<div class="container py-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <h3 class="text-white fw-bold mb-0"><i class="bi bi-ticket-perforated me-2" style="color:#a855f7"></i>Coupon</h3>
        <a href="/Admin/CreateCoupon" class="btn btn-gradient ms-auto">
            <i class="bi bi-plus-lg me-2"></i>Tạo Coupon
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="glass p-4 text-center text-muted-white">Chưa có coupon nào.</div>
    }
    else
    {
        <div class="glass p-0 overflow-hidden">
            <table class="table table-dark table-hover mb-0" style="font-size:.85rem">
                <thead>
                    <tr style="background:rgba(255,255,255,.05)">
                        <th class="px-3 py-2">Mã</th>
                        <th class="px-3 py-2">Loại giảm</th>
                        <th class="px-3 py-2">Giá trị</th>
                        <th class="px-3 py-2">Đơn tối thiểu</th>
                        <th class="px-3 py-2">Đã dùng</th>
                        <th class="px-3 py-2">Hết hạn</th>
                        <th class="px-3 py-2">Filter</th>
                        <th class="px-3 py-2">Trạng thái</th>
                        <th class="px-3 py-2"></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var c in Model)
                {
                    var expired = c.ExpiresAt.HasValue && c.ExpiresAt.Value < now;
                    var exhausted = c.MaxUses.HasValue && c.UsedCount >= c.MaxUses.Value;
                    <tr>
                        <td class="px-3 py-2">
                            <span class="fw-bold" style="color:#c084fc;font-family:monospace">@c.Code</span>
                            @if (c.IsFreeShip)
                            {
                                <span class="badge ms-1" style="background:rgba(96,165,250,.2);color:#60a5fa;font-size:.7rem">FREESHIP</span>
                            }
                        </td>
                        <td class="px-3 py-2">@(c.DiscountType == TechSpecs.Models.DiscountType.Percent ? "%" : "đ")</td>
                        <td class="px-3 py-2 fw-bold">
                            @if (c.DiscountType == TechSpecs.Models.DiscountType.Percent)
                            { <span style="color:#f59e0b">@c.DiscountValue%</span> }
                            else
                            { <span style="color:#f59e0b">@c.DiscountValue.ToString("N0")đ</span> }
                        </td>
                        <td class="px-3 py-2 text-muted-white">@(c.MinOrderAmount.HasValue ? c.MinOrderAmount.Value.ToString("N0") + "đ" : "—")</td>
                        <td class="px-3 py-2">@c.UsedCount/@(c.MaxUses.HasValue ? c.MaxUses.Value.ToString() : "∞")</td>
                        <td class="px-3 py-2 text-muted-white" style="font-size:.78rem">
                            @(c.ExpiresAt.HasValue ? c.ExpiresAt.Value.ToString("dd/MM/yyyy") : "—")
                        </td>
                        <td class="px-3 py-2 text-muted-white" style="font-size:.78rem">
                            @if (!string.IsNullOrEmpty(c.CategoryFilter)) { <span>Cat: @c.CategoryFilter</span> }
                            @if (!string.IsNullOrEmpty(c.BrandFilter)) { <span> Brand: @c.BrandFilter</span> }
                            @if (string.IsNullOrEmpty(c.CategoryFilter) && string.IsNullOrEmpty(c.BrandFilter)) { <span>Tất cả</span> }
                        </td>
                        <td class="px-3 py-2">
                            @if (!c.IsActive || expired || exhausted)
                            {
                                <span class="badge bg-secondary">@(expired ? "Hết hạn" : exhausted ? "Hết lượt" : "Tắt")</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                        </td>
                        <td class="px-3 py-2">
                            <div class="d-flex gap-1">
                                <form method="post" action="/Admin/ToggleCoupon/@c.Id">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm glass text-white" title="@(c.IsActive ? "Tắt" : "Bật")">
                                        <i class="bi @(c.IsActive ? "bi-toggle-on text-success" : "bi-toggle-off text-muted")"></i>
                                    </button>
                                </form>
                                <form method="post" action="/Admin/DeleteCoupon/@c.Id"
                                      onsubmit="return confirm('Xoá coupon @c.Code?')">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
