@model List<TechSpecs.Models.Coupon>
@{
    ViewData["Title"] = "Coupon";
    var now = DateTime.UtcNow;
}

<div class="p-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <h4 class="fw-bold mb-0" style="color:var(--text)">
            <i class="bi bi-ticket-perforated me-2" style="color:#a855f7"></i>Coupon
        </h4>
        <span class="badge glass-sm ms-1 px-2 py-1" style="color:var(--text-muted);font-size:.75rem">@Model.Count</span>
        <a href="/Admin/CreateCoupon" class="btn btn-gradient ms-auto">
            <i class="bi bi-plus-lg me-1"></i>Tạo Coupon
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="tx-card p-5 text-center" style="color:var(--text-muted)">
            <i class="bi bi-ticket fs-1 d-block mb-2 opacity-30"></i>Chưa có coupon nào.
        </div>
    }
    else
    {
        <div class="tx-card">
            <table class="tx-table">
                <thead>
                    <tr>
                        <th>Mã</th>
                        <th>Loại</th>
                        <th>Giá trị</th>
                        <th>Đơn tối thiểu</th>
                        <th>Đã dùng</th>
                        <th>Hết hạn</th>
                        <th>Filter</th>
                        <th class="text-center">Trạng thái</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var c in Model)
                {
                    var expired = c.ExpiresAt.HasValue && c.ExpiresAt.Value < now;
                    var exhausted = c.MaxUses.HasValue && c.UsedCount >= c.MaxUses.Value;
                    <tr>
                        <td>
                            <span class="fw-bold" style="color:var(--primary);font-family:monospace;font-size:.85rem">@c.Code</span>
                            @if (c.IsFreeShip)
                            {
                                <span class="badge ms-1 glass-sm" style="color:var(--accent);font-size:.68rem">FREESHIP</span>
                            }
                        </td>
                        <td style="color:var(--text-muted);font-size:.83rem">
                            @(c.DiscountType == TechSpecs.Models.DiscountType.Percent ? "Phần trăm" : "Cố định")
                        </td>
                        <td class="fw-bold" style="color:#f59e0b;font-size:.85rem">
                            @if (c.DiscountType == TechSpecs.Models.DiscountType.Percent)
                            { <span>@c.DiscountValue%</span> }
                            else
                            { <span>@c.DiscountValue.ToString("N0")đ</span> }
                        </td>
                        <td style="color:var(--text-muted);font-size:.82rem">
                            @(c.MinOrderAmount.HasValue ? c.MinOrderAmount.Value.ToString("N0") + "đ" : "—")
                        </td>
                        <td style="color:var(--text-muted);font-size:.82rem">
                            @c.UsedCount/@(c.MaxUses.HasValue ? c.MaxUses.Value.ToString() : "∞")
                        </td>
                        <td style="color:var(--text-muted);font-size:.78rem">
                            @(c.ExpiresAt.HasValue ? c.ExpiresAt.Value.ToString("dd/MM/yyyy") : "—")
                        </td>
                        <td style="color:var(--text-muted);font-size:.78rem">
                            @if (!string.IsNullOrEmpty(c.CategoryFilter)) { <span>@c.CategoryFilter</span> }
                            @if (!string.IsNullOrEmpty(c.BrandFilter)) { <span> @c.BrandFilter</span> }
                            @if (string.IsNullOrEmpty(c.CategoryFilter) && string.IsNullOrEmpty(c.BrandFilter)) { <span>Tất cả</span> }
                        </td>
                        <td class="text-center">
                            @if (!c.IsActive || expired || exhausted)
                            {
                                <span class="status-pill cancelled">@(expired ? "Hết hạn" : exhausted ? "Hết lượt" : "Tắt")</span>
                            }
                            else
                            {
                                <span class="status-pill completed">Hoạt động</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <form method="post" action="/Admin/ToggleCoupon/@c.Id">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm glass px-2 py-1" title="@(c.IsActive ? "Tắt" : "Bật")"
                                            style="color:@(c.IsActive ? "var(--accent)" : "var(--text-muted)")">
                                        <i class="bi @(c.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                    </button>
                                </form>
                                <form method="post" action="/Admin/DeleteCoupon/@c.Id"
                                      onsubmit="return confirm('Xoá coupon @c.Code?')">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm px-2 py-1" style="color:var(--danger);background:rgba(239,68,68,.12);border:none">
                                        <i class="bi bi-trash3" style="font-size:.8rem"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
