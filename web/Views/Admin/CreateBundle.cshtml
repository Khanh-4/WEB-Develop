@{
    ViewData["Title"] = "Tạo Combo";
}

<div class="p-4" style="max-width:720px">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/Admin/Bundles" class="btn glass" style="color:var(--text)"><i class="bi bi-arrow-left"></i></a>
        <h4 class="fw-bold mb-0" style="color:var(--text)"><i class="bi bi-boxes me-2" style="color:#4ade80"></i>Tạo Combo</h4>
    </div>

    <div class="tx-card p-4">
        <form method="post" id="bundleForm">
            @Html.AntiForgeryToken()
            <div class="row g-3 mb-3">
                <div class="col-8">
                    <label class="form-label small" style="color:var(--text-muted)">Tên combo</label>
                    <input name="name" type="text" class="form-control" required placeholder="VD: Bộ CPU + Mainboard Intel" />
                </div>
                <div class="col-4">
                    <label class="form-label small" style="color:var(--text-muted)">Giảm (%)</label>
                    <input name="discountPercent" type="number" class="form-control" required min="1" max="50" value="5" />
                </div>
                <div class="col-12">
                    <label class="form-label small" style="color:var(--text-muted)">Mô tả (tùy chọn)</label>
                    <input name="description" type="text" class="form-control" maxlength="500" />
                </div>
            </div>

            <h6 class="fw-semibold mb-2" style="color:var(--text)">Sản phẩm trong combo</h6>
            <div id="itemsContainer"></div>

            <button type="button" class="btn glass btn-sm mb-3" style="color:var(--text)" onclick="addItem()">
                <i class="bi bi-plus-lg me-1"></i>Thêm sản phẩm
            </button>

            <button type="submit" class="btn btn-gradient w-100">
                <i class="bi bi-boxes me-2"></i>Tạo Combo
            </button>
        </form>
    </div>
</div>

@section Scripts {
<script>
const cats = ['cpu','motherboard','memory','gpu','storage','psu','case','cooler'];
let itemCount = 0;

function addItem() {
    const idx = itemCount++;
    const div = document.createElement('div');
    div.className = 'tx-card p-3 mb-2';
    div.innerHTML = `
        <div class="row g-2 align-items-end">
            <div class="col-3">
                <label class="form-label small" style="color:var(--text-muted)">Danh mục</label>
                <select name="categories" class="form-select">
                    ${cats.map(c => `<option value="${c}">${c.toUpperCase()}</option>`).join('')}
                </select>
            </div>
            <div class="col-2">
                <label class="form-label small" style="color:var(--text-muted)">ID</label>
                <input name="componentIds" type="number" class="form-control" required min="1" />
            </div>
            <div class="col-4">
                <label class="form-label small" style="color:var(--text-muted)">Tên sản phẩm</label>
                <input name="productNames" type="text" class="form-control" required maxlength="300" />
            </div>
            <div class="col-2">
                <label class="form-label small" style="color:var(--text-muted)">Giá (đ)</label>
                <input name="prices" type="number" class="form-control" required min="0" />
            </div>
            <div class="col-1 d-flex align-items-end pb-1">
                <button type="button" class="btn btn-sm btn-danger" onclick="this.closest('.tx-card').remove()">
                    <i class="bi bi-x"></i>
                </button>
            </div>
        </div>`;
    document.getElementById('itemsContainer').appendChild(div);
}

// Start with 2 items
addItem(); addItem();
</script>
}
