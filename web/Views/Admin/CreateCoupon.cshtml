@model TechSpecs.Models.Coupon
@{
    ViewData["Title"] = "Tạo Coupon";
}

<div class="p-4" style="max-width:620px">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/Admin/Coupons" class="btn glass" style="color:var(--text)"><i class="bi bi-arrow-left"></i></a>
        <h4 class="fw-bold mb-0" style="color:var(--text)"><i class="bi bi-ticket-perforated me-2" style="color:var(--primary)"></i>Tạo Coupon</h4>
    </div>

    <div class="tx-card p-4">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-8">
                    <label class="form-label small" style="color:var(--text-muted)">Mã coupon</label>
                    <input name="Code" type="text" class="form-control" required
                           style="font-family:monospace;text-transform:uppercase"
                           placeholder="VD: SUMMER20" maxlength="50" />
                </div>
                <div class="col-4">
                    <label class="form-label small" style="color:var(--text-muted)">Loại giảm</label>
                    <select name="DiscountType" class="form-select">
                        <option value="0">% Phần trăm</option>
                        <option value="1">đ Số tiền</option>
                    </select>
                </div>
                <div class="col-6">
                    <label class="form-label small" style="color:var(--text-muted)">Giá trị giảm</label>
                    <input name="DiscountValue" type="number" class="form-control" required min="0" step="0.01" />
                </div>
                <div class="col-6">
                    <label class="form-label small" style="color:var(--text-muted)">Đơn tối thiểu (đ)</label>
                    <input name="MinOrderAmount" type="number" class="form-control" min="0" placeholder="Bỏ trống = không giới hạn" />
                </div>
                <div class="col-6">
                    <label class="form-label small" style="color:var(--text-muted)">Số lần dùng tối đa</label>
                    <input name="MaxUses" type="number" class="form-control" min="1" placeholder="Bỏ trống = không giới hạn" />
                </div>
                <div class="col-6">
                    <label class="form-label small" style="color:var(--text-muted)">Hết hạn</label>
                    <input name="ExpiresAt" type="datetime-local" class="form-control" />
                </div>
                <div class="col-6">
                    <label class="form-label small" style="color:var(--text-muted)">Chỉ áp dụng danh mục</label>
                    <input name="CategoryFilter" type="text" class="form-control" placeholder="VD: cpu,gpu (bỏ trống = tất cả)" maxlength="200" />
                </div>
                <div class="col-6">
                    <label class="form-label small" style="color:var(--text-muted)">Chỉ áp dụng thương hiệu</label>
                    <input name="BrandFilter" type="text" class="form-control" placeholder="VD: ASUS (bỏ trống = tất cả)" maxlength="100" />
                </div>
                <div class="col-12">
                    <label class="form-label small" style="color:var(--text-muted)">Mô tả</label>
                    <input name="Description" type="text" class="form-control" maxlength="200" />
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="IsFreeShip" value="true" id="freeshipCheck">
                        <label class="form-check-label" style="color:var(--text-muted)" for="freeshipCheck">Freeship</label>
                    </div>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-gradient w-100">
                        <i class="bi bi-ticket-perforated me-2"></i>Tạo Coupon
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>
