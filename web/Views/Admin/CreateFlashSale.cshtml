@model TechSpecs.Models.FlashSale
@{
    ViewData["Title"] = "Tạo Flash Sale";
}

<div class="p-4" style="max-width:660px">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/Admin/FlashSales" class="btn glass" style="color:var(--text)"><i class="bi bi-arrow-left"></i></a>
        <h4 class="fw-bold mb-0" style="color:var(--text)"><i class="bi bi-lightning-charge me-2" style="color:#f59e0b"></i>Tạo Flash Sale</h4>
    </div>

    <div class="tx-card p-4">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label small" style="color:var(--text-muted)">Danh mục</label>
                    <select name="Category" class="form-select" required>
                        @foreach (var cat in new[] {"cpu","motherboard","memory","gpu","storage","psu","case","cooler"})
                        {
                            <option value="@cat">@cat.ToUpper()</option>
                        }
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label small" style="color:var(--text-muted)">ID sản phẩm</label>
                    <input name="ProductId" type="number" class="form-control" required value="@Model.ProductId" />
                </div>
                <div class="col-12">
                    <label class="form-label small" style="color:var(--text-muted)">Tên sản phẩm</label>
                    <input name="ProductName" type="text" class="form-control" required value="@Model.ProductName" maxlength="300" />
                </div>
                <div class="col-6">
                    <label class="form-label small" style="color:var(--text-muted)">Giá gốc (đ)</label>
                    <input name="OriginalPrice" type="number" class="form-control" required value="@Model.OriginalPrice" min="0" />
                </div>
                <div class="col-6">
                    <label class="form-label small" style="color:var(--text-muted)">Giảm giá (%)</label>
                    <input name="DiscountPercent" type="number" class="form-control" required value="@Model.DiscountPercent" min="1" max="99" />
                </div>
                <div class="col-6">
                    <label class="form-label small" style="color:var(--text-muted)">Số lượng</label>
                    <input name="TotalQty" type="number" class="form-control" required value="@(Model.TotalQty > 0 ? Model.TotalQty : 20)" min="1" />
                </div>
                <div class="col-6">
                    <label class="form-label small" style="color:var(--text-muted)">Đã bán</label>
                    <input name="SoldQty" type="number" class="form-control" value="0" min="0" />
                </div>
                <div class="col-6">
                    <label class="form-label small" style="color:var(--text-muted)">Bắt đầu (UTC)</label>
                    <input name="StartsAt" type="datetime-local" class="form-control" required value="@Model.StartsAt.ToString("yyyy-MM-ddTHH:mm")" />
                </div>
                <div class="col-6">
                    <label class="form-label small" style="color:var(--text-muted)">Kết thúc (UTC)</label>
                    <input name="EndsAt" type="datetime-local" class="form-control" required value="@Model.EndsAt.ToString("yyyy-MM-ddTHH:mm")" />
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-gradient w-100">
                        <i class="bi bi-lightning-charge me-2"></i>Tạo Flash Sale
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>
