@model TechSpecs.ViewModels.AdminProductEditViewModel
@using System.Globalization
@{
    ViewData["Title"] = Model.Id == 0 ? "Thêm sản phẩm" : "Sửa sản phẩm";
    var catLabel = Model.Category switch {
        "cpu" => "CPU", "motherboard" => "Motherboard", "memory" => "RAM",
        "gpu" => "GPU", "psu" => "PSU", "case" => "Case",
        "storage" => "Storage", "cooler" => "Cooler", _ => Model.Category
    };
}

<div class="p-4" style="max-width:760px">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/Admin/Products?category=@Model.Category" class="btn glass px-2 py-1" style="color:var(--text)">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h4 class="fw-bold mb-0" style="color:var(--text)">
            @(Model.Id == 0 ? "Thêm" : "Sửa") @catLabel
        </h4>
    </div>

    <form asp-action="EditProduct" asp-controller="Admin" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Category">
        <input type="hidden" asp-for="Id">

        <div class="tx-card p-4 mb-4">
            <h6 class="fw-semibold mb-3" style="color:var(--text);font-size:.85rem;text-transform:uppercase;letter-spacing:.04em;opacity:.7">
                Thông tin chung
            </h6>
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Name" class="form-label small" style="color:var(--text-muted)">Tên sản phẩm *</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Manufacturer" class="form-label small" style="color:var(--text-muted)">Hãng sản xuất *</label>
                    <input asp-for="Manufacturer" class="form-control" />
                    <span asp-validation-for="Manufacturer" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Price" class="form-label small" style="color:var(--text-muted)">Giá (VNĐ) *</label>
                    <input name="Price" id="Price" class="form-control" type="number" min="0"
                           value="@Model.Price.ToString(CultureInfo.InvariantCulture)" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Stock" class="form-label small" style="color:var(--text-muted)">Tồn kho</label>
                    <input asp-for="Stock" class="form-control" type="number" min="0" />
                </div>
                <div class="col-md-4">
                    <label asp-for="StockStatusOverride" class="form-label small" style="color:var(--text-muted)">Trạng thái kho (override)</label>
                    <select asp-for="StockStatusOverride" class="form-select">
                        <option value="">— Tự động theo tồn kho —</option>
                        <option value="0">Còn hàng</option>
                        <option value="1">Còn ít</option>
                        <option value="2">Hết hàng</option>
                        <option value="3">Sắp về</option>
                        <option value="4">Liên hệ</option>
                    </select>
                </div>
                <div class="col-12">
                    <label asp-for="ImageUrl" class="form-label small" style="color:var(--text-muted)">Image URL</label>
                    <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                </div>
            </div>
        </div>

        @if (Model.Category == "cpu")
        {
            <div class="tx-card p-4 mb-4">
                <h6 class="fw-semibold mb-3" style="color:var(--text);font-size:.85rem;text-transform:uppercase;letter-spacing:.04em;opacity:.7">CPU Specs</h6>
                <div class="row g-3">
                    <div class="col-md-4"><label class="form-label small" style="color:var(--text-muted)">Socket</label><input asp-for="Socket" class="form-control" placeholder="LGA1700 / AM5 / AM4" /></div>
                    <div class="col-md-4"><label class="form-label small" style="color:var(--text-muted)">Số nhân</label><input asp-for="CoreCount" class="form-control" type="number" /></div>
                    <div class="col-md-4"><label class="form-label small" style="color:var(--text-muted)">Số thread</label><input asp-for="ThreadCount" class="form-control" type="number" /></div>
                    <div class="col-md-3"><label class="form-label small" style="color:var(--text-muted)">Base Clock (GHz)</label><input name="BaseClock" id="BaseClock" class="form-control" type="number" step="0.01" value="@Model.BaseClock?.ToString(CultureInfo.InvariantCulture)" /></div>
                    <div class="col-md-3"><label class="form-label small" style="color:var(--text-muted)">Boost Clock (GHz)</label><input name="BoostClock" id="BoostClock" class="form-control" type="number" step="0.01" value="@Model.BoostClock?.ToString(CultureInfo.InvariantCulture)" /></div>
                    <div class="col-md-3"><label class="form-label small" style="color:var(--text-muted)">TDP (W)</label><input asp-for="TDP" class="form-control" type="number" /></div>
                    <div class="col-md-3"><label class="form-label small" style="color:var(--text-muted)">Perf Score</label><input name="CpuPerformance" id="CpuPerformance" class="form-control" type="number" step="0.01" value="@Model.CpuPerformance?.ToString(CultureInfo.InvariantCulture)" /></div>
                </div>
            </div>
        }

        @if (Model.Category == "motherboard")
        {
            <div class="tx-card p-4 mb-4">
                <h6 class="fw-semibold mb-3" style="color:var(--text);font-size:.85rem;text-transform:uppercase;letter-spacing:.04em;opacity:.7">Motherboard Specs</h6>
                <div class="row g-3">
                    <div class="col-md-4"><label class="form-label small" style="color:var(--text-muted)">Socket</label><input asp-for="SocketCompatibility" class="form-control" placeholder="LGA1700 / AM5" /></div>
                    <div class="col-md-4"><label class="form-label small" style="color:var(--text-muted)">Form Factor</label><input asp-for="FormFactor" class="form-control" placeholder="ATX / mATX / ITX" /></div>
                    <div class="col-md-4"><label class="form-label small" style="color:var(--text-muted)">Memory Type</label><input asp-for="MemoryCompatibility" class="form-control" placeholder="DDR4 / DDR5" /></div>
                    <div class="col-md-4"><label class="form-label small" style="color:var(--text-muted)">Số khe RAM</label><input asp-for="MemorySlots" class="form-control" type="number" /></div>
                    <div class="col-md-4"><label class="form-label small" style="color:var(--text-muted)">Max RAM (GB)</label><input asp-for="MaxMemoryCapacity" class="form-control" type="number" /></div>
                </div>
            </div>
        }

        @if (Model.Category == "memory")
        {
            <div class="tx-card p-4 mb-4">
                <h6 class="fw-semibold mb-3" style="color:var(--text);font-size:.85rem;text-transform:uppercase;letter-spacing:.04em;opacity:.7">RAM Specs</h6>
                <div class="row g-3">
                    <div class="col-md-3"><label class="form-label small" style="color:var(--text-muted)">Type</label><input asp-for="MemoryType" class="form-control" placeholder="DDR4 / DDR5" /></div>
                    <div class="col-md-3"><label class="form-label small" style="color:var(--text-muted)">Dung lượng (GB)</label><input asp-for="Capacity" class="form-control" type="number" /></div>
                    <div class="col-md-3"><label class="form-label small" style="color:var(--text-muted)">Số thanh</label><input asp-for="Modules" class="form-control" type="number" /></div>
                    <div class="col-md-3"><label class="form-label small" style="color:var(--text-muted)">Speed (MHz)</label><input asp-for="Speed" class="form-control" type="number" /></div>
                </div>
            </div>
        }

        @if (Model.Category == "gpu")
        {
            <div class="tx-card p-4 mb-4">
                <h6 class="fw-semibold mb-3" style="color:var(--text);font-size:.85rem;text-transform:uppercase;letter-spacing:.04em;opacity:.7">GPU Specs</h6>
                <div class="row g-3">
                    <div class="col-md-3"><label class="form-label small" style="color:var(--text-muted)">VRAM (GB)</label><input asp-for="VRAM" class="form-control" type="number" /></div>
                    <div class="col-md-3"><label class="form-label small" style="color:var(--text-muted)">Chiều dài (mm)</label><input asp-for="GpuLength" class="form-control" type="number" /></div>
                    <div class="col-md-3"><label class="form-label small" style="color:var(--text-muted)">TDP (W)</label><input asp-for="TDP" class="form-control" type="number" /></div>
                    <div class="col-md-3"><label class="form-label small" style="color:var(--text-muted)">Perf Score</label><input name="GpuPerformance" id="GpuPerformance" class="form-control" type="number" step="0.01" value="@Model.GpuPerformance?.ToString(CultureInfo.InvariantCulture)" /></div>
                </div>
            </div>
        }

        @if (Model.Category == "psu")
        {
            <div class="tx-card p-4 mb-4">
                <h6 class="fw-semibold mb-3" style="color:var(--text);font-size:.85rem;text-transform:uppercase;letter-spacing:.04em;opacity:.7">PSU Specs</h6>
                <div class="row g-3">
                    <div class="col-md-4"><label class="form-label small" style="color:var(--text-muted)">Công suất (W)</label><input asp-for="Wattage" class="form-control" type="number" /></div>
                    <div class="col-md-4"><label class="form-label small" style="color:var(--text-muted)">Hiệu suất</label><input asp-for="Efficiency" class="form-control" placeholder="80+ Gold / Platinum" /></div>
                    <div class="col-md-4"><label class="form-label small" style="color:var(--text-muted)">Modular</label><input asp-for="Modular" class="form-control" placeholder="Full / Semi / Non" /></div>
                </div>
            </div>
        }

        @if (Model.Category == "case")
        {
            <div class="tx-card p-4 mb-4">
                <h6 class="fw-semibold mb-3" style="color:var(--text);font-size:.85rem;text-transform:uppercase;letter-spacing:.04em;opacity:.7">Case Specs</h6>
                <div class="row g-3">
                    <div class="col-md-4"><label class="form-label small" style="color:var(--text-muted)">Form Factor hỗ trợ</label><input asp-for="FormFactorSupport" class="form-control" placeholder="ATX,mATX,ITX" /></div>
                    <div class="col-md-4"><label class="form-label small" style="color:var(--text-muted)">Max GPU (mm)</label><input asp-for="MaxVGALength" class="form-control" type="number" /></div>
                    <div class="col-md-4"><label class="form-label small" style="color:var(--text-muted)">Màu sắc</label><input asp-for="Color" class="form-control" placeholder="Black / White" /></div>
                </div>
            </div>
        }

        @if (Model.Category == "storage")
        {
            <div class="tx-card p-4 mb-4">
                <h6 class="fw-semibold mb-3" style="color:var(--text);font-size:.85rem;text-transform:uppercase;letter-spacing:.04em;opacity:.7">Storage Specs</h6>
                <div class="row g-3">
                    <div class="col-md-3"><label class="form-label small" style="color:var(--text-muted)">Loại</label><input asp-for="StorageType" class="form-control" placeholder="NVMe / SSD / HDD" /></div>
                    <div class="col-md-3"><label class="form-label small" style="color:var(--text-muted)">Dung lượng (GB)</label><input asp-for="StorageCapacity" class="form-control" type="number" /></div>
                    <div class="col-md-3"><label class="form-label small" style="color:var(--text-muted)">Interface</label><input asp-for="Interface" class="form-control" placeholder="PCIe 4.0 / SATA" /></div>
                    <div class="col-md-3"><label class="form-label small" style="color:var(--text-muted)">Read (MB/s)</label><input asp-for="ReadSpeed" class="form-control" type="number" /></div>
                    <div class="col-md-3"><label class="form-label small" style="color:var(--text-muted)">Write (MB/s)</label><input asp-for="WriteSpeed" class="form-control" type="number" /></div>
                </div>
            </div>
        }

        @if (Model.Category == "cooler")
        {
            <div class="tx-card p-4 mb-4">
                <h6 class="fw-semibold mb-3" style="color:var(--text);font-size:.85rem;text-transform:uppercase;letter-spacing:.04em;opacity:.7">Cooler Specs</h6>
                <div class="row g-3">
                    <div class="col-12"><label class="form-label small" style="color:var(--text-muted)">Socket hỗ trợ</label><input asp-for="CoolerSocketCompatibility" class="form-control" placeholder="LGA1700,AM5,AM4" /></div>
                    <div class="col-md-4"><label class="form-label small" style="color:var(--text-muted)">Max TDP (W)</label><input asp-for="MaxTDP" class="form-control" type="number" /></div>
                    <div class="col-md-4"><label class="form-label small" style="color:var(--text-muted)">Chiều cao (mm)</label><input asp-for="Height" class="form-control" type="number" /></div>
                    <div class="col-md-4"><label class="form-label small" style="color:var(--text-muted)">Loại</label><input asp-for="CoolerType" class="form-control" placeholder="Air Tower / AIO 240mm" /></div>
                </div>
            </div>
        }

        <div class="d-flex gap-3">
            <a href="/Admin/Products?category=@Model.Category" class="btn glass px-4" style="color:var(--text)">Huỷ</a>
            <button type="submit" class="btn btn-gradient px-5">
                <i class="bi bi-check-circle me-1"></i>@(Model.Id == 0 ? L["Btn.Save"].Value + " mới" : L["Btn.Save"].Value)
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
