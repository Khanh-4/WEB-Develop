@model List<TechSpecs.Models.FlashSale>
@{
    ViewData["Title"] = "Flash Sales";
    Layout = "_Layout";
    var now = DateTime.UtcNow;
}

<div class="container py-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <h3 class="text-white fw-bold mb-0"><i class="bi bi-lightning-charge me-2" style="color:#f59e0b"></i>Flash Sales</h3>
        <a href="/Admin/CreateFlashSale" class="btn btn-gradient ms-auto">
            <i class="bi bi-plus-lg me-2"></i>Tạo Flash Sale
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="glass p-4 text-center text-muted-white">Chưa có flash sale nào.</div>
    }
    else
    {
        <div class="glass p-0 overflow-hidden">
            <table class="table table-dark table-hover mb-0" style="font-size:.85rem">
                <thead>
                    <tr style="background:rgba(255,255,255,.05)">
                        <th class="px-3 py-2">Sản phẩm</th>
                        <th class="px-3 py-2">Danh mục</th>
                        <th class="px-3 py-2">Giá gốc</th>
                        <th class="px-3 py-2">Giảm</th>
                        <th class="px-3 py-2">Giá KM</th>
                        <th class="px-3 py-2">Số lượng</th>
                        <th class="px-3 py-2">Thời gian</th>
                        <th class="px-3 py-2">Trạng thái</th>
                        <th class="px-3 py-2"></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var s in Model)
                {
                    var active = s.IsActive && s.StartsAt <= now && s.EndsAt > now && s.SoldQty < s.TotalQty;
                    <tr>
                        <td class="px-3 py-2" style="max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                            @s.ProductName
                        </td>
                        <td class="px-3 py-2"><span class="badge" style="background:rgba(168,85,247,.2);color:#c084fc">@s.Category.ToUpper()</span></td>
                        <td class="px-3 py-2 text-muted-white">@s.OriginalPrice.ToString("N0")đ</td>
                        <td class="px-3 py-2"><span class="badge bg-danger">-@s.DiscountPercent%</span></td>
                        <td class="px-3 py-2 fw-bold" style="color:#f59e0b">@s.SalePrice.ToString("N0")đ</td>
                        <td class="px-3 py-2">@s.SoldQty/@s.TotalQty</td>
                        <td class="px-3 py-2 text-muted-white" style="font-size:.78rem">
                            @s.StartsAt.ToString("dd/MM HH:mm") → @s.EndsAt.ToString("dd/MM HH:mm")
                        </td>
                        <td class="px-3 py-2">
                            @if (active)
                            {
                                <span class="badge bg-success">Đang diễn ra</span>
                            }
                            else if (!s.IsActive)
                            {
                                <span class="badge bg-secondary">Tắt</span>
                            }
                            else if (s.EndsAt <= now)
                            {
                                <span class="badge" style="background:rgba(107,114,128,.3);color:#9ca3af">Kết thúc</span>
                            }
                            else if (s.SoldQty >= s.TotalQty)
                            {
                                <span class="badge bg-warning text-dark">Hết SL</span>
                            }
                            else
                            {
                                <span class="badge" style="background:rgba(96,165,250,.2);color:#60a5fa">Sắp diễn ra</span>
                            }
                        </td>
                        <td class="px-3 py-2">
                            <div class="d-flex gap-1">
                                <form method="post" action="/Admin/ToggleFlashSale/@s.Id">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm glass text-white" title="@(s.IsActive ? "Tắt" : "Bật")">
                                        <i class="bi @(s.IsActive ? "bi-toggle-on text-success" : "bi-toggle-off text-muted")"></i>
                                    </button>
                                </form>
                                <form method="post" action="/Admin/DeleteFlashSale/@s.Id"
                                      onsubmit="return confirm('Xoá flash sale này?')">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
