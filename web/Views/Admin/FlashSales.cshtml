@model List<TechSpecs.Models.FlashSale>
@{
    ViewData["Title"] = "Flash Sales";
    var now = DateTime.UtcNow;
}

<div class="p-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <h4 class="fw-bold mb-0" style="color:var(--text)">
            <i class="bi bi-lightning-charge me-2" style="color:#f59e0b"></i>Flash Sales
        </h4>
        <span class="badge glass-sm ms-1 px-2 py-1" style="color:var(--text-muted);font-size:.75rem">@Model.Count</span>
        <a href="/Admin/CreateFlashSale" class="btn btn-gradient ms-auto">
            <i class="bi bi-plus-lg me-1"></i>Tạo Flash Sale
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="tx-card p-5 text-center" style="color:var(--text-muted)">
            <i class="bi bi-lightning fs-1 d-block mb-2 opacity-30"></i>Chưa có flash sale nào.
        </div>
    }
    else
    {
        <div class="tx-card">
            <table class="tx-table">
                <thead>
                    <tr>
                        <th>Sản phẩm</th>
                        <th>Danh mục</th>
                        <th>Giá gốc</th>
                        <th>Giảm</th>
                        <th>Giá KM</th>
                        <th>Số lượng</th>
                        <th>Thời gian</th>
                        <th class="text-center">Trạng thái</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var s in Model)
                {
                    var active = s.IsActive && s.StartsAt <= now && s.EndsAt > now && s.SoldQty < s.TotalQty;
                    <tr>
                        <td style="max-width:180px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--text);font-size:.85rem">
                            @s.ProductName
                        </td>
                        <td>
                            <span class="badge glass-sm" style="color:var(--primary);font-size:.7rem">@s.Category.ToUpper()</span>
                        </td>
                        <td style="color:var(--text-muted);font-size:.83rem">@s.OriginalPrice.ToString("N0")đ</td>
                        <td><span class="badge" style="background:rgba(239,68,68,.15);color:#f87171">-@s.DiscountPercent%</span></td>
                        <td class="fw-bold" style="color:#f59e0b;font-size:.85rem">@s.SalePrice.ToString("N0")đ</td>
                        <td style="color:var(--text-muted);font-size:.83rem">@s.SoldQty/@s.TotalQty</td>
                        <td style="color:var(--text-muted);font-size:.78rem">
                            @s.StartsAt.ToString("dd/MM HH:mm") → @s.EndsAt.ToString("dd/MM HH:mm")
                        </td>
                        <td class="text-center">
                            @if (active)
                            {
                                <span class="status-pill completed">Đang diễn ra</span>
                            }
                            else if (!s.IsActive)
                            {
                                <span class="status-pill cancelled">Tắt</span>
                            }
                            else if (s.EndsAt <= now)
                            {
                                <span class="status-pill" style="background:rgba(107,114,128,.15);color:#9ca3af">Kết thúc</span>
                            }
                            else if (s.SoldQty >= s.TotalQty)
                            {
                                <span class="status-pill pending">Hết SL</span>
                            }
                            else
                            {
                                <span class="status-pill confirmed">Sắp diễn ra</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <form method="post" action="/Admin/ToggleFlashSale/@s.Id">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm glass px-2 py-1" title="@(s.IsActive ? "Tắt" : "Bật")"
                                            style="color:@(s.IsActive ? "var(--accent)" : "var(--text-muted)")">
                                        <i class="bi @(s.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                    </button>
                                </form>
                                <form method="post" action="/Admin/DeleteFlashSale/@s.Id"
                                      onsubmit="return confirm('Xoá flash sale này?')">
                                    @Html.AntiForgeryToken()
                                    <button class="btn btn-sm px-2 py-1" style="color:var(--danger);background:rgba(239,68,68,.12);border:none">
                                        <i class="bi bi-trash3" style="font-size:.8rem"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
