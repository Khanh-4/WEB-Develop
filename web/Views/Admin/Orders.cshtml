@model TechSpecs.ViewModels.AdminOrdersViewModel
@{ ViewData["Title"] = "Admin — Orders"; }

@{
    var statuses = new[] {
        ((string?)null,   "Tất cả"),
        ("Pending",       "Chờ xác nhận"),
        ("Confirmed",     "Đã xác nhận"),
        ("Assembling",    "Đang lắp ráp"),
        ("InstallingOS",  "Đang cài Win"),
        ("Shipped",       "Đang giao"),
        ("Delivered",     "Đã nhận"),
        ("Cancelled",     "Đã huỷ"),
    };
    string StatusLabel(TechSpecs.Models.OrderStatus s) => s switch {
        TechSpecs.Models.OrderStatus.Pending      => "Chờ xác nhận",
        TechSpecs.Models.OrderStatus.Confirmed    => "Đã xác nhận",
        TechSpecs.Models.OrderStatus.Assembling   => "Đang lắp ráp",
        TechSpecs.Models.OrderStatus.InstallingOS => "Đang cài Win",
        TechSpecs.Models.OrderStatus.Shipped      => "Đang giao",
        TechSpecs.Models.OrderStatus.Delivered    => "Đã nhận",
        TechSpecs.Models.OrderStatus.Cancelled    => "Đã huỷ",
        _ => s.ToString()
    };
}

<div class="p-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h4 class="fw-bold mb-0" style="color:var(--text)">
            <i class="bi bi-receipt me-2" style="color:var(--primary)"></i>Đơn hàng
            <span class="badge glass-sm ms-2 px-2 py-1" style="color:var(--text-muted);font-size:.75rem">@Model.Orders.Count</span>
        </h4>
    </div>

    <!-- Status filter -->
    <div class="d-flex flex-wrap gap-2 mb-4">
        @foreach (var (key, label) in statuses)
        {
            <a href="/Admin/Orders@(key != null ? "?status=" + key : "")"
               class="category-pill @(Model.StatusFilter == key ? "active" : "")">
                @label
            </a>
        }
    </div>

    <div class="tx-card">
        <table class="tx-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Khách hàng</th>
                    <th>Địa chỉ</th>
                    <th>@L["Label.Total"]</th>
                    <th>Ngày đặt</th>
                    <th class="text-center">Trạng thái</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model.Orders)
                {
                    <tr id="order-row-@o.Id">
                        <td class="fw-semibold">#@o.Id</td>
                        <td style="font-size:.83rem">
                            <div>@o.RecipientName</div>
                            <div style="color:var(--text-muted)">@o.Phone</div>
                        </td>
                        <td style="font-size:.8rem;max-width:180px;color:var(--text-muted)">
                            <div class="text-truncate">@o.ShippingAddress</div>
                        </td>
                        <td class="fw-semibold" style="font-size:.85rem">
                            @o.TotalAmount.ToString("N0")đ
                            <div style="font-size:.75rem;color:var(--text-muted)">@o.ItemCount SP</div>
                        </td>
                        <td style="font-size:.8rem;color:var(--text-muted)">
                            @o.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")
                            <div>@o.CreatedAt.ToLocalTime().ToString("HH:mm")</div>
                        </td>
                        <td class="text-center">
                            <select class="form-select form-select-sm status-select"
                                    style="background:var(--surface-2);border-color:var(--border);color:var(--text);font-size:.78rem;width:auto;margin:0 auto"
                                    data-order-id="@o.Id"
                                    onchange="updateStatus(this)">
                                @foreach (TechSpecs.Models.OrderStatus s in Enum.GetValues(typeof(TechSpecs.Models.OrderStatus)))
                                {
                                    if (o.Status == s)
                                    {
                                        <option value="@((int)s)" selected>@StatusLabel(s)</option>
                                    }
                                    else
                                    {
                                        <option value="@((int)s)">@StatusLabel(s)</option>
                                    }
                                }
                            </select>
                        </td>
                        <td>
                            <a href="/Orders/Detail/@o.Id" target="_blank"
                               class="btn btn-sm glass px-2 py-1" style="color:var(--primary)">
                                <i class="bi bi-eye" style="font-size:.8rem"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Orders.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-5" style="color:var(--text-muted)">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>Không có đơn hàng
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
function updateStatus(select) {
    const orderId = select.dataset.orderId;
    const status  = select.value;
    const token   = document.querySelector('#csrfForm input[name="__RequestVerificationToken"]')?.value || '';

    fetch('/Admin/UpdateOrderStatus', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': token },
        body: `id=${orderId}&status=${status}`
    })
    .then(r => r.ok ? showToast('Đã cập nhật trạng thái', 'success') : showToast('Lỗi cập nhật', 'error'))
    .catch(() => showToast('Lỗi kết nối', 'error'));
}
</script>
}
