@model TechSpecs.ViewModels.AdminOrdersViewModel
@{ ViewData["Title"] = "Admin — Orders"; }

@{
    var statuses = new[] {
        ((string?)null, "Tất cả"),
        ("Pending",   "Chờ xác nhận"),
        ("Confirmed", "Đã xác nhận"),
        ("Shipped",   "Đang giao"),
        ("Delivered", "Đã nhận"),
        ("Cancelled", "Đã huỷ"),
    };
    string StatusLabel(TechSpecs.Models.OrderStatus s) => s switch {
        TechSpecs.Models.OrderStatus.Pending   => "Chờ xác nhận",
        TechSpecs.Models.OrderStatus.Confirmed => "Đã xác nhận",
        TechSpecs.Models.OrderStatus.Shipped   => "Đang giao",
        TechSpecs.Models.OrderStatus.Delivered => "Đã nhận",
        TechSpecs.Models.OrderStatus.Cancelled => "Đã huỷ",
        _ => s.ToString()
    };
}

<div class="container-xl py-4 px-3">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/Admin/Dashboard" class="btn glass text-white px-2 py-1">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="text-white fw-bold mb-0">Orders</h1>
        <span class="badge glass-sm text-white">@Model.Orders.Count</span>
    </div>

    <!-- Status filter -->
    <div class="d-flex flex-wrap gap-2 mb-4">
        @foreach (var (key, label) in statuses)
        {
            <a href="/Admin/Orders@(key != null ? "?status=" + key : "")"
               class="category-pill @(Model.StatusFilter == key ? "active" : "")">
                @label
            </a>
        }
    </div>

    <div class="glass overflow-hidden">
        <table class="table table-dark mb-0" style="background:transparent">
            <thead>
                <tr style="border-color:rgba(255,255,255,.1)">
                    <th class="text-muted-white fw-normal py-3 ps-4">#</th>
                    <th class="text-muted-white fw-normal py-3">Khách hàng</th>
                    <th class="text-muted-white fw-normal py-3">Địa chỉ</th>
                    <th class="text-muted-white fw-normal py-3">@L["Label.Total"]</th>
                    <th class="text-muted-white fw-normal py-3">Ngày đặt</th>
                    <th class="text-muted-white fw-normal py-3 text-center">Trạng thái</th>
                    <th class="py-3"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model.Orders)
                {
                    <tr style="border-color:rgba(255,255,255,.07)" id="order-row-@o.Id">
                        <td class="py-3 ps-4 text-white fw-semibold">#@o.Id</td>
                        <td class="py-3" style="font-size:.83rem">
                            <div class="text-white">@o.RecipientName</div>
                            <div class="text-muted-white">@o.Phone</div>
                        </td>
                        <td class="py-3 text-muted-white" style="font-size:.8rem;max-width:180px">
                            <div class="text-truncate">@o.ShippingAddress</div>
                        </td>
                        <td class="py-3 text-white fw-semibold" style="font-size:.85rem">
                            @o.TotalAmount.ToString("N0")đ
                            <div class="text-muted-white" style="font-size:.75rem">@o.ItemCount SP</div>
                        </td>
                        <td class="py-3 text-muted-white" style="font-size:.8rem">
                            @o.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")
                            <div>@o.CreatedAt.ToLocalTime().ToString("HH:mm")</div>
                        </td>
                        <td class="py-3 text-center">
                            <select class="form-select form-select-sm status-select"
                                    style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);color:#fff;font-size:.78rem;width:auto;margin:0 auto"
                                    data-order-id="@o.Id"
                                    onchange="updateStatus(this)">
                                @foreach (TechSpecs.Models.OrderStatus s in Enum.GetValues(typeof(TechSpecs.Models.OrderStatus)))
                                {
                                    if (o.Status == s)
                                    {
                                        <option value="@((int)s)" selected>@StatusLabel(s)</option>
                                    }
                                    else
                                    {
                                        <option value="@((int)s)">@StatusLabel(s)</option>
                                    }
                                }
                            </select>
                        </td>
                        <td class="py-3 pe-3">
                            <a href="/Orders/Detail/@o.Id" target="_blank"
                               class="btn btn-sm glass text-white px-2 py-1">
                                <i class="bi bi-eye" style="font-size:.8rem"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Orders.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted-white py-5">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>Không có đơn hàng
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
function updateStatus(select) {
    const orderId = select.dataset.orderId;
    const status  = select.value;
    const token   = document.querySelector('#csrfForm input[name="__RequestVerificationToken"]')?.value || '';

    fetch('/Admin/UpdateOrderStatus', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': token },
        body: `id=${orderId}&status=${status}`
    })
    .then(r => r.ok ? showToast('Đã cập nhật trạng thái', 'success') : showToast('Lỗi cập nhật', 'error'))
    .catch(() => showToast('Lỗi kết nối', 'error'));
}
</script>
}
