@model List<TechSpecs.ViewModels.ProductListItem>
@{
    ViewData["Title"] = "Admin — Products";
    var category  = (string)ViewBag.Category;
    var page      = (int)ViewBag.Page;
    var totalPages = (int)ViewBag.TotalPages;
    var total     = (int)ViewBag.Total;
    var cats = new[] {
        ("cpu","CPU"),("motherboard","Motherboard"),("memory","RAM"),("gpu","GPU"),
        ("psu","PSU"),("case","Case"),("storage","Storage"),("cooler","Cooler")
    };
}

<div class="container-xl py-4 px-3">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex align-items-center gap-3">
            <a href="/Admin/Dashboard" class="btn glass text-white px-2 py-1">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h1 class="text-white fw-bold mb-0">Products</h1>
            <span class="badge glass-sm text-white">@total</span>
        </div>
        <a href="/Admin/EditProduct?category=@category" class="btn btn-gradient px-3">
            <i class="bi bi-plus-lg me-1"></i>Thêm @(cats.FirstOrDefault(c => c.Item1 == category).Item2 ?? category)
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert glass text-success mb-3 py-2">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        </div>
    }

    <!-- Category tabs -->
    <div class="d-flex flex-wrap gap-2 mb-4">
        @foreach (var (key, label) in cats)
        {
            <a href="/Admin/Products?category=@key"
               class="category-pill @(category == key ? "active" : "")">@label</a>
        }
    </div>

    <!-- Table -->
    <div class="glass overflow-hidden">
        <table class="table table-dark mb-0" style="background:transparent">
            <thead>
                <tr style="border-color:rgba(255,255,255,.1)">
                    <th class="text-muted-white fw-normal py-3 ps-4">Tên sản phẩm</th>
                    <th class="text-muted-white fw-normal py-3">Hãng</th>
                    <th class="text-muted-white fw-normal py-3">Giá</th>
                    <th class="text-muted-white fw-normal py-3">Specs</th>
                    <th class="text-muted-white fw-normal py-3 text-center">Stock</th>
                    <th class="py-3"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr style="border-color:rgba(255,255,255,.07)">
                        <td class="py-3 ps-4">
                            <div class="d-flex align-items-center gap-3">
                                @if (!string.IsNullOrEmpty(p.ImageUrl))
                                {
                                    <img src="@p.ImageUrl" alt="" class="rounded" style="width:40px;height:40px;object-fit:cover">
                                }
                                else
                                {
                                    <div class="rounded d-flex align-items-center justify-content-center"
                                         style="width:40px;height:40px;background:rgba(255,255,255,.07)">
                                        <i class="bi bi-cpu text-muted-white"></i>
                                    </div>
                                }
                                <span class="text-white" style="font-size:.85rem">@p.Name</span>
                            </div>
                        </td>
                        <td class="py-3 text-muted-white" style="font-size:.85rem">@p.Manufacturer</td>
                        <td class="py-3 text-white fw-semibold" style="font-size:.85rem">@p.Price.ToString("N0")đ</td>
                        <td class="py-3">
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var (k, v) in p.Specs.Take(2))
                                {
                                    <span class="badge glass-sm text-white" style="font-size:.68rem">@k: @v</span>
                                }
                            </div>
                        </td>
                        <td class="py-3 text-center">
                            @{
                                var stockVal = p.Specs.ContainsKey("Stock") ? p.Specs["Stock"] : "—";
                                var stockInt = int.TryParse(stockVal, out var s) ? s : -1;
                            }
                            <span class="@(stockInt == 0 ? "text-danger" : stockInt > 0 && stockInt < 5 ? "text-warning" : "text-success")"
                                  style="font-size:.85rem">@stockVal</span>
                        </td>
                        <td class="py-3 pe-3">
                            <div class="d-flex gap-2 justify-content-end">
                                <a href="/Admin/EditProduct?category=@p.Category&id=@p.Id"
                                   class="btn btn-sm glass text-white px-2 py-1">
                                    <i class="bi bi-pencil" style="font-size:.8rem"></i>
                                </a>
                                <form asp-action="DeleteProduct" asp-controller="Admin" method="post"
                                      onsubmit="return confirm('Xoá sản phẩm này?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="category" value="@p.Category">
                                    <input type="hidden" name="id" value="@p.Id">
                                    <button type="submit" class="btn btn-sm text-danger px-2 py-1"
                                            style="background:rgba(239,68,68,.15);border:none">
                                        <i class="bi bi-trash3" style="font-size:.8rem"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted-white py-5">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>Không có sản phẩm
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <div class="d-flex justify-content-center gap-2 mt-4">
            @if (page > 1)
            {
                <a href="/Admin/Products?category=@category&page=@(page-1)" class="btn glass text-white px-3">&laquo;</a>
            }
            @for (int i = Math.Max(1, page - 2); i <= Math.Min(totalPages, page + 2); i++)
            {
                <a href="/Admin/Products?category=@category&page=@i"
                   class="btn @(i == page ? "btn-gradient" : "glass text-white") px-3">@i</a>
            }
            @if (page < totalPages)
            {
                <a href="/Admin/Products?category=@category&page=@(page+1)" class="btn glass text-white px-3">&raquo;</a>
            }
        </div>
    }
</div>
