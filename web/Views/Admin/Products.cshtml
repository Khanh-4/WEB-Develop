@model List<TechSpecs.ViewModels.ProductListItem>
@{
    ViewData["Title"] = "Admin — Products";
    var category  = (string)ViewBag.Category;
    var page      = (int)ViewBag.Page;
    var totalPages = (int)ViewBag.TotalPages;
    var total     = (int)ViewBag.Total;
    var cats = new[] {
        ("cpu","CPU"),("motherboard","Motherboard"),("memory","RAM"),("gpu","GPU"),
        ("psu","PSU"),("case","Case"),("storage","Storage"),("cooler","Cooler")
    };
}

<div class="p-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex align-items-center gap-3">
            <h4 class="fw-bold mb-0" style="color:var(--text)">
                <i class="bi bi-box-seam me-2" style="color:var(--primary)"></i>Sản phẩm
            </h4>
            <span class="badge glass-sm px-2 py-1" style="color:var(--text-muted);font-size:.78rem">@total</span>
        </div>
        <a href="/Admin/EditProduct?category=@category" class="btn btn-gradient px-3">
            <i class="bi bi-plus-lg me-1"></i>Thêm @(cats.FirstOrDefault(c => c.Item1 == category).Item2 ?? category)
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert glass text-success mb-3 py-2">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        </div>
    }

    <!-- Category tabs -->
    <div class="d-flex flex-wrap gap-2 mb-4">
        @foreach (var (key, label) in cats)
        {
            <a href="/Admin/Products?category=@key"
               class="category-pill @(category == key ? "active" : "")">@label</a>
        }
    </div>

    <!-- Table -->
    <div class="tx-card">
        <table class="tx-table">
            <thead>
                <tr>
                    <th>Tên sản phẩm</th>
                    <th>Hãng</th>
                    <th>Giá</th>
                    <th>Specs</th>
                    <th class="text-center">Stock</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                @if (!string.IsNullOrEmpty(p.ImageUrl))
                                {
                                    <img src="@p.ImageUrl" alt="" class="thumb">
                                }
                                else
                                {
                                    <div class="thumb d-flex align-items-center justify-content-center"
                                         style="background:var(--surface-2)">
                                        <i class="bi bi-cpu" style="color:var(--text-muted)"></i>
                                    </div>
                                }
                                <span style="font-size:.85rem">@p.Name</span>
                            </div>
                        </td>
                        <td style="color:var(--text-muted);font-size:.85rem">@p.Manufacturer</td>
                        <td class="fw-semibold" style="font-size:.85rem">@p.Price.ToString("N0")đ</td>
                        <td>
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var (k, v) in p.Specs.Take(2))
                                {
                                    <span class="badge glass-sm" style="font-size:.68rem;color:var(--text-muted)">@k: @v</span>
                                }
                            </div>
                        </td>
                        <td class="text-center">
                            @{
                                var stockVal = p.Specs.ContainsKey("Stock") ? p.Specs["Stock"] : "—";
                                var stockInt = int.TryParse(stockVal, out var s) ? s : -1;
                            }
                            <span class="@(stockInt == 0 ? "text-danger" : stockInt > 0 && stockInt < 5 ? "text-warning" : "text-success")"
                                  style="font-size:.85rem">@stockVal</span>
                        </td>
                        <td>
                            <div class="d-flex gap-2 justify-content-end">
                                <a href="/Admin/EditProduct?category=@p.Category&id=@p.Id"
                                   class="btn btn-sm glass px-2 py-1" style="color:var(--primary)">
                                    <i class="bi bi-pencil" style="font-size:.8rem"></i>
                                </a>
                                <form asp-action="DeleteProduct" asp-controller="Admin" method="post"
                                      onsubmit="return confirm('Xoá sản phẩm này?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="category" value="@p.Category">
                                    <input type="hidden" name="id" value="@p.Id">
                                    <button type="submit" class="btn btn-sm px-2 py-1" style="color:var(--danger);background:rgba(239,68,68,.12);border:none">
                                        <i class="bi bi-trash3" style="font-size:.8rem"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-5" style="color:var(--text-muted)">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>Không có sản phẩm
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <div class="d-flex justify-content-center gap-2 mt-4">
            @if (page > 1)
            {
                <a href="/Admin/Products?category=@category&page=@(page-1)" class="btn glass px-3" style="color:var(--text)">&laquo;</a>
            }
            @for (int i = Math.Max(1, page - 2); i <= Math.Min(totalPages, page + 2); i++)
            {
                <a href="/Admin/Products?category=@category&page=@i"
                   class="btn @(i == page ? "btn-gradient" : "glass") px-3" style="@(i == page ? "" : "color:var(--text)")">@i</a>
            }
            @if (page < totalPages)
            {
                <a href="/Admin/Products?category=@category&page=@(page+1)" class="btn glass px-3" style="color:var(--text)">&raquo;</a>
            }
        </div>
    }
</div>
