@model List<TechSpecs.Models.QuoteRequest>
@{ ViewData["Title"] = "Admin — Báo giá nhanh"; }

<div class="container-xl py-4 px-3">
    <div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
        <a href="/Admin/Dashboard" class="btn glass text-white px-2 py-1">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="text-white fw-bold mb-0">Yêu cầu báo giá</h1>
        <span class="badge glass-sm text-white">@Model.Count</span>

        <div class="ms-auto d-flex gap-2">
            <a href="/Admin/QuoteRequests" class="btn @(ViewBag.FilterUncontacted != true ? "btn-gradient" : "glass") btn-sm text-white">
                Tất cả
            </a>
            <a href="/Admin/QuoteRequests?uncontacted=true" class="btn @(ViewBag.FilterUncontacted == true ? "btn-gradient" : "glass") btn-sm text-white">
                Chưa liên hệ
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="glass rounded-3 p-5 text-center text-white opacity-50">
            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
            Không có yêu cầu nào.
        </div>
    }
    else
    {
        <div class="glass rounded-3 overflow-hidden">
            <table class="table table-dark table-hover mb-0">
                <thead>
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Liên hệ</th>
                        <th>Ngân sách</th>
                        <th>Thời gian</th>
                        <th>Trạng thái</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var q in Model)
                    {
                        <tr class="@(q.IsContacted ? "opacity-50" : "")">
                            <td class="ps-3 text-white-50 small">@q.Id</td>
                            <td>
                                <span class="text-white fw-semibold">@q.PhoneOrEmail</span>
                            </td>
                            <td>
                                <span class="text-white-50">@(q.Budget ?? "—")</span>
                            </td>
                            <td>
                                <span class="text-white-50 small">@q.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                            </td>
                            <td>
                                @if (q.IsContacted)
                                {
                                    <span class="badge bg-success">Đã liên hệ</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Chưa liên hệ</span>
                                }
                            </td>
                            <td class="text-end pe-3">
                                <div class="d-flex gap-2 justify-content-end">
                                    @if (!q.IsContacted)
                                    {
                                        <form method="post" asp-action="MarkContacted" asp-route-id="@q.Id">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-sm glass text-white" title="Đánh dấu đã liên hệ">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </form>
                                    }
                                    <form method="post" asp-action="DeleteQuoteRequest" asp-route-id="@q.Id"
                                          onsubmit="return confirm('Xóa yêu cầu #@q.Id?')">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-danger" title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
