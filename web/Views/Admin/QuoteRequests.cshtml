@model List<TechSpecs.Models.QuoteRequest>
@{ ViewData["Title"] = "Báo giá nhanh"; }

<div class="p-4">
    <div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
        <h4 class="fw-bold mb-0" style="color:var(--text)">
            <i class="bi bi-envelope-paper me-2" style="color:#fb923c"></i>Yêu cầu báo giá
        </h4>
        <span class="badge glass-sm ms-1 px-2 py-1" style="color:var(--text-muted);font-size:.75rem">@Model.Count</span>

        <div class="ms-auto d-flex gap-2">
            <a href="/Admin/QuoteRequests" class="category-pill @(ViewBag.FilterUncontacted != true ? "active" : "")">
                Tất cả
            </a>
            <a href="/Admin/QuoteRequests?uncontacted=true" class="category-pill @(ViewBag.FilterUncontacted == true ? "active" : "")">
                Chưa liên hệ
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="tx-card p-5 text-center" style="color:var(--text-muted)">
            <i class="bi bi-inbox fs-1 d-block mb-2 opacity-30"></i>Không có yêu cầu nào.
        </div>
    }
    else
    {
        <div class="tx-card">
            <table class="tx-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Liên hệ</th>
                        <th>Ngân sách</th>
                        <th>Thời gian</th>
                        <th class="text-center">Trạng thái</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var q in Model)
                    {
                        <tr style="@(q.IsContacted ? "opacity:.5" : "")">
                            <td style="color:var(--text-muted);font-size:.82rem">@q.Id</td>
                            <td class="fw-semibold" style="color:var(--text)">@q.PhoneOrEmail</td>
                            <td style="color:var(--text-muted)">@(q.Budget ?? "—")</td>
                            <td style="color:var(--text-muted);font-size:.8rem">@q.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-center">
                                @if (q.IsContacted)
                                {
                                    <span class="status-pill completed">Đã liên hệ</span>
                                }
                                else
                                {
                                    <span class="status-pill pending">Chưa liên hệ</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2 justify-content-end">
                                    @if (!q.IsContacted)
                                    {
                                        <form method="post" asp-action="MarkContacted" asp-route-id="@q.Id">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-sm glass px-2 py-1" title="Đánh dấu đã liên hệ" style="color:var(--accent)">
                                                <i class="bi bi-check-lg" style="font-size:.8rem"></i>
                                            </button>
                                        </form>
                                    }
                                    <form method="post" asp-action="DeleteQuoteRequest" asp-route-id="@q.Id"
                                          onsubmit="return confirm('Xóa yêu cầu #@q.Id?')">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm px-2 py-1" title="Xóa"
                                                style="color:var(--danger);background:rgba(239,68,68,.12);border:none">
                                            <i class="bi bi-trash3" style="font-size:.8rem"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
