@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@{ ViewData["Title"] = "Scraper"; }

<div class="p-4" style="max-width:720px">
    <div class="d-flex align-items-center gap-3 mb-4">
        <h4 class="fw-bold mb-0" style="color:var(--text)">
            <i class="bi bi-arrow-repeat me-2" style="color:var(--accent)"></i>Scraper
        </h4>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert glass mb-4 py-2" style="color:#4ade80">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert glass mb-4 py-2" style="color:var(--danger)">
            <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
        </div>
    }

    @if (Env.IsProduction())
    {
        <div class="tx-card p-4 mb-4">
            <h6 class="fw-semibold mb-2" style="color:var(--text)">
                <i class="bi bi-cloud me-2" style="color:var(--accent)"></i>Production — GitHub Actions
            </h6>
            <p style="color:var(--text-muted);font-size:.85rem" class="mb-3">
                Trên Railway không có Python runtime. Scraper chạy tự động qua GitHub Actions cron mỗi 12 giờ
                (08:00 và 20:00 giờ Việt Nam). Để chạy thủ công:
            </p>
            <a href="https://github.com/Khanh-4/WEB-Develop/actions/workflows/scraper.yml"
               target="_blank" class="btn btn-gradient px-4">
                <i class="bi bi-github me-2"></i>Trigger scraper trên GitHub Actions
            </a>
        </div>
    }
    else
    {
        <div class="tx-card p-4 mb-4">
            <h6 class="fw-semibold mb-3" style="color:var(--text)">Chạy Scraper</h6>
            <p style="color:var(--text-muted);font-size:.85rem" class="mb-4">
                Scraper thu thập dữ liệu linh kiện từ các nguồn (~25 phút cho tất cả danh mục).
                Chạy nền, không block trang web.
            </p>

            <form asp-action="RunScraper" asp-controller="Admin" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-4">
                    <label class="form-label small mb-2" style="color:var(--text-muted)">Danh mục (để trống = tất cả)</label>
                    <div class="d-flex flex-wrap gap-3 mb-2">
                        @foreach (var cat in new[] { "cpu", "gpu", "ram", "motherboard", "psu", "case", "storage", "cooler" })
                        {
                            <label class="d-flex align-items-center gap-1 cursor-pointer">
                                <input type="checkbox" class="cat-check" value="@cat"
                                       style="accent-color:var(--primary)">
                                <span style="color:var(--text);font-size:.85rem">@cat</span>
                            </label>
                        }
                    </div>
                    <input type="hidden" name="categories" id="categoriesInput">
                </div>

                <button type="submit" class="btn btn-gradient px-4" onclick="buildCategories()">
                    <i class="bi bi-play-circle me-2"></i>Chạy Scraper
                </button>
            </form>
        </div>
    }

    <div class="tx-card p-4">
        <h6 class="fw-semibold mb-3" style="color:var(--text)">Chạy thủ công (local)</h6>
        <pre style="background:var(--surface-2);border:1px solid var(--border);border-radius:8px;padding:12px;color:var(--text-muted);font-size:.82rem;overflow-x:auto">cd scraper
source venv/bin/activate
python main.py                     # tất cả (~25 phút)
python main.py cpu gpu ram         # chỉ 3 danh mục</pre>
    </div>
</div>

@section Scripts {
<script>
function buildCategories() {
    const checked = [...document.querySelectorAll('.cat-check:checked')].map(c => c.value);
    document.getElementById('categoriesInput').value = checked.join(' ');
}
</script>
}
