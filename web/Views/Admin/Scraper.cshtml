@{ ViewData["Title"] = "Admin — Scraper"; }

<div class="container py-5 px-3" style="max-width:680px">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/Admin/Dashboard" class="btn glass text-white px-2 py-1">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="text-white fw-bold mb-0"><i class="bi bi-arrow-repeat me-2"></i>Scraper</h1>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert glass text-success mb-4 py-2">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert glass text-danger mb-4 py-2">
            <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
        </div>
    }

    <div class="glass p-4 mb-4">
        <h6 class="text-white fw-semibold mb-3">Chạy Scraper</h6>
        <p class="text-muted-white small mb-4">
            Scraper thu thập dữ liệu linh kiện từ Phong Vũ (~25 phút cho tất cả danh mục).
            Chạy nền, không block trang web.
        </p>

        <form asp-action="RunScraper" asp-controller="Admin" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-4">
                <label class="form-label text-muted-white small">Danh mục (để trống = tất cả)</label>
                <div class="d-flex flex-wrap gap-2 mb-2">
                    @foreach (var cat in new[] { "cpu", "gpu", "ram", "motherboard", "psu", "case", "storage", "cooler" })
                    {
                        <label class="d-flex align-items-center gap-1 cursor-pointer">
                            <input type="checkbox" class="cat-check" value="@cat"
                                   style="accent-color:#a855f7">
                            <span class="text-white small">@cat</span>
                        </label>
                    }
                </div>
                <input type="hidden" name="categories" id="categoriesInput">
            </div>

            <button type="submit" class="btn btn-gradient px-4" onclick="buildCategories()">
                <i class="bi bi-play-circle me-2"></i>Chạy Scraper
            </button>
        </form>
    </div>

    <div class="glass p-4">
        <h6 class="text-white fw-semibold mb-3">Hướng dẫn chạy thủ công</h6>
        <pre class="text-muted-white small mb-0" style="background:rgba(0,0,0,.3);padding:12px;border-radius:8px;overflow-x:auto">cd scraper
source venv/bin/activate
python main.py                     # tất cả (~25 phút)
python main.py cpu gpu ram         # chỉ 3 danh mục</pre>
    </div>
</div>

@section Scripts {
<script>
function buildCategories() {
    const checked = [...document.querySelectorAll('.cat-check:checked')].map(c => c.value);
    document.getElementById('categoriesInput').value = checked.join(' ');
}
</script>
}
