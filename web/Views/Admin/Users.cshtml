@model List<(TechSpecs.Models.ApplicationUser User, IList<string> Roles)>
@using TechSpecs.Models
@{
    ViewData["Title"] = "Người dùng";
    int page       = ViewBag.Page;
    int totalPages = ViewBag.TotalPages;
    int total      = ViewBag.Total;
    string? search = ViewBag.Search;
}

<div class="p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0" style="color:var(--text)">
                <i class="bi bi-people me-2" style="color:var(--primary)"></i>Người dùng
            </h4>
            <small style="color:var(--text-muted)">@total.ToString("N0") tài khoản</small>
        </div>
    </div>

    <form method="get" class="mb-4 d-flex gap-2">
        <input name="search" value="@search" class="form-control" style="max-width:360px;background:var(--surface-2);border-color:var(--border);color:var(--text)"
               placeholder="Tìm theo email hoặc tên...">
        <button type="submit" class="btn btn-gradient px-4">Tìm</button>
        @if (!string.IsNullOrEmpty(search))
        {
            <a asp-action="Users" class="btn glass px-3" style="color:var(--text)">Xóa bộ lọc</a>
        }
    </form>

    <div class="tx-card">
        <table class="tx-table">
            <thead>
                <tr>
                    <th>Người dùng</th>
                    <th>Vai trò</th>
                    <th>Hạng</th>
                    <th>Tổng chi tiêu</th>
                    <th>Điểm</th>
                    <th>Ngày tạo</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var (user, roles) in Model)
                {
                    var tier    = MembershipTier.Resolve(user.TotalSpend);
                    bool isAdmin = roles.Contains("Admin");
                    <tr>
                        <td>
                            <div class="fw-semibold" style="color:var(--text);font-size:.88rem">@(user.FullName ?? "—")</div>
                            <div style="color:var(--text-muted);font-size:.78rem">@user.Email</div>
                        </td>
                        <td>
                            @if (isAdmin)
                            {
                                <span class="badge" style="background:rgba(239,68,68,.15);color:#f87171;border:1px solid rgba(239,68,68,.25)">Admin</span>
                            }
                            else
                            {
                                <span class="badge glass-sm" style="color:var(--primary)">Customer</span>
                            }
                        </td>
                        <td>
                            <span style="color:@tier.Color;font-size:.82rem;font-weight:600">
                                <i class="bi @tier.Icon me-1"></i>@tier.NameVi
                            </span>
                        </td>
                        <td style="color:var(--text);font-size:.85rem">@user.TotalSpend.ToString("N0")đ</td>
                        <td style="color:var(--text);font-size:.85rem">@user.LoyaltyPoints.ToString("N0")</td>
                        <td style="color:var(--text-muted);font-size:.82rem">@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td>
                            <form method="post" asp-action="SetRole" class="d-inline"
                                  onsubmit="return confirm('Đổi vai trò cho @(user.Email?.Replace("'",""))?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@user.Id" />
                                <input type="hidden" name="role"   value="@(isAdmin ? "Customer" : "Admin")" />
                                <button type="submit" class="btn btn-sm glass px-2 py-1"
                                        style="@(isAdmin ? "color:#f87171" : "color:var(--primary)")">
                                    @(isAdmin ? "↓ Customer" : "↑ Admin")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center py-5" style="color:var(--text-muted)">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>Không tìm thấy người dùng nào.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <div class="d-flex justify-content-center gap-2 mt-4">
            @for (int i = 1; i <= totalPages; i++)
            {
                <a asp-action="Users" asp-route-page="@i" asp-route-search="@search"
                   class="btn @(i == page ? "btn-gradient" : "glass") px-3"
                   style="@(i == page ? "" : "color:var(--text)")">@i</a>
            }
        </div>
    }
</div>
