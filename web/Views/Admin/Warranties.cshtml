@model List<TechSpecs.Models.WarrantyRecord>
@{ ViewData["Title"] = "Bảo hành"; }

@{
    var catLabel = new Dictionary<string, string>
    {
        ["cpu"] = "CPU", ["gpu"] = "GPU", ["ram"] = "RAM", ["motherboard"] = "Mainboard",
        ["storage"] = "Ổ cứng", ["psu"] = "Nguồn", ["cooler"] = "Tản nhiệt", ["case"] = "Case"
    };
    var now = DateTime.UtcNow;
}

<div class="p-4">
    <div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
        <h4 class="fw-bold mb-0" style="color:var(--text)">
            <i class="bi bi-shield-check me-2" style="color:#22c55e"></i>Bảo hành
        </h4>
        <span class="badge glass-sm ms-1 px-2 py-1" style="color:var(--text-muted);font-size:.75rem">@Model.Count</span>

        <form method="get" class="ms-auto d-flex gap-2" style="min-width:260px">
            <input name="search" value="@ViewBag.Search" type="text" class="form-control"
                   style="background:var(--surface-2);border-color:var(--border);color:var(--text)"
                   placeholder="Tìm theo SĐT, serial, tên sản phẩm…">
            <button type="submit" class="btn glass px-3" style="color:var(--text)">
                <i class="bi bi-search"></i>
            </button>
        </form>
    </div>

    @if (!Model.Any())
    {
        <div class="tx-card p-5 text-center" style="color:var(--text-muted)">
            <i class="bi bi-shield-x fs-1 d-block mb-2 opacity-30"></i>
            Không có bản ghi bảo hành nào.
        </div>
    }
    else
    {
        <div class="tx-card">
            <table class="tx-table">
                <thead>
                    <tr>
                        <th>Sản phẩm</th>
                        <th>SĐT</th>
                        <th>Serial</th>
                        <th>Ngày mua</th>
                        <th>Hết hạn</th>
                        <th>Trạng thái</th>
                        <th>Đơn hàng</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var w in Model)
                    {
                        var expiry   = w.PurchaseDate.AddMonths(w.WarrantyMonths);
                        var daysLeft = (int)(expiry - now).TotalDays;
                        var isExp    = expiry < now;
                        var isSoon   = !isExp && daysLeft <= 30;
                        var statusColor = isExp ? "var(--danger)" : isSoon ? "#f59e0b" : "#22c55e";
                        var statusText  = isExp ? "Hết hạn" : $"Còn {daysLeft}d";

                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    @if (!string.IsNullOrEmpty(w.ImageUrl))
                                    {
                                        <img src="@w.ImageUrl" alt="" class="thumb" style="width:32px;height:32px">
                                    }
                                    <div>
                                        <div style="max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--text);font-size:.85rem">@w.ProductName</div>
                                        <span class="badge glass-sm" style="font-size:.65rem;color:var(--text-muted)">
                                            @(catLabel.TryGetValue(w.Category, out var cl) ? cl : w.Category)
                                        </span>
                                    </div>
                                </div>
                            </td>
                            <td style="color:var(--text-muted);font-size:.83rem">@(w.Phone ?? "—")</td>
                            <td style="color:var(--text-muted);font-size:.82rem">@(w.SerialNumber ?? "—")</td>
                            <td style="color:var(--text-muted);font-size:.82rem">@w.PurchaseDate.ToString("dd/MM/yy")</td>
                            <td style="color:var(--text-muted);font-size:.82rem">@expiry.ToString("dd/MM/yy")</td>
                            <td>
                                <span class="fw-semibold" style="color:@statusColor;font-size:.83rem">@statusText</span>
                            </td>
                            <td>
                                @if (w.OrderId.HasValue)
                                {
                                    <a href="/Admin/Orders" style="color:var(--primary)">#@w.OrderId</a>
                                }
                                else
                                {
                                    <span style="color:var(--text-muted)">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
