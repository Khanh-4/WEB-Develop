@model TechSpecs.Controllers.CompareViewModel
@using TechSpecs.Controllers
@{ ViewData["Title"] = "Compare Builds"; }

@{
    var catOrder  = new[] { "cpu","motherboard","memory","videoCard","storage","powerSupply","case","cooler" };
    var catLabels = new Dictionary<string,string> {
        ["cpu"]="Processor", ["motherboard"]="Motherboard", ["memory"]="Memory",
        ["videoCard"]="Graphics Card", ["storage"]="Storage", ["powerSupply"]="Power Supply",
        ["case"]="Case", ["cooler"]="CPU Cooler"
    };
    var catIcons = new Dictionary<string,string> {
        ["cpu"]="bi-cpu", ["motherboard"]="bi-motherboard", ["memory"]="bi-memory",
        ["videoCard"]="bi-gpu-card", ["storage"]="bi-device-hdd", ["powerSupply"]="bi-lightning-charge",
        ["case"]="bi-box", ["cooler"]="bi-thermometer-half"
    };
}

<div class="container-xl py-4 px-3">

    <!-- Header -->
    <div class="glass p-4 mb-4">
        <div class="row align-items-center g-3">
            <div class="col-12 col-md-5 text-center text-md-start">
                <div class="text-muted-white small mb-1">Build A</div>
                <h3 class="text-white fw-bold mb-0">@Model.BuildA.Name</h3>
                <div class="text-muted-white small">
                    by @(Model.BuildA.User?.FullName ?? "Anonymous") &bull;
                    @Model.BuildA.CreatedAt.ToString("dd/MM/yyyy")
                </div>
            </div>
            <div class="col-12 col-md-2 text-center">
                <span class="badge fs-6 px-3 py-2" style="background:rgba(255,255,255,.1);color:#a78bfa">VS</span>
            </div>
            <div class="col-12 col-md-5 text-center text-md-end">
                <div class="text-muted-white small mb-1">Build B</div>
                <h3 class="text-white fw-bold mb-0">@Model.BuildB.Name</h3>
                <div class="text-muted-white small">
                    by @(Model.BuildB.User?.FullName ?? "Anonymous") &bull;
                    @Model.BuildB.CreatedAt.ToString("dd/MM/yyyy")
                </div>
            </div>
        </div>
    </div>

    <!-- Comparison table -->
    <div class="glass p-0 mb-4 overflow-hidden">
        @foreach (var cat in catOrder)
        {
            var label = catLabels.GetValueOrDefault(cat, cat);
            var icon  = catIcons.GetValueOrDefault(cat, "bi-cpu");
            var compA = Model.ComponentsA.GetValueOrDefault(cat);
            var compB = Model.ComponentsB.GetValueOrDefault(cat);
            bool differ = compA?.Name != compB?.Name;

            <div class="row g-0 @(differ ? "" : "")" style="border-bottom:1px solid rgba(255,255,255,.06)">
                <!-- Build A -->
                <div class="col-12 col-md-5 p-3 @(differ && compA != null ? "build-a-highlight" : "")">
                    @if (compA != null)
                    {
                        <div class="d-flex align-items-center gap-3">
                            @if (compA.ImageUrl != null)
                            {
                                <img src="@compA.ImageUrl" alt="@compA.Name"
                                     style="width:48px;height:48px;object-fit:contain;border-radius:8px;background:rgba(255,255,255,.04);flex-shrink:0">
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center rounded-3 flex-shrink-0"
                                     style="width:48px;height:48px;background:rgba(255,255,255,.06)">
                                    <i class="bi @icon text-muted-white"></i>
                                </div>
                            }
                            <div class="overflow-hidden">
                                <div class="text-muted-white small">@label</div>
                                <div class="text-white fw-semibold" style="font-size:.93rem;line-height:1.3">@compA.Name</div>
                                <div class="text-white fw-bold small">@compA.Price.ToString("N0")đ</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex align-items-center gap-3 opacity-40">
                            <div class="d-flex align-items-center justify-content-center rounded-3 flex-shrink-0"
                                 style="width:48px;height:48px;background:rgba(255,255,255,.04)">
                                <i class="bi @icon text-muted-white"></i>
                            </div>
                            <div>
                                <div class="text-muted-white small">@label</div>
                                <div class="text-muted-white fst-italic small">Not included</div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Center diff indicator -->
                <div class="col-12 col-md-2 d-none d-md-flex align-items-center justify-content-center">
                    @if (differ)
                    {
                        <span class="badge rounded-pill px-2" style="background:rgba(167,139,250,.15);color:#a78bfa;font-size:.7rem">DIFF</span>
                    }
                    else
                    {
                        <span style="color:rgba(255,255,255,.2);font-size:.7rem">━</span>
                    }
                </div>

                <!-- Build B -->
                <div class="col-12 col-md-5 p-3 @(differ && compB != null ? "build-b-highlight" : "")"
                     style="border-left:1px solid rgba(255,255,255,.06)">
                    @if (compB != null)
                    {
                        <div class="d-flex align-items-center gap-3">
                            @if (compB.ImageUrl != null)
                            {
                                <img src="@compB.ImageUrl" alt="@compB.Name"
                                     style="width:48px;height:48px;object-fit:contain;border-radius:8px;background:rgba(255,255,255,.04);flex-shrink:0">
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center rounded-3 flex-shrink-0"
                                     style="width:48px;height:48px;background:rgba(255,255,255,.06)">
                                    <i class="bi @icon text-muted-white"></i>
                                </div>
                            }
                            <div class="overflow-hidden">
                                <div class="text-muted-white small">@label</div>
                                <div class="text-white fw-semibold" style="font-size:.93rem;line-height:1.3">@compB.Name</div>
                                <div class="text-white fw-bold small">@compB.Price.ToString("N0")đ</div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex align-items-center gap-3 opacity-40">
                            <div class="d-flex align-items-center justify-content-center rounded-3 flex-shrink-0"
                                 style="width:48px;height:48px;background:rgba(255,255,255,.04)">
                                <i class="bi @icon text-muted-white"></i>
                            </div>
                            <div>
                                <div class="text-muted-white small">@label</div>
                                <div class="text-muted-white fst-italic small">Not included</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Price summary row -->
        <div class="row g-0" style="background:rgba(255,255,255,.04)">
            <div class="col-12 col-md-5 p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted-white">Total</span>
                    <span class="text-white fw-bold fs-5">@Model.TotalA.ToString("N0")đ</span>
                </div>
                @{ var diff = Model.TotalA - Model.TotalB; }
                @if (diff != 0)
                {
                    <div class="text-end small mt-1 @(diff > 0 ? "text-danger" : "text-success")">
                        @(diff > 0 ? "+" : "")@diff.ToString("N0")đ vs Build B
                    </div>
                }
            </div>
            <div class="col-12 col-md-2 d-none d-md-flex align-items-center justify-content-center">
                <i class="bi bi-currency-dollar text-muted-white"></i>
            </div>
            <div class="col-12 col-md-5 p-3" style="border-left:1px solid rgba(255,255,255,.06)">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted-white">Total</span>
                    <span class="text-white fw-bold fs-5">@Model.TotalB.ToString("N0")đ</span>
                </div>
                @if (diff != 0)
                {
                    <div class="text-end small mt-1 @(diff < 0 ? "text-danger" : "text-success")">
                        @(diff < 0 ? "+" : "")@((-diff).ToString("N0"))đ vs Build A
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Action buttons -->
    <div class="row g-3">
        <div class="col-12 col-md-5">
            <button class="btn btn-gradient w-100" onclick="loadBuild('A')">
                <i class="bi bi-tools me-2"></i>Build A in Builder
            </button>
        </div>
        <div class="col-12 col-md-2 text-center">
            <a asp-action="MyBuilds" class="btn glass text-white w-100">
                <i class="bi bi-arrow-left me-1"></i>Back
            </a>
        </div>
        <div class="col-12 col-md-5">
            <button class="btn btn-gradient w-100" onclick="loadBuild('B')">
                <i class="bi bi-tools me-2"></i>Build B in Builder
            </button>
        </div>
    </div>
</div>

<style>
.build-a-highlight { background: rgba(99,102,241,.08); }
.build-b-highlight { background: rgba(167,139,250,.08); }
.opacity-40 { opacity: .4; }
</style>

@section Scripts {
<script>
const buildJsonA = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.BuildA.BuildJson));
const buildJsonB = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.BuildB.BuildJson));

function loadBuild(which) {
    try { sessionStorage.setItem('loadBuild', which === 'A' ? buildJsonA : buildJsonB); } catch {}
    window.location.href = '/Builder';
}
</script>
}
