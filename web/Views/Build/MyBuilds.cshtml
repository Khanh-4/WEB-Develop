@model List<TechSpecs.Models.SavedBuild>
@using System.Text.Json
@{ ViewData["Title"] = "My Saved Builds"; }

<div class="container-xl py-4 px-3">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h4 class="fw-bold mb-0" style="color:var(--text)">My Saved Builds</h4>
        <a asp-controller="Builder" asp-action="Index" class="btn btn-gradient px-4">
            <i class="bi bi-plus-lg me-2"></i>New Build
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="tx-card p-5 text-center">
            <i class="bi bi-bookmark-x fs-1 d-block mb-3" style="color:var(--text-muted);opacity:.4"></i>
            <h5 class="fw-bold mb-2" style="color:var(--text)">No saved builds yet</h5>
            <p class="mb-4" style="color:var(--text-muted)">Build a custom PC and save it to access it later or share with others.</p>
            <a asp-controller="Builder" asp-action="Index" class="btn btn-gradient px-4">
                <i class="bi bi-tools me-2"></i>Go to PC Builder
            </a>
        </div>
    }
    else
    {
        @if (Model.Any())
        {
            <div class="small mb-3" style="color:var(--text-muted)">
                <i class="bi bi-bar-chart-steps me-1"></i>
                @(Model.Count >= 2 ? L["MyBuilds.CompareHint2"].Value : L["MyBuilds.CompareHint1"].Value)
            </div>
        }

        <div class="row g-4">
            @foreach (var build in Model)
            {
                var components = new Dictionary<string, JsonElement>();
                int componentCount = 0;
                decimal totalPrice = 0;
                try {
                    var raw = JsonSerializer.Deserialize<Dictionary<string, JsonElement>>(build.BuildJson);
                    if (raw != null) {
                        components = raw;
                        componentCount = raw.Count;
                        foreach (var el in raw.Values) {
                            if (el.TryGetProperty("price", out var p)) totalPrice += (decimal)p.GetDouble();
                        }
                    }
                } catch { }

                var shareUrl = Url.Action("Share", "Build", new { token = build.ShareToken }, Context.Request.Scheme)!;
                var catIcons = new Dictionary<string,string> {
                    ["cpu"]="bi-cpu",["motherboard"]="bi-motherboard",["memory"]="bi-memory",
                    ["videoCard"]="bi-gpu-card",["storage"]="bi-device-hdd",["powerSupply"]="bi-lightning-charge",
                    ["case"]="bi-box",["cooler"]="bi-thermometer-half"
                };

                <div class="col-md-6 col-xl-4">
                    <div class="tx-card p-4 h-100 d-flex flex-column compare-card" data-token="@build.ShareToken" data-name="@build.Name">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="d-flex align-items-center gap-2 flex-grow-1 overflow-hidden">
                                @if (Model.Any())
                                {
                                    <input type="checkbox" class="compare-check form-check-input mt-0 flex-shrink-0"
                                           style="width:1.15rem;height:1.15rem;cursor:pointer" onchange="onCheckChange()">
                                }
                                <div class="overflow-hidden">
                                    <h5 class="fw-semibold mb-1 text-truncate" style="color:var(--text)">@build.Name</h5>
                                    <span class="small" style="color:var(--text-muted)">@build.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                </div>
                            </div>
                            <button class="btn btn-sm border-0 p-1 ms-2 flex-shrink-0" style="color:var(--danger)" title="Delete"
                                    onclick="deleteBuild(@build.Id, this)">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </div>

                        <div class="d-flex flex-wrap gap-2 mb-3">
                            @foreach (var (cat, el) in components)
                            {
                                var icon = catIcons.GetValueOrDefault(cat, "bi-cpu");
                                var name = el.TryGetProperty("name", out var n) ? n.GetString() ?? "" : "";
                                <span class="badge glass-sm" style="color:var(--text)" title="@name">
                                    <i class="bi @icon me-1"></i>@(name.Length > 20 ? name[..20] + "…" : name)
                                </span>
                            }
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-3 mt-auto">
                            <div>
                                <div class="small" style="color:var(--text-muted)">@componentCount component@(componentCount != 1 ? "s" : "")</div>
                                <div class="fw-bold" style="color:var(--primary)">@totalPrice.ToString("N0")đ</div>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <a href="@shareUrl" class="btn glass flex-grow-1" style="color:var(--text)" target="_blank">
                                <i class="bi bi-eye me-1"></i>View
                            </a>
                            <button class="btn glass px-3" style="color:var(--text)" onclick="copyLink('@shareUrl', this)" title="Copy share link">
                                <i class="bi bi-link-45deg"></i>
                            </button>
                            <button class="btn px-3 publish-btn @(build.IsPublic ? "btn-gradient" : "glass")"
                                    data-id="@build.Id" title="@(build.IsPublic ? "Đang public — nhấn để ẩn" : "Chia sẻ lên Community")"
                                    style="@(build.IsPublic ? "" : "color:var(--text)")"
                                    onclick="togglePublish(this)">
                                <i class="bi @(build.IsPublic ? "bi-globe2" : "bi-globe")"></i>
                            </button>
                            <a asp-controller="Builder" asp-action="Index"
                               onclick="sessionStorage.setItem('loadBuild', '@Html.Raw(build.BuildJson.Replace("'", "\\'")); return true;"
                               class="btn btn-gradient px-3" title="Open in Builder">
                                <i class="bi bi-tools"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Floating compare bar -->
        <div id="compareBar" class="tx-card p-3 d-none" style="position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);z-index:1000;min-width:320px;max-width:90vw;box-shadow:var(--shadow-lg)">
            <div class="d-flex align-items-center gap-3">
                <div class="flex-grow-1">
                    <div class="fw-semibold small" style="color:var(--text)" id="compareLabel">@L["MyBuilds.CompareHint2"]</div>
                </div>
                <button class="btn btn-sm glass px-3" style="color:var(--text)" onclick="clearCompare()">@L["MyBuilds.ClearCompare"]</button>
                <button class="btn btn-gradient px-4" onclick="goCompare()">
                    <i class="bi bi-bar-chart-steps me-1"></i>@L["Btn.Compare"]
                </button>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
const csrfToken = document.querySelector('#csrfForm input[name="__RequestVerificationToken"]')?.value || '';

async function deleteBuild(id, btn) {
    if (!confirm('Xoá build này?')) return;
    const r = await fetch('/Build/Delete/' + id, {
        method: 'POST',
        headers: { 'RequestVerificationToken': csrfToken }
    });
    if (r.ok) {
        btn.closest('.col-md-6, .col-xl-4').remove();
        onCheckChange();
    }
}

function copyLink(url, btn) {
    navigator.clipboard.writeText(url).then(() => {
        const icon = btn.querySelector('i');
        icon.className = 'bi bi-check-lg text-success';
        setTimeout(() => icon.className = 'bi bi-link-45deg', 2000);
    });
}

async function togglePublish(btn) {
    const id = btn.dataset.id;
    const r = await fetch(`/Build/Publish/${id}`, {
        method: 'POST',
        headers: { 'RequestVerificationToken': csrfToken }
    });
    if (!r.ok) return;
    const data = await r.json();
    const icon = btn.querySelector('i');
    if (data.isPublic) {
        btn.classList.remove('glass');
        btn.classList.add('btn-gradient');
        btn.style.color = '';
        btn.title = 'Đang public — nhấn để ẩn';
        icon.className = 'bi bi-globe2';
    } else {
        btn.classList.remove('btn-gradient');
        btn.classList.add('glass');
        btn.style.color = 'var(--text)';
        btn.title = 'Chia sẻ lên Community';
        icon.className = 'bi bi-globe';
    }
}

function onCheckChange() {
    const checked = [...document.querySelectorAll('.compare-check:checked')];
    const bar = document.getElementById('compareBar');
    const label = document.getElementById('compareLabel');

    if (checked.length > 2) {
        checked[checked.length - 1].checked = false;
        return;
    }

    document.querySelectorAll('.compare-card').forEach(c => c.style.outline = '');
    checked.forEach((cb, i) => {
        cb.closest('.compare-card').style.outline = `2px solid ${i === 0 ? '#6366f1' : '#a78bfa'}`;
    });

    if (checked.length === 2) {
        const nameA = checked[0].closest('.compare-card').dataset.name;
        const nameB = checked[1].closest('.compare-card').dataset.name;
        label.textContent = `"${nameA}" vs "${nameB}"`;
        bar.classList.remove('d-none');
    } else {
        bar.classList.add('d-none');
    }
}

function clearCompare() {
    document.querySelectorAll('.compare-check').forEach(cb => cb.checked = false);
    document.querySelectorAll('.compare-card').forEach(c => c.style.outline = '');
    document.getElementById('compareBar').classList.add('d-none');
}

function goCompare() {
    const checked = [...document.querySelectorAll('.compare-check:checked')];
    if (checked.length !== 2) return;
    const a = checked[0].closest('.compare-card').dataset.token;
    const b = checked[1].closest('.compare-card').dataset.token;
    window.location.href = `/Build/Compare?a=${a}&b=${b}`;
}
</script>
}
