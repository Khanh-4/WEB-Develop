@model TechSpecs.Controllers.ShareBuildViewModel
@{ ViewData["Title"] = Model.Build.Name + " — PC Build"; }

<div class="container-xl py-4 px-3">

    <!-- Header -->
    <div class="tx-card p-4 mb-4">
        <div class="row align-items-center">
            <div class="col">
                <div class="small mb-1" style="color:var(--text-muted)">
                    <i class="bi bi-share me-1"></i>Shared PC Build
                </div>
                <h4 class="fw-bold mb-1" style="color:var(--text)">@Model.Build.Name</h4>
                <span class="small" style="color:var(--text-muted)">
                    by @(Model.Build.User?.FullName ?? "Anonymous") &bull;
                    @Model.Build.CreatedAt.ToString("dd/MM/yyyy")
                </span>
            </div>
            <div class="col-auto d-flex gap-2">
                <button class="btn glass" style="color:var(--text)" onclick="copyPageLink(this)">
                    <i class="bi bi-link-45deg me-1"></i>Copy Link
                </button>
                <a asp-controller="Builder" asp-action="Index" class="btn btn-gradient" id="buildThisBtn">
                    <i class="bi bi-tools me-2"></i>Build This
                </a>
            </div>
        </div>
    </div>

    <div class="row g-4">

        <!-- Component List -->
        <div class="col-lg-8">
            <div class="tx-card p-4">
                <h5 class="fw-semibold mb-4" style="color:var(--text)">Components</h5>
                @{
                    var catLabels = new Dictionary<string,string> {
                        ["cpu"]="Processor",["motherboard"]="Motherboard",["memory"]="Memory",
                        ["videoCard"]="Graphics Card",["storage"]="Storage",["powerSupply"]="Power Supply",
                        ["case"]="Case",["cooler"]="CPU Cooler"
                    };
                    var catIcons = new Dictionary<string,string> {
                        ["cpu"]="bi-cpu",["motherboard"]="bi-motherboard",["memory"]="bi-memory",
                        ["videoCard"]="bi-gpu-card",["storage"]="bi-device-hdd",["powerSupply"]="bi-lightning-charge",
                        ["case"]="bi-box",["cooler"]="bi-thermometer-half"
                    };
                    var catOrder = new[] { "cpu","motherboard","memory","videoCard","storage","powerSupply","case","cooler" };
                }
                <div class="d-flex flex-column gap-3">
                    @foreach (var cat in catOrder)
                    {
                        var label = catLabels.GetValueOrDefault(cat, cat);
                        var icon  = catIcons.GetValueOrDefault(cat, "bi-cpu");
                        if (Model.Components.TryGetValue(cat, out var comp))
                        {
                            <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background:var(--surface-2)">
                                @if (comp.ImageUrl != null)
                                {
                                    <img src="@comp.ImageUrl" alt="@comp.Name"
                                         style="width:56px;height:56px;object-fit:contain;border-radius:8px;background:var(--surface)">
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center rounded-3" style="width:56px;height:56px;background:var(--surface)">
                                        <i class="bi @icon" style="font-size:1.4rem;color:var(--text-muted)"></i>
                                    </div>
                                }
                                <div class="flex-grow-1 overflow-hidden">
                                    <div class="small" style="color:var(--text-muted)">@label</div>
                                    <div class="fw-semibold text-truncate" style="color:var(--text)">@comp.Name</div>
                                </div>
                                <div class="fw-bold text-nowrap" style="color:var(--primary)">@comp.Price.ToString("N0")đ</div>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background:var(--surface-2);opacity:.4">
                                <div class="d-flex align-items-center justify-content-center rounded-3" style="width:56px;height:56px;background:var(--surface)">
                                    <i class="bi @icon" style="font-size:1.4rem;color:var(--text-muted)"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="small" style="color:var(--text-muted)">@label</div>
                                    <div class="small fst-italic" style="color:var(--text-muted)">Not included</div>
                                </div>
                                <div style="color:var(--text-muted)">—</div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Summary -->
        <div class="col-lg-4">
            <div class="tx-card p-4 mb-3">
                <h5 class="fw-semibold mb-4" style="color:var(--text)">Summary</h5>

                <div class="d-flex justify-content-between mb-3">
                    <span style="color:var(--text-muted)">Components</span>
                    <span class="fw-semibold" style="color:var(--text)">@Model.Components.Count / 8</span>
                </div>
                <div class="d-flex justify-content-between mb-4">
                    <span style="color:var(--text-muted)">Total Price</span>
                    <span class="fw-bold fs-5" style="color:var(--primary)">@Model.TotalPrice.ToString("N0")đ</span>
                </div>

                <hr style="border-color:var(--border);opacity:1" class="my-3">

                <a asp-controller="Builder" asp-action="Index" id="buildThisBtn2"
                   class="btn btn-gradient w-100 mb-2">
                    <i class="bi bi-tools me-2"></i>Build This PC
                </a>
                <button class="btn glass w-100" style="color:var(--text)" onclick="copyPageLink(this)">
                    <i class="bi bi-share me-2"></i>Share Build
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const buildJson = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Build.BuildJson));

document.querySelectorAll('#buildThisBtn, #buildThisBtn2').forEach(btn => {
    btn.addEventListener('click', e => {
        e.preventDefault();
        try { sessionStorage.setItem('loadBuild', buildJson); } catch {}
        window.location.href = '/Builder';
    });
});

function copyPageLink(btn) {
    navigator.clipboard.writeText(window.location.href).then(() => {
        const orig = btn.innerHTML;
        btn.innerHTML = '<i class="bi bi-check-lg me-1"></i>Copied!';
        setTimeout(() => btn.innerHTML = orig, 2000);
    });
}
</script>
}
