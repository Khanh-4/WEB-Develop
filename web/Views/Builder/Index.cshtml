@model TechSpecs.ViewModels.Builder.FilteredResult
@{ ViewData["Title"] = "PC Builder"; }

<div class="container-xl py-4 px-3">
    <h4 class="fw-bold mb-4" style="color:var(--text)">
        <i class="bi bi-cpu me-2" style="color:var(--primary)"></i>PC Builder
    </h4>

    <div class="row g-4">

        <!-- ── LEFT: Build Summary ─────────────────────────── -->
        <div class="col-lg-4">

            <!-- Step list -->
            <div class="tx-card p-4 mb-3">
                <h5 class="fw-semibold mb-3" style="color:var(--text)">Your Build</h5>
                <div id="buildSteps" class="d-flex flex-column gap-2">
                    @foreach (var step in new[] {
                        ("cpu",          "Processor",    "bi-cpu"),
                        ("motherboard",  "Motherboard",  "bi-motherboard"),
                        ("memory",       "Memory",       "bi-memory"),
                        ("videoCard",    "Graphics Card","bi-gpu-card"),
                        ("storage",      "Storage",      "bi-device-hdd"),
                        ("powerSupply",  "Power Supply", "bi-lightning-charge"),
                        ("case",         "Case",         "bi-box"),
                        ("cooler",       "CPU Cooler",   "bi-thermometer-half"),
                    })
                    {
                        <div class="build-step" data-category="@step.Item1" onclick="selectCategory('@step.Item1')">
                            <div class="d-flex align-items-center gap-3">
                                <i class="bi @step.Item3" style="font-size:1.1rem;width:20px;color:var(--text-muted)"></i>
                                <div class="flex-grow-1 overflow-hidden">
                                    <div class="small" style="color:var(--text-muted)">@step.Item2</div>
                                    <div class="small text-truncate" style="color:var(--text)" id="step-name-@step.Item1">Not selected</div>
                                </div>
                                <button class="btn btn-sm p-0 border-0 d-none"
                                        style="color:var(--danger)"
                                        id="step-remove-@step.Item1"
                                        onclick="removeComponent('@step.Item1', event)">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                            <div class="fw-semibold small mt-1 d-none" style="color:var(--primary)" id="step-price-@step.Item1"></div>
                            <div class="d-none align-items-center gap-2 mt-1" id="step-qty-row-@step.Item1" onclick="event.stopPropagation()">
                                <button class="builder-qty-btn" onclick="changeQty('@step.Item1',-1)">−</button>
                                <span class="small fw-semibold" style="min-width:18px;text-align:center;color:var(--text)" id="step-qty-@step.Item1">1</span>
                                <button class="builder-qty-btn" onclick="changeQty('@step.Item1',+1)">+</button>
                                <span class="small" style="color:var(--text-muted)" id="step-qty-label-@step.Item1"></span>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Build Stats -->
            <div class="tx-card p-4 mb-3">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span style="color:var(--text-muted)">Total Price</span>
                    <span class="fs-5 fw-bold" style="color:var(--text)" id="totalPrice">0đ</span>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span style="color:var(--text-muted)">Performance</span>
                    <div class="d-flex align-items-center gap-2">
                        <div class="perf-bar-track" style="width:96px">
                            <div class="perf-bar-fill" id="perfBar" style="width:0%"></div>
                        </div>
                        <span class="fw-semibold small" style="color:var(--text)" id="perfScore">0</span>
                    </div>
                </div>
                <!-- P34: Power breakdown panel -->
                <div>
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span style="color:var(--text-muted)">Power Draw</span>
                        <span class="fw-semibold" style="color:var(--text)" id="totalTdp">0W</span>
                    </div>
                    <div id="powerBreakdown" class="rounded-3 p-2 mb-2" style="background:var(--surface-2);display:none">
                        <div class="d-flex justify-content-between mb-1" style="font-size:.76rem">
                            <span style="color:var(--text-muted)"><i class="bi bi-cpu me-1"></i>CPU</span>
                            <span style="color:var(--text)" id="cpuTdpLabel">0W</span>
                        </div>
                        <div class="d-flex justify-content-between mb-1" style="font-size:.76rem">
                            <span style="color:var(--text-muted)"><i class="bi bi-gpu-card me-1"></i>GPU</span>
                            <span style="color:var(--text)" id="gpuTdpLabel">0W</span>
                        </div>
                        <div class="d-flex justify-content-between mb-1" style="font-size:.76rem">
                            <span style="color:var(--text-muted)"><i class="bi bi-motherboard me-1"></i>Overhead</span>
                            <span style="color:var(--text)">50W</span>
                        </div>
                        <hr class="divider-white my-1">
                        <div class="d-flex justify-content-between" style="font-size:.78rem">
                            <span class="fw-semibold" style="color:var(--text)">Tổng ước tính</span>
                            <span class="fw-semibold" style="color:var(--text)" id="totalTdpBreakdown">50W</span>
                        </div>
                    </div>
                    <button id="filterPsuBtn" class="btn btn-sm glass w-100 d-none" style="font-size:.75rem;color:var(--text)"
                            onclick="jumpToPsuFilter()">
                        <i class="bi bi-funnel me-1" style="color:var(--primary)"></i>Lọc PSU phù hợp
                    </button>
                </div>
                <hr class="divider-white my-3">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="small" style="color:var(--text-muted)">Recommended PSU</span>
                    <span class="small" style="color:var(--text)" id="recPsu">—</span>
                </div>
            </div>

            <!-- Compat status -->
            <div id="compatOk" class="compat-ok p-3 mb-3 d-none">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <i class="bi bi-check-circle-fill"></i>
                    <strong>Build Complete!</strong>
                </div>
                <button class="btn btn-gradient w-100 mb-2" onclick="addAllToCart()">
                    <i class="bi bi-cart-plus me-2"></i>Add All to Cart
                </button>
                <button class="btn glass w-100 mb-2" style="color:var(--text)" onclick="openSaveModal()">
                    <i class="bi bi-bookmark-plus me-2"></i>Save Build
                </button>
                <button class="btn glass w-100" style="color:var(--text)" id="exportPdfBtn" onclick="exportPdf()">
                    <i class="bi bi-file-earmark-pdf me-2"></i>Xuất báo giá PDF
                </button>
            </div>

            <!-- Save partial build (always visible when ≥1 component) -->
            <div id="partialSaveBar" class="d-none mb-3">
                <div class="d-flex gap-2 mb-2">
                    <button class="btn glass flex-grow-1 btn-sm" style="color:var(--text)" onclick="openSaveModal()">
                        <i class="bi bi-bookmark me-2"></i>Lưu / Chia sẻ
                    </button>
                    <button class="btn glass flex-grow-1 btn-sm" style="color:var(--text)" id="exportPdfBtnPartial" onclick="exportPdf()">
                        <i class="bi bi-file-earmark-pdf me-2"></i>Xuất PDF
                    </button>
                </div>
                <!-- P33: clear localStorage build -->
                <button class="btn btn-sm w-100" style="background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.3);color:#f87171;font-size:.78rem"
                        onclick="clearSavedBuild()">
                    <i class="bi bi-trash me-1"></i>Xóa build
                </button>
            </div>

            <!-- Compare Snapshot button (visible when ≥3 components selected) -->
            <div id="snapshotBar" class="d-none mb-3">
                <button class="btn w-100" id="snapshotBtn"
                        style="background:rgba(168,85,247,.15);border:1px solid rgba(168,85,247,.4);color:#c084fc;font-size:.82rem"
                        onclick="snapshotBuild()">
                    <i class="bi bi-pin-angle me-1"></i>Snapshot Build A để so sánh
                </button>
            </div>

            <!-- Budget filter -->
            <div class="tx-card p-3">
                <label class="small mb-2 d-block" style="color:var(--text-muted)">Budget Filter</label>
                <div class="input-group">
                    <input type="number" id="budgetInput" class="form-control"
                           placeholder="Max price (VNĐ)" oninput="debounceFilter()">
                    <button class="btn btn-gradient px-3" onclick="applyFilter()">
                        <i class="bi bi-funnel"></i>
                    </button>
                </div>
            </div>
        </div>

        <!-- ── RIGHT: Component Selection ─────────────────── -->
        <div class="col-lg-8">
            <div class="tx-card p-4">

                <!-- Category tabs -->
                <div class="d-flex flex-wrap gap-2 mb-4" id="categoryTabs">
                    @foreach (var tab in new[] {
                        ("cpu",         "Processor",    "bi-cpu"),
                        ("motherboard", "Motherboard",  "bi-motherboard"),
                        ("memory",      "Memory",       "bi-memory"),
                        ("videoCard",   "Graphics",     "bi-gpu-card"),
                        ("storage",     "Storage",      "bi-device-hdd"),
                        ("powerSupply", "PSU",          "bi-lightning-charge"),
                        ("case",        "Case",         "bi-box"),
                        ("cooler",      "Cooler",       "bi-thermometer-half"),
                    })
                    {
                        <button class="category-pill @(tab.Item1 == "cpu" ? "active" : "")"
                                data-tab="@tab.Item1"
                                onclick="selectCategory('@tab.Item1')">
                            <i class="bi @tab.Item3 me-1"></i>@tab.Item2
                        </button>
                    }
                </div>

                <!-- Search + sort bar -->
                <div class="d-flex gap-2 mb-4">
                    <div class="flex-grow-1 position-relative">
                        <i class="bi bi-search position-absolute" style="left:12px;top:50%;transform:translateY(-50%);color:var(--text-muted)"></i>
                        <input type="text" id="searchInput" class="form-control ps-5"
                               placeholder="Search components..." oninput="debounceFilter()">
                    </div>
                    <select class="form-select" style="width:auto;background:var(--surface-2);border-color:var(--border);color:var(--text)" id="sortSelect" onchange="sortProducts()">
                        <option value="pp">Best Value</option>
                        <option value="price-asc">Price ↑</option>
                        <option value="price-desc">Price ↓</option>
                        <option value="perf">Performance</option>
                    </select>
                </div>

                <!-- Product grid -->
                <div id="productGrid" class="row g-3">
                    <div class="col-12 text-center py-5" style="color:var(--text-muted)">
                        <i class="bi bi-hourglass-split fs-1 mb-3 d-block"></i>
                        Loading components...
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Compare Panel (slide-in from right) -->
<div id="comparePanel" style="display:none;position:fixed;right:0;top:0;bottom:0;width:440px;z-index:1055;background:var(--surface);border-left:1px solid var(--border);overflow-y:auto;box-shadow:-8px 0 32px rgba(0,0,0,.5)">
    <div class="d-flex align-items-center justify-content-between p-3" style="border-bottom:1px solid var(--border)">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-bar-chart-line" style="color:var(--primary);font-size:1.1rem"></i>
            <span class="fw-semibold" style="color:var(--text)">So sánh Build</span>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-sm" style="background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.3);color:var(--danger);font-size:.75rem"
                    onclick="clearSnapshot()"><i class="bi bi-x-lg me-1"></i>Xóa snapshot</button>
            <button class="btn btn-sm glass" style="color:var(--text-muted)" onclick="document.getElementById('comparePanel').style.display='none'">
                <i class="bi bi-chevron-right"></i>
            </button>
        </div>
    </div>

    <!-- Build labels -->
    <div class="d-flex gap-2 px-3 pt-3 pb-2">
        <div class="flex-1 text-center px-2 py-1 rounded-2 flex-grow-1" style="background:rgba(96,165,250,.12);border:1px solid rgba(96,165,250,.3);font-size:.75rem;color:#93c5fd">
            <i class="bi bi-pin-angle me-1"></i><strong>Build A</strong> (Snapshot)
        </div>
        <div class="flex-1 text-center px-2 py-1 rounded-2 flex-grow-1" style="background:rgba(168,85,247,.12);border:1px solid rgba(168,85,247,.3);font-size:.75rem;color:#c084fc">
            <i class="bi bi-lightning-charge me-1"></i><strong>Build B</strong> (Hiện tại)
        </div>
    </div>

    <!-- Tabs -->
    <ul class="nav nav-tabs px-3" style="border-color:var(--border)">
        <li class="nav-item">
            <button class="nav-link active compare-tab" data-tab="radar" onclick="switchCompareTab('radar')"
                    style="background:transparent;border:none;color:var(--primary);font-size:.82rem">
                <i class="bi bi-pentagon me-1"></i>Tổng quan
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link compare-tab" data-tab="detail" onclick="switchCompareTab('detail')"
                    style="background:transparent;border:none;color:var(--text-muted);font-size:.82rem">
                <i class="bi bi-list-ul me-1"></i>Chi tiết
            </button>
        </li>
    </ul>

    <!-- Tab: Radar -->
    <div id="compareTabRadar" class="p-3">
        <div id="compareLoading" class="text-center py-4" style="color:var(--text-muted)">
            <div class="spinner-border spinner-border-sm me-2"></div>Đang phân tích...
        </div>
        <!-- Price summary -->
        <div id="comparePrices" class="d-none mb-3">
            <div class="d-flex justify-content-around text-center">
                <div>
                    <div style="font-size:.7rem;color:var(--text-muted)">Build A</div>
                    <div class="fw-bold" style="color:var(--text)" id="cmpPriceA">—</div>
                </div>
                <div style="color:var(--text-muted);padding-top:12px">vs</div>
                <div>
                    <div style="font-size:.7rem;color:var(--text-muted)">Build B</div>
                    <div class="fw-bold" style="color:var(--text)" id="cmpPriceB">—</div>
                </div>
            </div>
        </div>
        <!-- Radar chart -->
        <div id="compareChartWrap" class="d-none" style="position:relative;height:260px">
            <canvas id="compareRadar"></canvas>
        </div>
        <!-- Benchmark data -->
        <div id="compareBenchmarks" class="d-none mt-3"></div>
    </div>

    <!-- Tab: Detail -->
    <div id="compareTabDetail" class="p-3 d-none">
        <div id="compareDetailContent"></div>
    </div>
</div>

<!-- Save Build Modal -->
<div class="modal fade" id="saveBuildModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass border-0">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-semibold" style="color:var(--text)">Save Build</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="saveModalBody">
                <div class="mb-3">
                    <label class="form-label small mb-1" style="color:var(--text-muted)">Build Name</label>
                    <input type="text" id="buildNameInput" class="form-control" maxlength="100"
                           placeholder="e.g. Gaming PC 2025, Workstation Build…">
                </div>
                <button class="btn btn-gradient w-100" onclick="saveBuild()">
                    <i class="bi bi-bookmark-check me-2"></i>Save & Get Share Link
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
// ── State ────────────────────────────────────────────────────
const buildState = {
    selectedCpuId: null, selectedMotherboardId: null, selectedMemoryId: null,
    selectedVideoCardId: null, selectedPowerSupplyId: null, selectedCaseId: null,
    selectedStorageId: null, selectedCoolerId: null,
    maxBudget: null, searchQuery: null
};

const selectedComponents = {}; // category → { id, name, price, ppScore, imageUrl, qty }
let currentCategory = 'cpu';
let currentProducts  = [];
let filterTimer      = null;

const CATEGORY_KEY_MAP = {
    cpu:          'selectedCpuId',
    motherboard:  'selectedMotherboardId',
    memory:       'selectedMemoryId',
    videoCard:    'selectedVideoCardId',
    powerSupply:  'selectedPowerSupplyId',
    case:         'selectedCaseId',
    storage:      'selectedStorageId',
    cooler:       'selectedCoolerId',
};

const RESULT_KEY_MAP = {
    cpu:         'cpus',
    motherboard: 'motherboards',
    memory:      'memories',
    videoCard:   'videoCards',
    powerSupply: 'powerSupplies',
    case:        'cases',
    storage:     'storages',
    cooler:      'coolers',
};

const LS_KEY = 'techspecsBuilder';

// ── P33: localStorage save/restore ───────────────────────────
function saveToLocalStorage() {
    try {
        localStorage.setItem(LS_KEY, JSON.stringify({
            buildState: { ...buildState },
            selectedComponents: { ...selectedComponents }
        }));
    } catch {}
}

function clearSavedBuild() {
    try { localStorage.removeItem(LS_KEY); } catch {}
    // Clear all selections
    Object.keys(CATEGORY_KEY_MAP).forEach(cat => {
        delete selectedComponents[cat];
        buildState[CATEGORY_KEY_MAP[cat]] = null;
    });
    updateBuildPanel();
    callFilterApi();
    showToast('<i class="bi bi-trash me-2"></i>Đã xóa build', 'info');
}

// ── Init ─────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
    const savedBuild = sessionStorage.getItem('loadBuild');
    const aiPreset   = sessionStorage.getItem('aiBuildPreset');

    if (savedBuild) {
        sessionStorage.removeItem('loadBuild');
        loadSavedBuild(JSON.parse(savedBuild));
    } else if (aiPreset) {
        sessionStorage.removeItem('aiBuildPreset');
        loadAiPreset(JSON.parse(aiPreset));
    } else {
        // P33: check localStorage for persisted build
        try {
            const lsRaw = localStorage.getItem(LS_KEY);
            if (lsRaw) {
                const { buildState: lsState, selectedComponents: lsComps } = JSON.parse(lsRaw);
                if (lsState && lsComps && Object.keys(lsComps).length > 0) {
                    Object.assign(buildState, lsState);
                    Object.assign(selectedComponents, lsComps);
                    updateBuildPanel();
                    selectCategory('cpu');
                    callFilterApi();
                    return;
                }
            }
        } catch {}
        selectCategory('cpu');
        callFilterApi();
    }
});

function loadSavedBuild(components) {
    for (const [cat, comp] of Object.entries(components)) {
        const key = CATEGORY_KEY_MAP[cat];
        if (!key) continue;
        buildState[key] = comp.id;
        selectedComponents[cat] = { id: comp.id, name: comp.name, price: comp.price, ppScore: 0, imageUrl: comp.imageUrl || null };
    }
    updateBuildPanel();
    selectCategory('cpu');
    callFilterApi();
}

function loadAiPreset(preset) {
    // Apply each preselected component to build state
    for (const [stateKey, comp] of Object.entries(preset)) {
        buildState[stateKey] = comp.id;
        selectedComponents[comp.category] = { id: comp.id, name: comp.name, price: comp.price, ppScore: 0 };
    }
    updateBuildPanel();
    // Start on cpu tab, load fresh filtered results
    selectCategory('cpu');
    callFilterApi();
}

// ── Category switching ────────────────────────────────────────
function selectCategory(cat) {
    currentCategory = cat;

    document.querySelectorAll('.category-pill').forEach(b =>
        b.classList.toggle('active', b.dataset.tab === cat));
    document.querySelectorAll('.build-step').forEach(s =>
        s.classList.toggle('active', s.dataset.category === cat));

    currentProducts = []; // clear stale data from previous tab
    callFilterApi();
}

// ── Filter API ────────────────────────────────────────────────
function debounceFilter() {
    clearTimeout(filterTimer);
    filterTimer = setTimeout(() => {
        buildState.searchQuery = document.getElementById('searchInput').value.trim() || null;
        const budget = parseFloat(document.getElementById('budgetInput').value);
        buildState.maxBudget = isNaN(budget) ? null : budget;
        callFilterApi();
    }, 400);
}

function applyFilter() {
    debounceFilter();
}

function callFilterApi() {
    const grid = document.getElementById('productGrid');
    grid.innerHTML = '<div class="col-12 text-center py-4" style="color:var(--text-muted)"><div class="spinner-border spinner-border-sm me-2"></div>Loading...</div>';

    fetch('/Builder/Filter', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(buildState)
    })
    .then(r => r.json())
    .then(data => {
        const key = RESULT_KEY_MAP[currentCategory];
        currentProducts = data[key] || [];
        renderGrid(currentProducts);
        updateStats(data);
    })
    .catch(() => {
        grid.innerHTML = '<div class="col-12 text-center py-4" style="color:var(--text-muted)">Failed to load components</div>';
    });
}

// ── Render product grid ───────────────────────────────────────
function renderGrid(products) {
    const sort = document.getElementById('sortSelect').value;
    const sorted = [...products].sort((a, b) => {
        // First sort by IsCompatible
        if (a.isCompatible !== b.isCompatible) return a.isCompatible ? -1 : 1;
        // Then sort by IsRecommended
        if (a.isRecommended !== b.isRecommended) return a.isRecommended ? -1 : 1;
        // Then by chosen metric
        if (sort === 'price-asc')  return a.price - b.price;
        if (sort === 'price-desc') return b.price - a.price;
        if (sort === 'perf')       return b.ppScore - a.ppScore;
        return b.ppScore - a.ppScore; // best value default
    });

    const sel = selectedComponents[currentCategory];
    const grid = document.getElementById('productGrid');

    if (sorted.length === 0) {
        grid.innerHTML = `
            <div class="col-12 text-center py-5" style="color:var(--text-muted)">
                <i class="bi bi-exclamation-circle fs-1 mb-3 d-block"></i>
                <p class="mb-0">No components found</p>
            </div>`;
        return;
    }

    grid.innerHTML = sorted.map(p => {
        const isSelected = sel && sel.id === p.id;
        const specs = Object.entries(p.specs || {}).slice(0, 3)
            .map(([k, v]) => `<span class="badge glass-sm small" style="color:var(--text-muted)">${k}: ${v}</span>`)
            .join(' ');

        const badges = (p.badges || []).map(b => `<span class="badge glass-sm mb-1 me-1" style="color:var(--primary)">${b}</span>`).join('');

        const ppDisplay = p.ppScore > 0 ? p.ppScore.toFixed(1) : '—';
        const imgHtml = p.imageUrl
            ? `<img src="${p.imageUrl}" alt="${p.name}" class="w-100 h-100 object-fit-cover">`
            : `<i class="bi bi-cpu" style="font-size:2.5rem;color:var(--text-muted)"></i>`;

        const incompatibleAlert = !p.isCompatible
            ? `<div class="small mt-2 fw-semibold" style="color:var(--danger)"><i class="bi bi-x-circle me-1"></i>${p.incompatibleReason}</div>`
            : '';

        const recommendedBadge = p.isRecommended
            ? `<div class="position-absolute top-0 end-0 m-2 badge shadow-sm z-1" style="background:var(--accent);color:#000"><i class="bi bi-star-fill me-1"></i>Best</div>`
            : '';

        const cardStyle = !p.isCompatible ? 'opacity: 0.55; filter: grayscale(0.6); cursor: not-allowed;' : 'cursor: pointer;';
        const safeImg = p.imageUrl ? `'${escHtml(p.imageUrl)}'` : 'null';
        const onClick = p.isCompatible ? `onclick="selectComponent(${p.id}, '${escHtml(p.name)}', ${p.price}, ${p.ppScore}, ${safeImg})"` : '';

        return `
        <div class="col-sm-6 col-xl-4">
            <div class="component-card p-3 h-100 ${isSelected ? 'selected' : ''} position-relative"
                 style="${cardStyle}" ${onClick}>
                ${recommendedBadge}
                <div class="rounded-2 overflow-hidden d-flex align-items-center justify-content-center mb-2"
                     style="height:120px;background:var(--surface-2)">
                    ${imgHtml}
                </div>
                <div class="mb-2">${badges}</div>
                <h6 class="mb-2 lh-sm" style="font-size:.85rem;color:var(--text)">${escHtml(p.name)}</h6>
                <div class="mb-2 d-flex flex-wrap gap-1">${specs}</div>
                <div class="d-flex justify-content-between align-items-center mt-auto">
                    <span class="fw-bold" style="color:var(--primary)">${fmtPrice(p.price)}</span>
                    <div class="d-flex align-items-center gap-1">
                        <i class="bi bi-graph-up text-purple"></i>
                        <span class="small" style="color:var(--text-muted)">${ppDisplay}</span>
                    </div>
                </div>
                ${incompatibleAlert}
            </div>
        </div>`;
    }).join('');
}

// ── Select / remove component ─────────────────────────────────
function selectComponent(id, name, price, ppScore, imageUrl = null) {
    const key = CATEGORY_KEY_MAP[currentCategory];
    if (!key) return;

    const prevQty = selectedComponents[currentCategory]?.qty ?? 1;
    selectedComponents[currentCategory] = { id, name, price, ppScore, imageUrl, qty: prevQty };
    buildState[key] = id;

    updateBuildPanel();
    saveToLocalStorage();
    callFilterApi();
    if (snapshotState) updateComparePanel();
}

function changeQty(category, delta) {
    const comp = selectedComponents[category];
    if (!comp) return;
    comp.qty = Math.max(1, Math.min(9, (comp.qty ?? 1) + delta));
    updateBuildPanel();
    saveToLocalStorage();
}

function removeComponent(category, event) {
    event.stopPropagation();
    const key = CATEGORY_KEY_MAP[category];
    if (!key) return;

    delete selectedComponents[category];
    buildState[key] = null;

    updateBuildPanel();
    saveToLocalStorage();
    callFilterApi();
    if (snapshotState) updateComparePanel();
}

// ── Update left panel ─────────────────────────────────────────
function updateBuildPanel() {
    let totalPrice = 0;
    let totalTdp   = 0;
    let perfSum    = 0;
    let perfCount  = 0;
    const requiredCats = ['cpu','motherboard','memory','videoCard','storage','powerSupply','case'];
    let allDone    = true;

    Object.entries(CATEGORY_KEY_MAP).forEach(([cat]) => {
        const comp = selectedComponents[cat];
        const nameEl   = document.getElementById(`step-name-${cat}`);
        const priceEl  = document.getElementById(`step-price-${cat}`);
        const removeEl = document.getElementById(`step-remove-${cat}`);

        const qtyRowEl  = document.getElementById(`step-qty-row-${cat}`);
        const qtyEl     = document.getElementById(`step-qty-${cat}`);
        const qtyLblEl  = document.getElementById(`step-qty-label-${cat}`);
        if (comp) {
            const qty = comp.qty ?? 1;
            nameEl.textContent  = comp.name;
            priceEl.textContent = qty > 1 ? `×${qty} = ${fmtPrice(comp.price * qty)}` : fmtPrice(comp.price);
            priceEl.classList.remove('d-none');
            removeEl.classList.remove('d-none');
            if (qtyRowEl) { qtyRowEl.classList.remove('d-none'); qtyRowEl.classList.add('d-flex'); }
            if (qtyEl) qtyEl.textContent = qty;
            if (qtyLblEl) qtyLblEl.textContent = qty > 1 ? `× ${fmtPrice(comp.price)}` : '';
            totalPrice += comp.price * qty;
            if (comp.ppScore) { perfSum += comp.ppScore; perfCount++; }
        } else {
            nameEl.textContent = 'Not selected';
            priceEl.classList.add('d-none');
            removeEl.classList.add('d-none');
            if (qtyRowEl) { qtyRowEl.classList.add('d-none'); qtyRowEl.classList.remove('d-flex'); }
            if (requiredCats.includes(cat)) allDone = false;
        }
    });

    document.getElementById('totalPrice').textContent = fmtPrice(totalPrice);

    const avgPerf = perfCount > 0 ? perfSum / perfCount : 0;
    const perfPct = Math.min(100, avgPerf / 10);
    document.getElementById('perfBar').style.width  = perfPct + '%';
    document.getElementById('perfScore').textContent = Math.round(avgPerf);

    document.getElementById('compatOk').classList.toggle('d-none', !allDone);

    const hasAny = Object.keys(selectedComponents).length > 0;
    const partialBar = document.getElementById('partialSaveBar');
    partialBar.classList.toggle('d-none', !hasAny || allDone);

    // Show snapshot bar when ≥3 components selected
    const compCount = Object.keys(selectedComponents).length;
    document.getElementById('snapshotBar').classList.toggle('d-none', compCount < 3);
}

function updateStats(data) {
    const cpuTdp = data.cpuTDP || 0;
    const gpuTdp = data.gpuTDP || 0;
    const total  = data.totalTDP || 0;

    document.getElementById('totalTdp').textContent = total + 'W';
    document.getElementById('recPsu').textContent   = data.recommendedPsuWattage > 0 ? data.recommendedPsuWattage + 'W+' : '—';

    // P34: power breakdown
    const breakdown = document.getElementById('powerBreakdown');
    const filterBtn = document.getElementById('filterPsuBtn');
    if (cpuTdp > 0 || gpuTdp > 0) {
        document.getElementById('cpuTdpLabel').textContent = cpuTdp + 'W';
        document.getElementById('gpuTdpLabel').textContent = gpuTdp + 'W';
        document.getElementById('totalTdpBreakdown').textContent = (cpuTdp + gpuTdp + 50) + 'W';
        breakdown.style.display = '';
        if (data.recommendedPsuWattage > 0) filterBtn.classList.remove('d-none');
    } else {
        breakdown.style.display = 'none';
        filterBtn.classList.add('d-none');
    }
}

function jumpToPsuFilter() {
    const recW = document.getElementById('recPsu').textContent.replace(/\D/g, '');
    if (recW) {
        document.getElementById('budgetInput').value = '';
        selectCategory('powerSupply');
        buildState.maxBudget = null;
        callFilterApi();
    }
}

// ── Sort (client-side re-render) ──────────────────────────────
function sortProducts() { renderGrid(currentProducts); }

// ── Add all to cart ───────────────────────────────────────────
async function addAllToCart() {
    const components = Object.entries(selectedComponents);
    if (components.length === 0) return;

    const token = document.querySelector('#csrfForm input[name="__RequestVerificationToken"]')?.value || '';
    let addedCount = 0;

    for (const [cat, comp] of components) {
        const qty = comp.qty ?? 1;
        for (let i = 0; i < qty; i++) {
            try {
                const r = await fetch('/Cart/Add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                    body: JSON.stringify({ componentId: comp.id, category: cat, name: comp.name, price: comp.price, imageUrl: comp.imageUrl || null })
                });
                if (r.status === 401) { window.location.href = '/Account/Login?returnUrl=' + encodeURIComponent(window.location.pathname); return; }
                if (r.ok) { const d = await r.json(); addedCount = d.count; }
            } catch (e) { /* skip failed items */ }
        }
    }

    if (addedCount > 0) {
        updateCartBadge(addedCount);
        showToast(`Đã thêm ${components.length} linh kiện vào giỏ hàng`, 'success');
    }
}

// ── Helpers ───────────────────────────────────────────────────
function fmtPrice(n) {
    if (!n || n === 0) return '0đ';
    return new Intl.NumberFormat('vi-VN').format(n) + 'đ';
}

function escHtml(s) {
    return String(s).replace(/[&<>"']/g, c =>
        ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

// ── Save Build ────────────────────────────────────────────────
let saveBuildModal = null;

function openSaveModal() {
    @if (User.Identity?.IsAuthenticated == true)
    {
        <text>
        if (!saveBuildModal) saveBuildModal = new bootstrap.Modal(document.getElementById('saveBuildModal'));
        document.getElementById('buildNameInput').value = '';
        document.getElementById('saveModalBody').innerHTML = `
            <div class="mb-3">
                <label class="form-label small mb-1" style="color:var(--text-muted)">Build Name</label>
                <input type="text" id="buildNameInput" class="form-control" maxlength="100"
                       placeholder="e.g. Gaming PC 2025, Workstation Build…">
            </div>
            <button class="btn btn-gradient w-100" onclick="saveBuild()">
                <i class="bi bi-bookmark-check me-2"></i>Save & Get Share Link
            </button>`;
        saveBuildModal.show();
        </text>
    }
    else
    {
        <text>
        window.location.href = '/Account/Login?returnUrl=/Builder';
        </text>
    }
}

async function saveBuild() {
    const name = document.getElementById('buildNameInput')?.value?.trim();
    if (!name) { alert('Vui lòng nhập tên cho build.'); return; }

    const token = document.querySelector('#csrfForm input[name="__RequestVerificationToken"]')?.value || '';
    const btn = document.querySelector('#saveBuildModal .btn-gradient');
    if (btn) { btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving…'; }

    const r = await fetch('/Build/Save', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
        body: JSON.stringify({
            name,
            buildJson: JSON.stringify(selectedComponents)
        })
    });

    if (!r.ok) {
        if (btn) { btn.disabled = false; btn.innerHTML = '<i class="bi bi-bookmark-check me-2"></i>Save & Get Share Link'; }
        showToast('Lưu build thất bại, thử lại.', 'danger');
        return;
    }

    const data = await r.json();
    document.getElementById('saveModalBody').innerHTML = `
        <div class="text-center mb-3">
            <i class="bi bi-bookmark-check-fill text-success" style="font-size:2rem"></i>
            <div class="fw-semibold mt-2" style="color:var(--text)">Build saved!</div>
        </div>
        <div class="mb-3">
            <label class="form-label small mb-1" style="color:var(--text-muted)">Share Link</label>
            <div class="input-group">
                <input type="text" class="form-control" id="shareLinkInput" value="${data.shareUrl}" readonly>
                <button class="btn glass" style="color:var(--text)" onclick="copyShareLink(this)">
                    <i class="bi bi-clipboard"></i>
                </button>
            </div>
        </div>
        <div class="d-flex gap-2">
            <a href="/Build/MyBuilds" class="btn glass flex-grow-1" style="color:var(--text)">My Builds</a>
            <a href="${data.shareUrl}" class="btn btn-gradient flex-grow-1" target="_blank">View</a>
        </div>`;
}

function copyShareLink(btn) {
    const input = document.getElementById('shareLinkInput');
    navigator.clipboard.writeText(input.value).then(() => {
        btn.innerHTML = '<i class="bi bi-check-lg text-success"></i>';
        setTimeout(() => btn.innerHTML = '<i class="bi bi-clipboard"></i>', 2000);
    });
}

// ── Compare / Snapshot ───────────────────────────────────────
let snapshotState       = null;
let snapshotComponents  = null;
let compareChart        = null;
let compareUpdateTimer  = null;

function snapshotBuild() {
    snapshotState      = JSON.parse(JSON.stringify(buildState));
    snapshotComponents = JSON.parse(JSON.stringify(selectedComponents));
    document.getElementById('comparePanel').style.display = '';
    updateComparePanel();
    document.getElementById('snapshotBtn').innerHTML = '<i class="bi bi-pin-angle-fill me-1"></i>Snapshot đã lưu — đang so sánh';
}

function clearSnapshot() {
    snapshotState = null;
    snapshotComponents = null;
    document.getElementById('comparePanel').style.display = 'none';
    document.getElementById('snapshotBtn').innerHTML = '<i class="bi bi-pin-angle me-1"></i>Snapshot Build A để so sánh';
    if (compareChart) { compareChart.destroy(); compareChart = null; }
}

function switchCompareTab(tab) {
    document.querySelectorAll('.compare-tab').forEach(b => {
        const active = b.dataset.tab === tab;
        b.classList.toggle('active', active);
        b.style.color = active ? '#c084fc' : 'rgba(255,255,255,.5)';
    });
    document.getElementById('compareTabRadar').classList.toggle('d-none', tab !== 'radar');
    document.getElementById('compareTabDetail').classList.toggle('d-none', tab !== 'detail');
}

async function updateComparePanel() {
    if (!snapshotState) return;
    clearTimeout(compareUpdateTimer);
    compareUpdateTimer = setTimeout(async () => {
        document.getElementById('compareLoading').style.display = '';
        document.getElementById('comparePrices').classList.add('d-none');
        document.getElementById('compareChartWrap').classList.add('d-none');
        document.getElementById('compareBenchmarks').classList.add('d-none');

        try {
            const r = await fetch('/Builder/CompareBuilds', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ buildA: snapshotState, buildB: buildState })
            });
            if (!r.ok) return;
            const data = await r.json();
            renderCompareResult(data);
        } catch { /* silently ignore */ }
    }, 500);
}

function renderCompareResult(data) {
    document.getElementById('compareLoading').style.display = 'none';

    // Prices
    document.getElementById('cmpPriceA').textContent = fmtPrice(data.a?.totalPrice || 0);
    document.getElementById('cmpPriceB').textContent = fmtPrice(data.b?.totalPrice || 0);
    document.getElementById('comparePrices').classList.remove('d-none');

    // Radar chart
    const ra = data.a?.radar, rb = data.b?.radar;
    if (ra && rb) {
        document.getElementById('compareChartWrap').classList.remove('d-none');
        const labels = ['Gaming', 'Đa nhiệm', 'Lưu trữ', 'Tản nhiệt', 'Nâng cấp'];
        const scoresA = [ra.gaming, ra.multitasking, ra.storage, ra.thermal, ra.upgrade];
        const scoresB = [rb.gaming, rb.multitasking, rb.storage, rb.thermal, rb.upgrade];

        if (compareChart) compareChart.destroy();
        const ctx = document.getElementById('compareRadar').getContext('2d');
        compareChart = new Chart(ctx, {
            type: 'radar',
            data: {
                labels,
                datasets: [
                    {
                        label: 'Build A',
                        data: scoresA,
                        borderColor: 'rgba(96,165,250,.9)',
                        backgroundColor: 'rgba(96,165,250,.12)',
                        pointBackgroundColor: '#60a5fa',
                        borderWidth: 2,
                    },
                    {
                        label: 'Build B',
                        data: scoresB,
                        borderColor: 'rgba(168,85,247,.9)',
                        backgroundColor: 'rgba(168,85,247,.12)',
                        pointBackgroundColor: '#a855f7',
                        borderWidth: 2,
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: { r: {
                    min: 0, max: 100,
                    ticks: { display: false, stepSize: 25 },
                    grid: { color: 'rgba(255,255,255,.1)' },
                    pointLabels: { color: 'rgba(255,255,255,.75)', font: { size: 11 } },
                    angleLines: { color: 'rgba(255,255,255,.1)' },
                }},
                plugins: { legend: { labels: { color: 'rgba(255,255,255,.75)', font: { size: 11 } } } }
            }
        });
    }

    // Benchmark summary
    const bncEl = document.getElementById('compareBenchmarks');
    const ba = data.a?.benchmark, bb = data.b?.benchmark;
    if (ba || bb) {
        bncEl.classList.remove('d-none');
        let html = '<div class="mt-2" style="font-size:.78rem">';
        html += '<div class="mb-1 fw-semibold" style="font-size:.72rem;letter-spacing:.05em;color:var(--text-muted)">BENCHMARK</div>';
        if (ba?.cinebenchMulti || bb?.cinebenchMulti) {
            html += buildBenchRow('CB R23 Multi', ba?.cinebenchMulti, bb?.cinebenchMulti, v => v?.toLocaleString());
        }
        if (ba?.fpsCs2_1080p || bb?.fpsCs2_1080p) {
            html += buildBenchRow('CS2 1080p', ba?.fpsCs2_1080p, bb?.fpsCs2_1080p, v => v ? v + ' fps' : null);
        }
        if (ba?.fpsCyberpunk_1080p || bb?.fpsCyberpunk_1080p) {
            html += buildBenchRow('Cyberpunk 1080p', ba?.fpsCyberpunk_1080p, bb?.fpsCyberpunk_1080p, v => v ? v + ' fps' : null);
        }
        if (ba?.estimatedGamingScore || bb?.estimatedGamingScore) {
            html += buildBenchRow('Est. Gaming Score', ba?.estimatedGamingScore, bb?.estimatedGamingScore, v => v?.toString());
        }
        html += '</div>';
        bncEl.innerHTML = html;
    } else {
        bncEl.classList.add('d-none');
    }

    // Detail tab
    renderDetailTab(data);
}

function buildBenchRow(label, va, vb, fmt) {
    const fa = fmt(va), fb = fmt(vb);
    const na = parseFloat(va), nb = parseFloat(vb);
    const aWins = !isNaN(na) && !isNaN(nb) && na > nb;
    const bWins = !isNaN(na) && !isNaN(nb) && nb > na;
    return `<div class="d-flex justify-content-between align-items-center mb-1 py-1" style="border-bottom:1px solid rgba(255,255,255,.06)">
        <span style="color:rgba(255,255,255,.55)">${label}</span>
        <div class="d-flex gap-3">
            <span style="color:${aWins ? '#4ade80' : bWins ? '#f87171' : 'rgba(255,255,255,.7)'}">${fa ?? '—'}</span>
            <span style="color:${bWins ? '#4ade80' : aWins ? '#f87171' : 'rgba(255,255,255,.7)'}">${fb ?? '—'}</span>
        </div>
    </div>`;
}

function renderDetailTab(data) {
    const sa = data.a?.specs, sb = data.b?.specs;
    if (!sa || !sb) return;

    const groups = [
        {
            title: '🎮 Performance',
            rows: [
                ['CPU', sa.cpu?.name, sb.cpu?.name],
                ['GPU', sa.gpu?.name, sb.gpu?.name],
                ['RAM', sa.memory?.name, sb.memory?.name],
            ]
        },
        {
            title: '🔩 Core Specs',
            rows: [
                ['Storage', sa.storage?.name, sb.storage?.name],
                ['PSU', sa.psu?.name, sb.psu?.name],
                ['PSU Headroom', sa.psuHeadroomW ? sa.psuHeadroomW + 'W' : null, sb.psuHeadroomW ? sb.psuHeadroomW + 'W' : null],
            ]
        },
        {
            title: '🛡️ Ổn định & Nâng cấp',
            rows: [
                ['Motherboard', sa.motherboard?.name, sb.motherboard?.name],
                ['RAM slots còn', sa.ramFreeSlots + ' slots', sb.ramFreeSlots + ' slots'],
                ['Cooler', sa.coolerType, sb.coolerType],
            ]
        },
        {
            title: '📦 Form Factor',
            rows: [
                ['Case', sa.case?.name, sb.case?.name],
                ['Form factor', sa.caseFormFactor, sb.caseFormFactor],
                ['TDP tổng', data.a?.totalTDP + 'W', data.b?.totalTDP + 'W'],
            ]
        }
    ];

    let html = '';
    for (const g of groups) {
        html += `<div class="mb-3">
            <div class="fw-semibold mb-2" style="font-size:.78rem;color:rgba(255,255,255,.6)">${g.title}</div>`;
        for (const [label, va, vb] of g.rows) {
            const diff = va && vb && va !== vb;
            const aStyle = diff ? 'color:#93c5fd' : 'color:rgba(255,255,255,.75)';
            const bStyle = diff ? 'color:#c084fc' : 'color:rgba(255,255,255,.75)';
            html += `<div class="d-flex mb-1" style="font-size:.75rem;gap:8px">
                <div style="width:70px;color:rgba(255,255,255,.4);flex-shrink:0">${label}</div>
                <div style="${aStyle};flex:1;overflow:hidden;white-space:nowrap;text-overflow:ellipsis" title="${va ?? '—'}">${va ?? '—'}</div>
                <div style="${bStyle};flex:1;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;text-align:right" title="${vb ?? '—'}">${vb ?? '—'}</div>
            </div>`;
        }
        html += '</div>';
    }
    document.getElementById('compareDetailContent').innerHTML = html;
}

async function exportPdf() {
    const hasItems = Object.keys(selectedComponents).length > 0;
    if (!hasItems) { showToast('Chưa chọn linh kiện nào.', 'warning'); return; }

    const btns = document.querySelectorAll('#exportPdfBtn,#exportPdfBtnPartial');
    btns.forEach(b => { b.disabled = true; b.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang tạo…'; });

    try {
        const r = await fetch('/Builder/ExportPdf', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(buildState)
        });
        if (!r.ok) { showToast('Lỗi tạo PDF, thử lại.', 'warning'); return; }
        const blob = await r.blob();
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `TechSpecs-BaoGia-${new Date().toISOString().slice(0,10)}.pdf`;
        a.click();
        URL.revokeObjectURL(url);
    } catch {
        showToast('Lỗi kết nối, thử lại.', 'warning');
    } finally {
        btns.forEach(b => { b.disabled = false; b.innerHTML = '<i class="bi bi-file-earmark-pdf me-2"></i>Xuất PDF'; });
        const full = document.getElementById('exportPdfBtn');
        if (full) full.innerHTML = '<i class="bi bi-file-earmark-pdf me-2"></i>Xuất báo giá PDF';
    }
}
</script>
}
