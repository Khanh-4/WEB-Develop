@model TechSpecs.ViewModels.CartViewModel
@{ ViewData["Title"] = L["Cart.Title"].Value; }

<div class="container-xl py-5 px-3">

    <!-- Header -->
    <div class="d-flex align-items-center gap-3 mb-4">
        <h1 class="fw-bold mb-0" style="color:var(--text)">
            <i class="bi bi-cart3 me-2" style="color:var(--primary)"></i>@L["Cart.Title"]
        </h1>
        @if (Model.ItemCount > 0)
        {
            <span class="badge rounded-pill px-3 py-2" style="background:rgba(139,92,246,.2);color:#c084fc;font-size:.78rem">
                @Model.ItemCount @L["Label.Items"]
            </span>
        }
    </div>

    @if (!Model.Items.Any())
    {
        <div class="tx-card p-5 text-center">
            <i class="bi bi-cart-x" style="font-size:4rem;color:var(--text-muted)"></i>
            <h4 class="mt-3" style="color:var(--text)">@L["Cart.Empty"]</h4>
            <p class="mb-4" style="color:var(--text-muted)">@L["Cart.EmptyHint"]</p>
            <a href="/Products" class="btn btn-gradient px-4">@L["Cart.BrowseProducts"]</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Cart items -->
            <div class="col-lg-8">
                <div class="tx-card p-0 overflow-hidden" id="cartItemsContainer">
                    @foreach (var item in Model.Items)
                    {
                        <div class="d-flex align-items-center gap-3 p-3" id="item-@item.CartItemId"
                             style="border-bottom:1px solid var(--border)">

                            <!-- Thumbnail -->
                            <div class="d-flex align-items-center justify-content-center rounded-3 overflow-hidden flex-shrink-0"
                                 style="width:72px;height:72px;background:var(--surface-2)">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.ComponentName" class="w-100 h-100" style="object-fit:cover">
                                }
                                else
                                {
                                    <i class="bi bi-cpu" style="font-size:1.8rem;color:var(--text-muted)"></i>
                                }
                            </div>

                            <!-- Name + category -->
                            <div class="flex-grow-1 min-width-0">
                                <span class="badge mb-1" style="background:rgba(139,92,246,.2);color:#c084fc;font-size:.68rem">
                                    @item.Category.ToUpper()
                                </span>
                                <p class="mb-1 lh-sm" style="font-size:.85rem;color:var(--text)">@item.ComponentName</p>
                                <span style="font-size:.8rem;color:var(--text-muted)">
                                    @item.Price.ToString("N0")đ @L["Cart.UnitPrice"]
                                </span>
                            </div>

                            <!-- Quantity stepper -->
                            <div class="d-flex align-items-center gap-2">
                                <button class="btn btn-sm glass px-2 py-1" style="color:var(--text)"
                                        onclick="updateQty(@item.CartItemId, @(item.Quantity - 1))">
                                    <i class="bi bi-dash"></i>
                                </button>
                                <span class="qty-display fw-semibold" id="qty-@item.CartItemId"
                                      style="min-width:24px;text-align:center;color:var(--text)">@item.Quantity</span>
                                <button class="btn btn-sm glass px-2 py-1" style="color:var(--text)"
                                        onclick="updateQty(@item.CartItemId, @(item.Quantity + 1))">
                                    <i class="bi bi-plus"></i>
                                </button>
                            </div>

                            <!-- Line total -->
                            <div class="text-end" style="min-width:100px">
                                <span class="fw-bold subtotal-display" id="sub-@item.CartItemId"
                                      style="color:var(--danger)">
                                    @item.Subtotal.ToString("N0")đ
                                </span>
                            </div>

                            <!-- Remove -->
                            <button class="btn btn-sm p-1" onclick="removeItem(@item.CartItemId)"
                                    title="@L["Btn.Delete"]" style="color:var(--danger)">
                                <i class="bi bi-trash3"></i>
                            </button>
                        </div>
                    }
                </div>

                <div class="d-flex justify-content-between mt-3">
                    <a href="/Products" class="btn glass px-3" style="color:var(--text)">
                        <i class="bi bi-arrow-left me-1"></i>@L["Label.ContinueShopping"]
                    </a>
                    <button class="btn glass px-3" onclick="clearCart()" style="color:var(--danger)">
                        <i class="bi bi-trash3 me-1"></i>@L["Cart.ClearAll"]
                    </button>
                </div>
            </div>

            <!-- Order summary -->
            <div class="col-lg-4">
                <div class="tx-card p-4 sticky-top" style="top:80px">
                    <h5 class="fw-semibold mb-4" style="color:var(--text)">@L["Cart.OrderSummary"]</h5>

                    <div class="d-flex justify-content-between mb-2">
                        <span style="color:var(--text-muted)">@L["Label.Subtotal"] (@Model.ItemCount @L["Label.Items"])</span>
                        <span id="cartTotal" style="color:var(--text)">@Model.Total.ToString("N0")đ</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span style="color:var(--text-muted)">@L["Label.Shipping"]</span>
                        <span class="text-success fw-semibold">@L["Label.Free"]</span>
                    </div>

                    <!-- Bundle discount row (shown dynamically) -->
                    <div id="bundleDiscountRow" class="d-none">
                        <div class="d-flex justify-content-between mb-2">
                            <span id="bundleLabel" style="color:#4ade80"></span>
                            <span class="fw-semibold" id="bundleDiscount" style="color:#4ade80"></span>
                        </div>
                    </div>

                    <hr style="border-color:var(--border)">
                    <div class="d-flex justify-content-between mb-4">
                        <span class="fw-semibold" style="color:var(--text)">@L["Label.Total"]</span>
                        <span class="fw-bold fs-5" id="grandTotal" style="color:var(--danger)">@Model.Total.ToString("N0")đ</span>
                    </div>

                    <a href="/Orders/Checkout" class="btn btn-gradient w-100 py-2 d-flex align-items-center justify-content-center gap-2">
                        <i class="bi bi-bag-check"></i>@L["Cart.Checkout"]
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
<script>
const _clearConfirm = '@Html.Raw(L["Cart.ClearConfirm"].Value.Replace("'", "\\'"))';

function updateQty(itemId, qty) {
    if (qty < 1) { removeItem(itemId); return; }
    fetch('/Cart/UpdateQty', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
        body: JSON.stringify({ cartItemId: itemId, quantity: qty })
    })
    .then(r => r.json())
    .then(() => location.reload());
}

function removeItem(itemId) {
    fetch('/Cart/Remove', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': getToken() },
        body: JSON.stringify({ cartItemId: itemId })
    })
    .then(r => r.json())
    .then(d => {
        document.getElementById('item-' + itemId)?.remove();
        updateCartBadge(d.count);
        if (d.count === 0) location.reload();
    });
}

function clearCart() {
    if (!confirm(_clearConfirm)) return;
    fetch('/Cart/Clear', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'RequestVerificationToken': getToken() }
    })
    .then(() => location.reload());
}

function getToken() {
    return document.querySelector('#csrfForm input[name="__RequestVerificationToken"]')?.value || '';
}

// Bundle auto-detect
const cartItems = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    Model.Items.Select(i => new { cat = i.Category, id = i.ComponentId })));
const cartTotal = @Model.Total;

(async () => {
    try {
        const bundles = await fetch('/Admin/BundlesApi').then(r => r.json());
        let bestDiscount = 0, bestName = '';
        for (const b of bundles) {
            const allMatch = b.items.every(bi =>
                cartItems.some(ci => ci.cat === bi.category && ci.id === bi.componentId));
            if (allMatch) {
                const sum = b.items.reduce((s, i) => s + i.price, 0);
                const disc = Math.round(sum * b.discountPercent / 100);
                if (disc > bestDiscount) { bestDiscount = disc; bestName = b.name; }
            }
        }
        if (bestDiscount > 0) {
            const fmt = n => new Intl.NumberFormat('vi-VN').format(n) + 'đ';
            document.getElementById('bundleLabel').textContent = `🎁 Combo: ${bestName}`;
            document.getElementById('bundleDiscount').textContent = `-${fmt(bestDiscount)}`;
            document.getElementById('bundleDiscountRow').classList.remove('d-none');
            document.getElementById('grandTotal').textContent = fmt(cartTotal - bestDiscount);
        }
    } catch {}
})();
</script>
}
