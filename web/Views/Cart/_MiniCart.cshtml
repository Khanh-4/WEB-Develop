@model TechSpecs.ViewModels.CartViewModel

@if (!Model.Items.Any())
{
    <div class="p-4 text-center" style="color:rgba(255,255,255,.4)">
        <i class="bi bi-cart3 d-block mb-2" style="font-size:2rem;opacity:.3"></i>
        <span style="font-size:.83rem">Giỏ hàng trống</span>
    </div>
}
else
{
    <div class="mini-cart-items py-1" style="max-height:240px;overflow-y:auto">
        @foreach (var item in Model.Items.Take(4))
        {
            <div class="mini-cart-item">
                <div class="flex-shrink-0 rounded overflow-hidden d-flex align-items-center justify-content-center"
                     style="width:44px;height:44px;background:rgba(255,255,255,.06)">
                    @if (item.ImageUrl != null)
                    {
                        <img src="@item.ImageUrl" style="width:44px;height:44px;object-fit:contain" alt="@item.ComponentName">
                    }
                    else
                    {
                        <i class="bi bi-box" style="color:rgba(255,255,255,.3)"></i>
                    }
                </div>
                <div class="flex-grow-1 overflow-hidden">
                    <div class="text-white" style="font-size:.76rem;line-height:1.3;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
                        @item.ComponentName
                    </div>
                    <div style="font-size:.75rem;color:#a855f7;font-weight:600">
                        @item.Price.ToString("N0")đ × @item.Quantity
                    </div>
                </div>
            </div>
        }
        @if (Model.Items.Count > 4)
        {
            <div class="px-3 py-1 text-center" style="font-size:.75rem;color:rgba(255,255,255,.35)">
                ... và @(Model.Items.Count - 4) sản phẩm khác
            </div>
        }
    </div>
    <div class="p-3 pt-2" style="border-top:1px solid rgba(255,255,255,.06)">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <span style="font-size:.8rem;color:rgba(255,255,255,.55)">Tổng cộng (@Model.ItemCount sản phẩm)</span>
            <span class="fw-bold text-white" style="font-size:.9rem">@Model.Total.ToString("N0")đ</span>
        </div>
        <div class="d-flex gap-2">
            <a href="/cart" class="btn glass text-white flex-grow-1 py-1" style="font-size:.78rem">
                <i class="bi bi-cart3 me-1"></i>Xem giỏ
            </a>
            <a href="/cart/checkout" class="btn btn-gradient flex-grow-1 py-1" style="font-size:.78rem">
                <i class="bi bi-credit-card me-1"></i>Thanh toán
            </a>
        </div>
    </div>
}
