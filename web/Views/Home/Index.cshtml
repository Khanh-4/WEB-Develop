@{
    ViewData["Title"] = "Home";
}

<!-- Hero -->
<section class="px-3 text-center d-flex align-items-center" style="min-height:82vh;">
    <div class="container">
        <h1 class="display-3 fw-bold text-white mb-3">
            Build Your Dream PC
            <span class="d-block gradient-text">With Confidence</span>
        </h1>
        <p class="lead text-muted-white mb-5 mx-auto" style="max-width:580px">
            Advanced compatibility engine ensures every component works perfectly together.
            Get the best performance per price with our AI-powered recommendations.
        </p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-controller="Builder" asp-action="Index" class="btn btn-gradient btn-lg px-5 py-3 rounded-3">
                <i class="bi bi-tools me-2"></i>Start Building
            </a>
            <a asp-controller="Products" asp-action="Index" class="btn glass btn-lg px-5 py-3 rounded-3 text-white">
                Browse Components
            </a>
        </div>
    </div>
</section>

<!-- Features -->
<section class="py-5 px-3">
    <div class="container">
        <div class="row g-4">
            <div class="col-sm-6 col-lg-3">
                <div class="glass p-4 h-100 text-center">
                    <div class="gradient-icon mb-3 mx-auto" style="width:56px;height:56px;">
                        <i class="bi bi-cpu text-white fs-4"></i>
                    </div>
                    <h5 class="text-white fw-semibold mb-2">Smart Compatibility</h5>
                    <p class="text-muted-white small mb-0">Real-time validation prevents incompatible parts from being selected together.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="glass p-4 h-100 text-center">
                    <div class="gradient-icon mb-3 mx-auto" style="width:56px;height:56px;">
                        <i class="bi bi-lightning-charge text-white fs-4"></i>
                    </div>
                    <h5 class="text-white fw-semibold mb-2">Performance Scoring</h5>
                    <p class="text-muted-white small mb-0">Know exactly how your build performs with our P/P rating system.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="glass p-4 h-100 text-center">
                    <div class="gradient-icon mb-3 mx-auto" style="width:56px;height:56px;">
                        <i class="bi bi-shield-check text-white fs-4"></i>
                    </div>
                    <h5 class="text-white fw-semibold mb-2">Quality Components</h5>
                    <p class="text-muted-white small mb-0">Curated selection of top-tier PC components from trusted brands.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="glass p-4 h-100 text-center">
                    <div class="gradient-icon mb-3 mx-auto" style="width:56px;height:56px;">
                        <i class="bi bi-graph-up-arrow text-white fs-4"></i>
                    </div>
                    <h5 class="text-white fw-semibold mb-2">Live Price Data</h5>
                    <p class="text-muted-white small mb-0">Up-to-date pricing scraped every 12 hours from Phong Vũ &amp; An Phát.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="py-5 px-3 mb-4">
    <div class="container">
        <div class="glass text-center p-5 mx-auto" style="max-width:760px;background:linear-gradient(135deg,rgba(168,85,247,.18),rgba(59,130,246,.18))!important;">
            <h2 class="display-5 fw-bold text-white mb-3">Ready to Build Something Amazing?</h2>
            <p class="text-muted-white mb-4">Join thousands of satisfied builders who trust TechSpecs for their custom PC needs.</p>
            <a asp-controller="Builder" asp-action="Index" class="btn btn-gradient btn-lg px-5 py-3 rounded-3">
                Launch PC Builder
            </a>
        </div>
    </div>
</section>
