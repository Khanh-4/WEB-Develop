@model TechSpecs.ViewModels.HomeViewModel
@{ ViewData["Title"] = "Home"; }

@{
    var catMeta = new (string Key, string Label, string Icon, string Color)[] {
        ("cpu",         "CPU",         "bi-cpu",              "#a855f7"),
        ("gpu",         "GPU",         "bi-gpu-card",         "#6366f1"),
        ("memory",      "RAM",         "bi-memory",           "#3b82f6"),
        ("motherboard", "Mainboard",   "bi-motherboard",      "#06b6d4"),
        ("storage",     "Storage",     "bi-device-hdd",       "#10b981"),
        ("psu",         "PSU",         "bi-lightning-charge", "#f59e0b"),
        ("case",        "Case",        "bi-box",              "#ef4444"),
        ("cooler",      "Cooler",      "bi-thermometer-half", "#8b5cf6"),
    };
    string DefaultCat = Model.Categories.Keys.FirstOrDefault() ?? "cpu";
}

<!-- ═══ HERO ═══ -->
<section class="px-3 text-center d-flex align-items-center" style="min-height:72vh">
    <div class="container">
        <div class="badge mb-4 px-3 py-2 rounded-pill" style="background:rgba(168,85,247,.15);color:#c084fc;font-size:.85rem;border:1px solid rgba(168,85,247,.3)">
            <i class="bi bi-stars me-2"></i>AI-Powered PC Builder — Smart Compatibility Engine
        </div>
        <h1 class="display-2 fw-bold text-white mb-3" style="line-height:1.1">
            Build Your Dream PC
            <span class="d-block gradient-text">With Confidence</span>
        </h1>
        <p class="lead text-muted-white mb-5 mx-auto" style="max-width:580px">
            Real-time compatibility validation, AI recommendations, and live pricing
            from Vietnam's top retailers — all in one place.
        </p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-controller="Builder" asp-action="Index" class="btn btn-gradient btn-lg px-5 py-3 rounded-3 fw-semibold">
                <i class="bi bi-tools me-2"></i>Start Building Free
            </a>
            <a asp-controller="Products" asp-action="Index" class="btn glass btn-lg px-5 py-3 rounded-3 text-white fw-semibold">
                <i class="bi bi-grid me-2"></i>Browse Components
            </a>
        </div>
    </div>
</section>

<!-- ═══ CATEGORY SHORTCUT BAR ═══ -->
<section class="px-3 pb-4">
    <div class="container-xl">
        <div class="glass p-3 p-md-4">
            <div class="row g-2 g-md-3 justify-content-center">
                @foreach (var (key, label, icon, color) in catMeta)
                {
                    <div class="col-3 col-sm-3 col-md-auto">
                        <a href="/Products?category=@key"
                           class="d-flex flex-column align-items-center gap-1 text-decoration-none p-2 rounded-3 cat-shortcut"
                           style="min-width:80px;transition:background .2s">
                            <div class="rounded-3 d-flex align-items-center justify-content-center"
                                 style="width:52px;height:52px;background:rgba(168,85,247,.12);border:1px solid rgba(168,85,247,.2)">
                                <i class="bi @icon text-white fs-4"></i>
                            </div>
                            <span class="text-muted-white small fw-semibold">@label</span>
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<!-- ═══ FEATURED PRODUCTS ═══ -->
<section class="px-3 pb-5">
    <div class="container-xl">

        <!-- Section header -->
        <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
            <div>
                <h2 class="text-white fw-bold mb-1">
                    <i class="bi bi-fire me-2" style="color:#f59e0b"></i>Featured Products
                </h2>
                <p class="text-muted-white small mb-0">Top picks from each category, updated daily</p>
            </div>
            <a asp-controller="Products" asp-action="Index" class="btn glass text-white px-4">
                <i class="bi bi-grid me-2"></i>View All
            </a>
        </div>

        <!-- Category tab buttons -->
        <div class="d-flex gap-2 mb-4 flex-wrap" id="featTabs">
            @foreach (var (key, label, icon, color) in catMeta)
            {
                @if (Model.Categories.ContainsKey(key) && Model.Categories[key].Any())
                {
                    <button class="btn feat-tab px-3 py-2 @(key == DefaultCat ? "btn-gradient" : "glass text-white")"
                            data-cat="@key" onclick="switchFeatCat('@key')">
                        <i class="bi @icon me-1"></i>@label
                    </button>
                }
            }
        </div>

        <!-- Product grids per category -->
        @foreach (var (key, label, icon, color) in catMeta)
        {
            @if (Model.Categories.ContainsKey(key))
            {
                var products = Model.Categories[key];
                <div class="feat-grid" data-cat="@key" style="display:@(key == DefaultCat ? "" : "none")">
                    @if (products.Any())
                    {
                        <div class="row g-3">
                            @await Html.PartialAsync("~/Views/Products/_ProductGrid.cshtml", products)
                        </div>
                    }
                    else
                    {
                        <div class="glass p-4 text-center text-muted-white">
                            <i class="bi bi-inbox fs-2 d-block mb-2"></i>No products available yet
                        </div>
                    }
                    <div class="text-center mt-4">
                        <a href="/Products?category=@key" class="btn glass text-white px-4">
                            <i class="bi bi-arrow-right me-2"></i>View All @label
                        </a>
                    </div>
                </div>
            }
        }
    </div>
</section>

<!-- ═══ FEATURES ═══ -->
<section class="py-5 px-3" style="border-top:1px solid rgba(255,255,255,.06)">
    <div class="container-xl">
        <h2 class="text-white fw-bold text-center mb-5">Why TechSpecs?</h2>
        <div class="row g-4">
            <div class="col-sm-6 col-lg-3">
                <div class="glass p-4 h-100 text-center">
                    <div class="gradient-icon mb-3 mx-auto" style="width:56px;height:56px">
                        <i class="bi bi-cpu text-white fs-4"></i>
                    </div>
                    <h5 class="text-white fw-semibold mb-2">Smart Compatibility</h5>
                    <p class="text-muted-white small mb-0">Real-time validation prevents incompatible parts — CPU socket, RAM type, GPU length, PSU wattage, all checked automatically.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="glass p-4 h-100 text-center">
                    <div class="gradient-icon mb-3 mx-auto" style="width:56px;height:56px">
                        <i class="bi bi-robot text-white fs-4"></i>
                    </div>
                    <h5 class="text-white fw-semibold mb-2">AI Recommendations</h5>
                    <p class="text-muted-white small mb-0">Describe what you need — gaming, editing, coding — and our AI picks the best compatible build within your budget.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="glass p-4 h-100 text-center">
                    <div class="gradient-icon mb-3 mx-auto" style="width:56px;height:56px">
                        <i class="bi bi-graph-up-arrow text-white fs-4"></i>
                    </div>
                    <h5 class="text-white fw-semibold mb-2">Live Price Data</h5>
                    <p class="text-muted-white small mb-0">Prices scraped every 12 hours from Phong Vũ, An Phát, GearVN, and TTGShop. Always current, never outdated.</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="glass p-4 h-100 text-center">
                    <div class="gradient-icon mb-3 mx-auto" style="width:56px;height:56px">
                        <i class="bi bi-people text-white fs-4"></i>
                    </div>
                    <h5 class="text-white fw-semibold mb-2">Build Community</h5>
                    <p class="text-muted-white small mb-0">Save, share, and compare your builds. Browse community builds sorted by upvotes and get inspired.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ═══ CTA ═══ -->
<section class="py-5 px-3 mb-4">
    <div class="container-xl">
        <div class="glass text-center p-5 mx-auto rounded-4"
             style="max-width:820px;background:linear-gradient(135deg,rgba(168,85,247,.2),rgba(59,130,246,.2))!important;
                    border:1px solid rgba(168,85,247,.25)">
            <div class="badge mb-3 px-3 py-2 rounded-pill" style="background:rgba(168,85,247,.15);color:#c084fc;border:1px solid rgba(168,85,247,.3)">
                Powered by AI
            </div>
            <h2 class="display-5 fw-bold text-white mb-3">Ready to Build Something Amazing?</h2>
            <p class="text-muted-white mb-4 mx-auto" style="max-width:520px">
                Chat with our AI assistant, select your budget, and get a full compatible build in seconds.
            </p>
            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a asp-controller="Builder" asp-action="Index" class="btn btn-gradient btn-lg px-5 py-3 rounded-3 fw-semibold">
                    <i class="bi bi-tools me-2"></i>Launch PC Builder
                </a>
                <a asp-controller="Build" asp-action="Community" class="btn glass btn-lg px-5 py-3 rounded-3 text-white fw-semibold">
                    <i class="bi bi-people me-2"></i>Browse Community
                </a>
            </div>
        </div>
    </div>
</section>

@section Scripts {
<script>
function switchFeatCat(cat) {
    document.querySelectorAll('.feat-tab').forEach(btn => {
        const active = btn.dataset.cat === cat;
        btn.classList.toggle('btn-gradient', active);
        btn.classList.toggle('glass', !active);
        btn.classList.toggle('text-white', true);
    });
    document.querySelectorAll('.feat-grid').forEach(grid => {
        grid.style.display = grid.dataset.cat === cat ? '' : 'none';
    });
}

function goBuilder(category, id) {
    window.location.href = '/Builder?preselect=' + category + ':' + id;
}
</script>

<style>
.cat-shortcut:hover {
    background: rgba(168, 85, 247, .12);
}
.cat-shortcut:hover span {
    color: #c084fc !important;
}
</style>
}
