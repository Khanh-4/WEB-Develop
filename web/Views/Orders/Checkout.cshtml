@model TechSpecs.ViewModels.CheckoutViewModel
@using TechSpecs.Models
@{ ViewData["Title"] = "Thanh toán"; }

<style>
    .step-header { display:flex; align-items:center; gap:12px; margin-bottom:1.2rem; }
    .step-num { width:32px; height:32px; border-radius:50%; background:linear-gradient(135deg,#a855f7,#6366f1);
                display:flex; align-items:center; justify-content:center; font-weight:700; font-size:.9rem; flex-shrink:0; }
    .step-title { font-weight:600; font-size:1.05rem; }
    .pay-card { border:2px solid rgba(255,255,255,.1); border-radius:12px; padding:1rem 1.2rem;
                cursor:pointer; transition:.2s; }
    .pay-card:hover { border-color:rgba(168,85,247,.5); background:rgba(168,85,247,.05); }
    .pay-card.selected { border-color:#a855f7; background:rgba(168,85,247,.1); }
    .coupon-badge { background:rgba(34,197,94,.15); color:#4ade80; border:1px solid rgba(34,197,94,.3);
                    border-radius:6px; padding:2px 10px; font-size:.8rem; }
    .coupon-err { color:#f87171; font-size:.8rem; }
    .summary-sticky { position:sticky; top:80px; }
    .order-item-img { width:44px; height:44px; object-fit:contain; border-radius:6px;
                      background:rgba(255,255,255,.06); }
    .discount-row { color:#4ade80; }
</style>

<div class="container-xl py-5 px-3">
    <h1 class="fw-bold mb-5">
        <i class="bi bi-bag-check me-2"></i>Thanh toán
    </h1>

    <div id="checkoutErrors" class="alert alert-danger mb-4 d-none"></div>

    <form id="checkoutForm" novalidate>
        @Html.AntiForgeryToken()
        <input type="hidden" name="PaymentMethod" id="hiddenPaymentMethod" value="0">

        <div class="row g-4">
            <!-- Left: form sections -->
            <div class="col-lg-7">

                <!-- Section 1: Shipping info -->
                <div class="glass p-4 rounded-4 mb-4">
                    <div class="step-header">
                        <div class="step-num">1</div>
                        <div class="step-title">Thông tin giao hàng</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small text-muted">Họ và tên *</label>
                        <input name="RecipientName" id="recipientName" class="form-control"
                               placeholder="Nguyễn Văn A" maxlength="200" required
                               value="@Model.RecipientName">
                        <div class="invalid-feedback">Vui lòng nhập họ tên.</div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small text-muted">Số điện thoại *</label>
                            <input name="Phone" id="phone" class="form-control"
                                   placeholder="0912 345 678" maxlength="20" required
                                   value="@Model.Phone">
                            <div class="invalid-feedback">Vui lòng nhập số điện thoại hợp lệ.</div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <label class="form-label small text-muted">Địa chỉ giao hàng *</label>
                        <textarea name="ShippingAddress" id="shippingAddress" class="form-control" rows="2"
                                  placeholder="Số nhà, đường, phường/xã, quận/huyện, tỉnh/thành phố"
                                  maxlength="500" required>@Model.ShippingAddress</textarea>
                        <div class="invalid-feedback">Vui lòng nhập địa chỉ.</div>
                    </div>

                    <div class="mt-3">
                        <label class="form-label small text-muted">Ghi chú (tuỳ chọn)</label>
                        <textarea name="Note" class="form-control" rows="2"
                                  placeholder="Giao giờ hành chính, để ở cổng...">@Model.Note</textarea>
                    </div>
                </div>

                <!-- Section 2: Payment method -->
                <div class="glass p-4 rounded-4 mb-4">
                    <div class="step-header">
                        <div class="step-num">2</div>
                        <div class="step-title">Phương thức thanh toán</div>
                    </div>

                    <div class="d-flex flex-column gap-3">
                        <label class="pay-card selected d-flex align-items-center gap-3" id="payCOD">
                            <input type="radio" name="_payMethod" value="0" checked class="visually-hidden">
                            <i class="bi bi-cash-coin fs-4" style="color:#fbbf24"></i>
                            <div>
                                <div class="fw-semibold">Thanh toán khi nhận hàng (COD)</div>
                                <div class="text-muted small">Trả tiền mặt khi shipper giao hàng</div>
                            </div>
                        </label>

                        <label class="pay-card d-flex align-items-center gap-3" id="payBank">
                            <input type="radio" name="_payMethod" value="1" class="visually-hidden">
                            <i class="bi bi-bank fs-4" style="color:#60a5fa"></i>
                            <div>
                                <div class="fw-semibold">Chuyển khoản ngân hàng</div>
                                <div class="text-muted small">Thông tin tài khoản sẽ hiển thị sau khi đặt hàng</div>
                            </div>
                        </label>
                    </div>
                </div>

                <!-- Section 3: Coupon -->
                <div class="glass p-4 rounded-4">
                    <div class="step-header">
                        <div class="step-num">3</div>
                        <div class="step-title">Mã giảm giá</div>
                    </div>

                    <div class="d-flex gap-2">
                        <input id="couponInput" name="CouponCode" type="text" class="form-control"
                               placeholder="Nhập mã giảm giá..." maxlength="50"
                               style="text-transform:uppercase">
                        <button type="button" id="applyCoupon" class="btn glass-sm px-4" style="white-space:nowrap">
                            Áp dụng
                        </button>
                    </div>
                    <div id="couponMsg" class="mt-2"></div>
                    <p class="text-muted small mt-2 mb-0">Thử mã: <code>TECHSPECS10</code> để giảm 10%</p>
                </div>
            </div>

            <!-- Right: order summary -->
            <div class="col-lg-5">
                <div class="summary-sticky">
                    <div class="glass p-4 rounded-4">
                        <h5 class="fw-semibold mb-4">Đơn hàng của bạn</h5>

                        <div id="orderItemsList">
                            @foreach (var item in Model.Cart.Items)
                            {
                                <div class="d-flex align-items-center gap-3 mb-3">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="" class="order-item-img">
                                    }
                                    else
                                    {
                                        <div class="order-item-img d-flex align-items-center justify-content-center">
                                            <i class="bi bi-cpu text-muted"></i>
                                        </div>
                                    }
                                    <div class="flex-grow-1">
                                        <p class="mb-0 lh-sm" style="font-size:.8rem">@item.ComponentName</p>
                                        <span class="text-muted" style="font-size:.75rem">×@item.Quantity</span>
                                    </div>
                                    <span class="fw-semibold" style="font-size:.85rem">
                                        @item.Subtotal.ToString("N0")đ
                                    </span>
                                </div>
                            }
                        </div>

                        <hr class="border-white border-opacity-20">

                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">Tạm tính</span>
                            <span>@Model.Cart.Total.ToString("N0")đ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">Vận chuyển</span>
                            <span class="text-success">Miễn phí</span>
                        </div>
                        <div id="discountRow" class="d-flex justify-content-between mb-1 d-none discount-row">
                            <span><i class="bi bi-tag-fill me-1"></i>Giảm giá</span>
                            <span id="discountAmt"></span>
                        </div>
                        <hr class="border-white border-opacity-20">
                        <div class="d-flex justify-content-between mb-4">
                            <span class="fw-semibold fs-6">Tổng cộng</span>
                            <span class="fw-bold fs-5" id="totalDisplay"
                                  style="background:linear-gradient(90deg,#a855f7,#6366f1);-webkit-background-clip:text;-webkit-text-fill-color:transparent">
                                @Model.Cart.Total.ToString("N0")đ
                            </span>
                        </div>

                        <button type="button" class="btn glass text-white w-100 mb-3"
                                onclick="showInstallment(@Model.Cart.Total, 'Đơn hàng của bạn')">
                            <i class="bi bi-calculator me-2"></i>Xem tùy chọn trả góp
                        </button>

                        <div class="d-flex gap-2">
                            <a href="/Cart" class="btn glass flex-shrink-0 px-3">
                                <i class="bi bi-arrow-left"></i>
                            </a>
                            <button type="submit" id="placeOrderBtn" class="btn btn-gradient flex-grow-1 py-2 fw-semibold">
                                <span id="placeOrderLabel">
                                    <i class="bi bi-check-circle me-1"></i>Đặt hàng
                                </span>
                                <span id="placeOrderSpinner" class="d-none">
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>Đang xử lý...
                                </span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
    const subtotal = @Model.Cart.Total.ToString(System.Globalization.CultureInfo.InvariantCulture);
    let discountAmount = 0;

    // Payment method toggle
    document.querySelectorAll('[name="_payMethod"]').forEach(radio => {
        radio.closest('label').addEventListener('click', function () {
            document.querySelectorAll('.pay-card').forEach(c => c.classList.remove('selected'));
            this.classList.add('selected');
            document.getElementById('hiddenPaymentMethod').value = radio.value;
        });
    });

    // Coupon apply
    document.getElementById('applyCoupon').addEventListener('click', async function () {
        const code = document.getElementById('couponInput').value.trim();
        const msg  = document.getElementById('couponMsg');
        if (!code) { msg.innerHTML = ''; return; }

        const resp = await fetch(`/Orders/CheckCoupon?code=${encodeURIComponent(code)}&subtotal=${subtotal}`);
        const data = await resp.json();

        if (data.valid) {
            discountAmount = data.discount;
            msg.innerHTML = `<span class="coupon-badge"><i class="bi bi-check-circle me-1"></i>Áp dụng thành công — giảm ${data.discount.toLocaleString('vi-VN')}đ</span>`;
            document.getElementById('discountRow').classList.remove('d-none');
            document.getElementById('discountAmt').textContent = `-${data.discount.toLocaleString('vi-VN')}đ`;
            document.getElementById('totalDisplay').textContent = `${data.total.toLocaleString('vi-VN')}đ`;
        } else {
            discountAmount = 0;
            msg.innerHTML = `<span class="coupon-err"><i class="bi bi-x-circle me-1"></i>Mã không hợp lệ.</span>`;
            document.getElementById('discountRow').classList.add('d-none');
            document.getElementById('totalDisplay').textContent = `${subtotal.toLocaleString('vi-VN')}đ`;
        }
    });

    // Form submit via fetch (AJAX)
    document.getElementById('checkoutForm').addEventListener('submit', async function (e) {
        e.preventDefault();

        // Client-side validation
        const form = e.target;
        let ok = true;
        ['recipientName', 'phone', 'shippingAddress'].forEach(id => {
            const el = document.getElementById(id);
            if (!el.value.trim()) { el.classList.add('is-invalid'); ok = false; }
            else el.classList.remove('is-invalid');
        });
        if (!ok) return;

        document.getElementById('placeOrderLabel').classList.add('d-none');
        document.getElementById('placeOrderSpinner').classList.remove('d-none');
        document.getElementById('placeOrderBtn').disabled = true;

        const formData = new FormData(form);
        const token = form.querySelector('input[name="__RequestVerificationToken"]').value;

        try {
            const resp = await fetch('/Checkout', {
                method: 'POST',
                headers: { 'RequestVerificationToken': token },
                body: formData,
            });

            if (resp.redirected) {
                window.location.href = resp.url;
                return;
            }

            const text = await resp.text();
            // If server returned the view with errors, show them
            const errDiv = document.getElementById('checkoutErrors');
            errDiv.textContent = 'Có lỗi xảy ra. Vui lòng kiểm tra lại thông tin và thử lại.';
            errDiv.classList.remove('d-none');
        } catch {
            document.getElementById('checkoutErrors').textContent = 'Lỗi kết nối. Vui lòng thử lại.';
            document.getElementById('checkoutErrors').classList.remove('d-none');
        } finally {
            document.getElementById('placeOrderLabel').classList.remove('d-none');
            document.getElementById('placeOrderSpinner').classList.add('d-none');
            document.getElementById('placeOrderBtn').disabled = false;
        }
    });
</script>
