@model TechSpecs.ViewModels.OrderDetailViewModel
@{ ViewData["Title"] = L["Order.PlacedSuccess"].Value; }

<div class="container py-5 px-3" style="max-width:680px">
    <div class="glass p-5 text-center mb-4">
        <div class="mb-3" style="font-size:3.5rem">🎉</div>
        <h2 class="text-white fw-bold mb-2">@L["Order.PlacedSuccess"]</h2>
        <p class="text-muted-white mb-1">@L["Order.Number"] <strong class="text-white">#@Model.Id</strong></p>
        <p class="text-muted-white">@L["Order.PlacedSuccessDesc"]</p>
    </div>

    <div class="glass p-4 mb-4">
        <h6 class="text-white fw-semibold mb-3">@L["Order.ShippingInfo"]</h6>
        <div class="row g-2 text-muted-white small">
            <div class="col-5">@L["Order.Recipient"]</div>
            <div class="col-7 text-white">@Model.RecipientName</div>
            <div class="col-5">@L["Order.Phone"]</div>
            <div class="col-7 text-white">@Model.Phone</div>
            <div class="col-5">@L["Order.Address"]</div>
            <div class="col-7 text-white">@Model.ShippingAddress</div>
            @if (!string.IsNullOrEmpty(Model.Note))
            {
                <div class="col-5">@L["Order.Note"]</div>
                <div class="col-7 text-white">@Model.Note</div>
            }
        </div>
    </div>

    <div class="glass p-4 mb-4">
        <h6 class="text-white fw-semibold mb-3">@L["Order.ItemsOrdered"]</h6>
        @foreach (var item in Model.Items)
        {
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="text-white" style="font-size:.85rem">@item.ComponentName <span class="text-muted-white">×@item.Quantity</span></span>
                <span class="text-white fw-semibold" style="font-size:.85rem">@item.Subtotal.ToString("N0")đ</span>
            </div>
        }
        <hr class="border-white border-opacity-20">
        <div class="d-flex justify-content-between">
            <span class="text-white fw-semibold">@L["Label.Total"]</span>
            <span class="text-white fw-bold">@Model.TotalAmount.ToString("N0")đ</span>
        </div>
    </div>

    <div class="d-flex gap-3 justify-content-center">
        <a href="/Orders" class="btn glass text-white px-4">
            <i class="bi bi-bag-check me-1"></i>@L["Order.ViewHistory"]
        </a>
        <a href="/Products" class="btn btn-gradient px-4">
            <i class="bi bi-arrow-right me-1"></i>@L["Label.ContinueShopping"]
        </a>
    </div>
</div>
