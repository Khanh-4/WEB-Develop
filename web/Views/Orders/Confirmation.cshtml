@model TechSpecs.ViewModels.OrderDetailViewModel
@using TechSpecs.Models
@{ ViewData["Title"] = L["Order.PlacedSuccess"].Value; }

<div class="container py-5 px-3" style="max-width:680px">
    <div class="tx-card p-5 text-center mb-4">
        <div class="mb-3" style="font-size:3.5rem">🎉</div>
        <h3 class="fw-bold mb-2" style="color:var(--text)">@L["Order.PlacedSuccess"]</h3>
        <p class="mb-1" style="color:var(--text-muted)">@L["Order.Number"] <strong style="color:var(--primary)">#@Model.Id</strong></p>
        <p style="color:var(--text-muted)">@L["Order.PlacedSuccessDesc"]</p>
    </div>

    <div class="tx-card p-4 mb-4">
        <h6 class="fw-semibold mb-3" style="color:var(--text)">@L["Order.ShippingInfo"]</h6>
        <div class="row g-2 small">
            <div class="col-5" style="color:var(--text-muted)">@L["Order.Recipient"]</div>
            <div class="col-7" style="color:var(--text)">@Model.RecipientName</div>
            <div class="col-5" style="color:var(--text-muted)">@L["Order.Phone"]</div>
            <div class="col-7" style="color:var(--text)">@Model.Phone</div>
            <div class="col-5" style="color:var(--text-muted)">@L["Order.Address"]</div>
            <div class="col-7" style="color:var(--text)">@Model.ShippingAddress</div>
            @if (!string.IsNullOrEmpty(Model.Note))
            {
                <div class="col-5" style="color:var(--text-muted)">@L["Order.Note"]</div>
                <div class="col-7" style="color:var(--text)">@Model.Note</div>
            }
            <div class="col-5" style="color:var(--text-muted)">Thanh toán</div>
            <div class="col-7" style="color:var(--text)">
                @switch (Model.PaymentMethod)
                {
                    case PaymentMethod.BankTransfer:
                        <text><i class="bi bi-bank me-1" style="color:#60a5fa"></i>Chuyển khoản ngân hàng</text>
                        break;
                    case PaymentMethod.VnPay:
                        <text><i class="bi bi-qr-code me-1" style="color:#a78bfa"></i>VNPAY-QR</text>
                        break;
                    case PaymentMethod.MoMo:
                        <text><i class="bi bi-qr-code me-1" style="color:#f472b6"></i>MoMo</text>
                        break;
                    case PaymentMethod.ZaloPay:
                        <text><i class="bi bi-qr-code me-1" style="color:#60a5fa"></i>ZaloPay</text>
                        break;
                    default:
                        <text><i class="bi bi-cash-coin me-1" style="color:#fbbf24"></i>Thanh toán khi nhận hàng (COD)</text>
                        break;
                }
            </div>
        </div>
    </div>

    @if (Model.PaymentMethod == PaymentMethod.BankTransfer)
    {
        <div class="tx-card p-4 mb-4" style="border-color:rgba(96,165,250,.4)">
            <h6 class="fw-semibold mb-3"><i class="bi bi-bank me-2" style="color:#60a5fa"></i>Thông tin chuyển khoản</h6>
            <div class="row g-2 small">
                <div class="col-5" style="color:var(--text-muted)">Ngân hàng</div><div class="col-7" style="color:var(--text)">Vietcombank</div>
                <div class="col-5" style="color:var(--text-muted)">Số tài khoản</div><div class="col-7 fw-semibold" style="color:var(--text)">1234 5678 9012</div>
                <div class="col-5" style="color:var(--text-muted)">Chủ tài khoản</div><div class="col-7" style="color:var(--text)">CONG TY TECHSPECS</div>
                <div class="col-5" style="color:var(--text-muted)">Nội dung CK</div>
                <div class="col-7 fw-semibold" style="color:var(--primary)">TECHSPECS #@Model.Id</div>
            </div>
            <p style="color:var(--text-muted);font-size:.82rem" class="mt-2 mb-0">Đơn hàng sẽ được xác nhận sau khi nhận được thanh toán.</p>
        </div>
    }

    @if (Model.PaymentMethod is PaymentMethod.VnPay or PaymentMethod.MoMo or PaymentMethod.ZaloPay)
    {
        var (qrColor, qrName, qrBg) = Model.PaymentMethod switch {
            PaymentMethod.MoMo    => ("#B0006D", "MoMo",     "rgba(176,0,109,.12)"),
            PaymentMethod.ZaloPay => ("#0068FF", "ZaloPay",  "rgba(0,104,255,.12)"),
            _                     => ("#005BAA", "VNPAY-QR", "rgba(0,91,170,.12)"),
        };
        <div class="tx-card p-4 mb-4" style="border-color:@qrColor;background:@qrBg">
            <h6 class="fw-semibold mb-3">
                <i class="bi bi-qr-code me-2" style="color:@qrColor"></i>Quét mã QR để thanh toán qua @qrName
            </h6>
            <div class="d-flex justify-content-center mb-3">
                <div style="background:white;padding:16px;border-radius:12px;display:inline-block">
                    <svg width="160" height="160" viewBox="0 0 160 160" xmlns="http://www.w3.org/2000/svg">
                        <rect width="160" height="160" fill="white"/>
                        <rect x="10" y="10" width="50" height="50" rx="4" fill="#111"/>
                        <rect x="16" y="16" width="38" height="38" rx="2" fill="white"/>
                        <rect x="22" y="22" width="26" height="26" rx="1" fill="#111"/>
                        <rect x="100" y="10" width="50" height="50" rx="4" fill="#111"/>
                        <rect x="106" y="16" width="38" height="38" rx="2" fill="white"/>
                        <rect x="112" y="22" width="26" height="26" rx="1" fill="#111"/>
                        <rect x="10" y="100" width="50" height="50" rx="4" fill="#111"/>
                        <rect x="16" y="106" width="38" height="38" rx="2" fill="white"/>
                        <rect x="22" y="112" width="26" height="26" rx="1" fill="#111"/>
                        <rect x="72" y="10" width="8" height="8" fill="#111"/><rect x="82" y="10" width="8" height="8" fill="#111"/>
                        <rect x="72" y="20" width="8" height="8" fill="#111"/><rect x="72" y="40" width="8" height="8" fill="#111"/>
                        <rect x="82" y="30" width="8" height="8" fill="#111"/><rect x="82" y="50" width="8" height="8" fill="#111"/>
                        <rect x="10" y="72" width="8" height="8" fill="#111"/><rect x="20" y="72" width="8" height="8" fill="#111"/>
                        <rect x="40" y="72" width="8" height="8" fill="#111"/><rect x="50" y="72" width="8" height="8" fill="#111"/>
                        <rect x="10" y="82" width="8" height="8" fill="#111"/><rect x="30" y="82" width="8" height="8" fill="#111"/>
                        <rect x="72" y="72" width="8" height="8" fill="#111"/><rect x="82" y="72" width="8" height="8" fill="#111"/>
                        <rect x="92" y="72" width="8" height="8" fill="#111"/><rect x="102" y="72" width="8" height="8" fill="#111"/>
                        <rect x="72" y="82" width="8" height="8" fill="#111"/><rect x="92" y="82" width="8" height="8" fill="#111"/>
                        <rect x="112" y="72" width="8" height="8" fill="#111"/><rect x="122" y="72" width="8" height="8" fill="#111"/>
                        <rect x="112" y="82" width="8" height="8" fill="#111"/><rect x="132" y="82" width="8" height="8" fill="#111"/>
                        <rect x="72" y="92" width="8" height="8" fill="#111"/><rect x="82" y="102" width="8" height="8" fill="#111"/>
                        <rect x="102" y="102" width="8" height="8" fill="#111"/><rect x="122" y="92" width="8" height="8" fill="#111"/>
                        <rect x="72" y="112" width="8" height="8" fill="#111"/><rect x="92" y="112" width="8" height="8" fill="#111"/>
                        <rect x="72" y="132" width="8" height="8" fill="#111"/><rect x="112" y="122" width="8" height="8" fill="#111"/>
                        <rect x="132" y="112" width="8" height="8" fill="#111"/><rect x="142" y="122" width="8" height="8" fill="#111"/>
                        <rect x="66" y="66" width="28" height="28" rx="4" fill="@qrColor"/>
                        <text x="80" y="84" text-anchor="middle" fill="white" font-size="10" font-family="Arial" font-weight="bold">TS</text>
                    </svg>
                </div>
            </div>
            <p class="text-center mb-1" style="font-size:.82rem;color:var(--text-muted)">
                Số tiền: <span class="fw-bold" style="color:var(--text)">@Model.TotalAmount.ToString("N0")đ</span>
            </p>
            <p class="text-center mb-0" style="font-size:.75rem;color:var(--text-muted)">
                Nội dung: <span style="color:@qrColor">TECHSPECS #@Model.Id</span><br>
                <span style="opacity:.5;font-size:.7rem">Demo — Mã QR minh họa, chưa kết nối cổng thanh toán thật.</span>
            </p>
        </div>
    }

    <div class="tx-card p-4 mb-4">
        <h6 class="fw-semibold mb-3" style="color:var(--text)">@L["Order.ItemsOrdered"]</h6>
        @foreach (var item in Model.Items)
        {
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span style="font-size:.85rem;color:var(--text)">@item.ComponentName <span style="color:var(--text-muted)">×@item.Quantity</span></span>
                <span class="fw-semibold" style="font-size:.85rem;color:var(--text)">@item.Subtotal.ToString("N0")đ</span>
            </div>
        }
        <hr style="border-color:var(--border);opacity:1">
        @if (Model.DiscountAmount > 0)
        {
            <div class="d-flex justify-content-between mb-1">
                <span style="color:var(--text-muted)"><i class="bi bi-tag-fill me-1"></i>Giảm giá</span>
                <span style="color:#4ade80">-@Model.DiscountAmount.ToString("N0")đ</span>
            </div>
        }
        <div class="d-flex justify-content-between">
            <span class="fw-semibold" style="color:var(--text)">@L["Label.Total"]</span>
            <span class="fw-bold" style="color:var(--primary)">@Model.TotalAmount.ToString("N0")đ</span>
        </div>
    </div>

    <div class="d-flex gap-3 justify-content-center flex-wrap">
        <a href="/Orders" class="btn glass px-4" style="color:var(--text)">
            <i class="bi bi-bag-check me-1"></i>@L["Order.ViewHistory"]
        </a>
        <a href="/OrderTracking" class="btn glass px-4" style="color:var(--text)">
            <i class="bi bi-truck me-1"></i>Tra cứu đơn hàng
        </a>
        <a href="/Products" class="btn btn-gradient px-4">
            <i class="bi bi-arrow-right me-1"></i>@L["Label.ContinueShopping"]
        </a>
    </div>
</div>
