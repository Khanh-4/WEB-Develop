@model TechSpecs.ViewModels.OrderDetailViewModel
@using TechSpecs.Models
@{ ViewData["Title"] = $"#{Model.Id}"; }

@{
    string StatusLabel(TechSpecs.Models.OrderStatus s) => s switch
    {
        TechSpecs.Models.OrderStatus.Pending      => L["Order.Status.Pending"].Value,
        TechSpecs.Models.OrderStatus.Confirmed    => L["Order.Status.Confirmed"].Value,
        TechSpecs.Models.OrderStatus.Assembling   => L["Order.Status.Assembling"].Value,
        TechSpecs.Models.OrderStatus.InstallingOS => L["Order.Status.InstallingOS"].Value,
        TechSpecs.Models.OrderStatus.Shipped      => L["Order.Status.Shipped"].Value,
        TechSpecs.Models.OrderStatus.Delivered    => L["Order.Status.Delivered"].Value,
        TechSpecs.Models.OrderStatus.Cancelled    => L["Order.Status.Cancelled"].Value,
        _ => s.ToString()
    };
    string StatusPillClass(TechSpecs.Models.OrderStatus s) => s switch
    {
        TechSpecs.Models.OrderStatus.Pending      => "pending",
        TechSpecs.Models.OrderStatus.Confirmed    => "confirmed",
        TechSpecs.Models.OrderStatus.Assembling   => "confirmed",
        TechSpecs.Models.OrderStatus.InstallingOS => "confirmed",
        TechSpecs.Models.OrderStatus.Shipped      => "shipping",
        TechSpecs.Models.OrderStatus.Delivered    => "completed",
        TechSpecs.Models.OrderStatus.Cancelled    => "cancelled",
        _ => ""
    };

    var steps = new[]
    {
        (TechSpecs.Models.OrderStatus.Pending,      "bi-clock",            L["Order.Status.Pending"].Value),
        (TechSpecs.Models.OrderStatus.Confirmed,    "bi-check-circle",     L["Order.Status.Confirmed"].Value),
        (TechSpecs.Models.OrderStatus.Assembling,   "bi-tools",            L["Order.Status.Assembling"].Value),
        (TechSpecs.Models.OrderStatus.InstallingOS, "bi-display",          L["Order.Status.InstallingOS"].Value),
        (TechSpecs.Models.OrderStatus.Shipped,      "bi-truck",            L["Order.Status.Shipped"].Value),
        (TechSpecs.Models.OrderStatus.Delivered,    "bi-house-check",      L["Order.Status.Delivered"].Value),
    };
    int stepOrder(TechSpecs.Models.OrderStatus s) => s switch
    {
        TechSpecs.Models.OrderStatus.Pending      => 0,
        TechSpecs.Models.OrderStatus.Confirmed    => 1,
        TechSpecs.Models.OrderStatus.Assembling   => 2,
        TechSpecs.Models.OrderStatus.InstallingOS => 3,
        TechSpecs.Models.OrderStatus.Shipped      => 4,
        TechSpecs.Models.OrderStatus.Delivered    => 5,
        _ => -1
    };
    int currentStep = stepOrder(Model.Status);
    bool isCancelled = Model.Status == TechSpecs.Models.OrderStatus.Cancelled;
}

<div class="container py-5 px-3" style="max-width:760px">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/Orders" class="btn glass px-3 py-1" style="color:var(--text)">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h4 class="fw-bold mb-0" style="color:var(--text)">#@Model.Id</h4>
        <span class="status-pill @StatusPillClass(Model.Status) ms-auto">@StatusLabel(Model.Status)</span>
    </div>

    <!-- Progress stepper -->
    @if (isCancelled)
    {
        <div class="tx-card p-4 mb-4 d-flex align-items-center gap-3"
             style="border-left:3px solid var(--danger)">
            <i class="bi bi-x-circle-fill fs-4" style="color:var(--danger)"></i>
            <div>
                <p class="fw-semibold mb-0" style="color:var(--text)">@L["Order.Status.Cancelled"]</p>
                <p class="mb-0" style="color:var(--text-muted);font-size:.82rem">Đơn hàng đã bị huỷ.</p>
            </div>
        </div>
    }
    else
    {
        <div class="tx-card p-4 mb-4">
            <div class="d-flex align-items-start" style="overflow-x:auto;gap:0">
                @for (int i = 0; i < steps.Length; i++)
                {
                    var (stepStatus, icon, label) = steps[i];
                    bool done    = currentStep > i;
                    bool active  = currentStep == i;
                    string dotBg    = done || active ? "var(--primary)" : "var(--surface-2)";
                    string iconColor = done ? "#fff" : active ? "#fff" : "var(--text-muted)";
                    string textColor = done || active ? "var(--text)" : "var(--text-muted)";
                    string lineColor = done ? "var(--primary)" : "var(--border)";
                    bool isLast = i == steps.Length - 1;
                    <div class="d-flex flex-column align-items-center flex-shrink-0" style="min-width:88px">
                        <div class="d-flex align-items-center w-100">
                            @if (i > 0)
                            {
                                <div style="height:2px;flex:1;background:@lineColor;margin-top:-2px"></div>
                            }
                            else
                            {
                                <div style="flex:0.5"></div>
                            }
                            <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0"
                                 style="width:34px;height:34px;background:@dotBg;
                                        @(active ? "box-shadow:0 0 0 4px rgba(139,92,246,.25)" : "")
                                        transition:all .3s">
                                @if (done)
                                {
                                    <i class="bi bi-check-lg" style="color:#fff;font-size:.85rem"></i>
                                }
                                else
                                {
                                    <i class="bi @icon" style="color:@iconColor;font-size:.8rem"></i>
                                }
                            </div>
                            @if (!isLast)
                            {
                                <div style="height:2px;flex:1;background:@(done ? "var(--primary)" : "var(--border)");margin-top:-2px"></div>
                            }
                            else
                            {
                                <div style="flex:0.5"></div>
                            }
                        </div>
                        <p class="text-center mt-2 mb-0 lh-sm" style="font-size:.7rem;color:@textColor;font-weight:@(active?"600":"400")">
                            @label
                        </p>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Items -->
    <div class="tx-card p-4 mb-4">
        <h6 class="fw-semibold mb-3" style="color:var(--text)">@L["Order.Products"]</h6>
        @foreach (var item in Model.Items)
        {
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded overflow-hidden"
                     style="width:54px;height:54px;background:var(--surface-2)">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" alt="" class="w-100 h-100 object-fit-cover">
                    }
                    else
                    {
                        <i class="bi bi-cpu" style="color:var(--text-muted)"></i>
                    }
                </div>
                <div class="flex-grow-1">
                    <span class="badge glass-sm mb-1" style="color:var(--primary);font-size:.66rem">
                        @item.Category.ToUpper()
                    </span>
                    <p class="mb-0 lh-sm" style="color:var(--text);font-size:.85rem">@item.ComponentName</p>
                    <span style="color:var(--text-muted);font-size:.78rem">
                        @item.Price.ToString("N0")đ × @item.Quantity
                    </span>
                </div>
                <span class="fw-semibold" style="color:var(--text)">@item.Subtotal.ToString("N0")đ</span>
            </div>
        }
        <hr style="border-color:var(--border)">
        <div class="d-flex justify-content-between">
            <span class="fw-semibold" style="color:var(--text)">@L["Label.Total"]</span>
            <span class="fw-bold fs-5" style="color:var(--primary)">@Model.TotalAmount.ToString("N0")đ</span>
        </div>
    </div>

    <!-- Cancel button (Pending only) -->
    @if (Model.Status == TechSpecs.Models.OrderStatus.Pending)
    {
        <div class="mb-4">
            @if (TempData["Error"] != null)
            {
                <div class="alert glass py-2 mb-3" style="color:var(--danger)">@TempData["Error"]</div>
            }
            <button class="btn px-4" style="background:rgba(239,68,68,.15);color:var(--danger);border:1px solid rgba(239,68,68,.3)"
                    data-bs-toggle="modal" data-bs-target="#cancelModal">
                <i class="bi bi-x-circle me-1"></i>@L["Order.Cancel"]
            </button>
        </div>

        <div class="modal fade" id="cancelModal" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content" style="background:var(--surface);border:1px solid var(--border)">
                    <div class="modal-header" style="border-color:var(--border)">
                        <h5 class="modal-title" style="color:var(--text)">@L["Order.CancelConfirmTitle"]</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body" style="color:var(--text-muted)">@L["Order.CancelConfirmBody"]</div>
                    <div class="modal-footer" style="border-color:var(--border)">
                        <button type="button" class="btn glass" style="color:var(--text)" data-bs-dismiss="modal">@L["Label.No"]</button>
                        <form asp-controller="Orders" asp-action="Cancel" asp-route-id="@Model.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn" style="background:rgba(239,68,68,.2);color:var(--danger);border:1px solid rgba(239,68,68,.3)">
                                @L["Label.YesCancel"]
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert glass py-2 mb-4" style="color:#4ade80">@TempData["Success"]</div>
    }

    <!-- Shipping info -->
    <div class="tx-card p-4">
        <h6 class="fw-semibold mb-3" style="color:var(--text)">@L["Order.ShippingInfo"]</h6>
        <div class="row g-2">
            <div class="col-5 small" style="color:var(--text-muted)">@L["Order.Recipient"]</div>
            <div class="col-7 small" style="color:var(--text)">@Model.RecipientName</div>
            <div class="col-5 small" style="color:var(--text-muted)">@L["Order.Phone"]</div>
            <div class="col-7 small" style="color:var(--text)">@Model.Phone</div>
            <div class="col-5 small" style="color:var(--text-muted)">@L["Order.Address"]</div>
            <div class="col-7 small" style="color:var(--text)">@Model.ShippingAddress</div>
            <div class="col-5 small" style="color:var(--text-muted)">@L["Order.PlacedDate"]</div>
            <div class="col-7 small" style="color:var(--text)">@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
            @if (!string.IsNullOrEmpty(Model.Note))
            {
                <div class="col-5 small" style="color:var(--text-muted)">@L["Order.Note"]</div>
                <div class="col-7 small" style="color:var(--text)">@Model.Note</div>
            }
            <div class="col-5 small" style="color:var(--text-muted)">Thanh toán</div>
            <div class="col-7 small" style="color:var(--text)">
                @if (Model.PaymentMethod == PaymentMethod.BankTransfer)
                {
                    <i class="bi bi-bank me-1" style="color:#60a5fa"></i><text>Chuyển khoản ngân hàng</text>
                }
                else
                {
                    <i class="bi bi-cash-coin me-1" style="color:#fbbf24"></i><text>COD</text>
                }
            </div>
            @if (Model.DiscountAmount > 0)
            {
                <div class="col-5 small" style="color:var(--text-muted)">Giảm giá</div>
                <div class="col-7 small" style="color:#4ade80">-@Model.DiscountAmount.ToString("N0")đ</div>
            }
        </div>
    </div>
</div>
