@model TechSpecs.ViewModels.OrderDetailViewModel
@{ ViewData["Title"] = $"#{Model.Id}"; }

@{
    string StatusLabel(TechSpecs.Models.OrderStatus s) => s switch
    {
        TechSpecs.Models.OrderStatus.Pending      => L["Order.Status.Pending"].Value,
        TechSpecs.Models.OrderStatus.Confirmed    => L["Order.Status.Confirmed"].Value,
        TechSpecs.Models.OrderStatus.Assembling   => L["Order.Status.Assembling"].Value,
        TechSpecs.Models.OrderStatus.InstallingOS => L["Order.Status.InstallingOS"].Value,
        TechSpecs.Models.OrderStatus.Shipped      => L["Order.Status.Shipped"].Value,
        TechSpecs.Models.OrderStatus.Delivered    => L["Order.Status.Delivered"].Value,
        TechSpecs.Models.OrderStatus.Cancelled    => L["Order.Status.Cancelled"].Value,
        _ => s.ToString()
    };

    string StatusClass(TechSpecs.Models.OrderStatus s) => s switch
    {
        TechSpecs.Models.OrderStatus.Pending      => "text-warning",
        TechSpecs.Models.OrderStatus.Confirmed    => "text-info",
        TechSpecs.Models.OrderStatus.Assembling   => "text-info",
        TechSpecs.Models.OrderStatus.InstallingOS => "text-info",
        TechSpecs.Models.OrderStatus.Shipped      => "text-primary",
        TechSpecs.Models.OrderStatus.Delivered    => "text-success",
        TechSpecs.Models.OrderStatus.Cancelled    => "text-danger",
        _ => "text-white"
    };

    // Ordered pipeline steps (Cancelled handled separately)
    var steps = new[]
    {
        (TechSpecs.Models.OrderStatus.Pending,      "bi-clock",            L["Order.Status.Pending"].Value),
        (TechSpecs.Models.OrderStatus.Confirmed,    "bi-check-circle",     L["Order.Status.Confirmed"].Value),
        (TechSpecs.Models.OrderStatus.Assembling,   "bi-tools",            L["Order.Status.Assembling"].Value),
        (TechSpecs.Models.OrderStatus.InstallingOS, "bi-display",          L["Order.Status.InstallingOS"].Value),
        (TechSpecs.Models.OrderStatus.Shipped,      "bi-truck",            L["Order.Status.Shipped"].Value),
        (TechSpecs.Models.OrderStatus.Delivered,    "bi-house-check",      L["Order.Status.Delivered"].Value),
    };
    int stepOrder(TechSpecs.Models.OrderStatus s) => s switch
    {
        TechSpecs.Models.OrderStatus.Pending      => 0,
        TechSpecs.Models.OrderStatus.Confirmed    => 1,
        TechSpecs.Models.OrderStatus.Assembling   => 2,
        TechSpecs.Models.OrderStatus.InstallingOS => 3,
        TechSpecs.Models.OrderStatus.Shipped      => 4,
        TechSpecs.Models.OrderStatus.Delivered    => 5,
        _ => -1
    };
    int currentStep = stepOrder(Model.Status);
    bool isCancelled = Model.Status == TechSpecs.Models.OrderStatus.Cancelled;
}

<div class="container py-5 px-3" style="max-width:760px">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/Orders" class="btn glass text-white px-3 py-1">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="text-white fw-bold mb-0">#@Model.Id</h1>
        <span class="@StatusClass(Model.Status) fw-semibold ms-auto">● @StatusLabel(Model.Status)</span>
    </div>

    <!-- Progress stepper -->
    @if (isCancelled)
    {
        <div class="glass p-4 mb-4 d-flex align-items-center gap-3"
             style="border-left:4px solid #ef4444">
            <i class="bi bi-x-circle-fill text-danger fs-4"></i>
            <div>
                <p class="text-white fw-semibold mb-0">@L["Order.Status.Cancelled"]</p>
                <p class="text-muted-white mb-0" style="font-size:.82rem">Đơn hàng đã bị huỷ.</p>
            </div>
        </div>
    }
    else
    {
        <div class="glass p-4 mb-4">
            <div class="d-flex align-items-start" style="overflow-x:auto;gap:0">
                @for (int i = 0; i < steps.Length; i++)
                {
                    var (stepStatus, icon, label) = steps[i];
                    bool done    = currentStep > i;
                    bool active  = currentStep == i;
                    bool pending = currentStep < i;
                    string dotColor  = done || active ? "#a855f7" : "rgba(255,255,255,0.15)";
                    string iconColor = done ? "#a855f7" : active ? "#ffffff" : "rgba(255,255,255,0.3)";
                    string textColor = done || active ? "#ffffff" : "rgba(255,255,255,0.35)";
                    string lineColor = done ? "#a855f7" : "rgba(255,255,255,0.1)";
                    bool isLast = i == steps.Length - 1;
                    <div class="d-flex flex-column align-items-center flex-shrink-0" style="min-width:90px">
                        <div class="d-flex align-items-center w-100">
                            <!-- Left connector -->
                            @if (i > 0)
                            {
                                <div style="height:2px;flex:1;background:@lineColor;margin-top:-2px"></div>
                            }
                            else
                            {
                                <div style="flex:0.5"></div>
                            }
                            <!-- Dot -->
                            <div class="d-flex align-items-center justify-content-center rounded-circle flex-shrink-0"
                                 style="width:36px;height:36px;background:@dotColor;
                                        @(active ? "box-shadow:0 0 0 4px rgba(168,85,247,0.25)" : "")
                                        transition:all .3s">
                                @if (done)
                                {
                                    <i class="bi bi-check-lg" style="color:#fff;font-size:.9rem"></i>
                                }
                                else
                                {
                                    <i class="bi @icon" style="color:@iconColor;font-size:.85rem"></i>
                                }
                            </div>
                            <!-- Right connector -->
                            @if (!isLast)
                            {
                                <div style="height:2px;flex:1;background:@(done ? "#a855f7" : "rgba(255,255,255,0.1)");margin-top:-2px"></div>
                            }
                            else
                            {
                                <div style="flex:0.5"></div>
                            }
                        </div>
                        <p class="text-center mt-2 mb-0 lh-sm" style="font-size:.72rem;color:@textColor;font-weight:@(active?"600":"400")">
                            @label
                        </p>
                    </div>
                }
            </div>
        </div>
    }

    <!-- Items -->
    <div class="glass p-4 mb-4">
        <h6 class="text-white fw-semibold mb-3">@L["Order.Products"]</h6>
        @foreach (var item in Model.Items)
        {
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded overflow-hidden"
                     style="width:56px;height:56px;background:rgba(255,255,255,.06)">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" alt="" class="w-100 h-100 object-fit-cover">
                    }
                    else
                    {
                        <i class="bi bi-cpu text-muted-white"></i>
                    }
                </div>
                <div class="flex-grow-1">
                    <span class="badge mb-1" style="background:rgba(168,85,247,.2);color:#c084fc;font-size:.66rem">
                        @item.Category.ToUpper()
                    </span>
                    <p class="text-white mb-0 lh-sm" style="font-size:.85rem">@item.ComponentName</p>
                    <span class="text-muted-white" style="font-size:.78rem">
                        @item.Price.ToString("N0")đ × @item.Quantity
                    </span>
                </div>
                <span class="text-white fw-semibold">@item.Subtotal.ToString("N0")đ</span>
            </div>
        }
        <hr class="border-white border-opacity-20">
        <div class="d-flex justify-content-between">
            <span class="text-white fw-semibold">@L["Label.Total"]</span>
            <span class="text-white fw-bold fs-5">@Model.TotalAmount.ToString("N0")đ</span>
        </div>
    </div>

    <!-- Cancel button (Pending only) -->
    @if (Model.Status == TechSpecs.Models.OrderStatus.Pending)
    {
        <div class="mb-4">
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger py-2">@TempData["Error"]</div>
            }
            <button class="btn btn-danger px-4" data-bs-toggle="modal" data-bs-target="#cancelModal">
                <i class="bi bi-x-circle me-1"></i>@L["Order.Cancel"]
            </button>
        </div>

        <!-- Confirm modal -->
        <div class="modal fade" id="cancelModal" tabindex="-1">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content glass border-0">
                    <div class="modal-header border-0">
                        <h5 class="modal-title text-white">@L["Order.CancelConfirmTitle"]</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body text-muted-white">@L["Order.CancelConfirmBody"]</div>
                    <div class="modal-footer border-0">
                        <button type="button" class="btn glass text-white" data-bs-dismiss="modal">@L["Label.No"]</button>
                        <form asp-controller="Orders" asp-action="Cancel" asp-route-id="@Model.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger">@L["Label.YesCancel"]</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success py-2 mb-4">@TempData["Success"]</div>
    }

    <!-- Shipping info -->
    <div class="glass p-4 mb-4">
        <h6 class="text-white fw-semibold mb-3">@L["Order.ShippingInfo"]</h6>
        <div class="row g-2 text-muted-white small">
            <div class="col-5">@L["Order.Recipient"]</div>
            <div class="col-7 text-white">@Model.RecipientName</div>
            <div class="col-5">@L["Order.Phone"]</div>
            <div class="col-7 text-white">@Model.Phone</div>
            <div class="col-5">@L["Order.Address"]</div>
            <div class="col-7 text-white">@Model.ShippingAddress</div>
            <div class="col-5">@L["Order.PlacedDate"]</div>
            <div class="col-7 text-white">@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
            @if (!string.IsNullOrEmpty(Model.Note))
            {
                <div class="col-5">@L["Order.Note"]</div>
                <div class="col-7 text-white">@Model.Note</div>
            }
        </div>
    </div>
</div>
