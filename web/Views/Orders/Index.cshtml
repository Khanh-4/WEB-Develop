@model TechSpecs.ViewModels.OrderListViewModel
@{ ViewData["Title"] = L["Order.MyOrders"].Value; }

@{
    string StatusLabel(TechSpecs.Models.OrderStatus s) => s switch
    {
        TechSpecs.Models.OrderStatus.Pending   => L["Order.Status.Pending"].Value,
        TechSpecs.Models.OrderStatus.Confirmed => L["Order.Status.Confirmed"].Value,
        TechSpecs.Models.OrderStatus.Shipped   => L["Order.Status.Shipped"].Value,
        TechSpecs.Models.OrderStatus.Delivered => L["Order.Status.Delivered"].Value,
        TechSpecs.Models.OrderStatus.Cancelled => L["Order.Status.Cancelled"].Value,
        _ => s.ToString()
    };

    string StatusClass(TechSpecs.Models.OrderStatus s) => s switch
    {
        TechSpecs.Models.OrderStatus.Pending   => "text-warning",
        TechSpecs.Models.OrderStatus.Confirmed => "text-info",
        TechSpecs.Models.OrderStatus.Shipped   => "text-primary",
        TechSpecs.Models.OrderStatus.Delivered => "text-success",
        TechSpecs.Models.OrderStatus.Cancelled => "text-danger",
        _ => "text-white"
    };
}

<div class="container-xl py-5 px-3">
    <h1 class="text-white fw-bold mb-4">
        <i class="bi bi-bag-check me-2"></i>@L["Order.MyOrders"]
    </h1>

    @if (!Model.Orders.Any())
    {
        <div class="glass p-5 text-center">
            <i class="bi bi-bag-x text-muted-white" style="font-size:3.5rem"></i>
            <h5 class="text-white mt-3">@L["Order.NoOrders"]</h5>
            <a href="/Products" class="btn btn-gradient px-4 mt-2">@L["Order.ShopNow"]</a>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var o in Model.Orders)
            {
                <div class="glass p-4 d-flex align-items-center gap-4">
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center gap-3 mb-1">
                            <span class="text-white fw-semibold">#@o.Id</span>
                            <span class="@StatusClass(o.Status) small fw-semibold">● @StatusLabel(o.Status)</span>
                        </div>
                        <p class="text-muted-white small mb-0">
                            @o.ItemCount @L["Label.Items"] &nbsp;·&nbsp;
                            @o.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </p>
                    </div>
                    <div class="text-end me-2">
                        <span class="text-white fw-bold">@o.TotalAmount.ToString("N0")đ</span>
                    </div>
                    <div class="d-flex gap-2 flex-shrink-0">
                        @if (o.Status == TechSpecs.Models.OrderStatus.Pending)
                        {
                            <form asp-controller="Orders" asp-action="Cancel" asp-route-id="@o.Id" method="post"
                                  onsubmit="return confirm('@L["Order.CancelConfirmBody"].Value')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger px-3 py-1">
                                    <i class="bi bi-x-circle"></i>
                                </button>
                            </form>
                        }
                        <a href="/Orders/Detail/@o.Id" class="btn glass text-white px-3 py-1">
                            @L["Order.ViewDetail"] <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>
