@model TechSpecs.ViewModels.OrderListViewModel
@{ ViewData["Title"] = L["Order.MyOrders"].Value; }

@{
    string StatusLabel(TechSpecs.Models.OrderStatus s) => s switch
    {
        TechSpecs.Models.OrderStatus.Pending   => L["Order.Status.Pending"].Value,
        TechSpecs.Models.OrderStatus.Confirmed => L["Order.Status.Confirmed"].Value,
        TechSpecs.Models.OrderStatus.Shipped   => L["Order.Status.Shipped"].Value,
        TechSpecs.Models.OrderStatus.Delivered => L["Order.Status.Delivered"].Value,
        TechSpecs.Models.OrderStatus.Cancelled => L["Order.Status.Cancelled"].Value,
        _ => s.ToString()
    };
    string StatusPillClass(TechSpecs.Models.OrderStatus s) => s switch
    {
        TechSpecs.Models.OrderStatus.Pending   => "pending",
        TechSpecs.Models.OrderStatus.Confirmed => "confirmed",
        TechSpecs.Models.OrderStatus.Shipped   => "shipping",
        TechSpecs.Models.OrderStatus.Delivered => "completed",
        TechSpecs.Models.OrderStatus.Cancelled => "cancelled",
        _ => ""
    };
}

<div class="container-xl py-5 px-3">
    <h4 class="fw-bold mb-4" style="color:var(--text)">
        <i class="bi bi-bag-check me-2" style="color:var(--primary)"></i>@L["Order.MyOrders"]
    </h4>

    @if (!Model.Orders.Any())
    {
        <div class="tx-card p-5 text-center">
            <i class="bi bi-bag-x" style="font-size:3.5rem;color:var(--text-muted);opacity:.4"></i>
            <h5 class="mt-3 fw-semibold" style="color:var(--text)">@L["Order.NoOrders"]</h5>
            <a href="/Products" class="btn btn-gradient px-4 mt-2">@L["Order.ShopNow"]</a>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var o in Model.Orders)
            {
                <div class="tx-card p-4 d-flex align-items-center gap-4">
                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center gap-3 mb-1">
                            <span class="fw-semibold" style="color:var(--text)">#@o.Id</span>
                            <span class="status-pill @StatusPillClass(o.Status)">@StatusLabel(o.Status)</span>
                        </div>
                        <p class="mb-0" style="color:var(--text-muted);font-size:.83rem">
                            @o.ItemCount @L["Label.Items"] &nbsp;·&nbsp;
                            @o.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </p>
                    </div>
                    <div class="text-end me-2">
                        <span class="fw-bold" style="color:var(--text)">@o.TotalAmount.ToString("N0")đ</span>
                    </div>
                    <div class="d-flex gap-2 flex-shrink-0">
                        @if (o.Status == TechSpecs.Models.OrderStatus.Pending)
                        {
                            <form asp-controller="Orders" asp-action="Cancel" asp-route-id="@o.Id" method="post"
                                  onsubmit="return confirm('@L["Order.CancelConfirmBody"].Value')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm px-3 py-1" style="color:var(--danger);background:rgba(239,68,68,.12);border:none">
                                    <i class="bi bi-x-circle"></i>
                                </button>
                            </form>
                        }
                        <a href="/Orders/Detail/@o.Id" class="btn btn-sm glass px-3 py-1" style="color:var(--primary)">
                            @L["Order.ViewDetail"] <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>
