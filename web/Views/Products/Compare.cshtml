@model List<TechSpecs.ViewModels.ProductDetailViewModel>
@{
    ViewData["Title"] = "So sánh sản phẩm";
    var allKeys = Model.SelectMany(p => p.Specs.Keys).Distinct().ToList();
    int cols = Model.Count;
}

<div class="container-xl py-4 px-3">

    <div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
        <a href="javascript:history.back()" class="btn glass text-white px-3 py-1">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h1 class="text-white fw-bold mb-0" style="font-size:1.4rem">So sánh sản phẩm</h1>
        <span class="badge rounded-pill px-3 py-2 ms-auto"
              style="background:rgba(168,85,247,.2);color:#c084fc">
            @Model[0].Category.ToUpper()
        </span>
    </div>

    <div class="glass rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table mb-0" style="min-width:@(340 + cols * 240)px">

                <!-- Product header row -->
                <thead>
                    <tr style="border-bottom:1px solid rgba(255,255,255,0.08)">
                        <th style="width:180px;background:rgba(255,255,255,0.03);padding:20px 16px;
                                   color:rgba(255,255,255,.4);font-size:.78rem;font-weight:500;text-transform:uppercase;letter-spacing:.05em;vertical-align:middle">
                            Thông số
                        </th>
                        @foreach (var p in Model)
                        {
                            <th style="padding:20px 16px;background:rgba(255,255,255,0.02);vertical-align:top;min-width:240px">
                                <!-- Image -->
                                <div class="d-flex align-items-center justify-content-center rounded-3 mb-3"
                                     style="height:140px;background:rgba(255,255,255,0.05)">
                                    @if (p.ImageUrl != null)
                                    {
                                        <img src="@p.ImageUrl" alt="@p.Name"
                                             style="max-height:130px;max-width:100%;object-fit:contain" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-cpu text-muted-white" style="font-size:3.5rem;opacity:.3"></i>
                                    }
                                </div>
                                <!-- Name -->
                                <p class="text-white fw-semibold mb-2 lh-sm" style="font-size:.88rem">@p.Name</p>
                                <!-- Price -->
                                <p class="fw-bold mb-3" style="font-size:1.25rem;background:linear-gradient(135deg,#a855f7,#6366f1);
                                   -webkit-background-clip:text;-webkit-text-fill-color:transparent">
                                    @p.Price.ToString("N0")đ
                                </p>
                                <!-- Stock + actions -->
                                <div class="d-flex gap-2 flex-wrap">
                                    @if (p.Stock > 0)
                                    {
                                        <span class="badge rounded-pill" style="background:rgba(34,197,94,.15);color:#4ade80;font-size:.72rem">
                                            <i class="bi bi-check-circle me-1"></i>Còn hàng
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill" style="background:rgba(239,68,68,.15);color:#f87171;font-size:.72rem">
                                            Hết hàng
                                        </span>
                                    }
                                </div>
                                <div class="d-flex gap-2 mt-2 flex-wrap">
                                    <button class="btn btn-gradient btn-sm px-3 py-1"
                                            @(p.Stock == 0 ? "disabled" : "")
                                            data-pid="@p.Id" data-pcat="@p.Category"
                                            data-pname="@p.Name" data-pprice="@p.Price"
                                            data-pimg="@p.ImageUrl"
                                            onclick="addToCartFromData(this)">
                                        <i class="bi bi-cart-plus me-1"></i>Giỏ hàng
                                    </button>
                                    <a href="/Products/Detail/@p.Category/@p.Id"
                                       class="btn glass text-white btn-sm px-3 py-1">
                                        Chi tiết
                                    </a>
                                </div>
                            </th>
                        }
                    </tr>
                </thead>

                <!-- Spec rows -->
                <tbody>
                    @foreach (var key in allKeys)
                    {
                        var vals = Model.Select(p => p.Specs.TryGetValue(key, out var v) ? v : "—").ToList();
                        bool allSame = vals.Distinct().Count() == 1;

                        <tr style="border-bottom:1px solid rgba(255,255,255,0.05)">
                            <td style="padding:12px 16px;background:rgba(255,255,255,0.03);
                                       color:rgba(255,255,255,.55);font-size:.82rem;vertical-align:middle;white-space:nowrap">
                                @key
                            </td>
                            @for (int i = 0; i < Model.Count; i++)
                            {
                                var val = vals[i];
                                bool isDiff = !allSame;
                                <td style="padding:12px 16px;vertical-align:middle;font-size:.85rem;
                                           color:@(isDiff ? "#fde68a" : "rgba(255,255,255,.85)");
                                           @(isDiff ? "background:rgba(251,191,36,0.06)" : "")">
                                    @if (isDiff)
                                    {
                                        <i class="bi bi-arrow-left-right me-1" style="font-size:.7rem;color:#f59e0b;opacity:.7"></i>
                                    }
                                    @val
                                </td>
                            }
                        </tr>
                    }

                    <!-- Price comparison row (always highlighted) -->
                    <tr style="background:rgba(168,85,247,0.06)">
                        <td style="padding:14px 16px;color:rgba(255,255,255,.55);font-size:.82rem;font-weight:600;vertical-align:middle">
                            Giá bán
                        </td>
                        @{
                            var prices = Model.Select(p => p.Price).ToList();
                            var minPrice = prices.Min();
                        }
                        @foreach (var p in Model)
                        {
                            bool isCheapest = p.Price == minPrice && cols > 1;
                            <td style="padding:14px 16px;vertical-align:middle">
                                <span class="fw-bold" style="font-size:1rem;color:@(isCheapest ? "#4ade80" : "rgba(255,255,255,.85)")">
                                    @p.Price.ToString("N0")đ
                                </span>
                                @if (isCheapest)
                                {
                                    <span class="badge ms-2" style="background:rgba(34,197,94,.2);color:#4ade80;font-size:.68rem">Rẻ nhất</span>
                                }
                            </td>
                        }
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Back to products -->
    <div class="text-center mt-4">
        <a href="/Products?category=@Model[0].Category" class="btn glass text-white px-4 py-2">
            <i class="bi bi-arrow-left me-2"></i>Quay lại danh sách
        </a>
    </div>

</div>

@section Scripts {
<script>
// P29: Compare diff highlight — green=winner, red=loser, yellow=text-diff
(function() {
    const tbody = document.querySelector('table tbody');
    if (!tbody) return;
    const specRows = Array.from(tbody.querySelectorAll('tr:not(:last-child)'));

    specRows.forEach(row => {
        const cells = Array.from(row.querySelectorAll('td')).slice(1); // skip label cell
        if (cells.length < 2) return;

        const rawVals = cells.map(c => c.textContent.trim());
        if (rawVals.every(v => v === rawVals[0])) return; // all same → no highlight

        // Try numeric parse (extract first number from string like "32 GB", "4.9 GHz", etc.)
        const nums = rawVals.map(v => { const m = v.match(/[\d,]+\.?\d*/); return m ? parseFloat(m[0].replace(',', '')) : null; });
        const allNumeric = nums.every(n => n !== null);

        if (allNumeric) {
            const max = Math.max(...nums);
            const min = Math.min(...nums);
            cells.forEach((cell, i) => {
                cell.style.removeProperty('color');
                cell.style.removeProperty('background');
                const prev = cell.querySelector('i.bi-arrow-left-right');
                if (prev) prev.remove();

                if (nums[i] === max && max !== min) {
                    cell.style.color = '#4ade80';
                    cell.style.background = 'rgba(34,197,94,0.08)';
                    cell.insertAdjacentHTML('afterbegin', '<i class="bi bi-trophy-fill me-1" style="font-size:.7rem;color:#4ade80"></i>');
                } else if (nums[i] === min && max !== min) {
                    cell.style.color = '#f87171';
                    cell.style.background = 'rgba(239,68,68,0.06)';
                }
            });
        } else {
            // Text diff → keep yellow (already done in Razor), just ensure icon present
            cells.forEach(cell => {
                const prev = cell.querySelector('i.bi-arrow-left-right');
                if (!prev) cell.insertAdjacentHTML('afterbegin', '<i class="bi bi-arrow-left-right me-1" style="font-size:.7rem;color:#f59e0b;opacity:.7"></i>');
            });
        }
    });
})();
</script>
}
