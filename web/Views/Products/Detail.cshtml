@model TechSpecs.ViewModels.ProductDetailViewModel
@{
    var catLabel = Model.Category switch {
        "cpu"         => "Processor",
        "motherboard" => "Motherboard",
        "memory"      => "Memory (RAM)",
        "gpu"         => "Graphics Card",
        "storage"     => "Storage",
        "psu"         => "Power Supply",
        "case"        => "Case",
        "cooler"      => "CPU Cooler",
        _             => Model.Category
    };
    ViewData["Title"] = Model.Name;
}

<div class="container-xl py-4 px-3">

    <!-- Price History Chart (hidden until data loads) -->
    <div id="priceHistorySection" class="glass p-4 mb-4" style="display:none">
        <h5 class="text-white fw-semibold mb-3">
            <i class="bi bi-graph-up me-2" style="color:#a855f7"></i>Lịch sử giá
        </h5>
        <div class="no-data text-muted-white small" style="display:none">Chưa có dữ liệu lịch sử giá.</div>
        <canvas id="priceChart" height="120"></canvas>
    </div>

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb" style="--bs-breadcrumb-divider-color:rgba(255,255,255,0.4)">
            <li class="breadcrumb-item">
                <a href="/Products" class="text-decoration-none" style="color:rgba(255,255,255,0.6)">Components</a>
            </li>
            <li class="breadcrumb-item">
                <a href="/Products?category=@Model.Category" class="text-decoration-none" style="color:rgba(255,255,255,0.6)">@catLabel</a>
            </li>
            <li class="breadcrumb-item active text-white" aria-current="page"
                style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                @Model.Name
            </li>
        </ol>
    </nav>

    <div class="row g-4">

        <!-- Image panel -->
        <div class="col-lg-5">
            <div class="glass p-3 rounded-4 d-flex align-items-center justify-content-center"
                 style="min-height:380px">
                @if (Model.ImageUrl != null)
                {
                    <img src="@Model.ImageUrl" alt="@Model.Name"
                         class="img-fluid rounded-3"
                         style="max-height:360px;object-fit:contain" />
                }
                else
                {
                    <i class="bi bi-cpu text-muted-white" style="font-size:6rem;opacity:.35"></i>
                }
            </div>
        </div>

        <!-- Info panel -->
        <div class="col-lg-7">
            <div class="glass p-4 rounded-4 h-100 d-flex flex-column">

                <!-- Category + stock -->
                <div class="d-flex align-items-center gap-2 mb-3">
                    <span class="badge rounded-pill px-3 py-2"
                          style="background:rgba(168,85,247,.25);color:#c084fc;font-size:.8rem">
                        @catLabel
                    </span>
                    @if (Model.Stock > 0)
                    {
                        <span class="badge rounded-pill px-3 py-2"
                              style="background:rgba(34,197,94,.15);color:#4ade80;font-size:.8rem">
                            <i class="bi bi-check-circle me-1"></i>In Stock
                        </span>
                    }
                    else
                    {
                        <span class="badge rounded-pill px-3 py-2"
                              style="background:rgba(239,68,68,.15);color:#f87171;font-size:.8rem">
                            Out of Stock
                        </span>
                    }
                </div>

                <!-- Name + manufacturer -->
                <p class="mb-1" style="color:rgba(255,255,255,0.5);font-size:.85rem">@Model.Manufacturer</p>
                <h1 class="text-white fw-bold mb-4" style="font-size:1.4rem;line-height:1.35">@Model.Name</h1>

                <!-- Price -->
                <div class="mb-4">
                    <span class="fw-bold" style="font-size:2rem;background:linear-gradient(135deg,#a855f7,#6366f1);
                          -webkit-background-clip:text;-webkit-text-fill-color:transparent">
                        @Model.Price.ToString("N0")đ
                    </span>
                </div>

                <!-- Action buttons -->
                <div class="d-flex gap-3 mb-4 flex-wrap">
                    <button class="btn btn-gradient px-4 py-2 rounded-3 fw-semibold"
                            @(Model.Stock == 0 ? "disabled" : "")
                            data-pid="@Model.Id" data-pcat="@Model.Category"
                            data-pname="@Model.Name" data-pprice="@Model.Price"
                            data-pimg="@Model.ImageUrl"
                            onclick="addToCartFromData(this)">
                        <i class="bi bi-cart-plus me-2"></i>Add to Cart
                    </button>
                    <button class="btn glass text-white px-4 py-2 rounded-3 fw-semibold"
                            onclick="goBuilder('@Model.Category',@Model.Id)">
                        <i class="bi bi-tools me-2"></i>Add to Builder
                    </button>
                    <button class="btn glass text-white px-4 py-2 rounded-3 fw-semibold"
                            onclick="showInstallment(@Model.Price, '@Html.Raw(Model.Name.Replace("'","\\'"  ))')">
                        <i class="bi bi-calculator me-2"></i>Trả góp
                    </button>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <button class="btn glass px-3 py-2 rounded-3" id="wishBtn"
                                onclick="toggleWishlist(this)"
                                data-category="@Model.Category" data-id="@Model.Id"
                                data-name="@Html.Raw(Model.Name.Replace("\"","&quot;"))"
                                data-price="@Model.Price" data-img="@Model.ImageUrl"
                                style="color:#f472b6" title="Add to Wishlist">
                            <i class="bi bi-heart" id="wishIcon"></i>
                        </button>
                    }
                </div>

                <!-- Specs table -->
                <div class="mt-auto">
                    <h6 class="text-white mb-3 fw-semibold" style="font-size:.9rem;letter-spacing:.04em;text-transform:uppercase;opacity:.7">
                        Specifications
                    </h6>
                    <div class="rounded-3 overflow-hidden" style="border:1px solid rgba(255,255,255,0.08)">
                        @foreach (var (key, val) in Model.Specs)
                        {
                            <div class="d-flex" style="border-bottom:1px solid rgba(255,255,255,0.06)">
                                <div class="px-3 py-2 flex-shrink-0"
                                     style="width:170px;background:rgba(255,255,255,0.04);
                                            color:rgba(255,255,255,0.55);font-size:.82rem">
                                    @key
                                </div>
                                <div class="px-3 py-2 text-white flex-grow-1" style="font-size:.85rem;word-break:break-word">
                                    @val
                                </div>
                            </div>
                        }
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- Cross-sell: related products -->
    <div id="crossSellSection" class="mt-4" style="display:none">
        <h5 class="text-white fw-semibold mb-3">
            <i class="bi bi-bag-heart me-2" style="color:#a855f7"></i>Mua kèm phù hợp
        </h5>
        <div id="crossSellGrid" class="row g-3"></div>
    </div>

    @if (!string.IsNullOrEmpty(Model.VideoUrl))
    {
        <div class="mt-4">
            <h5 class="text-white fw-semibold mb-3">
                <i class="bi bi-play-circle me-2" style="color:#a855f7"></i>Video đánh giá
            </h5>
            <div class="glass p-3" style="border-radius:16px">
                <div style="position:relative;padding-bottom:56.25%;height:0;overflow:hidden;border-radius:10px">
                    <iframe src="@Model.VideoUrl"
                            style="position:absolute;top:0;left:0;width:100%;height:100%;border:0"
                            allowfullscreen loading="lazy"
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
                    </iframe>
                </div>
            </div>
        </div>
    }

    <!-- Reviews & Q&A -->
    <div class="row g-4 mt-2">

        <!-- Reviews column -->
        <div class="col-lg-6">
            <div class="glass p-4 h-100">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <h5 class="text-white fw-semibold mb-0">
                        <i class="bi bi-star-half me-2" style="color:#f59e0b"></i>Đánh giá
                    </h5>
                    <div id="ratingBadge" class="ms-auto" style="display:none">
                        <span id="avgStars" class="fw-bold" style="color:#f59e0b;font-size:1.1rem"></span>
                        <span id="reviewCount" class="text-muted-white" style="font-size:.82rem"></span>
                    </div>
                </div>

                <!-- Star rating form (auth only) -->
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div id="reviewForm" class="mb-4 p-3 rounded-3" style="background:rgba(255,255,255,.04);display:none">
                        <p class="text-white mb-2" style="font-size:.85rem;font-weight:600">Đánh giá của bạn:</p>
                        <div class="d-flex gap-1 mb-2" id="starPicker">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="bi bi-star star-pick" data-val="@i"
                                   style="font-size:1.5rem;cursor:pointer;color:rgba(255,255,255,.25);transition:color .15s"
                                   onmouseover="hoverStars(@i)" onmouseout="resetStars()"
                                   onclick="pickStar(@i)"></i>
                            }
                        </div>
                        <textarea id="reviewComment" rows="2" class="form-control glass border-0 text-white mb-2"
                                  placeholder="Nhận xét (tuỳ chọn)..." style="font-size:.83rem;resize:none;background:rgba(255,255,255,.06)"></textarea>
                        <!-- Photo upload -->
                        <div class="mb-2">
                            <label class="text-muted-white d-block mb-1" style="font-size:.76rem;cursor:pointer">
                                <i class="bi bi-image me-1"></i>Thêm ảnh (tùy chọn, tối đa 5MB)
                                <input type="file" id="reviewPhotoInput" accept="image/*" class="d-none" onchange="previewPhoto(this)">
                            </label>
                            <div id="photoPreviewBox" class="d-none">
                                <img id="photoPreview" style="max-height:80px;border-radius:6px;object-fit:cover" />
                                <button type="button" class="btn btn-sm glass text-white ms-2 px-2 py-1" onclick="clearPhoto()" style="font-size:.72rem">
                                    <i class="bi bi-x"></i>
                                </button>
                            </div>
                        </div>
                        <button onclick="submitReview()" class="btn btn-gradient btn-sm px-4">Gửi đánh giá</button>
                        <p id="reviewMsg" class="mt-2 mb-0" style="font-size:.78rem;display:none"></p>
                    </div>
                }

                <!-- Reviews list -->
                <div id="reviewsList">
                    <p class="text-muted-white" style="font-size:.83rem">Đang tải đánh giá…</p>
                </div>
            </div>
        </div>

        <!-- Q&A column -->
        <div class="col-lg-6">
            <div class="glass p-4 h-100">
                <h5 class="text-white fw-semibold mb-3">
                    <i class="bi bi-chat-dots me-2" style="color:#6366f1"></i>Hỏi & Đáp
                </h5>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="mb-3 d-flex gap-2">
                        <input type="text" id="qInput" maxlength="500"
                               class="form-control glass border-0 text-white"
                               placeholder="Đặt câu hỏi về sản phẩm này…"
                               style="font-size:.83rem;background:rgba(255,255,255,.06)">
                        <button onclick="postQuestion()" class="btn glass text-white px-3 flex-shrink-0">
                            <i class="bi bi-send"></i>
                        </button>
                    </div>
                }

                <div id="qaList">
                    <p class="text-muted-white" style="font-size:.83rem">Đang tải hỏi đáp…</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
function goBuilder(category, id) {
    window.location.href = '/Builder?preselect=' + category + ':' + id;
}

// Wishlist heart button
const csrfToken = document.querySelector('#csrfForm input[name="__RequestVerificationToken"]')?.value || '';
const wishBtn  = document.getElementById('wishBtn');
if (wishBtn) {
    // Check initial state
    const cat = wishBtn.dataset.category, id = wishBtn.dataset.id;
    fetch(`/Wishlist/Check?category=${cat}&id=${id}`)
        .then(r => r.ok ? r.json() : null)
        .then(d => { if (d?.inWishlist) setWishState(true); })
        .catch(() => {});
}

function setWishState(inWishlist) {
    const icon = document.getElementById('wishIcon');
    if (!icon) return;
    icon.className = inWishlist ? 'bi bi-heart-fill' : 'bi bi-heart';
}

async function toggleWishlist(btn) {
    const body = {
        category: btn.dataset.category,
        componentId: parseInt(btn.dataset.id),
        name: btn.dataset.name,
        price: parseFloat(btn.dataset.price),
        imageUrl: btn.dataset.img || null,
    };
    btn.disabled = true;
    try {
        const r = await fetch('/Wishlist/Toggle', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': csrfToken },
            body: JSON.stringify(body),
        });
        if (r.ok) {
            const d = await r.json();
            setWishState(d.inWishlist);
        }
    } finally { btn.disabled = false; }
}

// Price history chart
(async () => {
    const category = '@Model.Category';
    const name     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Name));
    const section  = document.getElementById('priceHistorySection');
    const canvas   = document.getElementById('priceChart');
    if (!canvas) return;

    try {
        const r = await fetch(`/Products/PriceHistory?category=${encodeURIComponent(category)}&name=${encodeURIComponent(name)}`);
        const data = await r.json();
        if (!data || data.length < 1) {
            section.querySelector('.no-data').style.display = '';
            canvas.style.display = 'none';
            return;
        }
        section.style.display = '';
        new Chart(canvas, {
            type: 'line',
            data: {
                labels: data.map(d => d.date),
                datasets: [{
                    label: 'Price (đ)',
                    data: data.map(d => d.price),
                    borderColor: '#a855f7',
                    backgroundColor: 'rgba(168,85,247,.12)',
                    borderWidth: 2,
                    pointRadius: 4,
                    pointBackgroundColor: '#a855f7',
                    fill: true,
                    tension: 0.3,
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: ctx => ctx.parsed.y.toLocaleString('vi-VN') + 'đ'
                        }
                    }
                },
                scales: {
                    x: { ticks: { color: 'rgba(255,255,255,.55)', maxTicksLimit: 8 }, grid: { color: 'rgba(255,255,255,.06)' } },
                    y: {
                        ticks: { color: 'rgba(255,255,255,.55)', callback: v => (v/1000000).toFixed(1) + 'M' },
                        grid: { color: 'rgba(255,255,255,.06)' }
                    }
                }
            }
        });
    } catch {}
})();

// Cross-sell
(async () => {
    const category = '@Model.Category';
    const id       = @Model.Id;
    try {
        const r = await fetch(`/Products/CrossSell?category=${category}&id=${id}`);
        const items = await r.json();
        if (!items.length) return;

        const catLabels = { cpu:'CPU', motherboard:'Mainboard', memory:'RAM', gpu:'VGA',
                            storage:'Storage', psu:'Nguồn', case:'Case', cooler:'Tản nhiệt' };
        const grid = document.getElementById('crossSellGrid');
        grid.innerHTML = items.map(item => `
            <div class="col-sm-6 col-lg-3">
                <a href="/Products/Detail/${item.category}/${item.id}"
                   class="component-card p-0 h-100 overflow-hidden d-flex flex-column text-decoration-none">
                    <div style="height:120px;background:rgba(255,255,255,0.04);display:flex;align-items:center;justify-content:center">
                        ${item.imageUrl
                            ? `<img src="${item.imageUrl}" alt="" style="max-height:110px;max-width:100%;object-fit:contain">`
                            : `<i class="bi bi-cpu" style="font-size:2.5rem;color:rgba(255,255,255,.2)"></i>`}
                    </div>
                    <div class="p-3 d-flex flex-column flex-grow-1">
                        <span class="badge mb-2" style="background:rgba(168,85,247,.2);color:#c084fc;font-size:.68rem;width:fit-content">
                            ${catLabels[item.category] || item.category.toUpperCase()}
                        </span>
                        <p class="text-white mb-1 flex-grow-1 lh-sm" style="font-size:.8rem;opacity:.9">${item.name}</p>
                        <p class="fw-bold mb-0" style="font-size:.9rem;color:#a855f7">
                            ${item.price > 0 ? item.price.toLocaleString('vi-VN') + 'đ' : 'Liên hệ'}
                        </p>
                        ${item.hint ? `<p class="mb-0 mt-1" style="font-size:.68rem;color:rgba(255,255,255,.4)">${item.hint}</p>` : ''}
                    </div>
                </a>
            </div>
        `).join('');
        document.getElementById('crossSellSection').style.display = '';
    } catch {}
})();

// ── Reviews & Q&A ─────────────────────────────────────────────────────────────
const _cat = '@Model.Category', _id = @Model.Id;
const _csrf = document.querySelector('#csrfForm input[name="__RequestVerificationToken"]')?.value || '';
let _pickedStar = 0;

function starsHtml(rating, size) {
    let h = '';
    for (let i = 1; i <= 5; i++) {
        h += `<i class="bi ${i <= rating ? 'bi-star-fill' : 'bi-star'}"
                 style="font-size:${size};color:${i <= rating ? '#f59e0b' : 'rgba(255,255,255,.2)'}"></i>`;
    }
    return h;
}

// Reviews
(async () => {
    const el = document.getElementById('reviewsList');
    try {
        const r = await fetch(`/Reviews/ForProduct?category=${_cat}&id=${_id}`);
        const d = await r.json();
        // Badge
        if (d.count > 0) {
            document.getElementById('ratingBadge').style.display = '';
            document.getElementById('avgStars').innerHTML = starsHtml(Math.round(d.avg), '.9rem') + ` ${d.avg}`;
            document.getElementById('reviewCount').textContent = ` (${d.count} đánh giá)`;
        }
        // Form
        const form = document.getElementById('reviewForm');
        if (form) form.style.display = d.hasReviewed ? 'none' : '';
        // List
        el.innerHTML = d.reviews.length
            ? d.reviews.map(rv => `
                <div class="mb-3 pb-3" style="border-bottom:1px solid rgba(255,255,255,.06)">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <span style="font-size:.82rem;color:#fff;font-weight:600">${rv.userDisplayName}</span>
                        <span class="ms-auto">${starsHtml(rv.rating, '.8rem')}</span>
                    </div>
                    ${rv.comment ? `<p class="mb-1 text-muted-white" style="font-size:.82rem">${rv.comment}</p>` : ''}
                    ${rv.imageUrl ? `<img src="${rv.imageUrl}" alt="Review photo" style="max-height:120px;max-width:200px;border-radius:8px;object-fit:cover;margin-bottom:4px;cursor:pointer" onclick="window.open('${rv.imageUrl}','_blank')">` : ''}
                    <small class="text-muted-white" style="font-size:.72rem;opacity:.5">${rv.createdAt}</small>
                </div>`).join('')
            : '<p class="text-muted-white" style="font-size:.83rem">Chưa có đánh giá nào. Hãy là người đầu tiên!</p>';
    } catch { el.innerHTML = ''; }
})();

function hoverStars(n) {
    document.querySelectorAll('.star-pick').forEach((s, i) => {
        s.className = `bi ${i < n ? 'bi-star-fill' : 'bi-star'} star-pick`;
        s.style.color = i < n ? '#f59e0b' : 'rgba(255,255,255,.25)';
    });
}
function resetStars() { hoverStars(_pickedStar); }
function pickStar(n) { _pickedStar = n; resetStars(); }

function previewPhoto(input) {
    const file = input.files[0];
    if (!file) return;
    const box = document.getElementById('photoPreviewBox');
    const img = document.getElementById('photoPreview');
    img.src = URL.createObjectURL(file);
    box.classList.remove('d-none');
}
function clearPhoto() {
    document.getElementById('reviewPhotoInput').value = '';
    document.getElementById('photoPreviewBox').classList.add('d-none');
    document.getElementById('photoPreview').src = '';
}

async function submitReview() {
    if (!_pickedStar) { alert('Vui lòng chọn số sao'); return; }
    const comment = document.getElementById('reviewComment').value;
    const msg = document.getElementById('reviewMsg');

    // Upload photo first if selected
    let imageUrl = null;
    const photoInput = document.getElementById('reviewPhotoInput');
    if (photoInput?.files?.length) {
        msg.style.display = ''; msg.style.color = '#c084fc'; msg.textContent = 'Đang tải ảnh…';
        const fd = new FormData();
        fd.append('photo', photoInput.files[0]);
        fd.append('__RequestVerificationToken', _csrf);
        try {
            const up = await fetch('/Reviews/UploadPhoto', { method: 'POST', body: fd });
            if (up.ok) { const d = await up.json(); imageUrl = d.url; }
        } catch {}
    }

    try {
        const r = await fetch('/Reviews/Submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': _csrf },
            body: JSON.stringify({ category: _cat, componentId: _id, rating: _pickedStar, comment, imageUrl })
        });
        if (r.ok) {
            msg.style.display = ''; msg.style.color = '#4ade80'; msg.textContent = 'Đánh giá đã được ghi nhận!';
            document.getElementById('reviewForm').style.display = 'none';
            setTimeout(() => location.reload(), 1200);
        }
    } catch {}
}

// Q&A
(async () => {
    const el = document.getElementById('qaList');
    try {
        const r = await fetch(`/Reviews/Questions?category=${_cat}&id=${_id}`);
        const qs = await r.json();
        el.innerHTML = qs.length
            ? qs.map(q => `
                <div class="mb-3">
                    <div class="d-flex gap-2 mb-1">
                        <i class="bi bi-question-circle" style="color:#6366f1;font-size:.85rem;margin-top:2px"></i>
                        <div>
                            <p class="text-white mb-1 lh-sm" style="font-size:.83rem;font-weight:600">${q.question}</p>
                            <small class="text-muted-white" style="font-size:.72rem;opacity:.5">${q.userDisplayName} · ${q.createdAt}</small>
                        </div>
                    </div>
                    ${q.answers.map(a => `
                        <div class="d-flex gap-2 mt-2 ms-3">
                            <i class="bi bi-arrow-return-right" style="color:#a855f7;font-size:.8rem;margin-top:3px"></i>
                            <div>
                                <p class="text-white mb-0 lh-sm" style="font-size:.82rem">${a.answer}</p>
                                <small class="text-muted-white" style="font-size:.7rem;opacity:.5">${a.userDisplayName} · ${a.createdAt}</small>
                            </div>
                        </div>`).join('')}
                    <div class="ms-3 mt-2" id="answerArea_${q.id}" style="display:none">
                        <div class="d-flex gap-2">
                            <input type="text" class="form-control form-control-sm glass border-0 text-white"
                                   id="ansInput_${q.id}" placeholder="Viết câu trả lời…"
                                   style="font-size:.8rem;background:rgba(255,255,255,.06)">
                            <button onclick="postAnswer(${q.id})" class="btn glass text-white btn-sm px-2 flex-shrink-0">
                                <i class="bi bi-send"></i>
                            </button>
                        </div>
                    </div>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <text>
                    <button onclick="document.getElementById('answerArea_'+${q.id}).style.display=''"
                            class="btn btn-sm glass text-white px-2 py-0 mt-1 ms-3" style="font-size:.72rem">
                        Trả lời
                    </button>
                        </text>
                    }
                </div>`).join('')
            : '<p class="text-muted-white" style="font-size:.83rem">Chưa có câu hỏi nào.</p>';
    } catch { el.innerHTML = ''; }
})();

async function postQuestion() {
    const q = document.getElementById('qInput').value.trim();
    if (!q) return;
    try {
        const r = await fetch('/Reviews/PostQuestion', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': _csrf },
            body: JSON.stringify({ category: _cat, componentId: _id, question: q })
        });
        if (r.ok) { document.getElementById('qInput').value = ''; location.reload(); }
    } catch {}
}

async function postAnswer(questionId) {
    const inp = document.getElementById(`ansInput_${questionId}`);
    const a = inp?.value.trim();
    if (!a) return;
    try {
        const r = await fetch('/Reviews/PostAnswer', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': _csrf },
            body: JSON.stringify({ questionId, answer: a })
        });
        if (r.ok) location.reload();
    } catch {}
}
</script>
}
