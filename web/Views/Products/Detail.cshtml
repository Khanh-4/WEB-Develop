// P26: Sticky Add-to-Cart bar
(function() {
    const nameEl  = document.getElementById('productNameEl');
    const priceEl = document.querySelector('[style*="2rem"]');
    if (!nameEl || !priceEl) return;

    const productName  = @Json.Serialize(Model.Name);
    const productPrice = @Model.Price;
    const productCat   = '@Model.Category';
    const productId    = @Model.Id;
    const productImg   = @Json.Serialize(Model.ImageUrl ?? "");
    const outOfStock   = @(Model.Stock == 0 ? "true" : "false");

    // Build the bar
    const bar = document.createElement('div');
    bar.id = 'stickyCartBar';
    bar.innerHTML = `
        <div class="container-xl d-flex align-items-center gap-3 px-3">
            <div style="flex:1;min-width:0">
                <div class="fw-semibold" style="font-size:.85rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--text)">
                    ${productName}
                </div>
                <div style="font-size:.9rem;font-weight:700;background:linear-gradient(135deg,#a855f7,#6366f1);
                            -webkit-background-clip:text;-webkit-text-fill-color:transparent">
                    ${new Intl.NumberFormat('vi-VN').format(productPrice)}đ
                </div>
            </div>
            <button class="btn btn-gradient px-4 py-2 rounded-3 fw-semibold flex-shrink-0"
                    ${outOfStock ? 'disabled' : ''}
                    data-pid="${productId}" data-pcat="${productCat}"
                    data-pname="${productName.replace(/"/g,'&quot;')}"
                    data-pprice="${productPrice}" data-pimg="${productImg}"
                    onclick="addToCartFromData(this)">
                <i class="bi bi-cart-plus me-2"></i>Thêm vào giỏ
            </button>
        </div>`;
    bar.style.cssText = `
        position:fixed; top:0; left:0; right:0; z-index:1040;
        background:rgba(15,23,42,.95); backdrop-filter:blur(16px);
        border-bottom:1px solid rgba(168,85,247,.25);
        padding:10px 0;
        transform:translateY(-110%);
        transition:transform .3s cubic-bezier(.34,1.56,.64,1);
    `;
    document.body.appendChild(bar);

    const obs = new IntersectionObserver(([entry]) => {
        bar.style.transform = entry.isIntersecting ? 'translateY(-110%)' : 'translateY(0)';
    }, { threshold: 0 });
    obs.observe(nameEl);
})();

// Save to Recently Viewed (localStorage)
(function() {
    try {
        var item = {
            id: @Model.Id,
            category: '@Model.Category',
            name: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Name)),
            price: @Model.Price,
            imageUrl: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ImageUrl ?? "")),
            viewedAt: Date.now()
        };
        var list = [];
        try { list = JSON.parse(localStorage.getItem('recentlyViewed') || '[]'); } catch(e) {}
        list = list.filter(x => !(x.id === item.id && x.category === item.category));
        list.unshift(item);
        if (list.length > 10) list = list.slice(0, 10);
        localStorage.setItem('recentlyViewed', JSON.stringify(list));
    } catch(e) {}
})();
</script>
}
