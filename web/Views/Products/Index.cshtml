@model TechSpecs.ViewModels.ProductsIndexViewModel
@{ ViewData["Title"] = L["Products.Title"].Value; }

<div class="container-xl py-4 px-3">
    <h1 class="text-white fw-bold mb-4">@L["Products.Title"]</h1>

    <!-- Filter Bar -->
    <div class="glass p-4 mb-4">
        <div class="row g-3 mb-3">
            <div class="col-lg-7">
                <div class="position-relative">
                    <i class="bi bi-search position-absolute text-muted-white" style="left:14px;top:50%;transform:translateY(-50%)"></i>
                    <input type="text" id="searchInput" class="form-control ps-5"
                           placeholder="@L["Products.Search"]"
                           value="@Model.SearchQuery"
                           oninput="debounceSearch()">
                </div>
            </div>
            <div class="col-lg-3">
                <select class="form-select" id="sortSelect" onchange="applyFilters()">
                    <option value="pp">@L["Products.BestValue"]</option>
                    <option value="price-asc">@L["Products.PriceLow"]</option>
                    <option value="price-desc">@L["Products.PriceHigh"]</option>
                    <option value="name">@L["Products.NameAZ"]</option>
                </select>
            </div>
            <div class="col-lg-2">
                <span class="text-muted-white small d-flex align-items-center h-100">
                    <span id="countLabel">@Model.TotalCount @L["Products.Results"]</span>
                </span>
            </div>
        </div>

        <!-- Category pills -->
        <div class="d-flex flex-wrap gap-2 mb-3" id="catPills">
            @{
                var cats = new (string, string)[] {
                    ("all",         L["Cat.All"].Value),
                    ("cpu",         L["Cat.CPU"].Value),
                    ("motherboard", L["Cat.Motherboard"].Value),
                    ("memory",      L["Cat.Memory"].Value),
                    ("gpu",         L["Cat.GPU"].Value),
                    ("storage",     L["Cat.Storage"].Value),
                    ("psu",         L["Cat.PSU"].Value),
                    ("case",        L["Cat.Case"].Value),
                    ("cooler",      L["Cat.Cooler"].Value),
                    ("prebuilt",    L["Cat.Prebuilt"].Value),
                };
            }
            @foreach (var cat in cats)
            {
                <button class="category-pill @(Model.SelectedCategory == cat.Item1 ? "active" : "")"
                        data-cat="@cat.Item1"
                        onclick="setCategory('@cat.Item1')">
                    @cat.Item2
                </button>
            }
        </div>

        <!-- Advanced Filters toggle -->
        <div class="border-top pt-3" style="border-color:rgba(255,255,255,.1)!important">
            <button class="btn btn-sm glass text-white px-3" type="button"
                    data-bs-toggle="collapse" data-bs-target="#advFilters"
                    onclick="this.querySelector('i:last-child').classList.toggle('bi-chevron-up'); this.querySelector('i:last-child').classList.toggle('bi-chevron-down')">
                <i class="bi bi-sliders me-1"></i>@L["Products.AdvancedFilters"]
                <i class="bi bi-chevron-down ms-1"></i>
            </button>

            <div class="collapse" id="advFilters">
                <div class="row g-3 mt-2">
                    <!-- Price Range -->
                    <div class="col-sm-6 col-lg-3">
                        <label class="text-muted-white small mb-1 d-block">@L["Products.PriceRange"]</label>
                        <div class="d-flex gap-2">
                            <input type="number" id="minPrice" class="form-control" placeholder="Min (đ)" min="0" oninput="debounceSearch()">
                            <input type="number" id="maxPrice" class="form-control" placeholder="Max (đ)" min="0" oninput="debounceSearch()">
                        </div>
                    </div>
                    <!-- Brand Filter -->
                    <div class="col-sm-6 col-lg-3" id="brandFilterCol">
                        <label class="text-muted-white small mb-1 d-block">@L["Products.Brand"]</label>
                        <div class="dropdown">
                            <button class="btn glass text-white w-100 d-flex justify-content-between align-items-center"
                                    type="button" id="brandDropdownBtn" data-bs-toggle="dropdown" data-bs-auto-close="outside">
                                <span id="brandLabel">@L["Products.AllBrands"]</span>
                                <i class="bi bi-chevron-down"></i>
                            </button>
                            <div class="dropdown-menu glass p-3" style="min-width:200px;max-height:220px;overflow-y:auto">
                                <div id="brandCheckboxes">
                                    <span class="text-muted-white small">@L["Products.Loading"]</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Category-specific filters (dynamic) -->
                    <div id="catSpecificFilters" class="col-12 p-0">
                        <!-- populated by JS -->
                    </div>
                    <!-- Reset -->
                    <div class="col-sm-12 col-lg-2 d-flex align-items-end">
                        <button class="btn glass text-white px-4" onclick="resetAdvFilters()">
                            <i class="bi bi-arrow-counterclockwise me-1"></i>@L["Products.Reset"]
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- P24: Active filters display -->
    <div id="activeFilters" class="d-flex flex-wrap gap-2 mb-3" style="display:none!important"></div>

    <!-- Product Grid -->
    <div id="productGrid" class="row g-4">
        @await Html.PartialAsync("_ProductGrid", Model.Products)
    </div>

    <!-- Pagination -->
    <div id="pagination" class="d-flex justify-content-center flex-wrap gap-2 mt-5">
        @if (Model.TotalPages > 1)
        {
            var currentP = Model.Page;
            var totalP = Model.TotalPages;

            <button class="btn glass text-white rounded-3 px-3" @(currentP == 1 ? "disabled" : "") onclick="goPage(@(currentP - 1))">&laquo;</button>

            var startP = Math.Max(1, currentP - 2);
            var endP = Math.Min(totalP, currentP + 2);

            if (startP > 1)
            {
                <button class="btn glass text-white rounded-3 px-3" onclick="goPage(1)">1</button>
                if (startP > 2) { <span class="text-muted-white align-self-end px-1 pb-1">...</span> }
            }

            for (int p = startP; p <= endP; p++)
            {
                <button class="btn @(p == currentP ? "btn-gradient" : "glass text-white") rounded-3 px-3"
                        onclick="goPage(@p)">@p</button>
            }

            if (endP < totalP)
            {
                if (endP < totalP - 1) { <span class="text-muted-white align-self-end px-1 pb-1">...</span> }
                <button class="btn glass text-white rounded-3 px-3" onclick="goPage(@totalP)">@totalP</button>
            }

            <button class="btn glass text-white rounded-3 px-3" @(currentP == totalP ? "disabled" : "") onclick="goPage(@(currentP + 1))">&raquo;</button>
        }
    </div>
</div>

<!-- P30: Quick View Modal -->
<div class="modal fade" id="quickViewModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content glass border-0" style="background:rgba(15,23,42,.97)">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title text-muted-white fw-normal" id="qvModalLabel" style="font-size:.85rem">Xem nhanh</h6>
                <div class="ms-auto d-flex gap-2">
                    <button class="btn btn-sm glass text-white px-2 py-1" onclick="qvNav(-1)" title="Trước (←)">
                        <i class="bi bi-arrow-left"></i>
                    </button>
                    <button class="btn btn-sm glass text-white px-2 py-1" onclick="qvNav(1)" title="Sau (→)">
                        <i class="bi bi-arrow-right"></i>
                    </button>
                    <button type="button" class="btn-close btn-close-white ms-2" data-bs-dismiss="modal"></button>
                </div>
            </div>
            <div class="modal-body" id="qvModalBody">
                <div class="text-center py-5">
                    <div class="spinner-border text-light" role="status"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// Localization strings (injected from server)
const i18n = {
    allBrands:      '@L["Products.AllBrands"]',
    selected:       '@L["Products.Selected"]',
    loading:        '@L["Products.Loading"]',
    noResults:      '@L["Products.NoResults"]',
    noResultsHint:  '@L["Products.NoResultsHint"]',
    loadError:      '@L["Products.LoadError"]',
    results:        '@L["Products.Results"]',
    filterAll:      '@L["Filter.All"]',
    catLabels: {
        cpu:         '@L["Cat.CPU"]',
        motherboard: '@L["Cat.Motherboard"]',
        memory:      '@L["Cat.Memory"]',
        gpu:         '@L["Cat.GPU"]',
        storage:     '@L["Cat.Storage"]',
        psu:         '@L["Cat.PSU"]',
        case:        '@L["Cat.Case"]',
        cooler:      '@L["Cat.Cooler"]',
        prebuilt:    '@L["Cat.Prebuilt"]',
    },
    filters: {
        socket:      '@L["Filter.Socket"]',
        formFactor:  '@L["Filter.FormFactor"]',
        ramType:     '@L["Filter.RamType"]',
        memType:     '@L["Filter.MemType"]',
        capacity:    '@L["Filter.Capacity"]',
        vram:        '@L["Filter.VRAM"]',
        generation:  '@L["Filter.Generation"]',
        storageType: '@L["Filter.StorageType"]',
        iface:       '@L["Filter.Interface"]',
        wattage:     '@L["Filter.Wattage"]',
        efficiency:  '@L["Filter.Efficiency"]',
        modular:     '@L["Filter.Modular"]',
        coolerType:     '@L["Filter.CoolerType"]',
        minW:           '@L["Filter.MinW"]',
        chipset:        '@L["Filter.Chipset"]',
        profile:        '@L["Filter.Profile"]',
        psuFormFactor:  '@L["Filter.PsuFormFactor"]',
        caseType:       '@L["Filter.CaseType"]',
    }
};

let currentCat    = '@Model.SelectedCategory';
let currentPage   = 1;
let currentBrands = [];
let searchTimer   = null;

function debounceSearch() {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(applyFilters, 350);
}

function setCategory(cat) {
    currentCat    = cat;
    currentPage   = 1;
    currentBrands = [];
    document.querySelectorAll('.category-pill').forEach(b =>
        b.classList.toggle('active', b.dataset.cat === cat));
    loadBrands(cat);
    loadFilterOptions(cat);
    applyFilters();
}

/* ── Brand filter ── */
function loadBrands(cat) {
    const col = document.getElementById('brandFilterCol');
    if (cat === 'all') { col.style.display = 'none'; return; }
    col.style.display = '';
    document.getElementById('brandCheckboxes').innerHTML =
        `<span class="text-muted-white small"><span class="spinner-border spinner-border-sm me-1"></span>${i18n.loading}</span>`;

    fetch('/Products/Brands?category=' + cat)
        .then(r => r.json())
        .then(brands => {
            if (!brands.length) {
                document.getElementById('brandCheckboxes').innerHTML =
                    '<span class="text-muted-white small">—</span>';
                return;
            }
            document.getElementById('brandCheckboxes').innerHTML = brands.map(b => `
                <div class="form-check mb-1">
                    <input class="form-check-input" type="checkbox" id="br-${CSS.escape(b)}" value="${esc(b)}"
                           ${currentBrands.includes(b) ? 'checked' : ''} onchange="updateBrands()">
                    <label class="form-check-label text-white small" for="br-${CSS.escape(b)}">${esc(b)}</label>
                </div>`).join('');
        });
}

function updateBrands() {
    currentBrands = Array.from(document.querySelectorAll('#brandCheckboxes input:checked')).map(i => i.value);
    document.getElementById('brandLabel').textContent =
        currentBrands.length ? `${currentBrands.length} ${i18n.selected}` : i18n.allBrands;
    currentPage = 1;
    applyFilters();
}

/* ── Category-specific filters ── */
function loadFilterOptions(cat) {
    const container = document.getElementById('catSpecificFilters');
    container.innerHTML = '';

    const noCatFilters = ['all', 'cpu', 'prebuilt'];
    if (noCatFilters.includes(cat)) return;

    fetch('/Products/FilterOptions?category=' + cat)
        .then(r => r.json())
        .then(opts => renderCatFilters(cat, opts))
        .catch(() => {});
}

function renderCatFilters(cat, opts) {
    const container = document.getElementById('catSpecificFilters');
    let html = '<div class="row g-3 mt-0">';

    function makeSelect(id, label, paramKey, items, fmtLabel) {
        const options = items.map(v =>
            `<option value="${esc(String(v))}">${fmtLabel ? fmtLabel(v) : esc(String(v))}</option>`
        ).join('');
        return `
            <div class="col-sm-6 col-lg-3">
                <label class="text-muted-white small mb-1 d-block">${label}</label>
                <select class="form-select" id="${id}" data-param="${paramKey}" onchange="applyFilters()">
                    <option value="">${i18n.filterAll}</option>
                    ${options}
                </select>
            </div>`;
    }

    if (cat === 'motherboard') {
        html += makeSelect('filterSocket',    i18n.filters.socket,    'socket',    opts.sockets    || []);
        html += makeSelect('filterFormFactor',i18n.filters.formFactor,'formFactor',opts.formFactors|| []);
        html += makeSelect('filterMemType',   i18n.filters.ramType,   'memType',   opts.memTypes   || []);
        html += makeSelect('filterChipset',   i18n.filters.chipset,   'chipset',   opts.chipsets   || []);
    }
    else if (cat === 'memory') {
        html += makeSelect('filterMemType',  i18n.filters.memType, 'memType',  opts.types      || []);
        html += makeSelect('filterCapacity', i18n.filters.capacity,'capacity', opts.capacities || [],
            v => `${v} GB`);
        html += makeSelect('filterProfile',  i18n.filters.profile, 'profile',  opts.profiles   || []);
    }
    else if (cat === 'gpu') {
        html += makeSelect('filterGpuGen', i18n.filters.generation, 'gpuGen', opts.generations || []);
        html += makeSelect('filterVram',   i18n.filters.vram,       'vram',   opts.vrams       || [],
            v => `${v} GB`);
    }
    else if (cat === 'storage') {
        html += makeSelect('filterStorageType',      i18n.filters.storageType, 'storageType',      opts.types      || []);
        html += makeSelect('filterStorageInterface', i18n.filters.iface,       'storageInterface', opts.interfaces || []);
        html += makeSelect('filterCapacity',         i18n.filters.capacity,    'capacity',         opts.capacities || [],
            v => v >= 1024 ? (v % 1024 === 0 ? `≥ ${v/1024} TB` : `≥ ${(v/1024).toFixed(1)} TB`) : `≥ ${v} GB`);
    }
    else if (cat === 'psu') {
        html += `
            <div class="col-sm-6 col-lg-3">
                <label class="text-muted-white small mb-1 d-block">${i18n.filters.wattage}</label>
                <div class="input-group">
                    <input type="number" id="filterMinWattage" data-param="minWattage"
                           class="form-control" placeholder="${i18n.filters.minW}" min="0" step="50"
                           oninput="debounceSearch()">
                    <span class="input-group-text glass text-white border-0">W</span>
                </div>
            </div>`;
        html += makeSelect('filterEfficiency',    i18n.filters.efficiency,    'efficiency',    opts.efficiencies || []);
        html += makeSelect('filterModular',       i18n.filters.modular,       'modular',       opts.modulars     || []);
        html += makeSelect('filterPsuFormFactor', i18n.filters.psuFormFactor, 'psuFormFactor', opts.formFactors  || []);
    }
    else if (cat === 'case') {
        html += makeSelect('filterCaseType',   i18n.filters.caseType,   'caseType',   opts.caseTypes  || []);
        html += makeSelect('filterFormFactor', i18n.filters.formFactor, 'formFactor', opts.formFactors || []);
    }
    else if (cat === 'cooler') {
        html += makeSelect('filterCoolerType', i18n.filters.coolerType, 'coolerType', opts.types || []);
    }

    html += '</div>';
    container.innerHTML = html;
}

/* ── Core filter logic ── */
function getCatFilterParams() {
    const params = {};
    // Collect select elements
    document.querySelectorAll('#catSpecificFilters [data-param]').forEach(el => {
        const key = el.getAttribute('data-param');
        const val = el.value;
        if (val) params[key] = val;
    });
    return params;
}

function resetAdvFilters() {
    document.getElementById('minPrice').value = '';
    document.getElementById('maxPrice').value = '';
    currentBrands = [];
    document.querySelectorAll('#brandCheckboxes input').forEach(i => i.checked = false);
    document.getElementById('brandLabel').textContent = i18n.allBrands;
    document.querySelectorAll('#catSpecificFilters [data-param]').forEach(el => {
        if (el.tagName === 'SELECT') el.value = '';
        else if (el.type === 'number') el.value = '';
    });
    currentPage = 1;
    applyFilters();
}

function goPage(p) { currentPage = p; applyFilters(); }

function applyFilters() {
    const search = document.getElementById('searchInput').value.trim();
    const sort   = document.getElementById('sortSelect').value;
    const grid   = document.getElementById('productGrid');

    // P21: skeleton loading
    grid.innerHTML = Array(8).fill(0).map(() => `
        <div class="col-sm-6 col-lg-4 col-xl-3">
            <div class="component-card p-0 h-100 overflow-hidden d-flex flex-column">
                <div class="sk-box" style="height:160px"></div>
                <div class="p-3 d-flex flex-column gap-2">
                    <div class="sk-line" style="width:40%;height:14px"></div>
                    <div class="sk-line" style="width:90%;height:13px"></div>
                    <div class="sk-line" style="width:75%;height:13px"></div>
                    <div class="d-flex gap-1 mt-1">
                        <div class="sk-line" style="width:30%;height:20px;border-radius:12px"></div>
                        <div class="sk-line" style="width:28%;height:20px;border-radius:12px"></div>
                    </div>
                    <div class="d-flex justify-content-between mt-2">
                        <div class="sk-line" style="width:38%;height:18px"></div>
                        <div class="sk-box" style="width:32px;height:28px;border-radius:8px"></div>
                    </div>
                </div>
            </div>
        </div>`).join('');
    renderActiveFilters();

    const minP = document.getElementById('minPrice')?.value;
    const maxP = document.getElementById('maxPrice')?.value;

    const params = new URLSearchParams({ category: currentCat, sort, page: currentPage });
    if (search)              params.set('search', search);
    if (minP)                params.set('minPrice', minP);
    if (maxP)                params.set('maxPrice', maxP);
    if (currentBrands.length) params.set('brands', currentBrands.join(','));

    // Category-specific filters
    Object.entries(getCatFilterParams()).forEach(([k, v]) => { if (v) params.set(k, v); });

    fetch('/Products/Filter?' + params)
        .then(r => { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
        .then(data => {
            renderProducts(data.products);
            renderPagination(data.totalPages, data.page);
            document.getElementById('countLabel').textContent = data.totalCount + ' ' + i18n.results;
            renderActiveFilters();
        })
        .catch(() => {
            grid.innerHTML = `<div class="col-12 text-center py-5 text-muted-white">
                <i class="bi bi-exclamation-circle fs-1 mb-3 d-block"></i>
                <p>${i18n.loadError}</p></div>`;
        });
}

function renderProducts(products) {
    const grid = document.getElementById('productGrid');
    if (!products || !products.length) {
        grid.innerHTML = `<div class="col-12 text-center py-5 text-muted-white">
            <i class="bi bi-search fs-1 mb-3 d-block"></i>
            <p class="mb-0">${i18n.noResults}</p>
            <small>${i18n.noResultsHint}</small></div>`;
        return;
    }

    grid.innerHTML = products.map(p => {
        const isPrebuilt = p.isPrebuilt;
        const catLabel = isPrebuilt
            ? i18n.catLabels.prebuilt
            : (i18n.catLabels[p.category] || p.category.toUpperCase());

        const badgeColor = isPrebuilt
            ? 'background:rgba(16,185,129,.2);color:#34d399'
            : 'background:rgba(168,85,247,.25);color:#c084fc';

        const specs = isPrebuilt
            ? ''
            : Object.entries(p.specs || {}).slice(0, 3)
                .map(([k,v]) => `<span class="badge glass-sm text-white" style="font-size:.72rem">${k}: ${v}</span>`)
                .join(' ');

        // P23: lazy loading image; P22: image area gets card-img-wrap for hover overlay
        const img = p.imageUrl
            ? `<img src="${p.imageUrl}" alt="${esc(p.name)}" class="w-100 h-100 object-fit-cover" loading="lazy">`
            : `<i class="bi bi-cpu text-muted-white" style="font-size:3rem"></i>`;

        // P22: hover overlay showing 3 key specs
        const hoverSpecs = !isPrebuilt
            ? Object.entries(p.specs || {}).slice(0,3)
                .map(([k,v]) => `<div class="d-flex justify-content-between gap-2">
                    <span style="color:rgba(255,255,255,.6);font-size:.73rem">${k}</span>
                    <span style="color:#fff;font-size:.73rem;font-weight:600">${v}</span>
                </div>`).join('')
            : '';

        const detailUrl = `/Products/Detail/${p.category}/${p.id}`;
        const builderBtn = !isPrebuilt
            ? `<button class="btn btn-sm glass text-white px-2 py-1"
                       onclick="goBuilder('${p.category}',${p.id})"
                       title="Thêm vào PC Builder">
                   <i class="bi bi-tools" style="font-size:.8rem"></i>
               </button>`
            : '';

        // P27: compare checkbox (hidden when category=all or prebuilt)
        const cmpCheck = !isPrebuilt
            ? `<label class="card-cmp-check" title="Chọn để so sánh">
                   <input type="checkbox" data-cid="${p.id}" data-cat="${p.category}"
                          data-name="${esc(p.name)}" data-price="${p.price}"
                          data-img="${p.imageUrl||''}"
                          onchange="toggleCompare(this)">
                   <i class="bi bi-check2-square"></i>
               </label>`
            : '';

        // P30: eye icon for quick view
        const eyeBtn = `<button class="qv-eye-btn" title="Xem nhanh"
            onclick="event.preventDefault();event.stopPropagation();openQuickView('${p.category}',${p.id})">
            <i class="bi bi-eye-fill"></i>
        </button>`;

        return `<div class="col-sm-6 col-lg-4 col-xl-3">
            <div class="component-card p-0 h-100 overflow-hidden d-flex flex-column">
                <a href="${detailUrl}" class="card-img-wrap text-decoration-none"
                   style="height:160px;background:rgba(255,255,255,0.04);display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative;">
                    ${img}
                    ${hoverSpecs ? `<div class="card-specs-overlay">${hoverSpecs}</div>` : ''}
                    ${cmpCheck}
                    ${eyeBtn}
                </a>
                <div class="p-3 d-flex flex-column flex-grow-1">
                    <span class="badge mb-2" style="${badgeColor};font-size:.7rem">${catLabel}</span>
                    <h6 class="mb-2 lh-sm flex-grow-1" style="font-size:.82rem">
                        <a href="${detailUrl}" class="text-white text-decoration-none" style="opacity:.9">${esc(p.name)}</a>
                    </h6>
                    <div class="d-flex flex-wrap gap-1 mb-3">${specs}</div>
                    ${(() => {
                        const sale = activeSalesMap[`${p.category}_${p.id}`];
                        if (sale) {
                            return `<div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <span class="text-white fw-bold" style="color:#f59e0b!important">${fmt(sale.salePrice)}</span>
                                    <span class="text-muted-white ms-1" style="text-decoration:line-through;font-size:.78rem">${fmt(p.price)}</span>
                                </div>
                                <div class="d-flex gap-2">
                                    ${builderBtn}
                                    <button class="btn btn-sm btn-gradient px-2 py-1"
                                            onclick="addToCart(${p.id},'${p.category}','${esc(p.name)}',${sale.salePrice},${p.imageUrl?`'${esc(p.imageUrl)}'`:'null'},this)"
                                            title="Thêm vào giỏ hàng">
                                        <i class="bi bi-cart-plus" style="font-size:.8rem"></i>
                                    </button>
                                </div>
                            </div>
                            ${flashSaleHtml(sale)}`;
                        }
                        return `<div class="d-flex justify-content-between align-items-center">
                            <span class="text-white fw-bold">${fmt(p.price)}</span>
                            <div class="d-flex gap-2">
                                ${builderBtn}
                                <button class="btn btn-sm btn-gradient px-2 py-1"
                                        onclick="addToCart(${p.id},'${p.category}','${esc(p.name)}',${p.price},${p.imageUrl?`'${esc(p.imageUrl)}'`:'null'},this)"
                                        title="Thêm vào giỏ hàng">
                                    <i class="bi bi-cart-plus" style="font-size:.8rem"></i>
                                </button>
                            </div>
                        </div>`;
                    })()}
                </div>
            </div>
        </div>`;
    }).join('');
}

function renderPagination(totalPages, currentP) {
    const el = document.getElementById('pagination');
    if (totalPages <= 1) { el.innerHTML = ''; return; }

    let html = '';
    html += `<button class="btn glass text-white rounded-3 px-3" ${currentP === 1 ? 'disabled' : `onclick="goPage(${currentP - 1})"`}>&laquo;</button>`;

    let start = Math.max(1, currentP - 2);
    let end   = Math.min(totalPages, currentP + 2);

    if (start > 1) {
        html += `<button class="btn glass text-white rounded-3 px-3" onclick="goPage(1)">1</button>`;
        if (start > 2) html += `<span class="text-muted-white align-self-end px-1 pb-1">...</span>`;
    }

    for (let p = start; p <= end; p++)
        html += `<button class="btn ${p===currentP?'btn-gradient':'glass text-white'} rounded-3 px-3" onclick="goPage(${p})">${p}</button>`;

    if (end < totalPages) {
        if (end < totalPages - 1) html += `<span class="text-muted-white align-self-end px-1 pb-1">...</span>`;
        html += `<button class="btn glass text-white rounded-3 px-3" onclick="goPage(${totalPages})">${totalPages}</button>`;
    }

    html += `<button class="btn glass text-white rounded-3 px-3" ${currentP === totalPages ? 'disabled' : `onclick="goPage(${currentP + 1})"`}>&raquo;</button>`;
    el.innerHTML = html;
}

function goBuilder(category, id) {
    window.location.href = '/Builder?preselect=' + category + ':' + id;
}

let activeSalesMap = {};
async function loadActiveSales() {
    try {
        const data = await fetch('/Products/ActiveSales').then(r => r.json());
        activeSalesMap = {};
        data.forEach(s => activeSalesMap[s.key] = s);
    } catch { activeSalesMap = {}; }
}

function flashSaleHtml(sale) {
    const now = Date.now();
    const left = Math.max(0, sale.endsAtMs - now);
    const h = Math.floor(left / 3600000);
    const m = Math.floor((left % 3600000) / 60000);
    const s = Math.floor((left % 60000) / 1000);
    const timer = `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
    const pct = Math.round(sale.soldQty / sale.totalQty * 100);
    return `
        <div class="flash-sale-overlay px-2 pt-1 pb-2" style="background:linear-gradient(135deg,rgba(239,68,68,.12),rgba(245,158,11,.1));border-top:1px solid rgba(239,68,68,.25)">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <span class="badge" style="background:#ef4444;font-size:.68rem"><i class="bi bi-lightning-charge"></i> -${sale.discountPercent}%</span>
                <span style="font-size:.68rem;color:#fb923c;font-variant-numeric:tabular-nums" class="flash-timer" data-ends="${sale.endsAtMs}">${timer}</span>
            </div>
            <div style="height:3px;background:rgba(255,255,255,.1);border-radius:2px;margin-bottom:4px">
                <div style="width:${pct}%;height:100%;background:linear-gradient(90deg,#ef4444,#f59e0b);border-radius:2px"></div>
            </div>
            <div style="font-size:.68rem;color:rgba(255,255,255,.5)">Đã bán ${sale.soldQty}/${sale.totalQty}</div>
        </div>`;
}

document.addEventListener('DOMContentLoaded', async () => {
    loadBrands(currentCat);
    loadFilterOptions(currentCat);
    await loadActiveSales();
    // Refresh timers every second
    setInterval(() => {
        document.querySelectorAll('.flash-timer').forEach(el => {
            const left = Math.max(0, parseInt(el.dataset.ends) - Date.now());
            const h = Math.floor(left / 3600000);
            const m = Math.floor((left % 3600000) / 60000);
            const s = Math.floor((left % 60000) / 1000);
            el.textContent = `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
        });
    }, 1000);
});

function fmt(n) { return new Intl.NumberFormat('vi-VN').format(n) + 'đ'; }
function esc(s) {
    return String(s).replace(/[&<>"']/g, c =>
        ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

/* ── P24: Active Filters Display ─────────────────── */
function renderActiveFilters() {
    const bar = document.getElementById('activeFilters');
    const tags = [];

    const search = document.getElementById('searchInput')?.value.trim();
    if (search) tags.push({ label: `🔍 "${search}"`, clear: () => { document.getElementById('searchInput').value = ''; applyFilters(); } });

    if (currentCat && currentCat !== 'all')
        tags.push({ label: i18n.catLabels[currentCat] || currentCat, clear: () => setCategory('all') });

    if (currentBrands.length)
        currentBrands.forEach(b => tags.push({ label: `🏷 ${b}`, clear: () => {
            currentBrands = currentBrands.filter(x => x !== b);
            document.querySelectorAll(`#brandCheckboxes input[value="${CSS.escape(b)}"]`).forEach(el => el.checked = false);
            document.getElementById('brandLabel').textContent = currentBrands.length ? `${currentBrands.length} ${i18n.selected}` : i18n.allBrands;
            currentPage = 1; applyFilters();
        }}));

    const minP = document.getElementById('minPrice')?.value;
    const maxP = document.getElementById('maxPrice')?.value;
    if (minP) tags.push({ label: `≥ ${Number(minP).toLocaleString('vi')}đ`, clear: () => { document.getElementById('minPrice').value=''; applyFilters(); } });
    if (maxP) tags.push({ label: `≤ ${Number(maxP).toLocaleString('vi')}đ`, clear: () => { document.getElementById('maxPrice').value=''; applyFilters(); } });

    document.querySelectorAll('#catSpecificFilters [data-param]').forEach(el => {
        if (!el.value) return;
        const label = el.options ? el.options[el.selectedIndex]?.text : el.value;
        if (label) tags.push({ label: `⚙ ${label}`, clear: () => { el.value=''; applyFilters(); } });
    });

    if (!tags.length) { bar.style.display = 'none'; return; }
    bar.style.display = '';
    bar.innerHTML = tags.map((t, i) =>
        `<button class="filter-tag" data-idx="${i}">
            ${t.label}
            <i class="bi bi-x-circle-fill ms-1"></i>
         </button>`
    ).join('') +
    `<button class="filter-tag filter-tag-clear" onclick="clearAllFilters()">
        <i class="bi bi-x-lg me-1"></i>Xóa tất cả
     </button>`;

    bar.querySelectorAll('[data-idx]').forEach(btn => {
        btn.addEventListener('click', () => tags[+btn.dataset.idx].clear());
    });
}

function clearAllFilters() {
    document.getElementById('searchInput').value = '';
    document.getElementById('minPrice').value    = '';
    document.getElementById('maxPrice').value    = '';
    currentBrands = [];
    document.querySelectorAll('#brandCheckboxes input').forEach(i => i.checked = false);
    document.getElementById('brandLabel').textContent = i18n.allBrands;
    document.querySelectorAll('#catSpecificFilters [data-param]').forEach(el => { el.value = ''; });
    setCategory('all');
}

/* ── P27: Compare Sticky Bar ────────────────────── */
let cmpItems = [];

function toggleCompare(checkbox) {
    const { cid, cat, name, price, img } = checkbox.dataset;
    if (checkbox.checked) {
        if (cmpItems.length >= 3) {
            checkbox.checked = false;
            showToast('<i class="bi bi-exclamation-circle me-2"></i>Tối đa 3 sản phẩm để so sánh', 'info');
            return;
        }
        cmpItems.push({ id: cid, cat, name, price, img });
    } else {
        cmpItems = cmpItems.filter(i => i.id !== cid);
    }
    renderCompareBar();
}

function renderCompareBar() {
    let bar = document.getElementById('cmpBar');
    if (!bar) {
        bar = document.createElement('div');
        bar.id = 'cmpBar';
        bar.style.cssText = `
            position:fixed; bottom:0; left:0; right:0; z-index:1050;
            background:rgba(15,23,42,.96); backdrop-filter:blur(16px);
            border-top:1px solid rgba(168,85,247,.35);
            padding:12px 24px; display:flex; align-items:center; gap:16px;
            transform:translateY(100%); transition:transform .3s cubic-bezier(.34,1.56,.64,1);
        `;
        document.body.appendChild(bar);
    }

    if (!cmpItems.length) { bar.style.transform = 'translateY(100%)'; return; }
    bar.style.transform = 'translateY(0)';

    const avatars = cmpItems.map(item => `
        <div class="d-flex align-items-center gap-2 glass-sm rounded-3 px-2 py-1" style="min-width:0">
            ${item.img
                ? `<img src="${item.img}" style="width:36px;height:36px;object-fit:cover;border-radius:6px" loading="lazy">`
                : `<div style="width:36px;height:36px;border-radius:6px;background:rgba(168,85,247,.2);display:flex;align-items:center;justify-content:center"><i class="bi bi-cpu" style="color:#a855f7"></i></div>`}
            <div style="min-width:0">
                <div class="text-white" style="font-size:.73rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:120px">${item.name}</div>
                <div style="color:#a855f7;font-size:.7rem">${Number(item.price).toLocaleString('vi')}đ</div>
            </div>
            <button class="btn btn-sm p-0" style="color:rgba(255,255,255,.4);line-height:1;flex-shrink:0"
                    onclick="removeCmp('${item.id}')"><i class="bi bi-x"></i></button>
        </div>`).join('');

    const slots = cmpItems.length < 3
        ? `<div class="glass-sm rounded-3 px-3 py-2" style="color:rgba(255,255,255,.3);font-size:.78rem;border-style:dashed">
               + Thêm ${3 - cmpItems.length} sản phẩm
           </div>`
        : '';

    const canCompare = cmpItems.length >= 2 && cmpItems.every(i => i.cat === cmpItems[0].cat);
    const compareUrl = `/Products/Compare?category=${cmpItems[0]?.cat}&ids=${cmpItems.map(i => i.id).join(',')}`;

    bar.innerHTML = `
        <span class="text-white fw-semibold me-2" style="white-space:nowrap;font-size:.82rem">
            <i class="bi bi-layout-split me-1" style="color:#a855f7"></i>So sánh (${cmpItems.length}/3)
        </span>
        <div class="d-flex gap-2 flex-wrap flex-grow-1">${avatars}${slots}</div>
        <div class="d-flex gap-2 ms-auto flex-shrink-0">
            ${canCompare ? `<a href="${compareUrl}" class="btn btn-gradient btn-sm px-4 fw-semibold">So sánh chi tiết</a>` : `<button class="btn btn-gradient btn-sm px-4" disabled title="Cần ≥2 sản phẩm cùng loại">So sánh</button>`}
            <button class="btn glass text-white btn-sm px-3" onclick="clearCompare()"><i class="bi bi-x-lg"></i></button>
        </div>`;
}

function removeCmp(id) {
    cmpItems = cmpItems.filter(i => i.id !== id);
    document.querySelectorAll(`[data-cid="${id}"]`).forEach(cb => cb.checked = false);
    renderCompareBar();
}

function clearCompare() {
    cmpItems = [];
    document.querySelectorAll('.card-cmp-check input').forEach(cb => cb.checked = false);
    renderCompareBar();
}

/* ── P30: Quick View ─────────────────────────────── */
let qvModal = null;
let qvCurrentIdx = -1;
let qvProductList = []; // [{category, id}] from current grid

function openQuickView(category, id) {
    if (!qvModal) qvModal = new bootstrap.Modal(document.getElementById('quickViewModal'));

    // Build product list from current rendered grid for arrow navigation
    qvProductList = Array.from(document.querySelectorAll('.qv-eye-btn'))
        .map(btn => {
            const m = btn.getAttribute('onclick').match(/openQuickView\('([^']+)',(\d+)\)/);
            return m ? { category: m[1], id: parseInt(m[2]) } : null;
        }).filter(Boolean);

    qvCurrentIdx = qvProductList.findIndex(p => p.category === category && p.id === id);

    loadQuickView(category, id);
    qvModal.show();
}

async function loadQuickView(category, id) {
    const body = document.getElementById('qvModalBody');
    body.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-light" role="status"></div></div>';
    try {
        const r = await fetch(`/Products/QuickView/${category}/${id}`);
        if (!r.ok) throw new Error();
        const p = await r.json();

        const catLabels = { cpu:'CPU', motherboard:'Mainboard', memory:'RAM', gpu:'VGA', storage:'Storage', psu:'Nguồn', case:'Case', cooler:'Tản nhiệt' };
        const specsRows = Object.entries(p.specs || {}).map(([k, v]) =>
            `<div class="d-flex" style="border-bottom:1px solid rgba(255,255,255,.05)">
                <div class="px-3 py-2 text-muted-white" style="width:140px;font-size:.8rem;background:rgba(255,255,255,.03)">${k}</div>
                <div class="px-3 py-2 text-white" style="font-size:.82rem">${v}</div>
             </div>`).join('');

        const stockHtml = p.stock > 0
            ? '<span class="badge" style="background:rgba(34,197,94,.15);color:#4ade80"><i class="bi bi-check-circle me-1"></i>Còn hàng</span>'
            : '<span class="badge" style="background:rgba(239,68,68,.15);color:#f87171">Hết hàng</span>';

        body.innerHTML = `
            <div class="row g-4">
                <div class="col-md-5 d-flex align-items-center justify-content-center"
                     style="min-height:240px;background:rgba(255,255,255,.04);border-radius:12px">
                    ${p.imageUrl
                        ? `<img src="${p.imageUrl}" alt="" style="max-height:220px;max-width:100%;object-fit:contain">`
                        : `<i class="bi bi-cpu text-muted-white" style="font-size:5rem;opacity:.3"></i>`}
                </div>
                <div class="col-md-7">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="badge" style="background:rgba(168,85,247,.2);color:#c084fc;font-size:.75rem">${catLabels[p.category] || p.category}</span>
                        ${stockHtml}
                    </div>
                    <p class="text-muted-white mb-1" style="font-size:.8rem">${p.manufacturer}</p>
                    <h5 class="text-white fw-semibold mb-3 lh-sm" style="font-size:1rem">${p.name}</h5>
                    <div class="mb-3 fw-bold" style="font-size:1.5rem;background:linear-gradient(135deg,#a855f7,#6366f1);-webkit-background-clip:text;-webkit-text-fill-color:transparent">
                        ${new Intl.NumberFormat('vi-VN').format(p.price)}đ
                    </div>
                    <div class="rounded-3 overflow-hidden mb-3" style="border:1px solid rgba(255,255,255,.08)">
                        ${specsRows}
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-gradient px-4 py-2 rounded-3 fw-semibold" ${p.stock === 0 ? 'disabled' : ''}
                                onclick="addToCart(${p.id},'${p.category}','${p.name.replace(/'/g,"\\'")}',${p.price},${p.imageUrl?`'${p.imageUrl}'`:'null'},this)">
                            <i class="bi bi-cart-plus me-2"></i>Thêm vào giỏ
                        </button>
                        <a href="/Products/Detail/${p.category}/${p.id}" class="btn glass text-white px-4 py-2 rounded-3">
                            <i class="bi bi-info-circle me-2"></i>Chi tiết
                        </a>
                    </div>
                </div>
            </div>`;
    } catch {
        body.innerHTML = '<p class="text-muted-white text-center py-4">Không thể tải thông tin sản phẩm.</p>';
    }
}

function qvNav(dir) {
    if (!qvProductList.length) return;
    qvCurrentIdx = (qvCurrentIdx + dir + qvProductList.length) % qvProductList.length;
    const { category, id } = qvProductList[qvCurrentIdx];
    loadQuickView(category, id);
}

/* ── P31: Keyboard shortcuts ─────────────────────── */
document.addEventListener('keydown', e => {
    // '/' focuses search (not if typing in an input)
    if (e.key === '/' && !['INPUT', 'TEXTAREA', 'SELECT'].includes(e.target.tagName)) {
        e.preventDefault();
        document.getElementById('searchInput')?.focus();
    }
    // Esc closes quick view modal
    if (e.key === 'Escape') {
        qvModal?.hide();
    }
    // Arrow keys navigate quick view
    const modalEl = document.getElementById('quickViewModal');
    if (modalEl?.classList.contains('show')) {
        if (e.key === 'ArrowLeft')  { e.preventDefault(); qvNav(-1); }
        if (e.key === 'ArrowRight') { e.preventDefault(); qvNav(1); }
    }
});
</script>

