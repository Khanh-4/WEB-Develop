@model List<TechSpecs.ViewModels.ProductListItem>

@if (!Model.Any())
{
    <div class="col-12 text-center py-5 text-muted-white">
        <i class="bi bi-search fs-1 mb-3 d-block"></i>
        <p class="mb-0">@L["Products.NoResults"]</p>
        <small>@L["Products.NoResultsHint"]</small>
    </div>
}
else
{
    @foreach (var p in Model)
    {
        string catLabel = p.IsPrebuilt ? L["Cat.Prebuilt"].Value : p.Category switch {
            "cpu"         => L["Cat.CPU"].Value,
            "motherboard" => L["Cat.Motherboard"].Value,
            "memory"      => L["Cat.Memory"].Value,
            "gpu"         => L["Cat.GPU"].Value,
            "storage"     => L["Cat.Storage"].Value,
            "psu"         => L["Cat.PSU"].Value,
            "case"        => L["Cat.Case"].Value,
            "cooler"      => L["Cat.Cooler"].Value,
            _             => p.Category
        };
        string badgeStyle = p.IsPrebuilt
            ? "background:rgba(16,185,129,.2);color:#34d399"
            : "background:rgba(168,85,247,.25);color:#c084fc";

        <div class="col-sm-6 col-lg-4 col-xl-3">
            <div class="component-card p-0 h-100 overflow-hidden d-flex flex-column">
                <a href="/Products/Detail/@p.Category/@p.Id" class="text-decoration-none"
                   style="height:160px;background:rgba(255,255,255,0.04);display:flex;align-items:center;justify-content:center;overflow:hidden">
                    @if (p.ImageUrl != null)
                    {
                        <img src="@p.ImageUrl" alt="@p.Name" class="w-100 h-100 object-fit-cover" />
                    }
                    else
                    {
                        <i class="bi bi-cpu text-muted-white" style="font-size:3rem"></i>
                    }
                </a>
                <div class="p-3 d-flex flex-column flex-grow-1">
                    <div class="d-flex align-items-center gap-1 mb-2">
                        <span class="badge" style="@badgeStyle;font-size:.7rem">@catLabel</span>
                        @if (!p.IsPrebuilt)
                        {
                            if (p.Stock == 0)
                            {
                                <span class="badge" style="background:rgba(239,68,68,.15);color:#f87171;font-size:.65rem">Hết hàng</span>
                            }
                            else if (p.Stock <= 5)
                            {
                                <span class="badge" style="background:rgba(251,146,60,.15);color:#fb923c;font-size:.65rem">Còn @p.Stock</span>
                            }
                        }
                    </div>
                    <h6 class="mb-2 lh-sm flex-grow-1" style="font-size:.82rem">
                        <a href="/Products/Detail/@p.Category/@p.Id"
                           class="text-white text-decoration-none"
                           style="opacity:.9">@p.Name</a>
                    </h6>
                    @if (!p.IsPrebuilt)
                    {
                        <div class="d-flex flex-wrap gap-1 mb-3">
                            @foreach (var spec in p.Specs.Take(3))
                            {
                                <span class="badge glass-sm text-white" style="font-size:.72rem">@spec.Key: @spec.Value</span>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="mb-3"></div>
                    }
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-white fw-bold">@p.Price.ToString("N0")đ</span>
                        <div class="d-flex gap-2">
                            @if (!p.IsPrebuilt)
                            {
                                <button class="btn btn-sm glass text-white px-2 py-1"
                                        onclick="goBuilder('@p.Category',@p.Id)"
                                        title="Thêm vào PC Builder">
                                    <i class="bi bi-tools" style="font-size:.8rem"></i>
                                </button>
                                <button class="btn btn-sm glass text-white px-2 py-1 cmp-btn"
                                        id="cmpBtn_@(p.Category)_@(p.Id)"
                                        onclick="toggleCompare(@p.Id,'@p.Category',@Html.Raw(System.Text.Json.JsonSerializer.Serialize(p.Name)),@p.Price,'@(p.ImageUrl ?? "")')"
                                        title="So sánh">
                                    <i class="bi bi-bar-chart-steps" style="font-size:.8rem"></i>
                                </button>
                            }
                            <button class="btn btn-sm btn-gradient px-2 py-1 @(p.Stock == 0 && !p.IsPrebuilt ? "disabled" : "")"
                                    data-pid="@p.Id" data-pcat="@p.Category"
                                    data-pname="@p.Name" data-pprice="@p.Price"
                                    data-pimg="@p.ImageUrl"
                                    onclick="addToCartFromData(this)"
                                    title="@(p.Stock == 0 && !p.IsPrebuilt ? "Hết hàng" : "Thêm vào giỏ hàng")"
                                    @(p.Stock == 0 && !p.IsPrebuilt ? "disabled" : "")>
                                <i class="bi bi-cart-plus" style="font-size:.8rem"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
}
