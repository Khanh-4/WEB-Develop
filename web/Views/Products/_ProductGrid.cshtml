@model List<TechSpecs.ViewModels.ProductListItem>

@if (!Model.Any())
{
    <div class="col-12 text-center py-5 text-muted-white">
        <i class="bi bi-search fs-1 mb-3 d-block"></i>
        <p class="mb-0">No components found</p>
        <small>Try a different search or category</small>
    </div>
}
else
{
    @foreach (var p in Model)
    {
        var catLabel = p.Category switch {
            "cpu"         => "CPU",
            "motherboard" => "Motherboard",
            "memory"      => "RAM",
            "gpu"         => "GPU",
            "storage"     => "Storage",
            "psu"         => "PSU",
            "case"        => "Case",
            "cooler"      => "Cooler",
            _             => p.Category
        };
        <div class="col-sm-6 col-lg-4 col-xl-3">
            <div class="component-card p-0 h-100 overflow-hidden d-flex flex-column">
                <a href="/Products/Detail/@p.Category/@p.Id" class="text-decoration-none"
                   style="height:160px;background:rgba(255,255,255,0.04);display:flex;align-items:center;justify-content:center;overflow:hidden">
                    @if (p.ImageUrl != null)
                    {
                        <img src="@p.ImageUrl" alt="@p.Name" class="w-100 h-100 object-fit-cover" />
                    }
                    else
                    {
                        <i class="bi bi-cpu text-muted-white" style="font-size:3rem"></i>
                    }
                </a>
                <div class="p-3 d-flex flex-column flex-grow-1">
                    <span class="badge mb-2" style="background:rgba(168,85,247,.25);color:#c084fc;font-size:.7rem">@catLabel</span>
                    <h6 class="mb-2 lh-sm flex-grow-1" style="font-size:.82rem">
                        <a href="/Products/Detail/@p.Category/@p.Id"
                           class="text-white text-decoration-none"
                           style="opacity:.9">@p.Name</a>
                    </h6>
                    <div class="d-flex flex-wrap gap-1 mb-3">
                        @foreach (var spec in p.Specs.Take(3))
                        {
                            <span class="badge glass-sm text-white" style="font-size:.72rem">@spec.Key: @spec.Value</span>
                        }
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-white fw-bold">@p.Price.ToString("N0")đ</span>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm glass text-white px-2 py-1"
                                    onclick="goBuilder('@p.Category',@p.Id)"
                                    title="Add to PC Builder">
                                <i class="bi bi-tools" style="font-size:.8rem"></i>
                            </button>
                            <button class="btn btn-sm btn-gradient px-2 py-1"
                                    data-pid="@p.Id" data-pcat="@p.Category"
                                    data-pname="@p.Name" data-pprice="@p.Price"
                                    data-pimg="@p.ImageUrl"
                                    onclick="addToCartFromData(this)"
                                    title="Add to Cart">
                                <i class="bi bi-cart-plus" style="font-size:.8rem"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
}
