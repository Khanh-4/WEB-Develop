@{
    var c = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string Active(params string[] names) => names.Any(n => string.Equals(n, c, StringComparison.OrdinalIgnoreCase)) ? "active" : "";
}
<!DOCTYPE html>
<html lang="vi" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · Admin · TechSpecs</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
        (function () {
            var t = localStorage.getItem('ts.theme') || 'dark';
            document.documentElement.setAttribute('data-theme', t);
        })();
    </script>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
<div class="admin-shell">

    <!-- ══════════ SIDEBAR ══════════ -->
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="brand">
            <span class="logo"><i class="bi bi-cpu" style="font-size:.95rem"></i></span>
            <span>TechSpecs <small style="color:#64748b">Admin</small></span>
        </div>

        <div class="section-label">Tổng quan</div>
        <a href="/Admin" class="@Active("Admin")"><i class="bi bi-speedometer2"></i> Dashboard</a>

        <div class="section-label">Catalog</div>
        <a href="/Admin/Products" class="@Active("Admin")"><i class="bi bi-box-seam"></i> Sản phẩm</a>
        <a href="/Admin/Benchmarks"><i class="bi bi-bar-chart-fill"></i> Benchmarks</a>
        <a href="/Admin/Bundles"><i class="bi bi-boxes"></i> Combo / Bundles</a>

        <div class="section-label">Bán hàng</div>
        <a href="/Admin/Orders"><i class="bi bi-receipt"></i> Đơn hàng</a>
        <a href="/Admin/FlashSales"><i class="bi bi-lightning-charge"></i> Flash Sales</a>
        <a href="/Admin/Coupons"><i class="bi bi-ticket-perforated"></i> Coupons</a>
        <a href="/Admin/QuoteRequests"><i class="bi bi-envelope-paper"></i> Báo giá</a>
        <a href="/Admin/Warranties"><i class="bi bi-shield-check"></i> Bảo hành</a>

        <div class="section-label">Hệ thống</div>
        <a href="/Admin/Reviews"><i class="bi bi-star"></i> Đánh giá</a>
        <a href="/Admin/Users"><i class="bi bi-people"></i> Người dùng</a>
        <a href="/Admin/Scraper"><i class="bi bi-arrow-repeat"></i> Scraper</a>
        <a href="/" asp-area=""><i class="bi bi-box-arrow-left"></i> Về trang chính</a>
    </aside>

    <!-- ══════════ MAIN ══════════ -->
    <div class="admin-main">

        <!-- Topbar -->
        <div class="admin-topbar">
            <div class="d-flex align-items-center gap-2">
                <button class="btn-icon d-lg-none" id="sidebarToggle" type="button">
                    <i class="bi bi-list"></i>
                </button>
                <h5 class="mb-0">@(ViewData["Title"] ?? "Admin")</h5>
            </div>
            <div class="d-flex align-items-center gap-2">
                <button class="btn-icon" id="darkToggle" title="Đổi giao diện" type="button">
                    <i class="bi bi-moon-stars" id="themeIcon"></i>
                </button>
                <div class="dropdown">
                    <button class="btn p-0 d-flex align-items-center gap-2" data-bs-toggle="dropdown"
                            style="background:none;border:none">
                        <span class="avatar">@(User.Identity?.Name?.Length > 0 ? User.Identity.Name[0].ToString().ToUpper() : "A")</span>
                        <div class="d-none d-md-block text-start">
                            <div class="fw-semibold" style="font-size:.85rem;color:var(--text)">@User.Identity?.Name</div>
                            <div style="font-size:.72rem;color:var(--text-muted)">Quản trị viên</div>
                        </div>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" asp-area="" asp-controller="Account" asp-action="Profile"><i class="bi bi-person"></i> Hồ sơ</a></li>
                        <li><a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="Index"><i class="bi bi-shop"></i> Cửa hàng</a></li>
                        <li><hr class="dropdown-divider" style="border-color:var(--border)" /></li>
                        <li>
                            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button class="dropdown-item text-danger"><i class="bi bi-box-arrow-right"></i> Đăng xuất</button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        @if (TempData["Success"] is string ok)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@ok
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] is string err)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-octagon me-2"></i>@err
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>
</div>

<div class="tx-toast-wrap" id="toastWrap"></div>
<form id="csrfForm" style="display:none">@Html.AntiForgeryToken()</form>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
// Theme toggle
document.addEventListener('DOMContentLoaded', function () {
    var root = document.documentElement;
    var icon = document.getElementById('themeIcon');
    var btn  = document.getElementById('darkToggle');
    function applyTheme(t) {
        root.setAttribute('data-theme', t);
        if (icon) icon.className = t === 'dark' ? 'bi bi-moon-stars' : 'bi bi-sun';
    }
    applyTheme(root.getAttribute('data-theme') || 'dark');
    if (btn) btn.addEventListener('click', function () {
        var next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        localStorage.setItem('ts.theme', next);
        applyTheme(next);
    });
});

// Sidebar toggle (mobile)
document.getElementById('sidebarToggle')?.addEventListener('click', function () {
    document.getElementById('adminSidebar').classList.toggle('open');
});

// Close sidebar when clicking outside (mobile)
document.addEventListener('click', function (e) {
    var sidebar = document.getElementById('adminSidebar');
    var toggle  = document.getElementById('sidebarToggle');
    if (!sidebar || window.innerWidth >= 992) return;
    if (!sidebar.contains(e.target) && e.target !== toggle && !toggle?.contains(e.target)) {
        sidebar.classList.remove('open');
    }
});

function showToast(msg, type) {
    var wrap = document.getElementById('toastWrap');
    if (!wrap) return;
    var t = document.createElement('div');
    t.className = 'tx-toast ' + (type || 'info');
    var icons = { success:'bi-check-circle', error:'bi-x-circle', warning:'bi-exclamation-triangle', info:'bi-info-circle' };
    t.innerHTML = '<i class="bi ' + (icons[type] || icons.info) + '"></i><span>' + msg + '</span>';
    wrap.appendChild(t);
    setTimeout(function() { t.classList.add('show'); }, 10);
    setTimeout(function() { t.classList.remove('show'); setTimeout(function() { t.remove(); }, 350); }, 3500);
}
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
