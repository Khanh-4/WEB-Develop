<script>
// ── Product Compare ───────────────────────────────────────────────────────────
const CMP_MAX = 3;
const CMP_KEY = 'cmpList';

function getCmpList() {
    try { return JSON.parse(localStorage.getItem(CMP_KEY) || '[]'); } catch { return []; }
}
function saveCmpList(list) { localStorage.setItem(CMP_KEY, JSON.stringify(list)); }

function toggleCompare(id, category, name, price, imageUrl) {
    let list = getCmpList();
    const idx = list.findIndex(x => x.id === id && x.category === category);

    if (idx >= 0) {
        list.splice(idx, 1);
    } else {
        if (list.length > 0 && list[0].category !== category) {
            showToast(`Chỉ so sánh được sản phẩm cùng loại (${list[0].category.toUpperCase()})`, 'warning');
            return;
        }
        if (list.length >= CMP_MAX) {
            showToast(`Chỉ so sánh tối đa ${CMP_MAX} sản phẩm`, 'warning');
            return;
        }
        list.push({ id, category, name, price, imageUrl });
    }

    saveCmpList(list);
    renderCompareTray();
    syncCmpButtons();
}

function clearCompareList() {
    saveCmpList([]);
    renderCompareTray();
    syncCmpButtons();
}

function goCompare() {
    const list = getCmpList();
    if (list.length < 2) { showToast('Chọn ít nhất 2 sản phẩm để so sánh', 'warning'); return; }
    const ids = list.map(x => x.id).join(',');
    window.location.href = `/Products/Compare?category=${list[0].category}&ids=${ids}`;
}

function renderCompareTray() {
    const list = getCmpList();
    const tray = document.getElementById('compareTray');
    const container = document.getElementById('cmpItems');
    if (!tray || !container) return;

    if (list.length === 0) { tray.style.display = 'none'; return; }
    tray.style.display = '';

    container.innerHTML = list.map(item => `
        <div class="d-flex align-items-center gap-2 glass-sm rounded-3 px-2 py-1" style="min-width:160px;max-width:220px">
            <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded-2 overflow-hidden"
                 style="width:36px;height:36px;background:rgba(255,255,255,.08)">
                ${item.imageUrl
                    ? `<img src="${item.imageUrl}" style="width:36px;height:36px;object-fit:contain">`
                    : `<i class="bi bi-cpu" style="color:rgba(255,255,255,.4)"></i>`}
            </div>
            <div class="flex-grow-1 overflow-hidden">
                <div style="font-size:.72rem;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.2">${item.name}</div>
                <div style="font-size:.7rem;color:#a855f7;font-weight:600">${item.price.toLocaleString('vi-VN')}đ</div>
            </div>
            <button onclick="toggleCompare(${item.id},'${item.category}',${JSON.stringify(item.name)},${item.price},'${item.imageUrl || ''}')"
                    class="btn p-0 border-0" style="color:rgba(255,255,255,.4);font-size:.75rem;line-height:1;background:none;flex-shrink:0"
                    title="Bỏ khỏi so sánh">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    `).join('');

    // Disable go button if < 2
    const btn = document.getElementById('cmpGoBtn');
    if (btn) btn.disabled = list.length < 2;
}

function syncCmpButtons() {
    const list = getCmpList();
    // Reset all compare buttons
    document.querySelectorAll('.cmp-btn').forEach(btn => {
        btn.style.background = '';
        btn.style.borderColor = '';
        btn.style.color = '';
        const icon = btn.querySelector('i');
        if (icon) { icon.style.color = ''; }
    });
    // Highlight active ones
    list.forEach(item => {
        const btn = document.getElementById(`cmpBtn_${item.category}_${item.id}`);
        if (btn) {
            btn.style.background = 'rgba(168,85,247,0.3)';
            btn.style.borderColor = 'rgba(168,85,247,0.6)';
            const icon = btn.querySelector('i');
            if (icon) icon.style.color = '#c084fc';
        }
    });
}

// Init on page load
document.addEventListener('DOMContentLoaded', () => {
    renderCompareTray();
    syncCmpButtons();
});

// ── Installment Calculator ────────────────────────────────────────────────────
function showInstallment(price, productName) {
    document.getElementById('instProductName').textContent = productName || '';
    document.getElementById('instBasePrice').textContent = Number(price).toLocaleString('vi-VN') + 'đ';
    const plans = [
        { months: 3,  fee: 0.00,  label: '3 tháng',  badge: '0% phí',    badgeColor: '#4ade80' },
        { months: 6,  fee: 0.015, label: '6 tháng',  badge: '1.5%/tháng', badgeColor: '#fb923c' },
        { months: 9,  fee: 0.015, label: '9 tháng',  badge: '1.5%/tháng', badgeColor: '#fb923c' },
        { months: 12, fee: 0.020, label: '12 tháng', badge: '2%/tháng',  badgeColor: '#f87171' },
    ];
    const cards = plans.map(p => {
        const monthly = fee => Math.ceil(price * (1 + fee * p.months) / p.months);
        const mo = monthly(p.fee);
        return `<div class="col-6">
            <div class="glass-sm p-3 text-center h-100">
                <div class="text-white fw-bold mb-1">${p.label}</div>
                <div class="fs-5 fw-bold" style="color:#a855f7">${mo.toLocaleString('vi-VN')}đ</div>
                <div class="text-muted-white" style="font-size:.72rem">/tháng</div>
                <span class="badge mt-2" style="background:rgba(255,255,255,.08);color:${p.badgeColor};font-size:.7rem">${p.badge}</span>
            </div>
        </div>`;
    }).join('');
    document.getElementById('instCards').innerHTML = cards;
    new bootstrap.Modal(document.getElementById('installmentModal')).show();
}

