                    <li><a href="/Products?category=gpu">GPU</a></li>
                    <li><a href="/Products?category=ram">RAM</a></li>
                    <li><a href="/Builder">PC Builder</a></li>
                </ul>
            </div>
            <div class="col-md-3 col-6">
                <h6>Hỗ trợ</h6>
                <ul class="list-unstyled small d-flex flex-column gap-2">
                    <li><a href="/Warranty">Chính sách bảo hành</a></li>
                    <li><a href="#">Đổi trả 7 ngày</a></li>
                    <li><a href="#">Hướng dẫn thanh toán</a></li>
                    <li><a href="/OrderTracking">Tra cứu đơn hàng</a></li>
