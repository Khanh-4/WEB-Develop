<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechSpecs</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-glass px-3">
    <div class="container-xl">
        <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
            <span class="gradient-icon">
                <i class="bi bi-cpu text-white" style="font-size:1.1rem"></i>
            </span>
            TechSpecs
        </a>

        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
            <i class="bi bi-list text-white fs-4"></i>
        </button>

        <div class="collapse navbar-collapse" id="navMain">
            <ul class="navbar-nav me-auto gap-1 ms-3">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">@L["Nav.Home"]</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Products" asp-action="Index">@L["Nav.Products"]</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Build" asp-action="Community">@L["Nav.Community"]</a>
                </li>
                <li class="nav-item">
                    <a class="btn btn-gradient px-3 py-1 ms-1" asp-controller="Builder" asp-action="Index">
                        @L["Nav.PCBuilder"]
                    </a>
                </li>
            </ul>

            <ul class="navbar-nav align-items-center gap-2">
                <!-- Global search -->
                <li class="nav-item d-flex align-items-center" id="navSearchForm">
                    <div style="max-width:0;overflow:hidden;opacity:0;transition:max-width .3s ease,opacity .25s ease;position:relative" id="navSearchBox">
                        <form action="/Products" method="get" class="d-flex align-items-center" id="navSearchFormEl" onsubmit="return navSearchSubmit(event)">
                            <div class="glass d-flex align-items-center px-2" style="border-radius:8px;height:36px">
                                <input type="text" name="search" id="navSearchInput"
                                       class="border-0 bg-transparent text-white p-0"
                                       placeholder="@L["Nav.SearchPlaceholder"]"
                                       style="width:220px;font-size:.85rem;outline:none;box-shadow:none;color:inherit"
                                       autocomplete="off">
                            </div>
                        </form>
                        <!-- Live search dropdown -->
                        <div id="liveSearchDropdown" style="display:none;position:absolute;top:calc(100% + 6px);right:0;width:340px;z-index:9999;
                             background:rgba(15,10,30,0.97);border:1px solid rgba(168,85,247,0.25);border-radius:12px;
                             box-shadow:0 8px 32px rgba(0,0,0,0.5);overflow:hidden">
                        </div>
                    </div>
                    <button type="button" class="btn glass text-white px-2 py-1" id="navSearchToggle"
                            onclick="toggleNavSearch()" style="font-size:1.05rem;line-height:1" title="@L["Nav.Search"]">
                        <i class="bi bi-search"></i>
                    </button>
                </li>
                <li class="nav-item">
                    <button class="btn glass text-white px-2 py-1" id="themeToggle" onclick="toggleTheme()" title="Toggle light/dark mode" style="font-size:1.1rem;line-height:1">
                        <i class="bi bi-sun" id="themeIcon"></i>
                    </button>
                </li>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item">
                        <a class="nav-link position-relative" href="/cart">
                            <i class="bi bi-cart3 fs-5 text-white"></i>
                            <span class="cart-badge" id="cartCount" style="display:none">0</span>
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center gap-1" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle fs-5"></i>
                            <span>@(User.FindFirst("FullName")?.Value ?? User.Identity!.Name?.Split('@')[0])</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end glass-sm border-0 p-2">
                            @if (User.IsInRole("Admin"))
                            {
                                <li><a class="dropdown-item text-white rounded" href="/admin"><i class="bi bi-speedometer2 me-2"></i>@L["Nav.Admin"]</a></li>
                                <li><hr class="dropdown-divider divider-white my-1"></li>
                            }
                            <li><a class="dropdown-item text-white rounded" asp-controller="Account" asp-action="Profile"><i class="bi bi-person me-2"></i>@L["Nav.Profile"]</a></li>
                            <li><a class="dropdown-item text-white rounded" href="/orders"><i class="bi bi-bag-check me-2"></i>@L["Nav.Orders"]</a></li>
                            <li><a class="dropdown-item text-white rounded" asp-controller="Build" asp-action="MyBuilds"><i class="bi bi-bookmark me-2"></i>@L["Nav.MyBuilds"]</a></li>
                            <li><a class="dropdown-item text-white rounded" asp-controller="Wishlist" asp-action="Index"><i class="bi bi-heart me-2" style="color:#f472b6"></i>@L["Nav.Wishlist"]</a></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                    <button class="dropdown-item text-danger rounded"><i class="bi bi-box-arrow-right me-2"></i>@L["Nav.SignOut"]</button>
                                </form>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Login">@L["Nav.Login"]</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-gradient px-3 py-1" asp-controller="Account" asp-action="Register">@L["Nav.SignUp"]</a>
                    </li>
                }

                <!-- Language switcher -->
                @{
                    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
                    var currentUrl = Context.Request.Path + Context.Request.QueryString;
                    var targetCulture = currentCulture == "vi" ? "en" : "vi";
                    var langLabel = currentCulture == "vi" ? "EN" : "VI";
                }
                <li class="nav-item">
                    <a href="/Language/Set?culture=@targetCulture&returnUrl=@Uri.EscapeDataString(currentUrl)"
                       class="btn glass text-white px-2 py-1" style="font-size:.8rem;font-weight:600;text-decoration:none">
                        @langLabel
                    </a>
                </li>
            </ul>
        </div>
    </div>
</nav>

@if (User.Identity?.IsAuthenticated == true)
{
    <form id="csrfForm" style="display:none">@Html.AntiForgeryToken()</form>
}

<main class="pb-5">
    @RenderBody()
</main>

<!-- Compare floating tray -->
<div id="compareTray" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:1050;
     background:rgba(10,6,22,0.97);border-top:1px solid rgba(168,85,247,0.3);
     backdrop-filter:blur(20px);padding:10px 16px;box-shadow:0 -4px 24px rgba(0,0,0,0.5)">
    <div class="container-xl d-flex align-items-center gap-3 flex-wrap">
        <span class="text-white fw-semibold" style="font-size:.85rem;white-space:nowrap;opacity:.8">
            <i class="bi bi-bar-chart-steps me-2" style="color:#a855f7"></i>So sánh:
        </span>
        <div id="cmpItems" class="d-flex gap-2 flex-grow-1 overflow-auto"></div>
        <div class="d-flex gap-2 flex-shrink-0 ms-auto">
            <button onclick="clearCompareList()" class="btn glass text-white px-3 py-1"
                    style="font-size:.82rem;white-space:nowrap">
                <i class="bi bi-x-lg me-1"></i>Xóa tất cả
            </button>
            <button onclick="goCompare()" class="btn btn-gradient px-4 py-1"
                    id="cmpGoBtn" style="font-size:.82rem;white-space:nowrap">
                <i class="bi bi-arrow-right me-1"></i>So sánh ngay
            </button>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
window.i18n = {
    addedToCart: '@Html.Raw(L["Toast.AddedToCart"].Value.Replace("'", "\\'"))',
    cannotAdd:   '@Html.Raw(L["Toast.CannotAdd"].Value.Replace("'", "\\'"))'
};
</script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
// Apply theme before paint to avoid flash
(function() {
    if (localStorage.getItem('theme') === 'light') {
        document.body.classList.add('light-mode');
        const icon = document.getElementById('themeIcon');
        if (icon) icon.className = 'bi bi-moon-stars';
    }
})();
function toggleTheme() {
    const isLight = document.body.classList.toggle('light-mode');
    localStorage.setItem('theme', isLight ? 'light' : 'dark');
    document.getElementById('themeIcon').className = isLight ? 'bi bi-moon-stars' : 'bi bi-sun';
}
let navSearchOpen = false;
function toggleNavSearch() {
    const box   = document.getElementById('navSearchBox');
    const input = document.getElementById('navSearchInput');
    navSearchOpen = !navSearchOpen;
    box.style.maxWidth = navSearchOpen ? '360px' : '0';
    box.style.opacity  = navSearchOpen ? '1' : '0';
    if (navSearchOpen) { setTimeout(() => input.focus(), 310); }
    else { input.value = ''; hideLiveDropdown(); }
}
function navSearchSubmit(e) {
    hideLiveDropdown();
    return true; // allow normal form submit
}
document.addEventListener('keydown', e => {
    if ((e.key === '/' || (e.ctrlK = e.ctrlKey && e.key === 'k')) && !navSearchOpen
            && document.activeElement.tagName !== 'INPUT'
            && document.activeElement.tagName !== 'TEXTAREA') {
        e.preventDefault(); toggleNavSearch();
    }
    if (e.key === 'Escape' && navSearchOpen) { toggleNavSearch(); }
});
document.addEventListener('click', e => {
    const wrap = document.getElementById('navSearchForm');
    if (navSearchOpen && wrap && !wrap.contains(e.target)) toggleNavSearch();
});

// ── Live Search ──────────────────────────────────────────────────────────────
const catLabels = { cpu:'CPU', motherboard:'Mainboard', memory:'RAM', gpu:'VGA',
                    storage:'Storage', psu:'PSU', case:'Case', cooler:'Tản nhiệt' };
const catColors  = { cpu:'#a855f7', motherboard:'#6366f1', memory:'#22c55e',
                     gpu:'#f59e0b', storage:'#06b6d4', psu:'#ec4899',
                     case:'#64748b', cooler:'#14b8a6' };
let liveSearchTimer = null;
let liveSearchAbort = null;

document.getElementById('navSearchInput').addEventListener('input', function() {
    clearTimeout(liveSearchTimer);
    const q = this.value.trim();
    if (q.length < 2) { hideLiveDropdown(); return; }
    liveSearchTimer = setTimeout(() => runLiveSearch(q), 250);
});

async function runLiveSearch(q) {
    if (liveSearchAbort) liveSearchAbort.abort();
    liveSearchAbort = new AbortController();
    const drop = document.getElementById('liveSearchDropdown');
    drop.innerHTML = '<div class="px-3 py-2" style="color:rgba(255,255,255,.4);font-size:.8rem">Đang tìm…</div>';
    drop.style.display = 'block';
    try {
        const r = await fetch(`/Products/LiveSearch?q=${encodeURIComponent(q)}`, { signal: liveSearchAbort.signal });
        const items = await r.json();
        renderLiveResults(items, q);
    } catch(e) {
        if (e.name !== 'AbortError') hideLiveDropdown();
    }
}

function renderLiveResults(items, q) {
    const drop = document.getElementById('liveSearchDropdown');
    if (!items.length) {
        drop.innerHTML = '<div class="px-3 py-3 text-center" style="color:rgba(255,255,255,.4);font-size:.85rem">Không tìm thấy sản phẩm</div>';
        return;
    }
    const rows = items.map(item => {
        const img = item.imageUrl
            ? `<img src="${item.imageUrl}" alt="" style="width:40px;height:40px;object-fit:contain;border-radius:6px;background:rgba(255,255,255,.05)">`
            : `<div style="width:40px;height:40px;border-radius:6px;background:rgba(255,255,255,.06);display:flex;align-items:center;justify-content:center"><i class="bi bi-cpu" style="color:rgba(255,255,255,.3)"></i></div>`;
        const color = catColors[item.category] || '#a855f7';
        const label = catLabels[item.category] || item.category;
        const price = item.price.toLocaleString('vi-VN') + 'đ';
        const hl = item.name.replace(new RegExp(q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&'), 'gi'),
                   m => `<mark style="background:rgba(168,85,247,.35);color:#e9d5ff;border-radius:3px;padding:0 2px">${m}</mark>`);
        return `<a href="/Products/Detail/${item.category}/${item.id}"
                   class="d-flex align-items-center gap-3 px-3 py-2 live-result-row"
                   onclick="toggleNavSearch()"
                   style="text-decoration:none;transition:background .15s">
            ${img}
            <div class="flex-grow-1 overflow-hidden">
                <div style="font-size:.82rem;color:#fff;line-height:1.3;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${hl}</div>
                <div class="d-flex align-items-center gap-2 mt-1">
                    <span style="font-size:.7rem;background:rgba(${color.slice(1).match(/../g).map(h=>parseInt(h,16)).join(',')},0.2);
                                 color:${color};border-radius:4px;padding:1px 6px">${label}</span>
                    <span style="font-size:.78rem;color:#a855f7;font-weight:600">${price}</span>
                </div>
            </div>
        </a>`;
    });

    const footer = `<a href="/Products?search=${encodeURIComponent(q)}"
        class="d-block text-center px-3 py-2"
        style="font-size:.78rem;color:rgba(255,255,255,.4);border-top:1px solid rgba(255,255,255,.06);text-decoration:none;transition:background .15s"
        onmouseover="this.style.background='rgba(255,255,255,.04)'" onmouseout="this.style.background=''"
        onclick="toggleNavSearch()">
        Xem tất cả kết quả cho "<strong style="color:#c084fc">${q}</strong>"
    </a>`;

    drop.innerHTML = rows.join('') + footer;
}

function hideLiveDropdown() {
    const drop = document.getElementById('liveSearchDropdown');
    if (drop) drop.style.display = 'none';
}

// hover effect via CSS-in-JS
document.getElementById('liveSearchDropdown').addEventListener('mouseover', e => {
    const row = e.target.closest('.live-result-row');
    if (row) row.style.background = 'rgba(255,255,255,.06)';
});
document.getElementById('liveSearchDropdown').addEventListener('mouseout', e => {
    const row = e.target.closest('.live-result-row');
    if (row) row.style.background = '';
});
</script>
@await RenderSectionAsync("Scripts", required: false)

<script>
// ── Product Compare ───────────────────────────────────────────────────────────
const CMP_MAX = 3;
const CMP_KEY = 'cmpList';

function getCmpList() {
    try { return JSON.parse(localStorage.getItem(CMP_KEY) || '[]'); } catch { return []; }
}
function saveCmpList(list) { localStorage.setItem(CMP_KEY, JSON.stringify(list)); }

function toggleCompare(id, category, name, price, imageUrl) {
    let list = getCmpList();
    const idx = list.findIndex(x => x.id === id && x.category === category);

    if (idx >= 0) {
        list.splice(idx, 1);
    } else {
        if (list.length > 0 && list[0].category !== category) {
            showToast(`Chỉ so sánh được sản phẩm cùng loại (${list[0].category.toUpperCase()})`, 'warning');
            return;
        }
        if (list.length >= CMP_MAX) {
            showToast(`Chỉ so sánh tối đa ${CMP_MAX} sản phẩm`, 'warning');
            return;
        }
        list.push({ id, category, name, price, imageUrl });
    }

    saveCmpList(list);
    renderCompareTray();
    syncCmpButtons();
}

function clearCompareList() {
    saveCmpList([]);
    renderCompareTray();
    syncCmpButtons();
}

function goCompare() {
    const list = getCmpList();
    if (list.length < 2) { showToast('Chọn ít nhất 2 sản phẩm để so sánh', 'warning'); return; }
    const ids = list.map(x => x.id).join(',');
    window.location.href = `/Products/Compare?category=${list[0].category}&ids=${ids}`;
}

function renderCompareTray() {
    const list = getCmpList();
    const tray = document.getElementById('compareTray');
    const container = document.getElementById('cmpItems');
    if (!tray || !container) return;

    if (list.length === 0) { tray.style.display = 'none'; return; }
    tray.style.display = '';

    container.innerHTML = list.map(item => `
        <div class="d-flex align-items-center gap-2 glass-sm rounded-3 px-2 py-1" style="min-width:160px;max-width:220px">
            <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded-2 overflow-hidden"
                 style="width:36px;height:36px;background:rgba(255,255,255,.08)">
                ${item.imageUrl
                    ? `<img src="${item.imageUrl}" style="width:36px;height:36px;object-fit:contain">`
                    : `<i class="bi bi-cpu" style="color:rgba(255,255,255,.4)"></i>`}
            </div>
            <div class="flex-grow-1 overflow-hidden">
                <div style="font-size:.72rem;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.2">${item.name}</div>
                <div style="font-size:.7rem;color:#a855f7;font-weight:600">${item.price.toLocaleString('vi-VN')}đ</div>
            </div>
            <button onclick="toggleCompare(${item.id},'${item.category}',${JSON.stringify(item.name)},${item.price},'${item.imageUrl || ''}')"
                    class="btn p-0 border-0" style="color:rgba(255,255,255,.4);font-size:.75rem;line-height:1;background:none;flex-shrink:0"
                    title="Bỏ khỏi so sánh">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
    `).join('');

    // Disable go button if < 2
    const btn = document.getElementById('cmpGoBtn');
    if (btn) btn.disabled = list.length < 2;
}

function syncCmpButtons() {
    const list = getCmpList();
    // Reset all compare buttons
    document.querySelectorAll('.cmp-btn').forEach(btn => {
        btn.style.background = '';
        btn.style.borderColor = '';
        btn.style.color = '';
        const icon = btn.querySelector('i');
        if (icon) { icon.style.color = ''; }
    });
    // Highlight active ones
    list.forEach(item => {
        const btn = document.getElementById(`cmpBtn_${item.category}_${item.id}`);
        if (btn) {
            btn.style.background = 'rgba(168,85,247,0.3)';
            btn.style.borderColor = 'rgba(168,85,247,0.6)';
            const icon = btn.querySelector('i');
            if (icon) icon.style.color = '#c084fc';
        }
    });
}

// Init on page load
document.addEventListener('DOMContentLoaded', () => {
    renderCompareTray();
    syncCmpButtons();
});

function showToast(msg, type) {
    const t = document.createElement('div');
    const bg = type === 'warning' ? 'rgba(234,179,8,0.15)' : 'rgba(34,197,94,0.15)';
    const col = type === 'warning' ? '#fde047' : '#4ade80';
    t.style.cssText = `position:fixed;bottom:80px;left:50%;transform:translateX(-50%);
        background:${bg};border:1px solid ${col};color:${col};
        padding:8px 18px;border-radius:8px;font-size:.83rem;z-index:2000;
        backdrop-filter:blur(12px);white-space:nowrap`;
    t.textContent = msg;
    document.body.appendChild(t);
    setTimeout(() => t.remove(), 2500);
}
</script>

@await Html.PartialAsync("_ChatWidget")
