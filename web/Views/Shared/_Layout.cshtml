<script src="~/js/site.js" asp-append-version="true"></script>

<script>
// ── Theme toggle ──────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', function () {
    var root = document.documentElement;
    var icon = document.getElementById('themeIcon');
    var btn  = document.getElementById('darkToggle');
    if (!btn) return;

    function applyTheme(t) {
        root.setAttribute('data-theme', t);
        if (icon) icon.className = t === 'dark' ? 'bi bi-moon-stars' : 'bi bi-sun';
    }
    applyTheme(root.getAttribute('data-theme') || 'dark');

    btn.addEventListener('click', function () {
        var next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        localStorage.setItem('ts.theme', next);
        applyTheme(next);
    });
});

// ── Cart drawer ───────────────────────────────────────────────────────────────
(function () {
    var openBtn  = document.getElementById('cartOpen');
    var closeBtn = document.getElementById('cartClose');
    var backdrop = document.getElementById('cartBackdrop');
    var drawer   = document.getElementById('cartDrawer');
    if (!openBtn || !drawer) return;

    function openDrawer() {
        drawer.classList.add('open');
        backdrop.classList.add('show');
        document.body.style.overflow = 'hidden';
        loadDrawer();
    }
    function closeDrawer() {
        drawer.classList.remove('open');
        backdrop.classList.remove('show');
        document.body.style.overflow = '';
    }
    openBtn.addEventListener('click', openDrawer);
    closeBtn.addEventListener('click', closeDrawer);
    backdrop.addEventListener('click', closeDrawer);

    async function loadDrawer() {
        try {
            var r = await fetch('/Cart/Drawer');
            if (!r.ok) return;
            var data = await r.json();
            renderDrawer(data);
        } catch(e) {}
    }
    function fmt(n) { return Number(n).toLocaleString('vi-VN') + 'đ'; }
    function renderDrawer(data) {
        var items = data.items || [];
        var el = document.getElementById('cartDrawerItems');
        if (!el) return;
        if (!items.length) {
            el.innerHTML = '<div class="empty-state"><i class="bi bi-bag"></i><p style="color:var(--text-muted)">Giỏ hàng trống</p></div>';
        } else {
            el.innerHTML = items.map(function (i) {
                return '<div class="cart-line">' +
                    '<img src="' + (i.imageUrl || '') + '" alt="">' +
                    '<div class="meta">' +
                    '  <div class="name">' + i.name + '</div>' +
                    '  <div class="price">' + fmt(i.price) + '</div>' +
                    '  <small style="color:var(--text-muted)">x' + i.quantity + '</small>' +
                    '</div></div>';
            }).join('');
        }
        var sub = document.getElementById('drawerSubtotal');
        var tot = document.getElementById('drawerTotal');
        if (sub) sub.textContent = fmt(data.subtotal || 0);
        if (tot) tot.textContent = fmt(data.total || 0);
    }
    window.invalidateDrawer = function() {};
})();

// ── Auto-hide header on scroll down ──────────────────────────────────────────
(function () {
    var hdr = document.getElementById('siteHeader');
    if (!hdr) return;
    var lastY = 0, ticking = false;
    window.addEventListener('scroll', function () {
        if (!ticking) {
            requestAnimationFrame(function () {
                var y = window.scrollY;
                if (y > lastY && y > 80) hdr.classList.add('hide');
                else hdr.classList.remove('hide');
                lastY = y;
                ticking = false;
            });
            ticking = true;
        }
    }, { passive: true });
})();

// ── Bottom nav active tab ─────────────────────────────────────────────────────
(function () {
    var p = window.location.pathname;
    var map = { '/': 'bnHome', '/Products': 'bnProducts', '/Builder': 'bnBuilder', '/Cart': 'bnCart', '/Account': 'bnAccount' };
    var key = Object.keys(map).reverse().find(function (k) { return p === k || (k !== '/' && p.startsWith(k)); });
    if (key) { var el = document.getElementById(map[key]); if (el) el.classList.add('active'); }
})();

// ── Mega menu: CSS hover handles desktop, click navigates ────────────────────
function megaNavClick(e, el) {
    var isOpen = el.closest('.dropdown').classList.contains('show');
    if (isOpen) { window.location.href = '/Products'; return false; }
    return true;
}

// ── Live search ───────────────────────────────────────────────────────────────
var catLabels = { cpu:'CPU', motherboard:'Mainboard', memory:'RAM', gpu:'VGA', storage:'Storage', psu:'PSU', case:'Case', cooler:'Tản nhiệt' };
var catColors = { cpu:'#a855f7', motherboard:'#6366f1', memory:'#22c55e', gpu:'#f59e0b', storage:'#06b6d4', psu:'#ec4899', case:'#64748b', cooler:'#14b8a6' };
var lsTimer = null, lsAbort = null;

var navInput = document.getElementById('navSearchInput');
if (navInput) {
    navInput.addEventListener('input', function () {
        clearTimeout(lsTimer);
        var q = this.value.trim();
        if (q.length < 2) { hideLiveDrop(); return; }
        lsTimer = setTimeout(function () { runLiveSearch(q); }, 250);
    });
    navInput.addEventListener('focus', function () {
        if (window.innerWidth < 992) { openSearchOverlay(); this.blur(); }
    });
}

async function runLiveSearch(q) {
    if (lsAbort) lsAbort.abort();
    lsAbort = new AbortController();
    var drop = document.getElementById('liveSearchDropdown');
    if (!drop) return;
    drop.innerHTML = '<div class="px-3 py-2" style="color:var(--text-muted);font-size:.8rem">Đang tìm…</div>';
    drop.style.display = 'block';
    try {
        var r = await fetch('/Products/LiveSearch?q=' + encodeURIComponent(q), { signal: lsAbort.signal });
        renderLiveResults(await r.json(), q);
    } catch (e) { if (e.name !== 'AbortError') hideLiveDrop(); }
}
function renderLiveResults(items, q) {
    var drop = document.getElementById('liveSearchDropdown');
    if (!drop) return;
    if (!items.length) { drop.innerHTML = '<div class="px-3 py-3 text-center" style="color:var(--text-muted);font-size:.85rem">Không tìm thấy sản phẩm</div>'; return; }
    var rows = items.map(function (item) {
        var img = item.imageUrl ? '<img src="' + item.imageUrl + '" alt="" style="width:40px;height:40px;object-fit:contain;border-radius:6px;background:var(--surface-2)">'
            : '<div style="width:40px;height:40px;border-radius:6px;background:var(--surface-2);display:flex;align-items:center;justify-content:center"><i class="bi bi-cpu" style="color:var(--text-muted)"></i></div>';
        var color = catColors[item.category] || '#a855f7';
        var label = catLabels[item.category] || item.category;
        var price = Number(item.price).toLocaleString('vi-VN') + 'đ';
        var hl = item.name.replace(new RegExp(q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&'), 'gi'), function(m) { return '<mark style="background:rgba(139,92,246,.25);color:var(--primary);border-radius:3px;padding:0 2px">' + m + '</mark>'; });
        return '<a href="/Products/Detail/' + item.category + '/' + item.id + '" onclick="hideLiveDrop()" style="display:flex;align-items:center;gap:12px;padding:10px 14px;text-decoration:none;transition:background .15s;color:var(--text)" onmouseover="this.style.background=\'var(--surface-2)\'" onmouseout="this.style.background=\'\'">'
            + img + '<div style="flex:1;overflow:hidden"><div style="font-size:.82rem;line-height:1.3;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">' + hl + '</div>'
            + '<div style="display:flex;gap:8px;margin-top:3px"><span style="font-size:.7rem;background:rgba(139,92,246,.15);color:' + color + ';border-radius:4px;padding:1px 6px">' + label + '</span>'
            + '<span style="font-size:.78rem;color:var(--primary);font-weight:600">' + price + '</span></div></div></a>';
    });
    var footer = '<a href="/Products?search=' + encodeURIComponent(q) + '" onclick="hideLiveDrop()" style="display:block;text-align:center;padding:9px;font-size:.78rem;color:var(--text-muted);border-top:1px solid var(--border);text-decoration:none" onmouseover="this.style.background=\'var(--surface-2)\'" onmouseout="this.style.background=\'\'">Xem tất cả kết quả cho "<strong style="color:var(--primary)">' + q + '</strong>"</a>';
    drop.innerHTML = rows.join('') + footer;
}
function hideLiveDrop() { var d = document.getElementById('liveSearchDropdown'); if (d) d.style.display = 'none'; }
document.addEventListener('click', function (e) { if (!e.target.closest('#navSearchWrap')) hideLiveDrop(); });

// ── Search overlay (mobile) ───────────────────────────────────────────────────
function openSearchOverlay() {
    var overlay = document.getElementById('searchOverlay');
    var input   = document.getElementById('searchOverlayInput');
    if (!overlay) return;
    overlay.classList.add('open');
    setTimeout(function () { if (input) input.focus(); }, 100);
    renderSoHistory();
}
document.getElementById('searchOverlayCancel')?.addEventListener('click', function () {
    document.getElementById('searchOverlay').classList.remove('open');
});

function getHistory() { try { return JSON.parse(localStorage.getItem('searchHistory') || '[]'); } catch(e) { return []; } }
function saveHistory(kw) { var h = getHistory().filter(function(x) { return x !== kw; }); h.unshift(kw); if (h.length > 10) h = h.slice(0, 10); localStorage.setItem('searchHistory', JSON.stringify(h)); }
function renderSoHistory() {
    var h = getHistory(); var b = document.getElementById('soHistoryBlock'); var l = document.getElementById('soHistoryList');
    if (!b || !l) return;
    b.style.display = h.length ? '' : 'none';
    l.innerHTML = h.map(function(kw) { return '<div class="search-history-item"><i class="bi bi-clock" style="color:var(--text-muted)"></i><span onclick="doOverlaySearch(\'' + kw.replace(/'/g,"\\'") + '\')">' + kw + '</span><button class="search-history-del" onclick="deleteHistory(\'' + kw.replace(/'/g,"\\'") + '\')">✕</button></div>'; }).join('');
}
window.deleteHistory = function(kw) { var h = getHistory().filter(function(x) { return x !== kw; }); localStorage.setItem('searchHistory', JSON.stringify(h)); renderSoHistory(); };
window.doOverlaySearch = function(kw) { saveHistory(kw); window.location.href = '/Products?search=' + encodeURIComponent(kw); };

(function() {
    var soInput = document.getElementById('searchOverlayInput');
    var resList = document.getElementById('soResultsList');
    if (!soInput || !resList) return;
    var timer;
    soInput.addEventListener('input', function() {
        clearTimeout(timer);
        var q = this.value.trim();
        if (!q) { resList.innerHTML = ''; return; }
        timer = setTimeout(function() {
            fetch('/Products/LiveSearch?q=' + encodeURIComponent(q)).then(function(r) { return r.ok ? r.json() : []; }).then(function(items) {
                if (!items.length) { resList.innerHTML = '<div style="color:var(--text-muted);font-size:.85rem">Không tìm thấy kết quả</div>'; return; }
                resList.innerHTML = '<div class="search-overlay-section-title">Kết quả</div>' + items.slice(0,8).map(function(x) { return '<div class="search-history-item" onclick="doOverlaySearch(\'' + x.name.replace(/'/g,"\\'") + '\')"><img src="' + (x.imageUrl||'') + '" style="width:32px;height:32px;object-fit:contain;border-radius:6px;background:var(--surface-2)" alt=""><span style="flex:1">' + x.name + '</span><span style="color:var(--primary);font-size:.8rem">' + Number(x.price).toLocaleString('vi-VN') + 'đ</span></div>'; }).join('');
            }).catch(function() {});
        }, 300);
    });
    soInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') { var q = this.value.trim(); if (q) doOverlaySearch(q); } });
})();

// Keyboard shortcut: / or Ctrl+K
document.addEventListener('keydown', function (e) {
    var tag = document.activeElement.tagName;
    if ((e.key === '/' || (e.ctrlKey && e.key === 'k')) && tag !== 'INPUT' && tag !== 'TEXTAREA') {
        e.preventDefault();
        var input = document.getElementById('navSearchInput');
        if (input) { input.focus(); input.select(); }
    }
    if (e.key === 'Escape') { hideLiveDrop(); document.getElementById('navSearchInput')?.blur(); }
});

// ── Compare tray ──────────────────────────────────────────────────────────────
var CMP_MAX = 3, CMP_KEY = 'cmpList';
function getCmpList() { try { return JSON.parse(localStorage.getItem(CMP_KEY) || '[]'); } catch { return []; } }
function saveCmpList(l) { localStorage.setItem(CMP_KEY, JSON.stringify(l)); }
function toggleCompare(id, category, name, price, imageUrl) {
    var list = getCmpList();
    var idx = list.findIndex(function(x) { return x.id === id && x.category === category; });
    if (idx >= 0) { list.splice(idx, 1); }
    else {
        if (list.length > 0 && list[0].category !== category) { showToast('Chỉ so sánh sản phẩm cùng loại (' + list[0].category.toUpperCase() + ')', 'warning'); return; }
        if (list.length >= CMP_MAX) { showToast('Chỉ so sánh tối đa ' + CMP_MAX + ' sản phẩm', 'warning'); return; }
        list.push({ id, category, name, price, imageUrl });
    }
    saveCmpList(list); renderCompareTray(); syncCmpButtons();
}
function clearCompareList() { saveCmpList([]); renderCompareTray(); syncCmpButtons(); }
function goCompare() {
    var list = getCmpList();
    if (list.length < 2) { showToast('Chọn ít nhất 2 sản phẩm để so sánh', 'warning'); return; }
    window.location.href = '/Products/Compare?category=' + list[0].category + '&ids=' + list.map(function(x) { return x.id; }).join(',');
}
function renderCompareTray() {
    var list = getCmpList();
    var tray = document.getElementById('compareTray');
    var container = document.getElementById('cmpItems');
    if (!tray || !container) return;
    if (!list.length) { tray.style.display = 'none'; return; }
    tray.style.display = '';
    container.innerHTML = list.map(function(item) {
        return '<div class="glass-sm d-flex align-items-center gap-2 rounded-3 px-2 py-1" style="min-width:160px;max-width:220px">'
            + '<div style="width:36px;height:36px;border-radius:8px;overflow:hidden;background:var(--surface-2);flex-shrink:0;display:flex;align-items:center;justify-content:center">'
            + (item.imageUrl ? '<img src="' + item.imageUrl + '" style="width:36px;height:36px;object-fit:contain">' : '<i class="bi bi-cpu" style="color:var(--text-muted)"></i>') + '</div>'
            + '<div style="flex:1;overflow:hidden"><div style="font-size:.72rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--text)">' + item.name + '</div>'
            + '<div style="font-size:.7rem;color:var(--primary);font-weight:600">' + Number(item.price).toLocaleString('vi-VN') + 'đ</div></div>'
            + '<button onclick="toggleCompare(' + item.id + ',\'' + item.category + '\',' + JSON.stringify(item.name) + ',' + item.price + ',\'' + (item.imageUrl || '') + '\')" class="btn p-0 border-0" style="color:var(--text-muted);font-size:.75rem;background:none;flex-shrink:0"><i class="bi bi-x-lg"></i></button>'
            + '</div>';
    }).join('');
    var btn = document.getElementById('cmpGoBtn');
    if (btn) btn.disabled = list.length < 2;
}
function syncCmpButtons() {
    var list = getCmpList();
    document.querySelectorAll('.cmp-btn').forEach(function(btn) { btn.style.background = ''; btn.style.borderColor = ''; var ic = btn.querySelector('i'); if (ic) ic.style.color = ''; });
    list.forEach(function(item) { var btn = document.getElementById('cmpBtn_' + item.category + '_' + item.id); if (btn) { btn.style.background = 'rgba(var(--primary-rgb),.2)'; btn.style.borderColor = 'rgba(var(--primary-rgb),.5)'; var ic = btn.querySelector('i'); if (ic) ic.style.color = 'var(--primary)'; } });
}
document.addEventListener('DOMContentLoaded', function () { renderCompareTray(); syncCmpButtons(); });

// ── Installment calculator ────────────────────────────────────────────────────
function showInstallment(price, productName) {
    document.getElementById('instProductName').textContent = productName || '';
    document.getElementById('instBasePrice').textContent = Number(price).toLocaleString('vi-VN') + 'đ';
    var plans = [
        { months:3,  fee:0.00,  label:'3 tháng',  badge:'0% phí',    bc:'#4ade80' },
        { months:6,  fee:0.015, label:'6 tháng',  badge:'1.5%/tháng',bc:'#fb923c' },
        { months:9,  fee:0.015, label:'9 tháng',  badge:'1.5%/tháng',bc:'#fb923c' },
        { months:12, fee:0.020, label:'12 tháng', badge:'2%/tháng',  bc:'#f87171' },
    ];
    document.getElementById('instCards').innerHTML = plans.map(function(p) {
        var mo = Math.ceil(price * (1 + p.fee * p.months) / p.months);
        return '<div class="col-6"><div class="glass p-3 text-center h-100"><div class="fw-bold mb-1">' + p.label + '</div><div class="fs-5 fw-bold" style="color:var(--primary)">' + mo.toLocaleString('vi-VN') + 'đ</div><div class="small" style="color:var(--text-muted)">/tháng</div><span class="badge mt-2" style="background:var(--surface-2);color:' + p.bc + ';font-size:.7rem">' + p.badge + '</span></div></div>';
    }).join('');
    new bootstrap.Modal(document.getElementById('installmentModal')).show();
}

// ── Purchase toast ────────────────────────────────────────────────────────────
(function() {
    var data = [
        { name:"Anh K.", city:"TP.HCM",   product:"RTX 4070 Ti SUPER",       img:"https://placehold.co/44/1e1b4b/c084fc?text=GPU",  mins:2  },
        { name:"Chị L.", city:"Hà Nội",   product:"Intel Core i7-14700K",     img:"https://placehold.co/44/0f172a/60a5fa?text=CPU",  mins:5  },
        { name:"Anh T.", city:"Đà Nẵng",  product:"Corsair DDR5 32GB 6000",   img:"https://placehold.co/44/0f2a1b/4ade80?text=RAM",  mins:8  },
        { name:"Chị M.", city:"Cần Thơ",  product:"ASUS B760M Mainboard",     img:"https://placehold.co/44/0a1f2b/06b6d4?text=MB",   mins:12 },
        { name:"Anh P.", city:"Hải Phòng",product:"Samsung 980 Pro 2TB NVMe", img:"https://placehold.co/44/1a0a2b/a855f7?text=SSD",  mins:15 },
        { name:"Chị H.", city:"Huế",      product:"Lian Li PC-O11 Dynamic",   img:"https://placehold.co/44/2b1a0a/ef4444?text=CASE", mins:18 },
    ];
    var toast = document.getElementById('purchaseToast');
    var ptImg = document.getElementById('ptImg');
    var ptText = document.getElementById('ptText');
    var ptTime = document.getElementById('ptTime');
    var idx = 0;
    function show() {
        var d = data[idx % data.length]; idx++;
        ptImg.src = d.img;
        ptText.innerHTML = '<strong>' + d.name + '</strong> tại ' + d.city + ' vừa đặt mua <strong>' + d.product + '</strong>';
        ptTime.textContent = d.mins + ' phút trước';
        toast.classList.add('show');
        setTimeout(function() { toast.classList.remove('show'); }, 5000);
    }
    setTimeout(function() { show(); setInterval(show, 32000 + Math.random() * 15000); }, 15000);
})();

// ── Cart count on load ────────────────────────────────────────────────────────
@if (User.Identity?.IsAuthenticated == true)
{
    <text>
    (function() {
        fetch('/Cart/Count').then(function(r) { return r.ok ? r.json() : null; })
            .then(function(d) { if (d && d.count > 0) updateCartBadge(d.count); }).catch(function(){});
    })();
    </text>
}
</script>

@await Html.PartialAsync("_ChatWidget")
@await RenderSectionAsync("Scripts", required: false)
</body>
