    </div>
    <footer>
        <div class="row-sum"><span>Tạm tính</span><strong id="drawerSubtotal">0đ</strong></div>
        <div class="row-sum"><span>Vận chuyển</span><strong id="drawerShipping">Miễn phí</strong></div>
        <div class="row-sum total" style="margin-top:.5rem;padding-top:.5rem;border-top:1px solid var(--border)">
            <span style="font-weight:700">Tổng cộng</span>
            <strong id="drawerTotal" style="color:var(--danger);font-size:1.15rem">0đ</strong>
        </div>
