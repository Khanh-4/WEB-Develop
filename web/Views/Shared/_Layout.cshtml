        <a href="/orders/checkout" class="btn btn-gradient w-100 mt-2 ripple">
            <i class="bi bi-credit-card me-1"></i>Thanh toán ngay
        </a>
    </footer>
</aside>

<!-- ══════════════════════════════════════════════
     TOAST CONTAINER
     ══════════════════════════════════════════════ -->
<div class="tx-toast-wrap" id="toastWrap"></div>

<!-- ══════════════════════════════════════════════
     COMPARE TRAY
     ══════════════════════════════════════════════ -->
<div id="compareTray" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:1050;
