<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] · TechSpecs</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
        // Apply theme before paint — prevents flash
        (function () {
            var t = localStorage.getItem('ts.theme') || 'dark';
            document.documentElement.setAttribute('data-theme', t);
        })();
    </script>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

@{
    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var currentUrl = Context.Request.Path + Context.Request.QueryString;
    var targetCulture = currentCulture == "vi" ? "en" : "vi";
    var langLabel = currentCulture == "vi" ? "EN" : "VI";
    var currentCtrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}

<!-- ══════════════════════════════════════════════
     HEADER
     ══════════════════════════════════════════════ -->
<header class="tx-header" id="siteHeader">

    <!-- Top bar -->
    <div class="top-bar">
        <div class="container-xl d-flex justify-content-between align-items-center">
            <span><i class="bi bi-truck me-1"></i> Miễn phí vận chuyển cho đơn từ 500.000đ</span>
            <span class="d-none d-md-block">
                <i class="bi bi-telephone me-1"></i> Hotline: 1900 6969 ·
                <i class="bi bi-clock me-1"></i> 8:00 - 22:00
            </span>
        </div>
    </div>

    <div class="container-xl">
        <!-- Main bar: logo + search + actions -->
        <div class="main-bar">

            <!-- Logo -->
            <a class="tx-brand text-decoration-none" asp-controller="Home" asp-action="Index">
                <span class="logo"><i class="bi bi-cpu" style="font-size:1rem"></i></span>
                Tech<span class="text-gradient">Specs</span>
            </a>

            <!-- Search -->
            <div class="tx-search" id="navSearchWrap">
                <i class="bi bi-search"></i>
                <input type="search" name="q" id="navSearchInput"
                       placeholder="Tìm CPU, GPU, RAM, SSD, Mainboard..."
                       value="@(Context.Request.Query["search"])"
                       autocomplete="off"
                       onkeydown="if(event.key==='Enter'){window.location.href='/Products?search='+encodeURIComponent(this.value);}" />
                <button class="search-btn" type="button"
                        onclick="window.location.href='/Products?search='+encodeURIComponent(document.getElementById('navSearchInput').value)">
                    Tìm
                </button>
                <!-- Live search dropdown -->
                <div id="liveSearchDropdown"
                     style="display:none;position:absolute;top:calc(100% + 6px);left:0;right:0;z-index:9999;
                            background:var(--surface-solid);border:1px solid var(--border);border-radius:var(--radius);
                            box-shadow:var(--shadow-lg);overflow:hidden">
                </div>
            </div>

            <!-- Actions -->
            <div class="tx-actions">

                <!-- Dark mode toggle -->
                <button class="btn-icon" id="darkToggle" title="Đổi giao diện" type="button">
                    <i class="bi bi-moon-stars" id="themeIcon"></i>
                </button>

                <!-- Language -->
                <a href="/Language/Set?culture=@targetCulture&returnUrl=@Uri.EscapeDataString(currentUrl)"
                   class="btn-icon d-none d-sm-inline-flex"
                   style="font-size:.72rem;font-weight:700;text-decoration:none;width:auto;padding:0 10px;border-radius:8px">
                    @langLabel
                </a>

                <!-- Wishlist -->
                <a asp-controller="Wishlist" asp-action="Index" class="btn-icon icon-badge d-none d-md-inline-flex" title="Yêu thích">
                    <i class="bi bi-heart"></i>
                </a>

                <!-- Cart -->
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <button class="btn-icon icon-badge" id="cartOpen" type="button" title="Giỏ hàng">
                        <i class="bi bi-bag"></i>
                        <span class="count" id="cartCount" style="display:none">0</span>
                    </button>
                }

                <!-- User -->
                @if (User.Identity?.IsAuthenticated == true)
                {
                    var _av = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "";
                    var _avl = _av.Length > 0 ? _av[0].ToString().ToUpper() : "U";
                    <div class="dropdown">
                        <button class="btn p-0 d-flex align-items-center gap-2" data-bs-toggle="dropdown"
                                style="background:none;border:none">
                            <span class="avatar">@_avl</span>
                            <span class="d-none d-lg-block fw-semibold" style="color:var(--text);font-size:.88rem">@(User.FindFirst("FullName")?.Value ?? User.Identity!.Name?.Split('@')[0])</span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            @if (User.IsInRole("Admin"))
                            {
                                <li><a class="dropdown-item" href="/Admin"><i class="bi bi-speedometer2"></i> Admin Dashboard</a></li>
                                <li><hr class="dropdown-divider" style="border-color:var(--border)" /></li>
                            }
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="bi bi-person"></i> Tài khoản</a></li>
                            <li><a class="dropdown-item" href="/orders"><i class="bi bi-bag-check"></i> Đơn hàng</a></li>
                            <li><a class="dropdown-item" asp-controller="Build" asp-action="MyBuilds"><i class="bi bi-bookmark"></i> Build của tôi</a></li>
                            <li><a class="dropdown-item" asp-controller="Wishlist" asp-action="Index"><i class="bi bi-heart" style="color:#f472b6"></i> Yêu thích</a></li>
                            <li><a class="dropdown-item" asp-controller="Account" asp-action="Warranties"><i class="bi bi-shield-check" style="color:var(--primary)"></i> Bảo hành</a></li>
                            <li><hr class="dropdown-divider" style="border-color:var(--border)" /></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <button class="dropdown-item text-danger"><i class="bi bi-box-arrow-right"></i> Đăng xuất</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-gradient ripple px-3 py-1 d-none d-sm-inline-flex"
                       style="font-size:.85rem">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập
                    </a>
                }
            </div>
        </div>

        <!-- Navigation row -->
        <nav class="tx-nav d-none d-md-flex align-items-center">
            <a asp-controller="Home" asp-action="Index"
               class="@(currentCtrl == "Home" && currentAction == "Index" ? "active" : "")">
                <i class="bi bi-house-door me-1"></i>Trang chủ
            </a>

            <!-- Products mega menu (CSS hover) -->
            <div class="has-mega">
                <a href="/Products" class="@(currentCtrl == "Products" ? "active" : "")">
                    <i class="bi bi-grid-3x3-gap me-1"></i>Sản phẩm <i class="bi bi-chevron-down" style="font-size:.7rem"></i>
                </a>
                <div class="mega">
                    @await Component.InvokeAsync("CategoryMenu", new { renderAs = "Dropdown" })
                </div>
            </div>

            <a asp-controller="Builder" asp-action="Index"
               class="btn btn-gradient px-3 py-1 ripple @(currentCtrl == "Builder" ? "active" : "")"
               style="font-size:.84rem">
                <i class="bi bi-cpu me-1"></i>PC Builder
            </a>

            <a asp-controller="Build" asp-action="Community"
               class="@(currentCtrl == "Build" && currentAction == "Community" ? "active" : "")">
                <i class="bi bi-people me-1"></i>Cộng đồng
            </a>

            <a asp-controller="Warranty" asp-action="Index"
               class="@(currentCtrl == "Warranty" ? "active" : "")">
                <i class="bi bi-shield-check me-1"></i>Bảo hành
            </a>

            <a asp-controller="OrderTracking" asp-action="Index"
               class="@(currentCtrl == "OrderTracking" ? "active" : "")">
                <i class="bi bi-truck me-1"></i>Đơn hàng
            </a>
        </nav>
    </div>
</header>

@if (User.Identity?.IsAuthenticated == true)
{
    <form id="csrfForm" style="display:none">@Html.AntiForgeryToken()</form>
}

<main class="pb-5">
    @RenderBody()
</main>

<!-- ══════════════════════════════════════════════
     FOOTER
     ══════════════════════════════════════════════ -->
