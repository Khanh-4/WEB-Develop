            <i class="bi bi-bar-chart-steps me-2" style="color:var(--primary)"></i>So sánh:
        </span>
        <div id="cmpItems" class="d-flex gap-2 flex-grow-1 overflow-auto"></div>
        <div class="d-flex gap-2 flex-shrink-0 ms-auto">
