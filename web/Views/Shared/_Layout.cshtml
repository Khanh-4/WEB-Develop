@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@inject IHtmlLocalizer<TechSpecs.SharedResource> L
<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechSpecs</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-glass px-3">
    <div class="container-xl">
        <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
            <span class="gradient-icon">
                <i class="bi bi-cpu text-white" style="font-size:1.1rem"></i>
            </span>
            TechSpecs
        </a>

        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
            <i class="bi bi-list text-white fs-4"></i>
        </button>

        <div class="collapse navbar-collapse" id="navMain">
            <ul class="navbar-nav me-auto gap-1 ms-3">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">@L["Nav.Home"]</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Products" asp-action="Index">@L["Nav.Products"]</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Build" asp-action="Community">@L["Nav.Community"]</a>
                </li>
                <li class="nav-item">
                    <a class="btn btn-gradient px-3 py-1 ms-1" asp-controller="Builder" asp-action="Index">
                        @L["Nav.PCBuilder"]
                    </a>
                </li>
            </ul>

            <ul class="navbar-nav align-items-center gap-2">
                <li class="nav-item">
                    <button class="btn glass text-white px-2 py-1" id="themeToggle" onclick="toggleTheme()" title="Toggle light/dark mode" style="font-size:1.1rem;line-height:1">
                        <i class="bi bi-sun" id="themeIcon"></i>
                    </button>
                </li>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item">
                        <a class="nav-link position-relative" href="/cart">
                            <i class="bi bi-cart3 fs-5 text-white"></i>
                            <span class="cart-badge" id="cartCount" style="display:none">0</span>
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center gap-1" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle fs-5"></i>
                            <span>@(User.FindFirst("FullName")?.Value ?? User.Identity!.Name?.Split('@')[0])</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end glass-sm border-0 p-2">
                            @if (User.IsInRole("Admin"))
                            {
                                <li><a class="dropdown-item text-white rounded" href="/admin"><i class="bi bi-speedometer2 me-2"></i>@L["Nav.Admin"]</a></li>
                                <li><hr class="dropdown-divider divider-white my-1"></li>
                            }
                            <li><a class="dropdown-item text-white rounded" asp-controller="Account" asp-action="Profile"><i class="bi bi-person me-2"></i>@L["Nav.Profile"]</a></li>
                            <li><a class="dropdown-item text-white rounded" href="/orders"><i class="bi bi-bag-check me-2"></i>@L["Nav.Orders"]</a></li>
                            <li><a class="dropdown-item text-white rounded" asp-controller="Build" asp-action="MyBuilds"><i class="bi bi-bookmark me-2"></i>@L["Nav.MyBuilds"]</a></li>
                            <li><a class="dropdown-item text-white rounded" asp-controller="Wishlist" asp-action="Index"><i class="bi bi-heart me-2" style="color:#f472b6"></i>@L["Nav.Wishlist"]</a></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                    <button class="dropdown-item text-danger rounded"><i class="bi bi-box-arrow-right me-2"></i>@L["Nav.SignOut"]</button>
                                </form>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Login">@L["Nav.Login"]</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-gradient px-3 py-1" asp-controller="Account" asp-action="Register">@L["Nav.SignUp"]</a>
                    </li>
                }

                <!-- Language switcher -->
                @{
                    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
                    var currentUrl = Context.Request.Path + Context.Request.QueryString;
                    var targetCulture = currentCulture == "vi" ? "en" : "vi";
                    var langLabel = currentCulture == "vi" ? "EN" : "VI";
                }
                <li class="nav-item">
                    <a href="/Language/Set?culture=@targetCulture&returnUrl=@Uri.EscapeDataString(currentUrl)"
                       class="btn glass text-white px-2 py-1" style="font-size:.8rem;font-weight:600;text-decoration:none">
                        @langLabel
                    </a>
                </li>
            </ul>
        </div>
    </div>
</nav>

@if (User.Identity?.IsAuthenticated == true)
{
    <form id="csrfForm" style="display:none">@Html.AntiForgeryToken()</form>
}

<main class="pb-5">
    @RenderBody()
</main>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
// Apply theme before paint to avoid flash
(function() {
    if (localStorage.getItem('theme') === 'light') {
        document.body.classList.add('light-mode');
        const icon = document.getElementById('themeIcon');
        if (icon) icon.className = 'bi bi-moon-stars';
    }
})();
function toggleTheme() {
    const isLight = document.body.classList.toggle('light-mode');
    localStorage.setItem('theme', isLight ? 'light' : 'dark');
    document.getElementById('themeIcon').className = isLight ? 'bi bi-moon-stars' : 'bi bi-sun';
}
</script>
@await RenderSectionAsync("Scripts", required: false)
@await Html.PartialAsync("_ChatWidget")
@if (User.Identity?.IsAuthenticated == true)
{
<script>
(function() {
    fetch('/Cart/Count')
        .then(r => r.ok ? r.json() : null)
        .then(d => { if (d && d.count > 0) updateCartBadge(d.count); })
        .catch(() => {});
})();
</script>
}
</body>
</html>
