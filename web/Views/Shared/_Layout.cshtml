window.i18n = {
    addedToCart: '@Html.Raw((L?["Toast.AddedToCart"]?.Value ?? "Đã thêm vào giỏ hàng").Replace("'", "\\'"))',
    cannotAdd:   '@Html.Raw((L?["Toast.CannotAdd"]?.Value ?? "Không thể thêm").Replace("'", "\\'"))'
