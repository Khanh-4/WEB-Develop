@model List<TechSpecs.Models.WishlistItem>
@{ ViewData["Title"] = L["Wishlist.Title"].Value; }

<div class="container-xl py-4 px-3">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h4 class="fw-bold mb-0" style="color:var(--text)">
            <i class="bi bi-heart me-2" style="color:#f472b6"></i>@L["Wishlist.Title"]
        </h4>
        <a asp-controller="Products" asp-action="Index" class="btn glass px-4" style="color:var(--text)">
            <i class="bi bi-search me-2"></i>@L["Wishlist.Browse"]
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="tx-card p-5 text-center">
            <i class="bi bi-heart fs-1 d-block mb-3" style="color:#f472b6;opacity:.3"></i>
            <h5 class="fw-bold mb-2" style="color:var(--text)">@L["Wishlist.Empty"]</h5>
            <p class="mb-4" style="color:var(--text-muted)">@L["Wishlist.EmptyDesc"]</p>
            <a asp-controller="Products" asp-action="Index" class="btn btn-gradient px-4">
                <i class="bi bi-search me-2"></i>@L["Wishlist.Explore"]
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                var catLabel = item.Category switch {
                    "cpu" => "Processor", "motherboard" => "Motherboard", "memory" => "Memory",
                    "gpu" => "Graphics Card", "storage" => "Storage", "psu" => "Power Supply",
                    "case" => "Case", "cooler" => "CPU Cooler", _ => item.Category
                };
                <div class="col-md-6 col-xl-4" id="wish-@item.Id">
                    <div class="tx-card p-4 h-100 d-flex flex-column">
                        <div class="d-flex gap-3 mb-3">
                            @if (item.ImageUrl != null)
                            {
                                <img src="@item.ImageUrl" alt="@item.ComponentName"
                                     style="width:64px;height:64px;object-fit:contain;border-radius:8px;background:var(--surface-2);flex-shrink:0">
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center rounded-3 flex-shrink-0"
                                     style="width:64px;height:64px;background:var(--surface-2)">
                                    <i class="bi bi-cpu fs-4" style="color:var(--text-muted)"></i>
                                </div>
                            }
                            <div class="overflow-hidden flex-grow-1">
                                <div class="small mb-1" style="color:var(--text-muted)">@catLabel</div>
                                <div class="fw-semibold" style="font-size:.9rem;line-height:1.3;color:var(--text)">@item.ComponentName</div>
                                <div class="fw-bold mt-1" style="color:var(--primary)">@item.Price.ToString("N0")đ</div>
                            </div>
                        </div>

                        <div class="small mb-3" style="color:var(--text-muted)">
                            @L["Wishlist.SavedOn"] @item.AddedAt.ToString("dd/MM/yyyy HH:mm")
                        </div>

                        <div class="d-flex gap-2 mt-auto">
                            <a href="/Products/Detail/@item.Category/@item.ComponentId"
                               class="btn glass flex-grow-1" style="color:var(--text)">
                                <i class="bi bi-eye me-1"></i>@L["Wishlist.ViewDetail"]
                            </a>
                            <button class="btn btn-gradient px-3"
                                    data-pid="@item.ComponentId" data-pcat="@item.Category"
                                    data-pname="@item.ComponentName" data-pprice="@item.Price"
                                    data-pimg="@item.ImageUrl"
                                    onclick="addToCartFromData(this)" title="@L["Btn.AddToCart"]">
                                <i class="bi bi-cart-plus"></i>
                            </button>
                            <button class="btn glass px-3" style="color:var(--danger)" title="@L["Btn.Delete"]"
                                    onclick="removeWish(@item.Id, this)">
                                <i class="bi bi-heart-fill"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
<script>
const csrfToken = document.querySelector('#csrfForm input[name="__RequestVerificationToken"]')?.value || '';

async function removeWish(id, btn) {
    const r = await fetch(`/Wishlist/Remove/${id}`, {
        method: 'POST',
        headers: { 'RequestVerificationToken': csrfToken }
    });
    if (r.ok) document.getElementById('wish-' + id)?.remove();
}
</script>
}
